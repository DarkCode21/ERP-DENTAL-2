		}
		
		function calcularCuadroResumen() {
			let salariobase = $('#salariobase').val();
			let complementossalariales = $('#complementossalariales').val();
			let salarioespecie = $('#salarioespecie').val();
			let monto_extras_fuerza_mayor = $('#monto_extras_fuerza_mayor').val();
			let monto_extras_resto = $('#monto_extras_resto').val();
			let totaldevengado = $('#totaldevengado').val();

			let remuneracionMensual = 0;
			let prorratas = 0;
			let base_cotizacion_horas_extras_fuerza_mayor = 0;
			let base_cotizacion_horas_extras_resto = 0;
			let base_retencion_irpf = 0;
			let bccp = 0;
			
			if(!isBlank(salariobase)) { 
				remuneracionMensual += parseFloat(salariobase);
				bccp += parseFloat(salariobase);
				prorratas = parseFloat(salariobase) * 0.166666666666667;
			}

			if(!isBlank(complementossalariales)) { 
				remuneracionMensual += parseFloat(complementossalariales);
				bccp += parseFloat(complementossalariales);
			}

			if(!isBlank(salarioespecie)) { 
				remuneracionMensual += parseFloat(salarioespecie);
				bccp += parseFloat(salarioespecie);
			}
			
			if(!isBlank(monto_extras_fuerza_mayor)) { 
				base_cotizacion_horas_extras_fuerza_mayor += parseFloat(monto_extras_fuerza_mayor);
				bccp += parseFloat(monto_extras_fuerza_mayor);
			}

			if(!isBlank(monto_extras_resto)) { 
				base_cotizacion_horas_extras_resto += parseFloat(monto_extras_resto);
				bccp += parseFloat(monto_extras_resto);
			}
		
			if(!isBlank(totaldevengado)) { 
				base_retencion_irpf += parseFloat(totaldevengado);
			}

			$('#remuneracion_mensual_cotizacion').val((Math.round(remuneracionMensual * 100) / 100).toFixed(2));
			$('#prorratas_pagas_extras').val((Math.round(prorratas * 100) / 100).toFixed(2));
			$('#total_remuneracion').val((Math.round((prorratas + remuneracionMensual) * 100) / 100).toFixed(2));
			$('#base_cotizacion_horas_extras_fuerza_mayor').val((Math.round(base_cotizacion_horas_extras_fuerza_mayor * 100) / 100).toFixed(2));
			$('#base_cotizacion_horas_extras_resto').val((Math.round(base_cotizacion_horas_extras_resto * 100) / 100).toFixed(2));
			$('#base_retencion_irpf').val((Math.round(base_retencion_irpf * 100) / 100).toFixed(2));
			$('#base').val((Math.round((prorratas + remuneracionMensual) * 100) / 100).toFixed(2));
			$('#bccp').val((Math.round(bccp * 100) / 100).toFixed(2));
			
		}
		
		function calcularTotalDevengado() {
			let total = 0;
			let salario = $('#salariobase').val();
			let complementosalarial = $('#complementossalariales').val();
			let extrasfuerzamayor = $('#extrasfuerzamayor').val();
			let extrasresto = $('#extrasresto').val();
			let horascomplementarias = $('#horascomplementarias').val();
			let gratificacionesextraordinarias = $('#gratificacionesextraordinarias').val();
			let salarioespecie = $('#salarioespecie').val();
			
			let indemnizaciones = $('#indemnizaciones').val();
			let seguridadsocial = $('#seguridadsocial').val();
			let despidos = $('#despidos').val();	
			let otraspercepciones = $('#otraspercepciones').val();
			
			let porc_impuesto_renta = $('#porc_impuesto_renta').val();
			let monto_impuesto_renta = $('#monto_impuesto_renta').val();

			if(!isBlank(salario)) { 
				total += parseFloat(salario); 
				$('#salariobase').val(parseFloat(salario).toFixed(2)); 
			}
			if(!isBlank(complementosalarial)) { 
				total += parseFloat(complementosalarial); 
				$('#complementossalariales').val(parseFloat(complementosalarial).toFixed(2));
			}
			if(!isBlank(extrasfuerzamayor)) { 
				total += parseFloat(extrasfuerzamayor); 
				$('#extrasfuerzamayor').val(parseFloat(extrasfuerzamayor).toFixed(2));
			}
			if(!isBlank(extrasresto)) { 
				total += parseFloat(extrasresto); 
				$('#extrasresto').val(parseFloat(extrasresto).toFixed(2));
			}
			if(!isBlank(horascomplementarias)) { 
				total += parseFloat(horascomplementarias); 
				$('#horascomplementarias').val(parseFloat(horascomplementarias).toFixed(2));
			}
			if(!isBlank(gratificacionesextraordinarias)) { 
				total += parseFloat(gratificacionesextraordinarias); 
				$('#gratificacionesextraordinarias').val(parseFloat(gratificacionesextraordinarias).toFixed(2));
			}
			if(!isBlank(salarioespecie)) { 
				total += parseFloat(salarioespecie); 
				$('#salarioespecie').val(parseFloat(salarioespecie).toFixed(2));
			}
			if(!isBlank(indemnizaciones)) { 
				total += parseFloat(indemnizaciones); 
				$('#indemnizaciones').val(parseFloat(indemnizaciones).toFixed(2));
			}
			if(!isBlank(seguridadsocial)) { 
				total += parseFloat(seguridadsocial); 
				$('#seguridadsocial').val(parseFloat(seguridadsocial).toFixed(2));
			}
			if(!isBlank(despidos)) { 
				total += parseFloat(despidos); 
				$('#despidos').val(parseFloat(despidos).toFixed(2));
			}
			if(!isBlank(otraspercepciones)) { 
				total += parseFloat(otraspercepciones); 
				$('#otraspercepciones').val(parseFloat(otraspercepciones).toFixed(2));
			}
		
			$('#totaldevengado').val((Math.round(total * 100) / 100).toFixed(2));

			if(!isBlank(porc_impuesto_renta)) {
				let monto_imp = parseFloat(porc_impuesto_renta)/100 * parseFloat((Math.round(total * 100) / 100));
				$('#monto_impuesto_renta').val(monto_imp.toFixed(2));
				//totalDeducir += monto_imp.toFixed(2);
				calcularTotalAportaciones();
			}

			calcularLiquidoPercibir();
		}
		
		function isNumberKey(evt) {
 	   		const charCode = (evt.which) ? evt.which : event.keyCode;
    		// Permitir números y punto decimal
			if (charCode == 46 || (charCode >= 48 && charCode <= 57)) {
				if (charCode == 46) {
					return evt.target.value.includes('.')? false: true;
				}
				return true;
			} else {
				return false;
			}
		}
		
		function validarEntrada () {
			calcularCuadroResumen();
			calcularPorcResumen();
			$('#modalPreview').modal('show');
		}
		
		function guardarNomina () {
			calcularCuadroResumen();
			calcularPorcResumen();
			
			let formData = {};
			formData["action"] = "save-data";
			let formNomina = $("#formNomina").serializeArray();
			formNomina.forEach(el => {
				formData[el.name] = el.value;
			});
			let formNominaCuadro = $("#formNominaCuadro").serializeArray();
			formNominaCuadro.forEach(el => {
				formData[el.name] = el.value;
			});
			console.log("formData", formData);
			$.ajax({
				method: "POST",
				url: "{{ fsc.url() }}",
				data: formData,
				dataType: "json",
				success: function (results) {
					$('#message-alert').append('<div class="alert alert-'+ (results.type=='error'?'danger':results.type) + 
					' border-top mb-0" role="alert"><button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button><div>'+ results.message +'</div></div>')
					if (results.status == 'success') {
						setTimeout(window.location.href = "/ListEmpleado#ListNomina", 3000);
					}
				},
				error: function (msg) {
					alert(msg.status + " " + msg.responseText);
				}
			});
            
		}
	</script>
