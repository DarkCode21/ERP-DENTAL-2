<view>
    <columns>
        <column name="id" display="none" order="100">
            <widget type="text" fieldname="idrecibo" />
        </column>
        <column name="date" display="none" order="110">
            <widget type="date" fieldname="fecha" />
        </column>
        <column name="invoice" order="120">
            <widget type="autocomplete" fieldname="idfactura" onclick="EditFacturaCliente" readonly="dinamic">
                <values source="facturascli" fieldcode="idfactura" fieldtitle="codigo"></values>
            </widget>
        </column>
        <column name="customer" order="130">
            <widget type="autocomplete" fieldname="codcliente" onclick="EditCliente">
                <values source="clientes" fieldcode="codcliente" fieldtitle="nombre"></values>
            </widget>
        </column>
        <column name="observations" order="140">
            <widget type="textarea" fieldname="observaciones" />
        </column>
        <column name="amount" display="right" order="150">
            <widget type="money" fieldname="importe">
                <option color="danger">lt:0</option>
            </widget>
        </column>
        <column name="payment-method" order="160">
            <widget type="select" fieldname="codpago">
                <values source="formaspago" fieldcode="codpago" fieldtitle="descripcion"></values>
            </widget>
        </column>
        <column name="iban" order="170">
            <widget type="text" fieldname="iban" />
        </column>
        <column name="paid" display="center" order="180">
            <widget type="checkbox" fieldname="pagado" />
        </column>
        <column name="expiration" display="right" order="190">
            <widget type="date" fieldname="vencimiento" />
        </column>
    </columns>
    <rows>
        <row type="status">
            <option color="success" fieldname="pagado">1</option>
            <option color="warning" fieldname="iban"></option>
            <option color="warning" fieldname="iban">null:</option>
        </row>
    </rows>
</view>
