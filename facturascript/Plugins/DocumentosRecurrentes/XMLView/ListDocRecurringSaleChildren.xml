<view>
    <columns>
        <column name="code" order="150">
            <widget type="text" fieldname="codigo"/>
        </column>
        <column name="number2" order="160">
            <widget type="text" fieldname="numero2"/>
        </column>
        <column name="customer-code" display="none" order="170">
            <widget type="text" fieldname="codcliente"/>
        </column>
        <column name="customer" display="none" order="180">
            <widget type="text" fieldname="nombrecliente"/>
        </column>
        <column name="fiscal-number" display="none" order="190">
            <widget type="text" fieldname="cifnif"/>
        </column>
        <column name="status" display="none" order="270">
            <widget type="autocomplete" fieldname="idestado">
                <values source="estados_documentos" fieldcode="idestado" fieldtitle="nombre"/>
            </widget>
        </column>
        <column name="email-sent" display="center" order="280">
            <widget type="checkbox" fieldname="femail"/>
        </column>
        <column name="paid" display="center" order="290">
            <widget type="checkbox" fieldname="pagada"/>
        </column>
        <column name="payment-methods" display="none" order="300">
            <widget type="select" fieldname="codpago" onclick="EditFormaPago">
                <values source="formaspago" fieldcode="codpago" fieldtitle="descripcion"/>
            </widget>
        </column>
        <column name="subtotal" display="none" order="310">
            <widget type="money" fieldname="netosindto"/>
        </column>
        <column name="global-dto" display="none" order="320">
            <widget type="percentage" fieldname="dtopor1"/>
        </column>
        <column name="global-dto-2" display="none" order="330">
            <widget type="percentage" fieldname="dtopor2"/>
        </column>
        <column name="net" display="none" order="340">
            <widget type="money" fieldname="neto"/>
        </column>
        <column name="taxes" display="none" order="350">
            <widget type="money" fieldname="totaliva"/>
        </column>
        <column name="surcharge" display="none" order="360">
            <widget type="money" fieldname="totalrecargo"/>
        </column>
        <column name="retention" display="none" order="370">
            <widget type="percentage" fieldname="irpf"/>
        </column>
        <column name="retentions" display="none" order="380">
            <widget type="money" fieldname="totalirpf"/>
        </column>
        <column name="supplied-amount" display="none" order="390">
            <widget type="money" fieldname="totalsuplidos"/>
        </column>
        <column name="total" display="right" order="400">
            <widget type="money" fieldname="total">
                <option color="danger">lt:0</option>
            </widget>
        </column>
        <column name="currency" display="none" order="410">
            <widget type="select" fieldname="coddivisa" onclick="EditDivisa">
                <values source="divisas" fieldcode="coddivisa" fieldtitle="coddivisa"/>
            </widget>
        </column>
        <column name="agent" display="none" order="420">
            <widget type="autocomplete" fieldname="codagente">
                <values source="agentes" fieldcode="codagente" fieldtitle="nombre"/>
            </widget>
        </column>
        <column name="date" display="right" order="430">
            <widget type="date" fieldname="fecha"/>
        </column>
    </columns>
    <rows>
        <row type="status">
            <option color="danger" title="rectified-invoice" fieldname="idfacturarect">notnull:</option>
            <option color="success" title="paid" fieldname="pagada">1</option>
            <option color="warning" title="non-editable-document" fieldname="editable">0</option>
            <option color="info" title="email-sent" fieldname="femail">notnull:</option>
            <option color="dark" title="invoice-without-acc-entry" fieldname="idasiento">null:</option>
        </row>
    </rows>
</view>