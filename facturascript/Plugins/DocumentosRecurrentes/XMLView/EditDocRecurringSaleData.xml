<view>
    <columns>
        <group name="document" numcolumns="12">
            <column name="code" numcolumns="1" display="none" order="100">
                <widget type="text" fieldname="id" required="true" readonly="true" />
            </column>
            <column name="serie" numcolumns="2" order="160">
                <widget type="select" fieldname="codserie" onclick="EditSerie" required="true">
                    <values source="series" fieldcode="codserie" fieldtitle="descripcion" />
                </widget>
            </column>
            <column name="warehouse" numcolumns="2" description="warehouse-desc" order="170">
                <widget type="select" fieldname="codalmacen" onclick="EditAlmacen" required="true">
                    <values source="almacenes" fieldcode="codalmacen" fieldtitle="nombre" />
                </widget>
            </column>
            <column name="agent" numcolumns="3" order="180">
                <widget type="select" fieldname="codagente">
                    <values source="agentes" fieldcode="codagente" fieldtitle="nombre" />
                </widget>
            </column>
            <column name="payment" title="method-payment" order="190">
                <widget type="select" fieldname="codpago" onclick="EditFormaPago" required="true">
                    <values source="formaspago" fieldcode="codpago" fieldtitle="descripcion" />
                </widget>
            </column>
            <column name="currency" numcolumns="2" order="200">
                <widget type="select" fieldname="coddivisa" onclick="EditDivisa" required="true">
                    <values source="divisas" fieldcode="coddivisa" fieldtitle="descripcion" />
                </widget>
            </column>
        </group>
        <group name="others" numcolumns="12">
            <column name="state" numcolumns="2" order="100">
                <widget type="select" fieldname="idstatus">
                    <values />
                </widget>
            </column>
        </group>
        <group name="notes" numcolumns="12">
            <column name="observations" numcolumns="6" order="140" description="internal-note">
                <widget type="textarea" fieldname="notes" rows="5" />
            </column>
            <column name="doc-note" numcolumns="6" order="140" description="document-note">
                <widget type="textarea" fieldname="notesdocument" rows="5" />
            </column>
        </group>
    </columns>
</view>