<view>
    <columns>
        <group name="dates" numcolumns="12">
            <column name="code" numcolumns="1" display="none" order="100">
                <widget type="text" fieldname="id" required="true" readonly="true" />
            </column>
            <column name="start-date" numcolumns="3" order="110">
                <widget type="date" fieldname="startdate" required="true" />
            </column>
            <column name="end-date" numcolumns="3" order="120" description="empty-for-not-end">
                <widget type="date" fieldname="enddate" />
            </column>
            <column name="first-date" title="first-document" numcolumns="3" description="first-date-desc" order="130">
                <widget type="date" fieldname="firstdate" />
            </column>
            <column name="first-pct" description="first-pct-desc" order="130">
                <widget type="number" fieldname="firstpct" required="true" min="1" max="100" step="1" />
            </column>
        </group>
    </columns>
</view>