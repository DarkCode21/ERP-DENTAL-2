<table>
    <column>
        <name>amount</name>
        <type>double precision</type>
    </column>
    <column>
        <name>codcliente</name>
        <type>character varying(10)</type>
        <null>NO</null>
    </column>
    <column>
        <name>codpago</name>
        <type>character varying(10)</type>
    </column>
    <column>
        <name>copied</name>
        <type>boolean</type>
        <default>false</default>
    </column>
    <column>
        <name>creationdate</name>
        <type>timestamp</type>
    </column>
    <column>
        <name>editable</name>
        <type>boolean</type>
    </column>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>idasiento</name>
        <type>integer</type>
    </column>
    <column>
        <name>lastnick</name>
        <type>character varying(50)</type>
    </column>
    <column>
        <name>lastupdate</name>
        <type>timestamp</type>
    </column>
    <column>
        <name>modelid</name>
        <type>integer</type>
    </column>
    <column>
        <name>modelname</name>
        <type>character varying(50)</type>
    </column>
    <column>
        <name>nick</name>
        <type>character varying(50)</type>
    </column>
    <column>
        <name>notes</name>
        <type>text</type>
    </column>
    <column>
        <name>payment_date</name>
        <type>date</type>
    </column>
    <constraint>
        <name>prepagoscli_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>ca_prepagoscli_users_lastnick</name>
        <type>FOREIGN KEY (lastnick) REFERENCES users (nick) ON DELETE SET NULL ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_prepagoscli_users_nick</name>
        <type>FOREIGN KEY (nick) REFERENCES users (nick) ON DELETE SET NULL ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_prepagoscli_formaspago</name>
        <type>FOREIGN KEY (codpago) REFERENCES formaspago (codpago) ON DELETE SET NULL ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_prepagoscli_clientes</name>
        <type>FOREIGN KEY (codcliente) REFERENCES clientes (codcliente) ON DELETE RESTRICT ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_prepagoscli_asientos</name>
        <type>FOREIGN KEY (idasiento) REFERENCES asientos (idasiento) ON DELETE SET NULL ON UPDATE CASCADE</type>
    </constraint>
</table>