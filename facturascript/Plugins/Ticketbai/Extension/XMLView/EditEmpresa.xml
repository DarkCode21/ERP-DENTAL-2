<?xml version="1.0" encoding="UTF-8"?>
<view>
    <columns>
        <group name="ticketbai" title="ticketbai" icon="fa-solid fa-qrcode" numcolumns="12">
            <column name="license" numcolumns="3" order="100">
                <widget type="text" fieldname="tbai_license"/>
            </column>
            <column name="developer" numcolumns="3" order="110">
                <widget type="text" fieldname="tbai_developer"/>
            </column>
            <column name="supplier" numcolumns="3" order="120">
                <widget type="text" fieldname="tbai_supplier"/>
            </column>
            <column name="version" numcolumns="3" order="130">
                <widget type="text" fieldname="tbai_version"/>
            </column>
            <column name="certificate" numcolumns="3" order="140">
                <widget type="file" fieldname="tbai_signature" accept=".p12" readonly="dinamic"/>
            </column>
            <column name="password" numcolumns="3" order="150">
                <widget type="password" fieldname="tbai_password"/>
            </column>
            <column name="nif-certificate" numcolumns="3" order="160">
                <widget type="text" fieldname="tbai_signature_nif" maxlenght="30"/>
            </column>
            <column name="start-date-sign" numcolumns="3" order="170">
                <widget type="date" fieldname="tbai_startdatesign"/>
            </column>
            <column name="debug-mode" order="180">
                <widget type="checkbox" fieldname="tbai_debugmode"/>
            </column>
            <column name="allow-annular" order="190">
                <widget type="checkbox" fieldname="tbai_annular"/>
            </column>
        </group>
    </columns>
    <modals>
        <group name="tbai-new-file" title="signature" icon="fa-solid fa-file-upload">
            <column name="file" order="100">
                <widget type="file" fieldname="newfile" accept=".p12" required="true"/>
            </column>
        </group>
    </modals>
</view>