    Description:
        Estructura de la vista EditOrdenProducto.

        IMPORTANTE:
        Añade el botón para mostrar el producto asociado a la línea.
        El modal está implementado en la vista EditOrdenProduccion.xml
-->
<view>
    <columns>
        <group name="data" numcolumns="12">
            <column name="code" numcolumns="1" display="none" order="100">
                <widget type="number" fieldname="id" readonly="true" />
            </column>
            <column name="production" title="production-order" numcolumns="1" display="none" order="110">
                <widget type="text" fieldname="idorden" readonly="true" />
            </column>
            <column name="reference" description="reference-production" numcolumns="3" order="120">
                <widget type="autocomplete" fieldname="referencia" required="true">
                    <values source="Variante" fieldcode="referencia" fieldtitle="descripcion" />
                </widget>
            </column>
            <column name="quantity" numcolumns="1" order="130">
                <widget type="number" fieldname="cantidad" min="0" required="true" />
            </column>
            <column name="product" order="140">
                <widget type="text" fieldname="productname" readonly="true" />
            </column>
            <column name="serial-number" numcolumns="2" order="150">
                <widget type="select" fieldname="numserietype" translate="true" required="true">
                    <values title="none">0</values>
                    <values title="counter">1</values>
                    <values title="reference-counter">2</values>
                    <values title="family-counter">3</values>
                </widget>
            </column>
        </group>
    </columns>
    <rows>
        <row type="actions">
            <button type="js" label='product' color="info" action="showProduct(this.form)" icon="fa-solid fa-magnifying-glass-plus" />
        </row>
    </rows>
</view>
