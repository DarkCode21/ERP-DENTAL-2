<view>
    <columns>
        <column name="code" display="none" order="100">
            <widget type="text" fieldname="id"  />
        </column>
        <column name="production" order="110">
            <widget type="text" fieldname="idorden" onclick="EditOrdenProduccion" />
        </column>
        <column name="date" display="center" order="130">
            <widget type="date" fieldname="fecha"  />
        </column>
        <column name="time" display="center" order="140">
            <widget type="time" fieldname="hora"  />
        </column>
        <column name="manufactured-by" order="150">
            <widget type="text" fieldname="nick"  />
        </column>
        <column name="reference" order="160">
            <widget type="text" fieldname="reference"  />
        </column>
        <column name="product" order="170">
            <widget type="text" fieldname="producto"  />
        </column>
        <column name="numserie" order="180">
            <widget type="text" fieldname="numserie"  />
        </column>
        <column name="verified" display="center" order="190">
            <widget type="datetime" fieldname="verifydate"  />
        </column>
        <column name="verified-by" order="200">
            <widget type="text" fieldname="verifynick"  />
        </column>
        <column name="delivery-note" order="210">
            <widget type="autocomplete" fieldname="iddelivery" onclick="EditAlbaranCliente">
                <values source="albaranescli" fieldcode="idalbaran" fieldtitle="codigo" />
            </widget>
        </column>

    </columns>

    <rows>
        <row type="status" fieldname="verified">
            <option title="pending" color="danger">0</option>
            <option title="verified" color="white">1</option>
        </row>
    </rows>
</view>
