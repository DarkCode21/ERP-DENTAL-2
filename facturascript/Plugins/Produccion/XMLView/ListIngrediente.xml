<view>
    <columns>
        <column name="code" display="none" order="100">
            <widget type="text" fieldname="id"  />
        </column>
        <column name="production" order="110">
            <widget type="text" fieldname="idorden" onclick="EditOrdenProduccion" />
        </column>
        <column name="recipe" order="120">
            <widget type="text" fieldname="receta"  />
        </column>
        <column name="date" display="center" order="130">
            <widget type="date" fieldname="fecha"  />
        </column>
        <column name="time" display="center" order="140">
            <widget type="time" fieldname="hora"  />
        </column>
        <column name="reference" order="150">
            <widget type="text" fieldname="referencia"  />
        </column>
        <column name="product" order="160">
            <widget type="text" fieldname="producto"  />
        </column>
        <column name="quantity" display="right" order="170">
            <widget type="number" fieldname="cantidad"  />
        </column>
        <column name="status" numcolumns="3" display="none" order="180">
                <widget type="select" fieldname="estado" translate="true">
                    <values title="pending">0</values>
                    <values title="started">10</values>
                    <values title="finished">20</values>
                    <values title="cancelled">99</values>
                </widget>
            </column>
    </columns>
    <rows>
        <row type="status" fieldname="estado">
            <option title="started" color="warning">10</option>
            <option title="finished" color="white">20</option>
            <option title="cancelled" color="danger">99</option>
        </row>
    </rows>

</view>
