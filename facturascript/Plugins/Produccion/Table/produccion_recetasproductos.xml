<table>
    <column>
        <name>cantidad</name>
        <type>double precision</type>
    </column>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>idreceta</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>numserietype</name>
        <type>integer</type>
    </column>
    <column>
        <name>principal</name>
        <type>boolean</type>
        <null>NO</null>
        <default>false</default>
    </column>
    <column>
        <name>referencia</name>
        <type>character varying(30)</type>
        <null>NO</null>
    </column>
    <column>
        <name>repartircoste</name>
        <type>integer</type>
    </column>

    <constraint>
        <name>produccion_recetasproductos_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>ca_produccion_recetasproductos_recetas</name>
        <type>FOREIGN KEY (idreceta) REFERENCES produccion_recetas (idreceta) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_produccion_recetasproductos_variantes</name>
        <type>FOREIGN KEY (referencia) REFERENCES variantes (referencia) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
</table>
