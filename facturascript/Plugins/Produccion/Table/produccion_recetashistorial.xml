-->
<table>
    <column>
        <name>cantidad</name>
        <type>double precision</type>
        <null>NO</null>
    </column>
    <column>
        <name>docmodel</name>
        <type>character varying(30)</type>
        <null>NO</null>
    </column>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>idreceta</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>fecha</name>
        <type>date</type>
        <null>NO</null>
    </column>
    <column>
        <name>hora</name>
        <type>time</type>
        <null>NO</null>
    </column>
    <column>
        <name>nick</name>
        <type>character varying(50)</type>
    </column>

    <constraint>
        <name>produccion_recetashistorial_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>ca_recetashistorial_recetas</name>
        <type>FOREIGN KEY (idreceta) REFERENCES produccion_recetas (idreceta) ON DELETE RESTRICT ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_recetashistorial_users</name>
        <type>FOREIGN KEY (nick) REFERENCES users (nick) ON DELETE SET NULL ON UPDATE CASCADE</type>
    </constraint>
</table>
