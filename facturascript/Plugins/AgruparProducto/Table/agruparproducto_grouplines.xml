<table>
    <column>
        <name>barcode</name>
        <type>character varying(20)</type>
    </column>
    <column>
        <name>bydefault</name>
        <type>boolean</type>
        <default>false</default>
    </column>
    <column>
        <name>discount</name>
        <type>double precision</type>
        <null>NO</null>
        <default>0</default>
    </column>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>idproduct</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>idgroup</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>quantity</name>
        <type>double precision</type>
        <null>NO</null>
        <default>0</default>
    </column>
    <constraint>
        <name>agruparproducto_grouplines_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>ca_agruparproducto_grouplines_group</name>
        <type>FOREIGN KEY (idgroup) REFERENCES agruparproducto_group (id) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_agruparproducto_grouplines_productos</name>
        <type>FOREIGN KEY (idproduct) REFERENCES productos (idproducto) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>uniq_agruparproducto_grouplines_product</name>
        <type>UNIQUE (idgroup,idproduct)</type>
    </constraint>
</table>
