            </column>
	        <column name="user" titleurl="ListUser" order="140">
                <widget type="select" fieldname="nick" icon="fas fa-user-circle" onclick="EditUser" readonly="true"
                        required="true">
                    <values source="users" fieldcode="nick" fieldtitle="nick"/>
                </widget>
            </column>
			<!-- 
			<column name="status" order="160">
                <widget type="select" fieldname="idestado" required="true">
                    <values source="proyectos_estados" fieldcode="estado" fieldtitle="nombre"/>
                </widget>
            </column>
			-->
        </group>
	</columns>
</view>