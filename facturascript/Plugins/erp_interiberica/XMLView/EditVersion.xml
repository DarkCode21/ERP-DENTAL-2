<?xml version="1.0" encoding="UTF-8"?>
<view>
    <columns>
        <group name="main">
			<column name="code" display="none" order="100">
                <widget type="text" fieldname="id"/>
            </column>
            <column name="name-software" numcolumns="12" order="110">
                <widget type="text" fieldname="nombresoftware" required="true" />
            </column>
            <column name="version" order="120">
