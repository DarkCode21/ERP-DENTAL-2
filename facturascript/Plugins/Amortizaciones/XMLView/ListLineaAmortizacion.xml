    Description:
        Structure of the view for a list of lines for amortizations.
-->
<view>
    <columns>
        <column name="code" display="none" order="100">
            <widget type="text" fieldname="idlinea" />
        </column>
        <column name="amortization" order="110">
            <widget type="text" fieldname="idamortizacion" onclick="EditAmortizacion" />
        </column>
        <column name="description" order="120">
            <widget type="autocomplete" fieldname="idamortizacion">
                <values source="amortizaciones" fieldcode="idamortizacion" fieldtitle="descripcion"/>
            </widget>
        </column>
        <column name="year" display="center" order="130">
            <widget type="text" fieldname="ano" />
        </column>
        <column name="period" display="center" order="140">
            <widget type="text" fieldname="periodo" />
        </column>
        <column name="date" display="center" order="150">
            <widget type="date" fieldname="fecha" />
        </column>
        <column name="accounting-entry" display="center" order="160">
            <widget type="autocomplete" fieldname="idasiento" onclick="EditAsiento">
                <values source="asientos" fieldcode="idasiento" fieldtitle="numero" />
            </widget>
        </column>
        <column name="capital" display="none" order="170">
            <widget type="money" fieldname="capital" />
        </column>
        <column name="interest" display="none" order="180">
            <widget type="money" fieldname="interes" />
        </column>
        <column name="to-amortize" display="right" order="190">
            <widget type="money" fieldname="cantidad" />
        </column>
        <column name="amortized" display="right" order="200">
            <widget type="money" fieldname="amortizado" />
        </column>
    </columns>

    <modals>
        <group name="insertline" title="insert-amortization-line" icon="fa-solid fa-square-plus">
            <column name="insert-iddoc" display="none" order="100">
                <widget type="text" fieldname="idamortizacion" />
            </column>
            <column name="insert-year" title="year" numcolumns="3" order="200">
                <widget type="select" fieldname="ano" required="true" />
            </column>
            <column name="insert-period" title="period" numcolumns="3" order="210">
                <widget type="select" fieldname="periodo" required="true" />
            </column>
            <column name="insert-amortize" title="to-amortize" numcolumns="6" order="300">
                <widget type="money" fieldname="cantidad" required="true" />
            </column>
        </group>

        <group name="editline" title="edit-amortization-line" icon="fa-solid fa-pen-to-square">
            <column name="idline" display="none" order="100">
                <widget type="text" fieldname="idlinea" />
            </column>
            <column name="iddoc" display="none" order="100">
                <widget type="text" fieldname="idamortizacion" />
            </column>
            <column name="year" numcolumns="3" order="200">
                <widget type="text" fieldname="ano" readonly="true" />
            </column>
            <column name="period" numcolumns="3" order="210">
                <widget type="text" fieldname="periodo" readonly="true" />
            </column>
            <column name="date" numcolumns="6" order="220">
                <widget type="date" fieldname="fecha" readonly="true" />
            </column>
            <column name="to-amortize" numcolumns="6" order="300">
                <widget type="money" fieldname="cantidad"/>
            </column>
            <column name="amortized" numcolumns="6" order="310">
                <widget type="money" fieldname="amortizado" />
            </column>
            <column name="accounting-entry" numcolumns="12" order="400">
                <widget type="autocomplete" fieldname="idasiento">
                    <values source="asientos" fieldcode="idasiento" fieldtitle="concepto"/>
                </widget>
            </column>
        </group>
    </modals>

    <row type="status">
        <option title="accounted" fieldname="idasiento" color="success">notnull:</option>
    </row>
</view>
