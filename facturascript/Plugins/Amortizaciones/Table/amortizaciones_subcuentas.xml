<table>
    <column>
        <name>code</name>
        <type>character varying(10)</type>
        <null>NO</null>
    </column>
    <column>
        <name>groupid</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>grouptype</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <constraint>
        <name>amortizaciones_subcuentas_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>uniq_amortizaciones_subcuentas</name>
        <type>UNIQUE (grouptype, groupid, code)</type>
    </constraint>
</table>
