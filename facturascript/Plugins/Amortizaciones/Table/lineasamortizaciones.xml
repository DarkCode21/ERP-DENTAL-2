<table>
    <column>
        <name>ano</name>
        <type>integer</type>
    </column>
    <column>
        <name>amortizado</name>
        <type>double precision</type>
    </column>
    <column>
        <name>cantidad</name>
        <type>double precision</type>
    </column>
    <column>
        <name>capital</name>
        <type>double precision</type>
    </column>
    <column>
        <name>fecha</name>
        <type>date</type>
    </column>
    <column>
        <name>idamortizacion</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>idasiento</name>
        <type>integer</type>
    </column>
    <column>
        <name>idlinea</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>interes</name>
        <type>double precision</type>
    </column>
    <column>
        <name>periodo</name>
        <type>integer</type>
    </column>
    <constraint>
        <name>lineasamortizaciones_pkey</name>
        <type>PRIMARY KEY (idlinea)</type>
    </constraint>
    <constraint>
        <name>ca_lineasamortizaciones_amortizaciones</name>
        <type>FOREIGN KEY (idamortizacion) REFERENCES amortizaciones (idamortizacion) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_lineasamortizaciones_asientos</name>
        <type>FOREIGN KEY (idasiento) REFERENCES asientos (idasiento) ON DELETE SET NULL ON UPDATE CASCADE</type>
    </constraint>
</table>
