{% extends "Master/MenuTemplate.html.twig" %}

{% block body %}
<div class="container-fluid">

{% if fsc.active == 'ErrorDashboard' %}
    <!-- Tab Dashboard Visual -->
    <div class="row">
        <div class="col-12">
            <div class="page-header">
                <h1><i class="fas fa-exclamation-triangle text-warning mr-2"></i>{{ i18n.trans('verifactu-error-report') }}</h1>
                <p class="text-muted">Panel visual de errores de Verifactu</p>
            </div>
        </div>
    </div>

    <!-- Estadísticas resumen -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-danger text-white">
                <div class="card-body text-center">
                    <h2 class="card-title">{{ fsc.errorStats.total_errors ?? 0 }}</h2>
                    <p class="card-text">Total de Errores</p>
                    <i class="fas fa-exclamation-circle fa-2x"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-dark">
                <div class="card-body text-center">
                    <h2 class="card-title">{{ fsc.errorStats.unresolved_count ?? 0 }}</h2>
                    <p class="card-text">Sin Resolver</p>
                    <i class="fas fa-clock fa-2x"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body text-center">
                    <h2 class="card-title">{{ fsc.errorStats.certificate_issues ?? 0 }}</h2>
                    <p class="card-text">Problemas de Certificado</p>
                    <i class="fas fa-certificate fa-2x"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body text-center">
                    <h2 class="card-title">{{ (fsc.errorStats.total_errors ?? 0) - (fsc.errorStats.unresolved_count ?? 0) }}</h2>
                    <p class="card-text">Resueltos</p>
                    <i class="fas fa-check-circle fa-2x"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Errores por tipo -->
    {% if fsc.errorStats.by_type %}
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5><i class="fas fa-chart-pie mr-2"></i>Errores por Tipo</h5>
                </div>
                <div class="card-body">
                    {% for type, count in fsc.errorStats.by_type %}
                        <div class="mb-2">
                            <div class="d-flex justify-content-between">
                                <span class="badge badge-pill {% if type == 'CERTIFICATE_ERROR' %}badge-danger{% elseif type == 'SIGNATURE_GENERATION_FAILED' %}badge-warning{% elseif type == 'HASH_GENERATION_FAILED' %}badge-info{% else %}badge-secondary{% endif %}">
                                    {{ type }}
                                </span>
                                <strong>{{ count }}</strong>
                            </div>
                            <div class="progress mt-1" style="height: 8px;">
                                <div class="progress-bar {% if type == 'CERTIFICATE_ERROR' %}bg-danger{% elseif type == 'SIGNATURE_GENERATION_FAILED' %}bg-warning{% elseif type == 'HASH_GENERATION_FAILED' %}bg-info{% else %}bg-secondary{% endif %}" 
                                     style="width: {{ (count / fsc.errorStats.total_errors * 100)|round(1) }}%"></div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
    {% endif %}

    <!-- Lista de errores recientes -->
    {% if fsc.errors %}
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5><i class="fas fa-list mr-2"></i>Errores Recientes</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Tipo</th>
                                    <th>Factura</th>
                                    <th>Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for error in fsc.errors|slice(0, 10) %}
                                <tr class="{% if not error.resolved %}table-warning{% endif %}">
                                    <td>{{ error.fecha }}</td>
                                    <td>
                                        <span class="badge {% if error.error_type == 'CERTIFICATE_ERROR' %}badge-danger{% elseif error.error_type == 'SIGNATURE_GENERATION_FAILED' %}badge-warning{% elseif error.error_type == 'HASH_GENERATION_FAILED' %}badge-info{% else %}badge-secondary{% endif %}">
                                            {{ error.error_type }}
                                        </span>
                                    </td>
                                    <td>
                                        {% if error.factura_id %}
                                            <a href="EditFacturaCliente?code={{ error.factura_id }}" target="_blank">
                                                #{{ error.factura_id }}
                                            </a>
                                        {% else %}
                                            N/A
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if error.resolved %}
                                            <span class="badge badge-success">Resuelto</span>
                                        {% else %}
                                            <span class="badge badge-warning">Pendiente</span>
                                        {% endif %}
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% else %}
    <div class="row">
        <div class="col-12">
            <div class="alert alert-success text-center">
                <i class="fas fa-check-circle fa-3x mb-3"></i>
                <h4>¡Sin errores encontrados!</h4>
                <p>No se han detectado errores en el sistema Verifactu.</p>
            </div>
        </div>
    </div>
    {% endif %}

{% elseif fsc.active == 'ExportErrors' %}
    <!-- Tab Export JSON -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-download fa-fw" aria-hidden="true"></i>
                        Exportar Errores JSON
                    </h3>
                </div>
                <div class="card-body">
                    <form method="get" action="{{ fsc.url() }}">
                        <div class="row">
                            <div class="col-sm-6 col-lg-4">
                                <div class="form-group">
                                    <label for="idempresa">{{ i18n.trans('company') }}</label>
                                    <select name="idempresa" id="idempresa" class="form-control">
                                        {% for company in fsc.getCompanies() %}
                                            <option value="{{ company.idempresa }}">{{ company.nombre }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                            </div>
                            <div class="col-sm-6 col-lg-4">
                                <div class="form-group">
                                    <label for="days">{{ i18n.trans('days') }}</label>
                                    <select name="days" id="days" class="form-control">
                                        <option value="1">1 {{ i18n.trans('day') }}</option>
                                        <option value="7" selected>7 {{ i18n.trans('days') }}</option>
                                        <option value="15">15 {{ i18n.trans('days') }}</option>
                                        <option value="30">30 {{ i18n.trans('days') }}</option>
                                        <option value="60">60 {{ i18n.trans('days') }}</option>
                                        <option value="90">90 {{ i18n.trans('days') }}</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-lg-4">
                                <div class="form-group">
                                    <label>&nbsp;</label>
                                    <div class="btn-group d-block">
                                        <button type="submit" name="action" value="export-json" class="btn btn-primary">
                                            <i class="fas fa-download fa-fw" aria-hidden="true"></i>
                                            {{ i18n.trans('export-complete-json') }}
                                        </button>
                                        <button type="submit" name="action" value="export-summary" class="btn btn-info">
                                            <i class="fas fa-chart-pie fa-fw" aria-hidden="true"></i>
                                            {{ i18n.trans('export-summary-json') }}
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>

                    <hr>

                    <div class="row">
                        <div class="col-12">
                            <h4>{{ i18n.trans('error-types-captured') }}</h4>
                            <div class="table-responsive">
                                <table class="table table-sm table-hover">
                                    <thead>
                                        <tr>
                                            <th>{{ i18n.trans('error-type') }}</th>
                                            <th>{{ i18n.trans('description') }}</th>
                                            <th>{{ i18n.trans('source-job') }}</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td><code>HASH_GENERATION_FAILED</code></td>
                                            <td>{{ i18n.trans('hash-generation-failed') }}</td>
                                            <td>verifactu-invoice-hash-signature</td>
                                        </tr>
                                        <tr>
                                            <td><code>HASH_GENERATION_EXCEPTION</code></td>
                                            <td>{{ i18n.trans('hash-generation-exception') }}</td>
                                            <td>verifactu-invoice-hash-signature</td>
                                        </tr>
                                        <tr>
                                            <td><code>SIGNATURE_GENERATION_FAILED</code></td>
                                            <td>{{ i18n.trans('signature-generation-failed') }}</td>
                                            <td>verifactu-invoice-hash-signature</td>
                                        </tr>
                                        <tr>
                                            <td><code>SEND_MANUAL_ERROR</code></td>
                                            <td>{{ i18n.trans('send-manual-error') }}</td>
                                            <td>verifactu-invoice-send</td>
                                        </tr>
                                        <tr>
                                            <td><code>CERTIFICATE_ERROR</code></td>
                                            <td>{{ i18n.trans('certificate-error') }}</td>
                                            <td>{{ i18n.trans('various') }}</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="row mt-4">
                        <div class="col-12">
                            <div class="alert alert-info">
                                <h5><i class="fas fa-info-circle fa-fw"></i> {{ i18n.trans('json-export-info') }}</h5>
                                <ul class="mb-0">
                                    <li><strong>{{ i18n.trans('export-complete-json') }}:</strong> {{ i18n.trans('exports-all-error-details') }}</li>
                                    <li><strong>{{ i18n.trans('export-summary-json') }}:</strong> {{ i18n.trans('exports-error-summary-statistics') }}</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <h4>{{ i18n.trans('example-json-structure') }}</h4>
                            <pre><code>{
  "generated_at": "2025-01-23 10:30:00",
  "empresa_id": 1,
  "period_days": 7,
  "total_errors": 3,
  "errors": [
    {
      "id": 1,
      "timestamp": "2025-01-23 09:15:32",
      "job_name": "verifactu-invoice-hash-signature",
      "error_type": "SIGNATURE_GENERATION_FAILED",
      "error_message": "Error al generar la firma en el JSON: MyFiles/Verifactu/1/RegistrosFacturas/2025/578-alta.json",
      "factura_id": "23",
      "json_file": "MyFiles/Verifactu/1/RegistrosFacturas/2025/578-alta.json",
      "resolved": false,
      "details": {
        "step": "signature_generation"
      }
    }
  ]
}</code></pre>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endif %}
</div>
{% endblock %}