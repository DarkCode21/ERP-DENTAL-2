<view>
    <columns>
        <column name="id"  order="100">
            <widget type="text" fieldname="idfactura" />
        </column>
        <column name="code" order="110">
            <widget type="text" fieldname="codigo" />
        </column>
        <column name="date" display="right" order="120">
            <widget type="date" fieldname="fecha" />
        </column>
        <column name="cifnif" order="130">
            <widget type="text" fieldname="cifnif" />
        </column>
        <column name="customer" order="140">
            <widget type="text" fieldname="nombre" />
        </column>
        <column name="iva" display="right" order="150" title="IVA">
            <widget type="money" fieldname="totaliva">
                <option color="danger">&lt;0</option>
            </widget>
        </column>
       <column name="irpf" display="right" order="160">
            <widget type="money" fieldname="totalirpf">
                <option color="danger">&lt;0</option>
            </widget>
        </column>
        <column name="recargo" display="right" order="170">
            <widget type="money" fieldname="totalrecargo">
                <option color="danger">&lt;0</option>
            </widget>
        </column>
        <column name="amount" display="right" order="180">
            <widget type="money" fieldname="total">
                <option color="danger">&lt;0</option>
            </widget>
        </column>
        
    </columns>
    <rows>
        <row type="status">
            <option color="warning" fieldname="editable">1</option>
            <option color="success" fieldname="pagado">1</option>
        </row>
        <row type='actions'>
    <button type='action' label='print-report' color='success' action='print-pdf' icon='fas fa-print fa-fw' />   
    <button type='action' label='export-report' color='success' action='export-report' icon='fas fa-file-csv' />
</row>
    </rows>
</view>
