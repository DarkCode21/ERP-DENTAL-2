<table>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
        <default>nextval('fsreports_filters_seq'::regclass)</default>
    </column>
    <column>
        <name>idreport</name>
        <type>integer</type>
        <null>NO</null>
        <default>0</default>
    </column>
    <column>
        <name>type</name>
        <type>character varying(50)</type>
    </column>
    <column>
        <name>operator</name>
        <type>character varying(50)</type>
    </column>
    <column>
        <name>label</name>
        <type>character varying(50)</type>
    </column>
    <column>
        <name>default_value</name>
        <type>character varying(50)</type>
    </column>
    <constraint>
        <name>fsreports_filters_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>ca_filters_reports</name>
        <type>FOREIGN KEY (idfilters) REFERENCES fsreports_reports (id) ON DELETE RESTRICT ON UPDATE CASCADE</type>
    </constraint>
</table>