<view>
    <modals>
        <group name="upload-factura-e" title="import-factura-e" icon="fa-solid fa-qrcode">
            <column name="company" numcolumns="12" order="100">
                <widget type="select" fieldname="ife_company" required="true">
                    <values source="empresas" fieldcode="idempresa" fieldtitle="nombrecorto"/>
                </widget>
            </column>
            <column name="file" numcolumns="12" order="110">
                <widget type="file" fieldname="ife_file" accept=".xml,.xsig" required="true"/>
            </column>
        </group>
    </modals>
</view>