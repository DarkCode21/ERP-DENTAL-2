{% extends "Master/MenuBghTemplate.html.twig" %}

{% block body %}
    {{ parent() }}
    {% set divisa = fsc.getDivisa() %}
    {% set cajaContextUrl = fsc.url() ~ (fsc.mesa ? '?idmesa=' ~ fsc.mesa.idmesa : (fsc.vistaOrdenes ? '?vista=ordenes' : '')) %}
    <div class="bg-light pt-3 pb-5">
        <div class="container">
            <div class="row">
                <div class="col">
                    <h1 class="h2">
                        <i class="fas fa-cash-register"></i> Cerrar caja
                        ({{ divisa.simbolo }})
                    </h1>
                    <small class="text-secondary">RestauranteTPV - Serie: {{ fsc.cashSerie }}</small>
                </div>
            </div>
        </div>
    </div>
    <div class="container" style="margin-top: -40px;">
        <div class="row">
            <div class="col-sm">
                <div class="card shadow mb-4">
                    <div class="card-body">
                        <form action="{{ cajaContextUrl }}" method="post">
                            <input type="hidden" name="action" value="cash-close">
                            <div class="form-row">
                                {% for coin in fsc.getCoinTypes() %}
                                    <div class="col-sm-4 pb-3">
                                        {{ (coin.name < 1) ? coin.name | number_format(2) : coin.name }}
                                        {{ divisa.simbolo }}
                                        <input type="number" name="{{ coin.name|replace({'.': '_'}) }}" value="0" min="0" class="form-control" required>
                                    </div>
                                {% else %}
                                    <div class="col pb-4">
                                        <div class="form-group">
                                            <label>Final caja</label>
                                            <input type="number" step="0.01" min="0" name="cash-final" class="form-control" required>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                            <div class="form-group">
                                Observaciones
                                <textarea name="cash-note" class="form-control"></textarea>
                            </div>
                            <div class="form-row d-flex">
                                <div class="col align-self-center">
                                    <a href="{{ cajaContextUrl }}" class="btn btn-secondary">Cancelar</a>
                                </div>
                                <div class="col text-center align-self-center">
                                    <div class="font-weight-bolder">Inicio caja</div>
                                    <div>{{ fsc.getFormatMoney(fsc.cashBox.dineroini) }}</div>
                                </div>
                                <div class="col text-center align-self-center">
                                    <div class="font-weight-bolder">Ingresos</div>
                                    <div>{{ fsc.getFormatMoney(fsc.cashBox.ingresos) }}</div>
                                </div>
                                <div class="col text-center align-self-center">
                                    <div class="font-weight-bolder">Entrada caja</div>
                                    <div>{{ fsc.getFormatMoney(fsc.cashBox.getManualIncomes()) }}</div>
                                </div>
                                <div class="col text-center align-self-center">
                                    <div class="font-weight-bolder">Salida caja</div>
                                    <div>{{ fsc.getFormatMoney(fsc.cashBox.getManualOutcomes()) }}</div>
                                </div>
                                <div class="col text-center align-self-center">
                                    <div class="font-weight-bolder">Total en caja</div>
                                    <div>{{ fsc.getFormatMoney(fsc.cashBox.getTotalInBox()) }}</div>
                                </div>
                                <div class="col text-right align-self-center">
                                    <button type="submit" class="btn btn-primary btn-spin-action">Guardar</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
                {% set movements = fsc.cashBox.getMovements() %}
                <div class="card shadow mb-4">
                    <div class="card-body p-0">
                        <div class="px-3 py-2 border-bottom bg-light font-weight-bold">Movimientos de caja del dia</div>
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Usuario</th>
                                    <th>Tipo</th>
                                    <th>Concepto</th>
                                    <th class="text-right">Importe</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for movement in movements %}
                                    <tr>
                                        <td>{{ movement.fecha }}</td>
                                        <td>{{ movement.nick }}</td>
                                        <td>{{ movement.tipo == 'in' ? 'Entrada' : 'Salida' }}</td>
                                        <td>{{ movement.concepto }}</td>
                                        <td class="text-right">{{ fsc.getFormatMoney(movement.importe) }}</td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-3">Sin movimientos manuales.</td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
