	<script>
		/* ═══════════════════════════════════════════════════════
   TPV — Tabs, AJAX actions, buscador de productos
   ═══════════════════════════════════════════════════════ */

// ── Tabs ──────────────────────────────────────────────
var TAB_KEY = 'tpv_tab_       {{ fsc.mesa ? fsc.mesa.idmesa : 0 }}';

function tpvTab(tab, save) {
var elCatalogo = document.getElementById('panel-catalogo');
var elComandaTab = document.getElementById('panel-comanda-tab');
var elOrdenesTab = document.getElementById('panel-ordenes-tab');
var lnkCatalogo = document.getElementById('tab-catalogo-link');
var lnkComanda = document.getElementById('tab-comanda-link');
var lnkOrdenes = document.getElementById('tab-ordenes-link');
if (! elCatalogo) 
return;



// Ocultar todo
elCatalogo.classList.add('d-none');
if (elComandaTab) 
elComandaTab.classList.add('d-none');



if (elOrdenesTab) {
elOrdenesTab.classList.add('d-none');
elOrdenesTab.style.display = '';
}


if (lnkCatalogo) 
lnkCatalogo.classList.remove('active');



if (lnkComanda) 
lnkComanda.classList.remove('active');



if (lnkOrdenes) 
lnkOrdenes.classList.remove('active');



if (tab === 'catalogo') {
elCatalogo.classList.remove('d-none');
if (lnkCatalogo) 
lnkCatalogo.classList.add('active');



} else if (tab === 'ordenes') {
if (elOrdenesTab) {
elOrdenesTab.classList.remove('d-none');
elOrdenesTab.style.display = 'flex';
}
if (lnkOrdenes) 
lnkOrdenes.classList.add('active');



} else {
if (elComandaTab) 
elComandaTab.classList.remove('d-none');



if (lnkComanda) 
lnkComanda.classList.add('active');



}
if (save !== false) {
try {
localStorage.setItem(TAB_KEY, tab);
} catch (e) {}
}
}

function restoreTab() {
if (window.innerWidth >= 1200) 
return;



// xl: no tabs
try {
var saved = localStorage.getItem(TAB_KEY) || 'catalogo';
tpvTab(saved, false);
} catch (e) {}
}

// En xl+ siempre mostrar catálogo, ocultar panel-comanda-tab y panel-ordenes-tab
function checkWidth() {
var catEl = document.getElementById('panel-catalogo');
var comEl = document.getElementById('panel-comanda-tab');
var ordEl = document.getElementById('panel-ordenes-tab');
if (! catEl || ! comEl) 
return;



if (window.innerWidth >= 1200) {
catEl.classList.remove('d-none');
comEl.classList.add('d-none');
if (ordEl) 
ordEl.classList.add('d-none');



} else {
restoreTab();
}
}
window.addEventListener('resize', checkWidth);

// ── Familias AJAX ────────────────────────────────────
function _tpvFiltrarGrid(url) {
fetch(url).then(function (r) {
return r.text();
}).then(function (html) {
var doc = new DOMParser().parseFromString(html, 'text/html');
var newGrid = doc.getElementById('grid-productos');
var curGrid = document.getElementById('grid-productos');
if (newGrid && curGrid) 
curGrid.innerHTML = newGrid.innerHTML;



var inp = document.getElementById('buscador-productos');
if (inp) 
inp.value = '';



}).catch(function () {});
}

// Sidebar xl: marcar activo y cargar
function tpvFiltrarSidebar(btn, url, label) {
document.querySelectorAll('.cat-sidebar-btn').forEach(function (b) {
b.classList.remove('active', 'active-est');
});
var isEst = url.indexOf('&estacion=') !== -1;
btn.classList.add(isEst ? 'active-est' : 'active');
// actualizar dropdown label (por si se usa en mobile también)
var dropdBtn = document.getElementById('dropdownFamiliaBtn');
if (dropdBtn) 
dropdBtn.firstChild.textContent = label;



_tpvFiltrarGrid(url);
}

// Dropdown mobile: actualizar label y cargar
function tpvFiltrarDropdown(item, url, label) {
var dropdBtn = document.getElementById('dropdownFamiliaBtn');
if (dropdBtn) 
dropdBtn.firstChild.textContent = label;



if (dropdBtn && typeof $ !== 'undefined') 
$(dropdBtn).dropdown('hide');



_tpvFiltrarGrid(url);
}

function modalCashMovement(actionType) {
$('#cashMovementAmount').val('');
$('#cashMovementConcept').val('');

if (actionType === 'cash-out') {
$('#cashMovementTitle').text('Salida de caja');
} else {
$('#cashMovementTitle').text('Entrada de caja');
}

$('#cashMovementAction').val(actionType);
$('#modalCashMovement').off('shown.bs.modal').on('shown.bs.modal', function () {
$('#cashMovementAmount').focus();
});
$('#modalCashMovement').modal('show');
return false;
}

// ── Buscador de facturas en modal ─────────────────────
var _busFacturasTimer = null;
var _busFacturasQ = '';
var _busFacturasPag = 1;

function tpvFiltrarFacturas(q) {
clearTimeout(_busFacturasTimer);
_busFacturasQ = q.trim();
_busFacturasPag = 1;
_busFacturasTimer = setTimeout(function () {
_busFacturasAjax(_busFacturasQ, _busFacturasPag);
}, 350);
}

function _busFacturasAjax(q, page) {
var tbody = document.querySelector('#modalCuenta tbody');
if (! tbody) 
return;



tbody.innerHTML = '<tr><td colspan="5" class="text-center py-3"><i class="fa-solid fa-spinner fa-spin"></i></td></tr>';
fetch('{{ fsc.url() }}?action=search-facturas&q=' + encodeURIComponent(q) + '&page=' + page + '&_t=' + Date.now()).then(function (r) {
return r.json();
}).then(function (d) {
if (! d.rows || d.rows.length === 0) {
tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-3">No se encontraron facturas.</td></tr>';
_busFacturasRenderPag(0, 0, 0, 20);
return;
}
tbody.innerHTML = d.rows.map(function (fac) {
var cambio = parseFloat(fac.tpv_cambio || 0);
var cambioHtml = cambio > 0 ? cambio.toFixed(2) + ' \u20ac' : '-';
return '<tr>' + '<td class="font-weight-bold">' + _escHtml(fac.codigo) + '</td>' + '<td>' + _escHtml(fac.fecha) + '</td>' + '<td>' + _escHtml(fac.nombrecliente) + '</td>' + '<td class="text-right">' + parseFloat(fac.total).toFixed(2) + ' \u20ac</td>' + '<td class="text-right" style="white-space:nowrap;">' + '<button type="button" class="btn btn-sm btn-outline-primary" style="padding:2px 7px;" onclick="tpvVerFactura(' + fac.idfactura + ')"><i class="fa-solid fa-eye"></i></button>' + '</td>' + '</tr>';
}).join('');
_busFacturasRenderPag(d.total, d.page, d.limit, d.limit);
}).catch(function () {
tbody.innerHTML = '<tr><td colspan="6" class="text-center text-danger py-3">Error al buscar.</td></tr>';
});
}

function _busFacturasRenderPag(total, page, limit) {
var cont = document.getElementById('facturas-paginacion');
var info = document.getElementById('facturas-info');
var pages = document.getElementById('facturas-pages');
if (! cont) 
return;



if (total <= (limit || 20)) {
cont.style.display = 'none';
return;
}
cont.style.display = 'flex';
var totalPages = Math.ceil(total / limit);
var from = (page - 1) * limit + 1;
var to = Math.min(page * limit, total);
info.textContent = 'Mostrando ' + from + '-' + to + ' de ' + total;
var html = '';
// Anterior
html += '<button type="button" class="btn btn-outline-secondary btn-sm' + (
page <= 1 ? ' disabled' : ''
) + '" onclick="_busFacturasIrPag(' + (
page - 1
) + ')">&laquo;</button>';
// Páginas cercanas
var start = Math.max(1, page - 2);
var end = Math.min(totalPages, page + 2);
if (start > 1) 
html += '<button type="button" class="btn btn-outline-secondary btn-sm" onclick="_busFacturasIrPag(1)">1</button>';



if (start > 2) 
html += '<span class="btn btn-sm disabled">…</span>';



for (var i = start; i <= end; i++) {
html += '<button type="button" class="btn btn-sm ' + (
i === page ? 'btn-secondary' : 'btn-outline-secondary'
) + '" onclick="_busFacturasIrPag(' + i + ')">' + i + '</button>';
}
if (end < totalPages - 1) 
html += '<span class="btn btn-sm disabled">…</span>';



if (end < totalPages) 
html += '<button type="button" class="btn btn-outline-secondary btn-sm" onclick="_busFacturasIrPag(' + totalPages + ')">' + totalPages + '</button>';



// Siguiente
html += '<button type="button" class="btn btn-outline-secondary btn-sm' + (
page >= totalPages ? ' disabled' : ''
) + '" onclick="_busFacturasIrPag(' + (
page + 1
) + ')">&raquo;</button>';
pages.innerHTML = html;
}

function _busFacturasIrPag(p) {
_busFacturasPag = p;
_busFacturasAjax(_busFacturasQ, p);
}

function _escHtml(s) {
return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

// ── Buscador de productos ─────────────────────────────
function initBuscador() {
var input = document.getElementById('buscador-productos');
if (! input) 
return;



input.addEventListener('input', function () {
var q = this.value.toLowerCase().trim();
document.querySelectorAll('#grid-productos .col-producto').forEach(function (col) {
var txt = col.querySelector('.prod-nombre');
if (! txt) 
return;



col.style.display = (! q || txt.textContent.toLowerCase().indexOf(q) !== -1) ? '' : 'none';
});
});
}

// ── AJAX — actualizar comanda sin recargar ────────────
function refreshComanda(responseHtml) {
var parser = new DOMParser();
var doc = parser.parseFromString(responseHtml, 'text/html');

// Reemplazar paneles de comanda (su HTML ya trae tokens frescos)
['panel-comanda', 'panel-comanda-tab'].forEach(function (id) {
var n = doc.getElementById(id);
var c = document.getElementById(id);
if (n && c) 
c.innerHTML = n.innerHTML;



});

// Reconstruir tpvSubLineas desde el DOM recién actualizado (para pre-checkboxes en modal editar)
tpvSubLineas = {};
document.querySelectorAll('.tpv-modif-row[data-idlineapadre]').forEach(function (tr) {
var padre = tr.getAttribute('data-idlineapadre');
var desc = tr.getAttribute('data-desclinea');
if (! padre || ! desc) 
return;



if (!tpvSubLineas[padre]) 
tpvSubLineas[padre] = [];



tpvSubLineas[padre].push(desc);
});

// Actualizar tokens de los formularios del catálogo por posición
var newToks = doc.querySelectorAll('#panel-catalogo .col-producto form input[name="multireqtoken"]');
var curToks = document.querySelectorAll('#panel-catalogo .col-producto form input[name="multireqtoken"]');
for (var i = 0; i < newToks.length && i < curToks.length; i++) {
curToks[i].value = newToks[i].value;
}

// Re-enganchar handlers a los nuevos forms de cantidad
attachAjaxForms();

// Actualizar badge del carrito
var _badgeRows = document.querySelectorAll('.tpv-table tbody tr:not(.tpv-modif-row)').length;
var _badge = document.getElementById('tpv-cart-badge');
if (_badge) {
_badge.textContent = _badgeRows;
_badge.style.display = _badgeRows > 0 ? 'inline' : 'none';
}
}

function attachAjaxForms() { // Forms de comanda y catálogo (no el modal de cobro)
var sel = '#panel-comanda form, #panel-comanda-tab form, #panel-catalogo .col-producto form';
document.querySelectorAll(sel).forEach(function (form) {
if (form._tpvAjax) 
return;



if (form.hasAttribute('data-no-ajax')) 
return;



form._tpvAjax = true;
form.addEventListener('submit', handleAjaxSubmit);

// Para inputs de precio: submit al cambiar
var priceInput = form.querySelector('input[name="precio"]');
if (priceInput && ! priceInput._tpvAjax) {
priceInput._tpvAjax = true;
priceInput.addEventListener('change', function () {
form.dispatchEvent(new Event('submit'));
});
}
});
}

// ── Modificadores de producto ──────────────────────────
var _modBtn,
_modUrl,
_modRef,
_modToken,
_modBase;

function tpvClickProducto(btn, url, referencia, token) {
var modifData = [];
try {
modifData = JSON.parse(btn.getAttribute('data-modif') || '[]');
} catch (e) {}
if (modifData && modifData.length > 0) {
var base = parseFloat(btn.getAttribute('data-precio') || '0') || 0;
tpvAbrirModificadores(btn, url, referencia, token, modifData, base);
} else {
tpvAddProducto(btn, url, referencia, token);
}
}

function tpvAbrirModificadores(btn, url, referencia, token, modificadores, base) {
_modBtn = btn;
_modUrl = url;
_modRef = referencia;
_modToken = token;
_modBase = base;

document.getElementById('mod-titulo').innerHTML = '<i class="fa-solid fa-sliders mr-2"></i>' + btn.querySelector('.prod-nombre').textContent.trim();
document.getElementById('mod-cantidad').value = 1;
document.getElementById('mod-nota').value = '';
document.getElementById('mod-confirmar').disabled = false;

var lista = document.getElementById('mod-lista');
lista.innerHTML = '';
modificadores.forEach(function (m) {
var item = document.createElement('div');
item.className = 'form-check border rounded px-3 py-2 mb-1';
item.innerHTML = '<label class="form-check-label d-flex justify-content-between w-100 mb-0" style="cursor:pointer;">' + '<span><input type="checkbox" class="form-check-input mr-2 mod-chk"' + ' data-nombre="' + m.nombre.replace(/"/g, '&quot;') + '"' + ' data-precio="' + m.precio + '"' + ' onchange="modActualizarTotal()"> ' + m.nombre + '</span>' + '<span class="text-muted small">+' + parseFloat(m.precio).toFixed(2) + '\u00a0\u20ac</span>' + '</label>';
lista.appendChild(item);
});

modActualizarTotal();
$('#modalModificadores').modal('show');
}

function modActualizarTotal() {
var cant = Math.max(1, parseInt(document.getElementById('mod-cantidad').value) || 1);
var extra = 0;
document.querySelectorAll('#mod-lista .mod-chk:checked').forEach(function (c) {
extra += parseFloat(c.dataset.precio) || 0;
});
document.getElementById('mod-total-unit').textContent = (_modBase + extra).toFixed(2) + ' \u20ac';
document.getElementById('mod-total').textContent = 'Total: ' + (
(_modBase + extra) * cant
).toFixed(2) + ' \u20ac';
}

function modCambiarCantidad(delta) {
var inp = document.getElementById('mod-cantidad');
inp.value = Math.max(1, (parseInt(inp.value) || 1) + delta);
modActualizarTotal();
}

function tpvConfirmarModificadores() {
var btn = document.getElementById('mod-confirmar');
if (tipoActual === 'in-table' && tpvIdMesa === 0) {
alert('Selecciona una mesa antes de añadir productos.');
$('#modalModificadores').modal('hide');
return;
}
btn.disabled = true;
var selModifs = [];
document.querySelectorAll('#mod-lista .mod-chk:checked').forEach(function (c) {
selModifs.push({nombre: c.dataset.nombre, precio: c.dataset.precio});
});
var body = new URLSearchParams();
body.append('multireqtoken', _modToken);
body.append('action', 'add-producto-con-modif');
body.append('referencia', _modRef);
body.append('cantidad', document.getElementById('mod-cantidad').value);
body.append('nota', document.getElementById('mod-nota').value.trim());
body.append('modificadores', JSON.stringify(selModifs));
fetch(_modUrl, {
method: 'POST',
body: body,
headers: {
'Content-Type': 'application/x-www-form-urlencoded'
}
}).then(function (r) {
return r.text();
}).then(function (html) {
refreshComanda(html);
// Refrescar tokens de los botones de catálogo
var parser = new DOMParser();
var doc = parser.parseFromString(html, 'text/html');
var newBtns = doc.querySelectorAll('#grid-productos .col-producto button');
var curBtns = document.querySelectorAll('#grid-productos .col-producto button');
for (var i = 0; i < newBtns.length && i < curBtns.length; i++) {
var m = newBtns[i].getAttribute('onclick').match(/'([^']{30,})'\s*\)/);
var mc = curBtns[i].getAttribute('onclick').match(/'([^']{30,})'\s*\)/);
if (m && mc) {
curBtns[i].setAttribute('onclick', curBtns[i].getAttribute('onclick').replace(mc[1], m[1]));
if (_modBtn === curBtns[i]) 
_modToken = m[1];



}
}
$('#modalModificadores').modal('hide');
btn.disabled = false;
}).catch(function () {
window.location.reload();
});
}

// ── Añadir producto al carrito (AJAX directo) ──
function tpvAddProducto(btn, url, referencia, token) {
if (tipoActual === 'in-table' && tpvIdMesa === 0) {
alert('Selecciona una mesa antes de añadir productos.');
return;
}
btn.disabled = true;
var rowsBefore = document.querySelectorAll('.tpv-table tbody tr').length;
var body = new URLSearchParams();
body.append('multireqtoken', token);
body.append('action', 'add-producto');
body.append('referencia', referencia);
fetch(url, {
method: 'POST',
body: body,
headers: {
'Content-Type': 'application/x-www-form-urlencoded'
}
}).then(function (r) {
return r.text();
}).then(function (html) {
refreshComanda(html);
var rowsAfter = document.querySelectorAll('.tpv-table tbody tr').length;
tpvPlaySound();
// Refrescar token del botón desde la respuesta
var parser = new DOMParser();
var doc = parser.parseFromString(html, 'text/html');
var btns = doc.querySelectorAll('#grid-productos .col-producto button');
var curBtns = document.querySelectorAll('#grid-productos .col-producto button');
for (var i = 0; i < btns.length && i < curBtns.length; i++) {
var m = btns[i].getAttribute('onclick').match(/'([^']{20,})'\s*\)/);
var mc = curBtns[i].getAttribute('onclick').match(/'([^']{20,})'\s*\)/);
if (m && mc) {
curBtns[i].setAttribute('onclick', curBtns[i].getAttribute('onclick').replace(mc[1], m[1]));
}
}
btn.disabled = false;
}).catch(function () {
window.location.reload();
});
}

// ── Cambiar cantidad (AJAX directo) ──
function tpvQty(btn, url, idlinea, cantidad, token) {
btn.disabled = true;
var body = new URLSearchParams();
body.append('multireqtoken', token);
body.append('action', 'update-cantidad');
body.append('idlinea', idlinea);
body.append('cantidad', cantidad);
fetch(url, {
method: 'POST',
body: body,
headers: {
'Content-Type': 'application/x-www-form-urlencoded'
}
}).then(function (r) {
return r.text();
}).then(function (html) {
refreshComanda(html);
tpvPlaySound2();
}).catch(function () {
window.location.reload();
});
}

// ── Eliminar línea (AJAX directo, sin form submit) ──
function tpvDelLinea(btn) {
if (!confirm('{{ i18n.trans("are-you-sure") }}')) 
return;



var wrap = btn.closest('.tpv-del-wrap');
var url = wrap.getAttribute('data-url');
var idlinea = wrap.getAttribute('data-idlinea');
var token = wrap.getAttribute('data-token');

btn.disabled = true;

var body = new URLSearchParams();
body.append('multireqtoken', token);
body.append('action', 'remove-linea');
body.append('idlinea', idlinea);

fetch(url, {
method: 'POST',
body: body,
headers: {
'Content-Type': 'application/x-www-form-urlencoded'
}
}).then(function (r) {
return r.text();
}).then(function (html) {
refreshComanda(html);
}).catch(function () {
window.location.reload();
});
}

function handleAjaxSubmit(e) {
e.preventDefault();
var form = this;

var formData = new FormData(form);
var url = form.getAttribute('action') || window.location.href;

// Deshabilitar botón para evitar doble click
var submitBtn = form.querySelector('[type=submit]');
if (submitBtn) 
submitBtn.disabled = true;



fetch(url, {
method: 'POST',
body: formData
}).then(function (r) {
if (r.redirected) { // cobrar redirige a otro sitio, dejamos que navegue
window.location.href = r.url;
return null;
}
return r.text();
}).then(function (html) {
if (! html) 
return;



refreshComanda(html);
if (submitBtn) 
submitBtn.disabled = false;



}).catch(function () { // Fallback: recarga normal
form._tpvAjax = false;
form.submit();
});
}

// ── Init ──────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', function () {
checkWidth();
initBuscador();
attachAjaxForms();

// Sincronizar los dos selectores de cliente (mobile ↔ desktop)
['sel-cliente-mobile', 'sel-cliente-desktop'].forEach(function (id) {
var el = document.getElementById(id);
if (! el) 
return;



el.addEventListener('change', function () {
var other = id === 'sel-cliente-mobile' ? 'sel-cliente-desktop' : 'sel-cliente-mobile';
var otherEl = document.getElementById(other);
if (otherEl) 
otherEl.value = this.value;



});
});
});

