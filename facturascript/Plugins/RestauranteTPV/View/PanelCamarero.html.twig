];

function abrirSplitArticulos() {
_splitAsignaciones = {};
_splitNumPersonas = Math.max(2, _cobroPersonas);
// Inicializar asignaciones desde _tpvLineasSplit (cargado al abrir el modal de cobro)
_tpvLineasSplit.forEach(function (l) {
_splitAsignaciones[l.idlinea] = new Array(_splitNumPersonas).fill(0);
});
var html = '';
_tpvLineasSplit.forEach(function (l) {
var pu = l.cantidad > 0 ? (l.subtotal / l.cantidad) : 0;
html += '<div class="py-2 border-bottom" id="split-row-' + l.idlinea + '">';
html += '<div class="font-weight-bold mb-1">' + l.descripcion + ' <span class="text-muted small font-weight-normal">(' + parseFloat(pu).toFixed(2) + '\u20ac/ud)</span></div>';
html += '<div class="d-flex align-items-center flex-wrap" style="gap:6px;row-gap:4px;">';
for (var p = 1; p <= _splitNumPersonas; p++) {
var col = _splitColores[(p - 1) % _splitColores.length];
html += '<span class="badge badge-' + col + '">P' + p + '</span>';
html += '<button type="button" class="btn btn-outline-secondary btn-sm" style="padding:1px 7px;" onclick="splitCambiarQty(' + l.idlinea + ',' + p + ',-1)">\u2212</button>';
html += '<span id="split-qty-' + p + '-' + l.idlinea + '" class="font-weight-bold text-' + col + '" style="min-width:22px;text-align:center;">0</span>';
html += '<button type="button" class="btn btn-outline-secondary btn-sm" style="padding:1px 7px;" onclick="splitCambiarQty(' + l.idlinea + ',' + p + ',1)">+</button>';
if (p < _splitNumPersonas) 
html += '<span class="text-muted" style="font-size:.8em;">|</span>';



}
html += '<span class="ml-auto text-danger small" id="split-sin-' + l.idlinea + '">sin: ' + l.cantidad + '</span>';
html += '</div></div>';
});
if (! html) 
html = '<p class="text-muted text-center p-3 small">No hay art\u00edculos para dividir.</p>';



document.getElementById('split-lineas-list').innerHTML = html;
// Generar fila de totales dinámica
var totalesHtml = '';
for (var p = 1; p <= _splitNumPersonas; p++) {
var col = _splitColores[(p - 1) % _splitColores.length];
totalesHtml += '<div><div class="small font-weight-bold text-' + col + '">Persona ' + p + '</div>';
totalesHtml += '<div class="h5 mb-0 text-' + col + '" id="split-total-' + p + '">0.00 \u20ac</div></div>';
}
totalesHtml += '<div><div class="small font-weight-bold text-danger" id="split-sin-asignar-lbl" style="display:none;">Sin asignar</div>';
totalesHtml += '<div class="h5 mb-0 text-danger" id="split-total-sin">0.00 \u20ac</div></div>';
document.getElementById('split-totales-row').innerHTML = totalesHtml;
splitRecalcTotales();
$('#modalCobro').modal('hide');
setTimeout(function () {
$('#modalSplitArticulos').modal('show');
}, 300);
}

function splitCambiarQty(idlinea, persona, delta) {
var l = _tpvLineasSplit.find(function (x) {
return x.idlinea === idlinea;
});
if (! l) 
return;



var asig = _splitAsignaciones[idlinea];
if (! asig) 
return;



var idx = persona - 1;
var sumaOtras = 0;
for (var i = 0; i < asig.length; i++) {
if (i !== idx) 
sumaOtras += asig[i];



}
var maxVal = l.cantidad - sumaOtras;
asig[idx] = Math.max(0, Math.min(maxVal, asig[idx] + delta));
document.getElementById('split-qty-' + persona + '-' + idlinea).textContent = asig[idx];
var suma = asig.reduce(function (a, b) {
return a + b;
}, 0);
var sinQty = l.cantidad - suma;
var sinEl = document.getElementById('split-sin-' + idlinea);
if (sinEl) 
sinEl.textContent = sinQty > 0 ? 'sin: ' + sinQty : '';



splitRecalcTotales();
}

function splitRecalcTotales() {
var totals = new Array(_splitNumPersonas).fill(0);
var tSin = 0;
var todoAsignado = true;
_tpvLineasSplit.forEach(function (l) {
var asig = _splitAsignaciones[l.idlinea] || new Array(_splitNumPersonas).fill(0);
var pu = l.cantidad > 0 ? (l.subtotal / l.cantidad) : 0;
for (var i = 0; i < _splitNumPersonas; i++) {
totals[i] += (asig[i] || 0) * pu;
}
var suma = asig.reduce(function (a, b) {
return a + b;
}, 0);
var sin = l.cantidad - suma;
tSin += sin * pu;
if (sin > 0) 
todoAsignado = false;



});
for (var p = 1; p <= _splitNumPersonas; p++) {
var el = document.getElementById('split-total-' + p);
if (el) 
el.textContent = totals[p - 1].toFixed(2) + ' \u20ac';



}
var sinTotalEl = document.getElementById('split-total-sin');
if (sinTotalEl) 
sinTotalEl.textContent = tSin.toFixed(2) + ' \u20ac';



var sinLbl = document.getElementById('split-sin-asignar-lbl');
if (sinLbl) 
sinLbl.style.display = tSin > 0.001 ? '' : 'none';



var confirmBtn = document.getElementById('split-confirmar-btn');
if (confirmBtn) 
confirmBtn.disabled = ! todoAsignado;



}

