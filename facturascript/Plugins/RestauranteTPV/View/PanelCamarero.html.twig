							<i class="fa-solid fa-arrows-rotate"></i>
						</a>
					</div>
					{% if fsc.ordenesAbiertas|length > 1 %}
						<div style="padding:4px 6px;border-bottom:1px solid #dee2e6;">
							<input type="search" id="sidebarOrdenesSearch" class="form-control form-control-sm" placeholder="Buscar orden..." oninput="filtrarSidebar(this.value)">
						</div>
					{% endif %}
					<div class="flex-fill overflow-auto" id="tpv-orders-list">
						{% if fsc.ordenesAbiertas is empty %}
							<div class="text-center text-muted small py-3">Sin pedidos</div>
						{% endif %}
						{% for ord in fsc.ordenesAbiertas %}
							<div class="tpv-order-card" data-id="{{ ord.idcomanda }}" data-idpedido="{{ ord.idpedido }}" data-idmesa="{{ ord.idmesa|default(0) }}" data-tipo="{{ ord.tipo|capitalize }}" data-num="{{ ord.codigo_pedido|default(ord.idpedido) }}" data-cam="{{ ord.codcamarero|e }}" data-cl="{{ ord.cliente_nombre|default('')|e }}" data-mesa="{{ ord.mesa_nombre|default('None')|e }}" data-total="{{ ord.total }}" data-tax="{{ ord.totaliva|default(0) }}" data-totalpedido="{{ ord.total_pedido|default(ord.total) }}" data-dt="{{ ord.fecha }} {{ ord.hora }}" data-ls="{{ (ord.lineas|map(l => l.estado != 'cancelado' ? [l.descripcion, l.pvpunitario, l.cantidad] : null)|filter(v => v is not null))|json_encode|e }}" data-lsf="{{ (ord.lineas|map(l => l.estado != 'cancelado' ? [l.idlinea, l.descripcion, l.cantidad, l.pvpunitario] : null)|filter(v => v is not null))|json_encode|e }}" onclick="tpvSelectOrder(this)">
								<div class="tpv-oc-top">{{ ord.cliente_nombre|default('Sin cliente')|slice(0,22) }}</div>
								<div class="tpv-oc-sub">Pedido:
									{{ ord.codigo_pedido|default(ord.idpedido) }}</div>
								<div class="tpv-oc-extra">
									<div>Tipo:
										{{ ord.tipo|capitalize }}</div>
									{% if ord.mesa_nombre %}
										<div>Mesa:
											{{ ord.mesa_nombre }}</div>
									{% endif %}
									<div>GARZÓN:
										{{ ord.codcamarero }}</div>
								</div>
							</div>
						{% endfor %}
					</div>
					<div style="flex-shrink:0;border-top:2px solid #dee2e6;padding:5px;">
						<button type="button" class="tpv-act-btn" onclick="tpvSideCuenta()">
							<i class="fa-solid fa-receipt mr-1"></i>Cuenta
						</button>
					</div>
					<div class="tpv-orders-actions" id="tpv-orders-actions" style="display:none;">
						<a id="tpv-act-modificar" href="#" class="tpv-act-btn">
