										{% for li in orden.lineas %}
											{% if li.estado != 'cancelado' %}
												{% set ls = ls|merge([[li.descripcion, li.cantidad, li.pvpunitario]]) %}
											{% endif %}
										{% endfor %}
										<button type="button" class="btn btn-sm btn-outline-dark" style="flex:1 1 auto;min-width:80px;" data-id="{{ orden.idcomanda }}" data-total="{{ orden.total }}" data-dt="{{ orden.fecha }} {{ orden.hora }}" data-cam="{{ orden.codcamarero|e }}" data-cl="{{ orden.cliente_nombre|default('')|e }}" data-ls="{{ ls|json_encode|e }}" onclick="tpvImprimirCuentaBtn(this)">
