h += '<div style="text-align:center;margin-top:12px;margin-bottom:8px;">' + '<svg id="bc-' + idx + '"></svg>' + '<div style="font-size:12px;font-weight:bold;color:#000;margin-top:4px;">' + esc(tkt.docCodigo) + '</div>' + '</div>';
}
h += '</div>';
