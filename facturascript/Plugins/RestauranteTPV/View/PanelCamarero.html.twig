function tpvImprimirFactura(idfactura) {
if (tpvEscposEnabled && idfactura) {
fetch('{{ fsc.url() }}?action=print-escpos&idfactura=' + idfactura).then(function (r) {
return r.json();
}).then(function (d) {
if (! d.ok || ! d.buffer) {
console.warn('ESC/POS buffer error:', d.error);
tpvImprimirFacturaPDF(idfactura);
return;
}
// Enviar buffer al relay local (corre en el PC con la impresora)
var payload = {
buffer: d.buffer
};
if (d.tipo === 'usb') {
payload.usb = d.usb;
} else {
payload.ip = d.ip;
payload.port = d.port;
}
return fetch(tpvRelayUrl, {
method: 'POST',
headers: {
'Content-Type': 'application/json'
},
body: JSON.stringify(payload)
}).then(function (r) {
return r.json();
}).then(function (rd) {
if (rd.ok) {
var toast = document.createElement('div');
toast.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#27ae60;color:#fff;padding:8px 20px;border-radius:6px;font-size:14px;z-index:9999;box-shadow:0 2px 8px rgba(0,0,0,.25);';
toast.textContent = 'Enviado a impresora';
document.body.appendChild(toast);
setTimeout(function () {
toast.remove();
}, 3000);
} else {
var toast2 = document.createElement('div');
toast2.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#c0392b;color:#fff;padding:8px 20px;border-radius:6px;font-size:14px;z-index:9999;box-shadow:0 2px 8px rgba(0,0,0,.25);';
toast2.textContent = 'Relay error: ' + rd.error;
document.body.appendChild(toast2);
setTimeout(function () {
toast2.remove();
}, 6000);
}
}).catch(function (e) {
var toast3 = document.createElement('div');
toast3.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#c0392b;color:#fff;padding:8px 20px;border-radius:6px;font-size:14px;z-index:9999;box-shadow:0 2px 8px rgba(0,0,0,.25);';
toast3.textContent = 'No se pudo conectar con el relay: ' + e.message;
document.body.appendChild(toast3);
setTimeout(function () {
toast3.remove();
}, 6000);
});
}).catch(function (e) {
console.warn('ESC/POS catch:', e);
tpvImprimirFacturaPDF(idfactura);
});
return;
}
tpvImprimirFacturaPDF(idfactura);
}
function tpvImprimirFacturaPDF(idfactura) {
fetch('{{ fsc.url() }}?action=get-factura-html&mode=pdf&idfactura=' + idfactura).then(function (r) {
return r.json();
}).then(function (d) {
var w = window.open('', '_blank', 'width=420,height=620');
if (w) {
var hasBc = !! d.docCodigo;
w.document.write('<html><head><meta charset="utf-8"><style>@page{margin:0;}body{font-size:16px;margin:0;padding:0;}.sec-doc{font-size:14px !important;}</style></head><body>');
w.document.write(d.html);
if (hasBc) {
w.document.write('<script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.6/dist/JsBarcode.all.min.js"><\/script>');
w.document.write('<script>window.onload=function(){try{JsBarcode(\'#ticket-barcode\',\'' + d.docCodigo.replace(/'/g, "\\'") + '\',{format:\'CODE128\',width:1.5,height:50,displayValue:false,margin:5});}catch(e){ }};<\/script>');
}
w.document.write('</body></html>');
w.document.close();
w.focus();
setTimeout(function () {
w.print();
}, hasBc ? 900 : 400);
}
}).catch(function () {
alert('Error al generar PDF.');
});
}

