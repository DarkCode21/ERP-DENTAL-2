					<i class="fa-solid fa-pencil"></i>
				</button>
				<button class="sel-btn" onclick="tpvAbrirNuevoCliente()">
					<i class="fa-solid fa-plus"></i>
				</button>
				{% if fsc.cashSerie and not fsc.cashBox %}
					<form action="{{ cajaContextUrl }}" method="post" class="mb-0" data-no-ajax="true">
						{{ formToken() }}
						<button type="submit" name="action" value="cash-open-start" class="btn btn-success btn-sm text-nowrap">
							<i class="fas fa-lock-open mr-1"></i>Abrir caja
						</button>
					</form>
				{% else %}
					<div class="btn-group dropdown">
						<button class="sel-btn dropdown-toggle" type="button" id="dropdownCashMobile" data-toggle="dropdown" aria-expanded="false" title="Caja">
							<i class="fa-solid fa-cash-register {{ fsc.cashBox ? 'text-success' : 'text-danger' }}"></i>
						</button>
						<div class="dropdown-menu dropdown-menu-right" aria-labelledby="dropdownCashMobile">
							{% if fsc.cashSerie %}
								<button type="button" class="dropdown-item p-3" onclick="return modalCashMovement('cash-in')">
									<i class="fas fa-level-down-alt fa-fw"></i>
									Entrada de caja
								</button>
								<button type="button" class="dropdown-item p-3" onclick="return modalCashMovement('cash-out')">
									<i class="fas fa-level-up-alt fa-fw"></i>
									Salida de caja
								</button>
								<form action="{{ cajaContextUrl }}" method="post" data-no-ajax="true">
									{{ formToken() }}
									<button type="submit" name="action" value="cash-close-start" class="dropdown-item p-3 text-danger">
										<i class="fas fa-times fa-fw"></i>
										Cerrar caja
									</button>
								</form>
							{% else %}
								<span class="dropdown-item-text text-muted p-3">Sin serie configurada</span>
							{% endif %}
						</div>
					</div>
				{% endif %}
