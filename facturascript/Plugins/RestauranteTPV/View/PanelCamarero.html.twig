						{{ i18n.trans('current-order') }}
					</div>
					<div class="flex-fill overflow-auto">
						{% if fsc.lineas is empty %}
							<p class="text-muted text-center p-3 small">{{ i18n.trans('no-lines-yet') }}</p>
						{% else %}
							<table class="table table-sm table-hover tpv-table mb-0">
								<thead class="thead-light">
									<tr>
										<th>{{ i18n.trans('description') }}</th>
										<th class="text-center">{{ i18n.trans('quantity') }}</th>
										<th class="text-right">{{ i18n.trans('price') }}</th>
										<th class="text-right">Sub.</th>
										<th></th>
									</tr>
								</thead>
