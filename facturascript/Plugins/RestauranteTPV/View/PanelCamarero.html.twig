										{# Cancelar pedido #}
										<form method="post" action="{{ fsc.url() }}" style="flex:1 1 auto;min-width:80px;" onsubmit="return confirm('\u00bfEst\u00e1 seguro?')">
											<input type="hidden" name="multireqtoken" value="{{ formToken(false) }}">
