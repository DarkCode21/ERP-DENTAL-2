				<div class="modal-body p-2">
					<p class="small text-muted mb-2">Asigna cada artículo a una persona. Usa los +/− para repartir cantidades entre personas.</p>
					<div id="split-lineas-list"></div>
					<hr class="my-2">
					<div id="split-totales-row" class="d-flex justify-content-around text-center flex-wrap" style="gap:6px;"></div>
				</div>
				<div class="modal-footer py-2">
					<button type="button" class="btn btn-secondary btn-sm" onclick="$('#modalSplitArticulos').modal('hide');setTimeout(function(){$('#modalCobro').modal('show');},300);">Volver</button>
					<button type="button" class="btn btn-success" id="split-confirmar-btn" onclick="splitConfirmar()" disabled>
						<i class="fa-solid fa-check mr-1"></i>Confirmar reparto
					</button>
				</div>
			</div>
		</div>
	</div>

	{# Formulario oculto para enviar el cobro #}
	<form id="form-cobro" method="POST" action="{{ fsc.url() }}?idmesa={{ fsc.mesa ? fsc.mesa.idmesa : 0 }}" style="display:none;">
		<input type="hidden" name="multireqtoken" value="{{ formToken(false) }}">
		<input type="hidden" name="action" value="cobrar">
		<input type="hidden" name="tipodoc" id="cobro-tipodoc" value="">
		<input type="hidden" name="codcliente" id="cobro-codcliente" value="">
		<input type="hidden" name="codpago" id="cobro-codpago-hidden" value="">
		<input type="hidden" name="importedado" id="cobro-dado-hidden" value="">
		<input type="hidden" name="num_personas" id="cobro-num-personas" value="1">
		<input type="hidden" name="split_asignaciones" id="cobro-split-asignaciones" value="">
		<input type="hidden" name="idcomanda" id="cobro-idcomanda" value="">
		<input type="hidden" name="dados_personas" id="cobro-dados-personas" value="">
	</form>

{% endblock %}
