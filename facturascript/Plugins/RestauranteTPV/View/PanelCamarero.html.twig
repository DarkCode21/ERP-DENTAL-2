// ── Imprimir comanda de cocina (auto o manual) ───────
function tpvPrintComanda() {
var table = document.querySelector('#panel-comanda .tpv-table, #panel-comanda-tab .tpv-table');
if (! table) 
return;



var rows = table.querySelectorAll('tbody tr');
if (! rows.length) 
return;



var lineasHtml = '';
rows.forEach(function (tr) {
var esModif = tr.classList.contains('tpv-modif-row');
if (esModif) {
var descSpan = tr.querySelector('td:first-child span[style*="padding-left"] span');
if (! descSpan) 
descSpan = tr.querySelector('td:first-child span[style*="padding-left"]');



var desc = descSpan ? descSpan.textContent.trim() : '';
var cantSpan = tr.querySelector('td:nth-child(2) span');
var cant = cantSpan ? cantSpan.textContent.trim() : '';
lineasHtml += '<tr><td style="padding-left:18px;color:#555;font-size:.9em;">&#8627; ' + escHtml(desc) + '</td><td style="text-align:center;color:#555;">' + escHtml(cant) + '</td></tr>';
} else {
var boldSpan = tr.querySelector('td:first-child .font-weight-bold');
var desc = boldSpan ? boldSpan.textContent.trim() : '';
var cantSpan = tr.querySelector('td:nth-child(2) span[style*="min-width"]');
var cant = cantSpan ? cantSpan.textContent.trim() : '1';
var notaEl = tr.querySelector('td:first-child .font-italic');
var nota = notaEl ? notaEl.textContent.trim() : '';
lineasHtml += '<tr><td style="font-weight:bold;padding:3px 4px;">' + escHtml(desc) + (nota ? '<div style="font-size:.85em;color:#555;font-style:italic;padding-left:4px;">' + escHtml(nota) + '</div>' : '') + '</td><td style="text-align:center;font-weight:bold;padding:3px 4px;">' + escHtml(cant) + '</td></tr>';
}
});
var hora = new Date().toLocaleTimeString('es-ES', {
hour: '2-digit',
minute: '2-digit'
});
var infoMesa = tpvMesaNombreGlobal ? 'Mesa: <strong>' + escHtml(tpvMesaNombreGlobal) + '</strong>' : escHtml(tipoActual === 'take-away' ? 'Para llevar' : (tipoActual === 'delivery' ? 'Delivery' : ''));
var html = '<!DOCTYPE html><html><head><meta charset="utf-8">' + '<style>@page{margin:0;}body{font-family:monospace;font-size:14px;max-width:380px;margin:0 auto;padding:0;}' + 'h1{text-align:center;font-size:17px;margin:0 0 2px;}' + '.sep{border-top:1px dashed #000;margin:5px 0;}' + 'table{width:100%;border-collapse:collapse;}' + 'td{vertical-align:top;}' + '</style></head><body>';
html += '<h1>COMANDA</h1>';
html += '<div class="sep"></div>';
if (tpvIdComandaGlobal) 
html += '<div>Comanda #<strong>' + tpvIdComandaGlobal + '</strong> &mdash; ' + hora + '</div>';



if (infoMesa) 
html += '<div>' + infoMesa + '</div>';



html += '<div class="sep"></div>';
html += '<table>' + lineasHtml + '</table>';
html += '<div class="sep"></div>';
html += '</body></html>';
var w = window.open('', '_blank', 'width=400,height=520');
if (w) {
w.document.write(html);
w.document.close();
w.focus();
setTimeout(function () {
w.print();
}, 350);
}
}

function tpvSelectMesa(idmesa, estado) {
