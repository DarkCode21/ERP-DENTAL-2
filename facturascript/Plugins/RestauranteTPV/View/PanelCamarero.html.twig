									{% if fsc.cashSerie %}
										<button type="button" class="dropdown-item p-3" onclick="return modalCashMovement('cash-in')">
											<i class="fas fa-level-down-alt fa-fw"></i>
											Entrada de caja
										</button>
										<button type="button" class="dropdown-item p-3" onclick="return modalCashMovement('cash-out')">
											<i class="fas fa-level-up-alt fa-fw"></i>
											Salida de caja
										</button>
										<form action="{{ cajaContextUrl }}" method="post" data-no-ajax="true">
											{{ formToken() }}
											<button type="submit" name="action" value="cash-close-start" class="dropdown-item p-3 text-danger">
												<i class="fas fa-times fa-fw"></i>
												Cerrar caja
											</button>
										</form>
									{% else %}
										<span class="dropdown-item-text text-muted p-3">Sin serie configurada</span>
									{% endif %}
								</div>
							</div>
						{% endif %}
					</div>

					<div class="bg-dark text-white px-2 py-1 small font-weight-bold flex-shrink-0">
