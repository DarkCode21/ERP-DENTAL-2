													</div>
													{% if linea.estado != 'pendiente' %}
														<span class="badge badge-{{ linea.estado == 'preparado' ? 'success' : (linea.estado == 'servido' ? 'primary' : 'danger') }}" style="font-size:.58rem;margin-left:20px;">{{ i18n.trans(linea.estado) }}</span>
													{% endif %}
												</td>
												<td class="text-center">
													<span class="text-muted small">{{ linea.cantidad|number_format(0) }}</span>
												</td>
												<td class="text-right">
