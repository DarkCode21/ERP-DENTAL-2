													{% endif %}
												</td>
												<td class="text-center" style="white-space:nowrap;">
													<div class="d-flex align-items-center justify-content-center" style="gap:2px;">
														<button type="button" onclick="tpvQty(this,'{{ fsc.url() }}?idmesa={{ fsc.mesa ? fsc.mesa.idmesa : 0 }}',{{ linea.idlinea }},{{ linea.cantidad - 1 }},'{{ formToken(false) }}')" class="btn btn-outline-secondary btn-sm px-1" style="padding:1px 5px;">
															<i class="fa-solid fa-minus"></i>
														</button>
														<span style="min-width:20px;text-align:center;font-weight:700;">{{ linea.cantidad|number_format(0) }}</span>
														<button type="button" onclick="tpvQty(this,'{{ fsc.url() }}?idmesa={{ fsc.mesa ? fsc.mesa.idmesa : 0 }}',{{ linea.idlinea }},{{ linea.cantidad + 1 }},'{{ formToken(false) }}')" class="btn btn-outline-secondary btn-sm px-1" style="padding:1px 5px;">
															<i class="fa-solid fa-plus"></i>
														</button>
													</div>
												</td>
												<td class="text-right">{{ linea.pvpunitario|number_format(2) }}</td>
												<td class="text-right font-weight-bold">{{ linea.subtotal()|number_format(2) }}</td>
												<td>
													<span data-url="{{ fsc.url() }}?idmesa={{ fsc.mesa ? fsc.mesa.idmesa : 0 }}" data-idlinea="{{ linea.idlinea }}" data-token="{{ formToken(false) }}" class="tpv-del-wrap">
														<button type="button" onclick="tpvDelLinea(this)" class="btn btn-sm btn-outline-danger" style="padding:1px 5px;">
															<i class="fa-solid fa-xmark"></i>
														</button>
													</span>
												</td>
											</tr>
										{% endif %}
									{% endfor %}
								</tbody>
							</table>
						{% endif %}
					</div>
					<div class="tpv-footer flex-shrink-0">
						<div class="tpv-total-row">
							<span class="tpv-total-label">{{ i18n.trans('total') }}
								a pagar:</span>
							<span class="tpv-total-val">{{ fsc.comanda ? fsc.comanda.total|number_format(2) : '0.00' }}
								€</span>
						</div>
						<div class="tpv-actions">
							<a href="{{ fsc.url() ~ '?action=cancel-order&idmesa=' ~ (fsc.mesa ? fsc.mesa.idmesa : 0) }}" class="ta-btn ta-cancel text-center text-decoration-none">
								<i class="fa-solid fa-xmark mr-1"></i>
								{{ i18n.trans('cancel') }}
							</a>
							<button type="button" class="ta-btn ta-invoice" onclick="tpvCobrar('factura')">
								<i class="fa-solid fa-file-invoice mr-1"></i>Factura rápida
							</button>
							<button type="button" class="ta-btn ta-charge" onclick="tpvRealizarPedido()">
								<i class="fa-solid fa-paper-plane mr-1"></i>Realizar pedido
							</button>
						</div>
					</div>
				</div>
				{# /panel-comanda xl #}

			</div>
			{# /tpv-xl-cart-group #}

			{# ════ CATÁLOGO (móvil + xl) ════ #}
			<div
				id="panel-catalogo">

				{# ── Sidebar vertical familias/estaciones (xl) ── #}
				<div id="cat-sidebar">
					<button type="button" onclick="tpvFiltrarSidebar(this, '{{ fsc.url() }}?idmesa={{ fsc.mesa ? fsc.mesa.idmesa : 0 }}', '{{ i18n.trans('all') }}')" class="cat-sidebar-btn{{ fsc.codfamiliaActiva == '' and fsc.idestacionActiva is null ? ' active' : '' }}">
						{{ i18n.trans('all') }}
					</button>
					{% for fam in fsc.familias %}
						<button type="button" onclick="tpvFiltrarSidebar(this, '{{ fsc.url() }}?idmesa={{ fsc.mesa ? fsc.mesa.idmesa : 0 }}&familia={{ fam.codfamilia }}', '{{ fam.descripcion|e('js') }}')" class="cat-sidebar-btn{{ fsc.codfamiliaActiva == fam.codfamilia ? ' active' : '' }}">
							{{ fam.descripcion }}
						</button>
					{% endfor %}
				</div>

				{# ── Área principal: topbar + grid ── #}
				<div
					id="cat-main">

					{# Topbar: dropdown (mobile) + buscador (siempre) #}
					<div
						id="cat-topbar" class="d-flex px-1 pt-1 pb-1" style="gap:5px;border-bottom:1px solid #dee2e6;flex-shrink:0;align-items:center;">
						{# Dropdown selector — solo móvil/tablet #}
						<div class="dropdown flex-shrink-0 d-xl-none">
							<button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" id="dropdownFamiliaBtn" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
								{% if fsc.codfamiliaActiva != '' %}
									{% for fam in fsc.familias %}
										{% if fam.codfamilia == fsc.codfamiliaActiva %}
											{{ fam.descripcion }}
										{% endif %}
									{% endfor %}
								{% else %}
									{{ i18n.trans('all') }}
								{% endif %}
							</button>
							<div class="dropdown-menu" aria-labelledby="dropdownFamiliaBtn">
								<a class="dropdown-item" href="#" onclick="tpvFiltrarDropdown(this, '{{ fsc.url() }}?idmesa={{ fsc.mesa ? fsc.mesa.idmesa : 0 }}', '{{ i18n.trans('all') }}'); return false;">
									{{ i18n.trans('all') }}
								</a>
								{% for fam in fsc.familias %}
									<a class="dropdown-item" href="#" onclick="tpvFiltrarDropdown(this, '{{ fsc.url() }}?idmesa={{ fsc.mesa ? fsc.mesa.idmesa : 0 }}&familia={{ fam.codfamilia }}', '{{ fam.descripcion|e('js') }}'); return false;">
										{{ fam.descripcion }}
									</a>
								{% endfor %}
							</div>
						</div>
						<input
						type="text" id="buscador-productos" class="form-control form-control-sm" style="flex:1;min-width:0;" placeholder="Buscar...">
						{# Accesos rápidos: solo estaciones configuradas #}
						{% if fsc.estaciones|length > 0 %}
							<div class="d-flex flex-shrink-0" style="gap:3px;">
								{% for est in fsc.estaciones %}
									<a href="{{ asset('PanelCocina') }}?idestacion={{ est.idestacion }}" target="_blank" class="btn btn-sm btn-outline-secondary p-1" title="{{ est.nombre }}" style="height:30px;padding:0 6px;display:flex;align-items:center;justify-content:center;font-size:.7rem;white-space:nowrap;">
										{{ est.nombre }}
									</a>
								{% endfor %}
							</div>
						{% endif %}
					</div>

					{# Grid productos #}
					<div class="overflow-auto px-1 pt-2" id="catalogo-grid-wrap" style="flex:1;">
						{% if fsc.productos is empty %}
							<p class="text-muted text-center p-3 small">{{ i18n.trans('no-products') }}</p>
						{% else %}
							<div class="row no-gutters" id="grid-productos">
								{% for prod in fsc.productos %}
									<div class="col-4 col-md-3 pr-1 pb-1 col-producto">
										<button type="button" data-modif="{{ prod.modificadores|json_encode|e('html_attr') }}" data-precio="{{ prod.precio }}" onclick="tpvClickProducto(this,'{{ fsc.url() }}?idmesa={{ fsc.mesa ? fsc.mesa.idmesa : 0 }}','{{ prod.referencia }}','{{ formToken(false) }}')" class="prod-card w-100 border-0">
											<div class="prod-img-wrap{% if not prod.imagen_url %} prod-no-img{% endif %}">
												{% if prod.imagen_url %}
													<img src="{{ prod.imagen_url }}" alt="{{ prod.descripcion }}" loading="lazy">
												{% else %}
													<i class="fa-solid fa-image"></i>
												{% endif %}
											</div>
											<div class="prod-info">
												<div class="prod-nombre">{{ prod.descripcion }}</div>
												<div class="prod-precio">{{ prod.precio|number_format(2) }}
													€</div>
											</div>
										</button>
									</div>
								{% endfor %}
							</div>
						{% endif %}
					</div>
					{# /catalogo-grid-wrap #}

				</div>
				{# /cat-main #}

			</div>
			{# /panel-catalogo #}

			{# ════ COMANDA TAB MÓVIL/TABLET ════ #}
			<div class="d-xl-none d-none flex-column" id="panel-comanda-tab">
				<div class="overflow-auto">
					{% if fsc.lineas is empty %}
						<p class="text-muted text-center p-3 small">{{ i18n.trans('no-lines-yet') }}</p>
					{% else %}
						<table class="table table-sm table-hover tpv-table mb-0">
							<thead class="thead-light">
								<tr>
									<th>{{ i18n.trans('description') }}</th>
									<th class="text-center">Cant.</th>
									<th class="text-right">€</th>
									<th class="text-right">Sub.</th>
									<th></th>
								</tr>
							</thead>
							<tbody>
								{% for linea in fsc.lineas %}
									{% if linea.idlinea_padre %}
										<tr data-idlineapadre="{{ linea.idlinea_padre }}" data-desclinea="{{ linea.descripcion|e('html_attr') }}" class="tpv-modif-row {{ linea.estado == 'cancelado' ? 'table-danger' : '' }}">
											<td>
												<div class="d-flex align-items-center" style="padding-left:20px;gap:4px;">
													<span class="text-muted" style="font-size:.8em;">↳</span>
													<span class="text-muted" style="font-style:italic;font-size:.88em;">{{ linea.descripcion }}</span>
												</div>
												{% if linea.estado != 'pendiente' %}
													<span class="badge badge-{{ linea.estado == 'preparado' ? 'success' : (linea.estado == 'servido' ? 'primary' : 'danger') }}" style="font-size:.58rem;margin-left:20px;">{{ i18n.trans(linea.estado) }}</span>
												{% endif %}
											</td>
											<td class="text-center" style="white-space:nowrap;">
												<div class="d-flex align-items-center justify-content-center" style="gap:2px;">
													<button type="button" onclick="tpvQty(this,'{{ fsc.url() }}?idmesa={{ fsc.mesa ? fsc.mesa.idmesa : 0 }}',{{ linea.idlinea }},{{ linea.cantidad - 1 }},'{{ formToken(false) }}')" class="btn btn-outline-secondary btn-sm px-1" style="padding:1px 5px;opacity:.7;">
														<i class="fa-solid fa-minus"></i>
													</button>
													<span class="text-muted" style="min-width:20px;text-align:center;">{{ linea.cantidad|number_format(0) }}</span>
													<button type="button" onclick="tpvQty(this,'{{ fsc.url() }}?idmesa={{ fsc.mesa ? fsc.mesa.idmesa : 0 }}',{{ linea.idlinea }},{{ linea.cantidad + 1 }},'{{ formToken(false) }}')" class="btn btn-outline-secondary btn-sm px-1" style="padding:1px 5px;opacity:.7;">
														<i class="fa-solid fa-plus"></i>
													</button>
												</div>
											</td>
											<td class="text-right">
												<span class="text-muted small">+{{ linea.pvpunitario|number_format(2) }}</span>
											</td>
											<td class="text-right">
												<span class="text-muted small">+{{ linea.subtotal()|number_format(2) }}</span>
											</td>
											<td>
												<span data-url="{{ fsc.url() }}?idmesa={{ fsc.mesa ? fsc.mesa.idmesa : 0 }}" data-idlinea="{{ linea.idlinea }}" data-token="{{ formToken(false) }}" class="tpv-del-wrap">
													<button type="button" onclick="tpvDelLinea(this)" class="btn btn-sm btn-outline-danger" style="padding:1px 5px;opacity:.55;">
														<i class="fa-solid fa-xmark"></i>
													</button>
												</span>
											</td>
										</tr>
									{% else %}
										<tr class="{{ linea.estado == 'preparado' ? 'table-success' : (linea.estado == 'cancelado' ? 'table-danger' : '') }}">
											<td>
												<div class="d-flex align-items-center" style="gap:4px;">
													<button type="button" class="btn btn-sm btn-outline-secondary" style="padding:1px 5px;flex-shrink:0;" onclick="tpvAbrirEditarLinea({{ linea.idlinea }},{{ linea.descripcion|json_encode|e('html_attr') }},{{ linea.cantidad }},{{ linea.observaciones|default('')|json_encode|e('html_attr') }},{{ linea.referencia|default('')|json_encode|e('html_attr') }})">
														<i class="fa-solid fa-pencil"></i>
													</button>
													<span class="font-weight-bold">{{ linea.descripcion }}</span>
												</div>
												{% if linea.observaciones %}
													<div class="font-italic text-muted" style="font-size:.82em;padding-left:28px;">{{ linea.observaciones }}</div>
												{% endif %}
												{% if linea.estado != 'pendiente' %}
													<span class="badge badge-{{ linea.estado == 'preparado' ? 'success' : (linea.estado == 'servido' ? 'primary' : 'danger') }}" style="font-size:.58rem;">{{ i18n.trans(linea.estado) }}</span>
												{% endif %}
											</td>
											<td class="text-center" style="white-space:nowrap;">
												<div class="d-flex align-items-center justify-content-center" style="gap:2px;">
													<button type="button" onclick="tpvQty(this,'{{ fsc.url() }}?idmesa={{ fsc.mesa ? fsc.mesa.idmesa : 0 }}',{{ linea.idlinea }},{{ linea.cantidad - 1 }},'{{ formToken(false) }}')" class="btn btn-outline-secondary btn-sm px-1" style="padding:1px 5px;">
														<i class="fa-solid fa-minus"></i>
													</button>
													<span style="min-width:20px;text-align:center;font-weight:700;">{{ linea.cantidad|number_format(0) }}</span>
													<button type="button" onclick="tpvQty(this,'{{ fsc.url() }}?idmesa={{ fsc.mesa ? fsc.mesa.idmesa : 0 }}',{{ linea.idlinea }},{{ linea.cantidad + 1 }},'{{ formToken(false) }}')" class="btn btn-outline-secondary btn-sm px-1" style="padding:1px 5px;">
														<i class="fa-solid fa-plus"></i>
													</button>
												</div>
											</td>
											<td class="text-right">{{ linea.pvpunitario|number_format(2) }}</td>
											<td class="text-right font-weight-bold">{{ linea.subtotal()|number_format(2) }}</td>
											<td>
												<span data-url="{{ fsc.url() }}?idmesa={{ fsc.mesa ? fsc.mesa.idmesa : 0 }}" data-idlinea="{{ linea.idlinea }}" data-token="{{ formToken(false) }}" class="tpv-del-wrap">
													<button type="button" onclick="tpvDelLinea(this)" class="btn btn-sm btn-outline-danger" style="padding:1px 5px;">
														<i class="fa-solid fa-xmark"></i>
													</button>
												</span>
											</td>
										</tr>
									{% endif %}
								{% endfor %}
							</tbody>
						</table>
					{% endif %}
				</div>
				<div class="tpv-footer">
					<div class="tpv-total-row">
						<span class="tpv-total-label">{{ i18n.trans('total') }}
							a pagar:</span>
						<span class="tpv-total-val">{{ fsc.comanda ? fsc.comanda.total|number_format(2) : '0.00' }}
							€</span>
					</div>
					<div class="tpv-actions">
						<a href="{{ fsc.url() ~ '?action=cancel-order&idmesa=' ~ (fsc.mesa ? fsc.mesa.idmesa : 0) }}" class="ta-btn ta-cancel text-center text-decoration-none">
							<i class="fa-solid fa-xmark mr-1"></i>
							{{ i18n.trans('cancel') }}
						</a>
						<button type="button" class="ta-btn ta-invoice" onclick="tpvCobrar('factura')">
							<i class="fa-solid fa-file-invoice mr-1"></i>Factura rápida
						</button>
						<button type="button" class="ta-btn ta-charge" onclick="tpvRealizarPedido()">
							<i class="fa-solid fa-paper-plane mr-1"></i>Realizar pedido
						</button>
					</div>
				</div>
			</div>
			{# /panel-comanda-tab #}

			{# ════ PANEL ÓRDENES (móvil) ════ #}
			<div id="panel-ordenes-tab" class="d-none flex-column" style="overflow:hidden;">
				<div style="flex:1;overflow-y:auto;padding:8px;">
					{% if fsc.ordenesAbiertas is empty %}
						<div class="text-center text-muted py-5">
							<i class="fa-solid fa-circle-check fa-3x mb-2 d-block"></i>
							No hay pedidos en curso.
						</div>
					{% else %}
						{% if fsc.ordenesAbiertas|length > 1 %}
							<div class="mb-2">
								<input type="search" class="form-control form-control-sm" placeholder="Buscar orden..." oninput="filtrarMovil(this.value)">
							</div>
						{% endif %}
						{% for orden in fsc.ordenesAbiertas %}
							<div class="card mb-3 orden-movil-card" data-search="{{ orden.idcomanda }} {{ orden.mesa_nombre|default('')|lower }} {{ orden.cliente_nombre|default('')|lower }} {{ orden.codcamarero|lower }} {{ orden.tipo|lower }}">
								<div class="card-header d-flex justify-content-between align-items-center py-2">
									<span>
										<strong>#{{ orden.idcomanda }}</strong>
										{% if orden.tipo == 'in-table' %}
											<span class="badge badge-info ml-1">{{ i18n.trans('dine-in') }}</span>
										{% elseif orden.tipo == 'take-away' %}
											<span class="badge badge-secondary ml-1">{{ i18n.trans('take-away') }}</span>
										{% else %}
											<span class="badge badge-warning ml-1">{{ i18n.trans('delivery') }}</span>
										{% endif %}
									</span>
									<small class="text-muted">{{ orden.fecha }}
										{{ orden.hora }}</small>
								</div>
								<div class="card-body py-2">
									{% if orden.mesa_nombre %}
										<div class="small">
											<i class="fa-solid fa-table-cells mr-1 text-muted"></i>
											<strong>Mesa:</strong>
											{{ orden.mesa_nombre }}</div>
									{% endif %}
									{% if orden.cliente_nombre %}
										<div class="small">
											<i class="fa-solid fa-user mr-1 text-muted"></i>
											<strong>Cliente:</strong>
											{{ orden.cliente_nombre }}</div>
									{% endif %}
									<div class="small">
										<i class="fa-solid fa-utensils mr-1 text-muted"></i>
										<strong>Garzón:</strong>
										{{ orden.codcamarero }}</div>
									<div class="mt-2 border-top pt-1" style="max-height:120px;overflow-y:auto;">
										{% for linea in orden.lineas %}
											{% if linea.estado != 'cancelado' %}
												<div class="d-flex justify-content-between" style="font-size:.82rem;">
													<span>{{ linea.descripcion }}</span>
													<span class="font-weight-bold ml-2">&times;
														{{ linea.cantidad|number_format(0) }}</span>
												</div>
											{% endif %}
										{% endfor %}
									</div>
									<div class="text-right font-weight-bold mt-1">{{ orden.total|number_format(2) }}
										&euro;</div>
								</div>
								<div class="card-footer py-2">
									<div class="d-flex flex-wrap" style="gap:4px;">
										<form method="post" action="{{ fsc.url() }}" style="flex:1 1 auto;">
											<input type="hidden" name="multireqtoken" value="{{ formToken(false) }}">
											<input type="hidden" name="action" value="reabrir-comanda">
											<input type="hidden" name="idcomanda" value="{{ orden.idcomanda }}">
											<button type="submit" class="btn btn-sm btn-outline-secondary w-100">
												<i class="fa-solid fa-pen mr-1"></i>Modificar
											</button>
										</form>
										{% set _lsfsc = [] %}
										{% for _li in orden.lineas %}
											{% if _li.estado != 'cancelado' %}
												{% set _lsfsc = _lsfsc|merge([[_li.idlinea, _li.descripcion, _li.cantidad, _li.pvpunitario]]) %}
											{% endif %}
										{% endfor %}
										<div style="flex:1 1 auto;">
											<button type="button" class="btn btn-sm btn-warning w-100" data-lsf="{{ _lsfsc|json_encode|e }}" onclick="tpvAbrirModalFactura('{{ orden.idcomanda }}', this)">
												<i class="fa-solid fa-file-invoice mr-1"></i>
												{{ i18n.trans('invoice') }}
											</button>
										</div>
										<form method="post" action="{{ fsc.url() }}" style="flex:1 1 auto;" onsubmit="return confirm('\u00bfEst\u00e1 seguro?')">
											<input type="hidden" name="multireqtoken" value="{{ formToken(false) }}">
											<input type="hidden" name="action" value="cancel-pedido">
											<input type="hidden" name="idcomanda" value="{{ orden.idcomanda }}">
											<button type="submit" class="btn btn-sm btn-danger w-100">
												<i class="fa-solid fa-xmark mr-1"></i>
												{{ i18n.trans('cancel') }}
											</button>
										</form>
									</div>
								</div>
							</div>
						{% endfor %}
					{% endif %}
				</div>
				<div style="flex-shrink:0;border-top:2px solid #dee2e6;padding:5px;background:#fff;">
					<button type="button" class="tpv-act-btn w-100" onclick="tpvSideCuenta()">
						<i class="fa-solid fa-receipt mr-1"></i>Cuenta
					</button>
				</div>
			</div>
			{# /panel-ordenes-tab #}

		</div>
		{# /tpv-wrap #}

	{% else %}
		{# ── Vista: pedidos en curso ── #}
		<div
			class="container-fluid py-3">

			{# Cabecera #}
			<div class="row mb-3 align-items-center">
				<div class="col">
					<h5 class="mb-0">
						<i class="fa-solid fa-list-check mr-2"></i>Pedidos en curso
						<span class="badge badge-primary ml-1" id="ordenesCount">{{ fsc.ordenesAbiertas|length }}</span>
					</h5>
				</div>
				<div class="col-auto">
					<a href="{{ fsc.url() }}" class="btn btn-sm btn-outline-secondary mr-2">
						<i class="fa-solid fa-arrow-left mr-1"></i>Volver
					</a>
					<a href="{{ fsc.url() }}" class="btn btn-sm btn-success">
						<i class="fa-solid fa-plus mr-1"></i>Nueva orden
					</a>
				</div>
			</div>

			{# Buscador #}
			{% if fsc.ordenesAbiertas|length > 1 %}
				<div class="row mb-3">
					<div class="col-12 col-md-6 col-lg-4">
						<div class="input-group input-group-sm">
							<div class="input-group-prepend">
								<span class="input-group-text">
									<i class="fa-solid fa-magnifying-glass"></i>
								</span>
							</div>
							<input type="search" id="ordenesSearch" class="form-control" placeholder="Buscar por mesa, cliente, camarero o nº..." oninput="filtrarOrdenes(this.value)">
						</div>
					</div>
				</div>
			{% endif %}

			{% if fsc.ordenesAbiertas is empty %}
				<div class="text-center text-muted py-5">
					<i class="fa-solid fa-circle-check fa-3x mb-2 d-block"></i>
					No hay pedidos en curso.
				</div>
			{% else %}
				<div class="row" id="ordenesGrid">
					{% for orden in fsc.ordenesAbiertas %}
						<div class="col-12 col-md-6 col-xl-4 mb-3 orden-card" data-search="{{ orden.idcomanda }} {{ orden.mesa_nombre|default('')|lower }} {{ orden.cliente_nombre|default('')|lower }} {{ orden.codcamarero|lower }} {{ orden.tipo|lower }}">
							<div
