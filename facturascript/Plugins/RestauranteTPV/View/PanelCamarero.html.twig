});
html += '<tr><td style="text-align:right;font-weight:bold;border-top:1px solid #aaa;">TOTAL:</td>' + '<td style="text-align:right;font-weight:bold;border-top:1px solid #aaa;">' + ticketTotal.toFixed(2) + ' \u20ac</td></tr>';
