if (estado === 'ocupada') {
window.location.href = panelCamarero + '?idmesa=' + idmesa;
} else {
window.location.href = panelCamarero + '?action=open-mesa&idmesa=' + idmesa;
}
}


// ── Menú contextual mesas ────────────────────────────
var _ctxMesa = {
el: null,
idmesa: 0,
estado: ''
};
var _longPressTimer = null;

function tpvMesaClick(e, el) { // click normal: comportamiento estándar solo si NO viene de long-press
if (el._longPressed) {
el._longPressed = false;
return;
}
var idmesa = parseInt(el.dataset.idmesa);
var estado = el.dataset.estado;
tpvSelectMesa(idmesa, estado);
}

function tpvMesaCtx(e, el) {
e.preventDefault();
tpvAbrirCtxMenu(e.clientX, e.clientY, el);
}

// long-press en touch
document.addEventListener('DOMContentLoaded', function () {
document.getElementById('modalMesas').addEventListener('touchstart', function (e) {
var thumb = e.target.closest('.mm-mesa-thumb');
if (! thumb) 
return;



_longPressTimer = setTimeout(function () {
thumb._longPressed = true;
var touch = e.touches[0];
tpvAbrirCtxMenu(touch.clientX, touch.clientY, thumb);
}, 600);
}, {passive: true});
document.getElementById('modalMesas').addEventListener('touchend', function () {
clearTimeout(_longPressTimer);
}, {passive: true});
document.getElementById('modalMesas').addEventListener('touchmove', function () {
clearTimeout(_longPressTimer);
}, {passive: true});

// Cerrar menú al clicar fuera
document.addEventListener('click', function (e) {
var menu = document.getElementById('tpvCtxMenu');
if (menu && ! menu.contains(e.target)) {
menu.classList.remove('show');
}
});
});

function tpvAbrirCtxMenu(x, y, el) {
_ctxMesa.el = el;
_ctxMesa.idmesa = parseInt(el.dataset.idmesa);
_ctxMesa.estado = el.dataset.estado;

var reservarTxt = document.getElementById('ctx-reservar-txt');
var ctxAbrir = document.getElementById('ctx-abrir');
var ctxMover = document.getElementById('ctx-mover');
var sepMover = document.getElementById('ctx-sep-mover');
var ctxJuntar = document.getElementById('ctx-juntar');
var sepJuntar = document.getElementById('ctx-sep-juntar');
if (_ctxMesa.estado === 'ocupada') { // mesa ocupada: solo "Abrir comanda", sin opción reservar ni mover
ctxAbrir.style.display = '';
document.querySelector('.tpv-ctx-sep').style.display = 'none';
document.getElementById('ctx-reservar').style.display = 'none';
ctxMover.style.display = 'none';
sepMover.style.display = 'none';
// Juntar: solo si la mesa actual tiene comanda y es una mesa diferente
var puedeJuntar = TPV_TIENE_COMANDA_MESA && _ctxMesa.idmesa !== TPV_CURRENT_MESA;
ctxJuntar.style.display = puedeJuntar ? '' : 'none';
sepJuntar.style.display = puedeJuntar ? '' : 'none';
} else {
ctxAbrir.style.display = '';
document.querySelector('.tpv-ctx-sep').style.display = '';
document.getElementById('ctx-reservar').style.display = '';
ctxJuntar.style.display = 'none';
sepJuntar.style.display = 'none';
reservarTxt.textContent = (_ctxMesa.estado === 'reservada') ? 'Quitar reserva' : 'Reservar';
// Mostrar "Mover comanda aquí" solo si hay comanda en otra mesa
var puedeMoverse = TPV_TIENE_COMANDA_MESA && _ctxMesa.idmesa !== TPV_CURRENT_MESA;
ctxMover.style.display = puedeMoverse ? '' : 'none';
sepMover.style.display = puedeMoverse ? '' : 'none';
}

var menu = document.getElementById('tpvCtxMenu');
// Ajustar posición para que no salga de la pantalla
menu.style.left = x + 'px';
menu.style.top = y + 'px';
menu.classList.add('show');

// Corregir si se sale por la derecha/abajo
requestAnimationFrame(function () {
var rect = menu.getBoundingClientRect();
if (rect.right > window.innerWidth) 
menu.style.left = (x - rect.width) + 'px';



if (rect.bottom > window.innerHeight) 
menu.style.top = (y - rect.height) + 'px';



});
}

document.addEventListener('DOMContentLoaded', function () {
document.getElementById('ctx-abrir').addEventListener('click', function () {
document.getElementById('tpvCtxMenu').classList.remove('show');
tpvSelectMesa(_ctxMesa.idmesa, _ctxMesa.estado);
});
document.getElementById('ctx-reservar').addEventListener('click', function () {
document.getElementById('tpvCtxMenu').classList.remove('show');
tpvToggleReserva(_ctxMesa.idmesa, _ctxMesa.el);
});
document.getElementById('ctx-mover').addEventListener('click', function () {
document.getElementById('tpvCtxMenu').classList.remove('show');
tpvMoverComanda(_ctxMesa.idmesa, _ctxMesa.el.dataset.nombre);
});
document.getElementById('ctx-juntar').addEventListener('click', function () {
document.getElementById('tpvCtxMenu').classList.remove('show');
tpvJuntarMesas(_ctxMesa.idmesa, _ctxMesa.el.dataset.nombre);
});
});

function tpvToggleReserva(idmesa, el) { // Actualización optimista: cambio visual inmediato
var nuevoEstado = (el.dataset.estado === 'reservada') ? 'libre' : 'reservada';
el.classList.remove('estado-libre', 'estado-reservada');
el.classList.add('estado-' + nuevoEstado);
el.dataset.estado = nuevoEstado;
el.querySelector('div:last-child').textContent = nuevoEstado;

var body = new URLSearchParams();
body.append('multireqtoken', '{{ formToken(false) }}');
body.append('action', 'toggle-reserva');
body.append('idmesa', idmesa);
fetch('{{ fsc.url() }}', {
method: 'POST',
body: body,
headers: {
'Content-Type': 'application/x-www-form-urlencoded'
}
}).catch(function () {
window.location.reload();
});
}

function tpvMoverComanda(idmesaNueva, nombreMesa) {
if (!confirm('¿Mover la comanda a la mesa "' + nombreMesa + '"?')) 
return;



var form = document.createElement('form');
form.method = 'POST';
form.action = '{{ fsc.url() }}?idmesa=       {{ fsc.mesa ? fsc.mesa.idmesa : 0 }}';
var fields = {
'multireqtoken': '{{ formToken(false) }}',
'action': 'mover-comanda',
'idmesa_nueva': idmesaNueva
};
Object.keys(fields).forEach(function (k) {
var inp = document.createElement('input');
inp.type = 'hidden';
inp.name = k;
inp.value = fields[k];
form.appendChild(inp);
});
document.body.appendChild(form);
form.submit();
}

function tpvJuntarMesas(idmesaSecundaria, nombreMesa) {
if (!confirm('¿Juntar la comanda actual con la mesa "' + nombreMesa + '"?\nLas líneas de esa mesa se añadirán a esta comanda.')) 
return;



var form = document.createElement('form');
form.method = 'POST';
form.action = '{{ fsc.url() }}?idmesa=   {{ fsc.mesa ? fsc.mesa.idmesa : 0 }}';
var fields = {
'multireqtoken': '{{ formToken(false) }}',
'action': 'juntar-mesas',
'idmesa_secundaria': idmesaSecundaria
};
Object.keys(fields).forEach(function (k) {
var inp = document.createElement('input');
inp.type = 'hidden';
inp.name = k;
inp.value = fields[k];
form.appendChild(inp);
});
document.body.appendChild(form);
form.submit();
}

// ── Modal nuevo cliente ───────────────────────────────
function tpvAbrirNuevoCliente() {
document.getElementById('nc-nombre').value = '';
document.getElementById('nc-cifnif').value = '';
document.getElementById('nc-email').value = '';
document.getElementById('nc-telefono').value = '';
document.getElementById('nc-direccion').value = '';
document.getElementById('nc-codpostal').value = '';
document.getElementById('nc-ciudad').value = '';
document.getElementById('nc-error').classList.add('d-none');
$('#modalNuevoCliente').modal('show');
}

function tpvCrearCliente() {
var nombre = document.getElementById('nc-nombre').value.trim();
var errEl = document.getElementById('nc-error');
if (! nombre) {
errEl.textContent = 'El nombre es obligatorio';
errEl.classList.remove('d-none');
return;
}
errEl.classList.add('d-none');

var btn = document.getElementById('nc-guardar');
btn.disabled = true;

var body = new URLSearchParams();
body.append('multireqtoken', document.getElementById('nc-token').value);
body.append('action', 'create-cliente');
body.append('nombre', nombre);
body.append('cifnif', document.getElementById('nc-cifnif').value.trim());
body.append('email', document.getElementById('nc-email').value.trim());
body.append('telefono1', document.getElementById('nc-telefono').value.trim());
body.append('direccion', document.getElementById('nc-direccion').value.trim());
body.append('codpostal', document.getElementById('nc-codpostal').value.trim());
body.append('ciudad', document.getElementById('nc-ciudad').value.trim());

fetch('{{ fsc.url() }}?idmesa=       {{ fsc.mesa ? fsc.mesa.idmesa : 0 }}', {
method: 'POST',
body: body,
headers: {
'Content-Type': 'application/x-www-form-urlencoded'
}
}).then(function (r) {
return r.json();
}).then(function (data) {
if (data.ok) { // Añadir al selector de cliente (mobile y desktop) y seleccionarlo
['sel-cliente-mobile', 'sel-cliente-desktop'].forEach(function (id) {
var s = document.getElementById(id);
if (! s) 
return;



var opt = new Option(data.nombre, data.codcliente, false, false);
s.appendChild(opt);
});
var selMobile = document.getElementById('sel-cliente-mobile');
var selDesktop = document.getElementById('sel-cliente-desktop');
if (selMobile) 
selMobile.value = data.codcliente;



if (selDesktop) 
selDesktop.value = data.codcliente;



$('#modalNuevoCliente').modal('hide');
} else {
errEl.textContent = data.error || 'Error al guardar';
errEl.classList.remove('d-none');
} btn.disabled = false;
}).catch(function () {
errEl.textContent = 'Error de conexión';
errEl.classList.remove('d-none');
btn.disabled = false;
});
}

