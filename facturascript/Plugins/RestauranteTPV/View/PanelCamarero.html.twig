								<i class="fa-solid fa-file-invoice mr-1"></i>
								{{ i18n.trans('invoice') }}
							</button>
						</div>
						<form method="post" action="{{ fsc.url() }}" id="tpv-side-form-can" onsubmit="return confirm('¿Está seguro?')">
							<input type="hidden" name="multireqtoken" value="{{ formToken(false) }}">
							<input type="hidden" name="action" value="cancel-pedido">
							<input type="hidden" name="idcomanda" id="tpv-side-can-id" value="">
							<button type="submit" class="tpv-act-btn tpv-act-cancel">
								<i class="fa-solid fa-xmark mr-1"></i>Cancelar pedido
							</button>
						</form>
					</div>
				</div>

				{# plit: cart + catalog on xl #}
				<div
