var bloqueMulti = document.getElementById('cobro-bloque-multipersona');
if (_cobroPersonas > 1) {
if (rowPP) 
rowPP.style.display = 'flex';


if (splitBtnRow) 
splitBtnRow.style.display = '';


document.getElementById('cobro-perpersona-val').textContent = (_cobroTotal / _cobroPersonas).toFixed(2) + ' €';
if (bloqueUnico) 
bloqueUnico.style.display = 'none';


if (bloqueMulti) 
bloqueMulti.style.display = '';


cobroRenderFilasPersonas();
} else {
if (rowPP) 
rowPP.style.display = 'none';


if (splitBtnRow) 
splitBtnRow.style.display = 'none';


if (bloqueUnico) 
bloqueUnico.style.display = '';


if (bloqueMulti) 
bloqueMulti.style.display = 'none';


cobroCalcCambio();
}
}

function cobroRenderFilasPersonas() {
var container = document.getElementById('cobro-personas-filas');
if (! container) 
return;


var html = '';
for (var i = 1; i <= _cobroPersonas; i++) {
var totalEstaPersona = (_splitTotalesPersonas.length >= i) ? _splitTotalesPersonas[i - 1] : (_cobroTotal / _cobroPersonas);
html += '<div class="d-flex align-items-center mb-2" style="gap:6px;">';
html += '<span class="badge badge-secondary" style="min-width:28px;">P' + i + '</span>';
html += '<span class="small text-muted" style="min-width:52px;">' + totalEstaPersona.toFixed(2) + '€ debe</span>';
html += '<input type="number" class="form-control form-control-sm text-right cobro-dado-persona" id="cobro-dado-p' + i + '" data-persona="' + i + '" step="0.01" min="0" placeholder="0.00" style="width:80px;" oninput="cobroCalcCambioMulti()">';
html += '<span class="small font-weight-bold text-primary" id="cobro-cambio-p' + i + '" style="min-width:52px;text-align:right;">cambio: 0.00€</span>';
html += '</div>';
}
container.innerHTML = html;
cobroCalcCambioMulti();
}

function cobroCalcCambioMulti() {
var cambioTotal = 0;
for (var i = 1; i <= _cobroPersonas; i++) {
var totalEstaPersona = (_splitTotalesPersonas.length >= i) ? _splitTotalesPersonas[i - 1] : (_cobroTotal / _cobroPersonas);
var inp = document.getElementById('cobro-dado-p' + i);
var dado = inp ? (parseFloat(inp.value) || 0) : 0;
var cambio = Math.max(0, dado - totalEstaPersona);
cambioTotal += cambio;
var sp = document.getElementById('cobro-cambio-p' + i);
if (sp) 
