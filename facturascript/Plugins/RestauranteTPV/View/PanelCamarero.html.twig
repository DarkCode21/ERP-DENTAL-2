});
}
htmlKot += '<tr>' + '<td style="text-align:left;">' + esc(l.desc) + (l.obs ? '<div style="font-size:.85em;color:#555;font-style:italic;padding-left:4px;">' + esc(l.obs) + '</div>' : '') + modsHtml + '</td>' + '<td style="text-align:right;">' + parseFloat(l.qty).toFixed(0) + '</td>' + '</tr>';
});
htmlKot += '</tbody></table></div>';
});
if (tpvEscposEnabled) {
fetch('{{ fsc.url() }}?action=print-kot&idcomanda=' + idComanda).then(function (r) {
return r.json();
}).then(function (d) {
if (! d.ok || ! d.kots || d.kots.length === 0) {
var te = document.createElement('div');
te.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#c0392b;color:#fff;padding:8px 20px;border-radius:6px;font-size:14px;z-index:9999;box-shadow:0 2px 8px rgba(0,0,0,.25);';
te.textContent = 'No hay KOT pendiente';
document.body.appendChild(te);
setTimeout(function () {
te.remove();
}, 4000);
return;
}
var kotPromises = d.kots.map(function (kot) {
var payload = {
buffer: kot.buffer
};
if (kot.tipo === 'usb') {
payload.usb = kot.usb;
} else {
payload.ip = kot.ip;
payload.port = kot.port;
}
return fetch(kot.relayUrl || tpvRelayUrl, {
method: 'POST',
headers: {
'Content-Type': 'application/json'
},
body: JSON.stringify(payload)
}).then(function (r) {
return r.json();
}).then(function (rd) {
return {
ok: rd.ok,
estacion: kot.estacion,
error: rd.error || ''
};
}).catch(function (e) {
return {ok: false, estacion: kot.estacion, error: e.message};
});
});
Promise.all(kotPromises).then(function (results) {
var ok = results.filter(function (r) {
return r.ok;
}).map(function (r) {
return r.estacion;
});
var err = results.filter(function (r) {
return ! r.ok;
});
if (ok.length > 0) {
var t = document.createElement('div');
t.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#27ae60;color:#fff;padding:8px 20px;border-radius:6px;font-size:14px;z-index:9999;box-shadow:0 2px 8px rgba(0,0,0,.25);';
t.textContent = 'Comanda enviada a: ' + ok.join(', ');
document.body.appendChild(t);
setTimeout(function () {
t.remove();
}, 3000);
}
err.forEach(function (r) {
var t2 = document.createElement('div');
t2.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#c0392b;color:#fff;padding:8px 20px;border-radius:6px;font-size:14px;z-index:9999;box-shadow:0 2px 8px rgba(0,0,0,.25);';
t2.textContent = 'Error (' + r.estacion + '): ' + (
r.error || 'desconocido'
);
document.body.appendChild(t2);
setTimeout(function () {
t2.remove();
}, 6000);
});
});
fetch('{{ fsc.url() }}?action=mark-kot-sent&idcomanda=' + idComanda).catch(function () {});
}).catch(function (e) {
var t4 = document.createElement('div');
t4.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#c0392b;color:#fff;padding:8px 20px;border-radius:6px;font-size:14px;z-index:9999;box-shadow:0 2px 8px rgba(0,0,0,.25);';
t4.textContent = 'Error al obtener KOT: ' + e.message;
document.body.appendChild(t4);
setTimeout(function () {
t4.remove();
}, 6000);
});
} else {
var wk = window.open('', '_blank', 'width=420,height=620');
if (wk) {
wk.document.write('<html><head><meta charset="utf-8"><style>@page{margin:0;}body{font-size:16px;margin:0;padding:0;}.sec-doc{font-size:14px !important;}</style></head><body>');
