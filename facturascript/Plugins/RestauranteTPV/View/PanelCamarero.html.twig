						</a>
						<button type="button" class="tpv-act-btn" onclick="tpvSideDetalles()">
							<i class="fa-solid fa-circle-info mr-1"></i>Detalles del pedido
						</button>
						<div id="tpv-side-form-fac">
							<input type="hidden" id="tpv-side-fac-id" value="">
							<input type="hidden" id="tpv-side-fac-total" value="">
