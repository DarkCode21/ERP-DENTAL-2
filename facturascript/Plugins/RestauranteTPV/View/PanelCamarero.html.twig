						{% if fsc.user.admin and fsc.usuarios|length > 1 %}
							<select>
								{% for u in fsc.usuarios %}
									<option value="{{ u.nick }}" {{ u.nick == fsc.user.nick ? 'selected' : '' }}>{{ u.nick }}</option>
								{% endfor %}
							</select>
						{% else %}
							<div style="flex:1;border:1px solid #ccc;border-radius:4px;padding:5px 6px;font-size:.78rem;background:#f8f9fa;color:#555;">
								<i class="fa-solid fa-user mr-1"></i>
								{{ fsc.user.nick }}
							</div>
						{% endif %}
						<div class="tpv-cli-wrap">
							<input type="text" class="tpv-cli-input" id="sel-cliente-desktop-input" autocomplete="off" placeholder="Buscar por nombre, teléfono..." value="{{ tpvNomClienteActual|e('html_attr') }}" style="width:100%;border:1px solid #ccc;border-radius:4px;padding:5px 6px;font-size:.78rem;background:#fff;" oninput="tpvFiltrarCliente(this,'sel-cliente-desktop')" onfocus="tpvFiltrarCliente(this,'sel-cliente-desktop')"/>
							<input type="hidden" id="sel-cliente-desktop" value="{{ fsc.codClienteDefault }}"/>
							<div id="sel-cliente-desktop-drop" class="tpv-cli-drop"></div>
						</div>
						<button type="button" class="sel-btn" onclick="tpvAbrirEditarCliente()">
							<i class="fa-solid fa-pencil"></i>
						</button>
						<button type="button" class="sel-btn" onclick="tpvAbrirNuevoCliente()">
							<i class="fa-solid fa-plus"></i>
						</button>
						{% if fsc.cashSerie and not fsc.cashBox %}
							<form action="{{ cajaContextUrl }}" method="post" class="mb-0" data-no-ajax="true">
								{{ formToken() }}
								<button type="submit" name="action" value="cash-open-start" class="btn btn-success btn-sm text-nowrap">
									<i class="fas fa-lock-open mr-1"></i>Abrir caja
								</button>
							</form>
						{% else %}
							<div class="btn-group dropdown">
								<button class="sel-btn dropdown-toggle" type="button" id="dropdownCashDesktop" data-toggle="dropdown" aria-expanded="false" title="Caja">
