var _cobroPersonas = 1;
var _splitAsignaciones = {};
var _tpvLineasSplit = [];
var _tpvPedidoLineas = [];
var _splitTotalesPersonas = [];
var _splitAsignacionesConfirmadas = '';

function cobroPersonasCambiar(delta) {
_cobroPersonas = Math.max(1, _cobroPersonas + delta);
_splitTotalesPersonas = [];
_splitAsignacionesConfirmadas = '';
document.getElementById('cobro-personas-val').textContent = _cobroPersonas;
var rowPP = document.getElementById('cobro-perpersona-row');
var splitBtnRow = document.getElementById('cobro-split-btn-row');
