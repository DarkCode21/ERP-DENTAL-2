wk.document.write('</body></html>');
wk.document.close();
wk.focus();
setTimeout(function () {
wk.print();
}, 400);
}
}
} else { // ── FACTURA o pedido sin estaciones: recibo completo ──
html = '<div id="receipt-data">' + '<div style="text-align:center;">' + '<h3 style="text-transform:uppercase;">' + esc(camarero) + '</h3>' + '<p>' + esc(empData.nombre || '') + '<br/>' + esc(empData.direccion || '') + '<br/>' + 'Tel: ' + esc(empData.telefono || '') + '<br/>' + 'NIF/CIF: ' + esc(empData.cifnif || '') + '</p>' + '</div>' + '<div style="text-align:center;">' + '<h4 style="font-weight:bold;">' + (
ticketEsFactura ? 'FACTURA SIMPLIFICADA' : ('PEDIDO' + (
ticketSerieDesc ? ' ' + esc(ticketSerieDesc.toUpperCase()) : ''
))
) + '</h4>' + (
ticketDocCodigo ? '<p style="margin:2px 0;">N\u00ba ' + esc(ticketDocCodigo) + '</p>' : ''
) + '</div>' + '<div class="sec-doc" style="text-align:left !important;padding-right:5px;padding-left:10px;">' + '<p>Fecha: ' + esc(fecha) + ' ' + esc(hora) + '<br/>' + 'Comanda: <strong>#' + idComanda + '</strong>';
if (mesa) 
