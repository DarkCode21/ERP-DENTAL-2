						<button type="button" class="ot-btn {{ ((fsc.comanda and fsc.comanda.tipo == 'in-table') or (not fsc.comanda and fsc.settingServicioDefecto == 'in-table')) ? 'active' : '' }}" onclick="tpvTipoOrden(this,'in-table')">
							<i class="fa-solid fa-table-cells mr-1"></i>
							{{ i18n.trans('dine-in') }}</button>
						<button type="button" class="ot-btn {{ ((fsc.comanda and fsc.comanda.tipo == 'take-away') or (not fsc.comanda and fsc.settingServicioDefecto == 'take-away')) ? 'active' : '' }}" onclick="tpvTipoOrden(this,'take-away')">
							<i class="fa-solid fa-bag-shopping mr-1"></i>
							{{ i18n.trans('take-away') }}</button>
						<button type="button" class="ot-btn {{ ((fsc.comanda and fsc.comanda.tipo == 'delivery') or (not fsc.comanda and fsc.settingServicioDefecto == 'delivery')) ? 'active' : '' }}" onclick="tpvTipoOrden(this,'delivery')">
							<i class="fa-solid fa-truck mr-1"></i>
							{{ i18n.trans('delivery') }}</button>
						<button type="button" class="ot-btn mesa-active" id="btn-mesa-desktop" onclick="$('#modalMesas').modal('show')" {{ ((fsc.comanda and fsc.comanda.tipo != 'in-table') or (not fsc.comanda and fsc.settingServicioDefecto != 'in-table')) ? 'disabled' : '' }}>
							<i class="fa-solid fa-right-left mr-1"></i>
							{{ i18n.trans('table') }}:
							{{ fsc.mesa ? fsc.mesa.nombre : '---' }}
						</button>
					</div>

					{# Selectores waiter + cliente — escritorio #}
					<div class="xl-sel-row">
						{% if fsc.empresas|length > 1 %}
							<select class="tpv-empresa-sel" onchange="tpvSetEmpresa(this.value)" style="flex:1;width:100%;border:1px solid #ccc;border-radius:4px;padding:5px 6px;font-size:.78rem;background:#fff;">
								{% for emp in fsc.empresas %}
									<option value="{{ emp.idempresa }}" {{ fsc.idempresaActual == emp.idempresa ? 'selected' : '' }}>{{ emp.nombre }}</option>
								{% endfor %}
							</select>
