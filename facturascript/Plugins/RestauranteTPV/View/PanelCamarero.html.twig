// ── Buscador de cliente ──────────────────────────────────
function tpvFiltrarCliente(inputEl, hiddenId) {
var q = inputEl.value.toLowerCase().trim();
var drop = document.getElementById(hiddenId + '-drop');
drop.innerHTML = '';
var results = [];
Object.keys(TPV_CLIENTES).forEach(function (cod) {
var c = TPV_CLIENTES[cod];
var haystack = ((c.nombre || '') + ' ' + (
c.telefono1 || ''
) + ' ' + (
c.direccion || ''
) + ' ' + (
c.ciudad || ''
)).toLowerCase();
if (q === '' || haystack.indexOf(q) !== -1) {
results.push({cod: cod, nombre: c.nombre, tel: c.telefono1, dir: c.direccion});
}
});
if (results.length === 0) {
drop.style.display = 'none';
return;
}
results.slice(0, 60).forEach(function (r) {
var div = document.createElement('div');
div.className = 'tpv-cli-opt';
var sub = [];
if (r.tel) 
sub.push(r.tel);



if (r.dir) 
sub.push(r.dir);



var esc = function (s) {
return(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;');
};
div.innerHTML = '<div>' + esc(r.nombre) + '</div>' + (
sub.length ? '<div class="cli-sub">' + esc(sub.join(' · ')) + '</div>' : ''
);
div.addEventListener('mousedown', function (e) {
e.preventDefault();
inputEl.value = r.nombre;
document.getElementById(hiddenId).value = r.cod;
drop.style.display = 'none';
var otherId = hiddenId === 'sel-cliente-mobile' ? 'sel-cliente-desktop' : 'sel-cliente-mobile';
var otherHidden = document.getElementById(otherId);
if (otherHidden) 
otherHidden.value = r.cod;



var otherInput = document.getElementById(otherId + '-input');
if (otherInput) 
otherInput.value = r.nombre;



});
drop.appendChild(div);
});
drop.style.display = 'block';
}
document.addEventListener('click', function (e) {
if (! e.target.classList.contains('tpv-cli-input')) {
document.querySelectorAll('.tpv-cli-drop').forEach(function (d) {
d.style.display = 'none';
});
}
});

var TPV_CURRENT_MESA = {{ fsc.mesa ? fsc.mesa.idmesa : 0 }};
var TPV_TIENE_COMANDA_MESA = {{ (fsc.comanda and fsc.comanda.idmesa) ? 'true' : 'false' }};

// ── Cambio de empresa por AJAX (sin recargar página) ─────
function tpvSetEmpresa(val) {
var token = document.getElementById('tpv-empresa-token');
if (! token) 
return;


var body = new URLSearchParams();
body.append('multireqtoken', token.value);
body.append('action', 'set-empresa');
body.append('idempresa', val);
fetch('{{ fsc.url() }}', {
method: 'POST',
headers: {
'Content-Type': 'application/x-www-form-urlencoded'
},
body: body.toString(),
redirect: 'manual'
}).then(function (r) {
return r.json();
}).then(function (d) { // Sincronizar todos los selects de empresa
document.querySelectorAll('.tpv-empresa-sel').forEach(function (s) {
s.value = val;
});
// Actualizar select de formas de pago del modal cobro
var sel = document.getElementById('cobro-codpago');
if (sel && d.formasPago) {
sel.innerHTML = '';
d.formasPago.forEach(function (fp) {
var opt = document.createElement('option');
opt.value = fp.codpago;
opt.textContent = fp.descripcion;
sel.appendChild(opt);
});
}
}).catch(function () {});
}

