										{# Detalles del pedido #}
										{% set ls2 = [] %}
										{% for li in orden.lineas %}
											{% if li.estado != 'cancelado' %}
												{% set ls2 = ls2|merge([[li.descripcion, li.pvpunitario, li.cantidad, 0]]) %}
											{% endif %}
										{% endfor %}
										<button type="button" class="btn btn-sm btn-outline-info" style="flex:1 1 auto;min-width:80px;" data-id="{{ orden.idcomanda }}" data-tipo="{{ orden.tipo|capitalize }}" data-num="{{ orden.idpedido }}" data-cam="{{ orden.codcamarero|e }}" data-cl="{{ orden.cliente_nombre|default('')|e }}" data-mesa="{{ orden.mesa_nombre|default('None')|e }}" data-total="{{ orden.total }}" data-ls="{{ ls2|json_encode|e }}" onclick="tpvAbrirDetalles(this)">
											<i class="fa-solid fa-circle-info mr-1"></i>Detalles
										</button>

										{# Imprimir cuenta #}
