<?xml version="1.0" encoding="UTF-8"?>
<!--
    Tabla: rest_mesas
    Descripción: Mesas del restaurante con su estado actual.
    Estados posibles: libre | ocupada | reservada
-->
<table>
    <column>
        <name>idmesa</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>idzona</name>
        <type>integer</type>
    </column>
    <column>
        <name>nombre</name>
        <type>character varying(50)</type>
        <null>NO</null>
    </column>
    <column>
        <name>capacidad</name>
        <type>integer</type>
        <null>NO</null>
        <default>4</default>
    </column>
    <column>
        <name>estado</name>
        <type>character varying(20)</type>
        <null>NO</null>
        <default>'libre'</default>
    </column>
    <column>
        <name>pos_x</name>
        <type>integer</type>
        <null>NO</null>
        <default>0</default>
    </column>
    <column>
        <name>pos_y</name>
        <type>integer</type>
        <null>NO</null>
        <default>0</default>
    </column>
    <constraint>
        <name>pk_rest_mesas</name>
        <type>PRIMARY KEY (idmesa)</type>
    </constraint>
    <constraint>
        <name>fk_rest_mesas_zona</name>
        <type>FOREIGN KEY (idzona) REFERENCES rest_zonas (idzona) ON DELETE SET NULL</type>
    </constraint>
</table>
