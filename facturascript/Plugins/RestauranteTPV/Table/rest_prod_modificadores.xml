<?xml version="1.0" encoding="UTF-8"?>
<!--
    Tabla: rest_prod_modificadores
    Descripción: Asigna modificadores a productos por referencia.
    Un mismo modificador puede asignarse a varios productos
    y un producto puede tener varios modificadores.
-->
<table>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>referencia</name>
        <type>character varying(30)</type>
        <null>NO</null>
    </column>
    <column>
        <name>idmodificador</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <constraint>
        <name>pk_rest_prod_modificadores</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>uq_rest_prod_mod</name>
        <type>UNIQUE (referencia, idmodificador)</type>
    </constraint>
    <constraint>
        <name>fk_rest_prod_mod_modificador</name>
        <type>FOREIGN KEY (idmodificador) REFERENCES rest_modificadores (idmodificador) ON DELETE CASCADE</type>
    </constraint>
</table>
