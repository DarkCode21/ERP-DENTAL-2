<?xml version="1.0" encoding="UTF-8"?>
<view>
    <columns>
        <column name="id" display="none" order="0">
            <widget type="text" fieldname="idcomanda"/>
        </column>
        <column name="date" order="100">
            <widget type="date" fieldname="fecha"/>
        </column>
        <column name="hour" order="110">
            <widget type="time" fieldname="hora"/>
        </column>
        <column name="table" order="200">
            <widget type="select" fieldname="idmesa">
                <values source="rest_mesas" fieldcode="idmesa" fieldtitle="nombre"/>
            </widget>
        </column>
        <column name="waiter" order="300">
            <widget type="select" fieldname="codcamarero">
                <values source="users" fieldcode="nick" fieldtitle="nick"/>
            </widget>
        </column>
        <column name="type" order="350">
            <widget type="text" fieldname="tipo"/>
        </column>
        <column name="state" order="400">
            <widget type="text" fieldname="estado" translate="true"/>
        </column>
        <column name="total" order="500" display="right">
            <widget type="money" fieldname="total"/>
        </column>
    </columns>
    <rows/>
</view>
