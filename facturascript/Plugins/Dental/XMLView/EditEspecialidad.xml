<?xml version="1.0" encoding="UTF-8"?>
<view>
    <columns>
        <group name="main" numcolumns="12">
            <column name="code" display="none" order="100">
                <widget type="text" fieldname="id" />
            </column>
            <column name="name" numcolumns="6" order="110">
                <widget type="text" fieldname="nombre" />
            </column>
            <column name="status" numcolumns="3" order="120">
                <widget type="select" fieldname="estado" translate="true">
                    <values title="active">activo</values>
                    <values title="inactive">inactivo</values>
                </widget>
            </column>
            <column name="description" numcolumns="12" order="130">
                <widget type="textarea" fieldname="descripcion" />
            </column>
        </group>
    </columns>
</view>
