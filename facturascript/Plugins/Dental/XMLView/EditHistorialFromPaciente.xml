<?xml version="1.0" encoding="UTF-8"?>
<view>
    <columns>
        <group name="main" numcolumns="12">
            <column name="code" display="none" order="100">
                <widget type="text" fieldname="id" />
            </column>
            <column name="patient" display="none" order="105">
                <widget type="text" fieldname="idpaciente" />
            </column>
            <column name="date" numcolumns="3" order="110">
                <widget type="date" fieldname="fecha" />
            </column>
            <column name="type" numcolumns="3" order="120">
                <widget type="select" fieldname="tipo" translate="true">
                    <values title="first-visit">primera_visita</values>
                    <values title="revision">revision</values>
                    <values title="diagnosis">diagnostico</values>
                    <values title="evolution">evolucion</values>
                    <values title="emergency">urgencia</values>
                    <values title="treatment-done">tratamiento_realizado</values>
                    <values title="prescription">prescripcion</values>
                    <values title="internal-observation">observacion_interna</values>
                    <values title="clinical-discharge">alta_clinica</values>
                    <values title="incident">incidencia</values>
                    <values title="consent-reviewed">consentimiento_revisado</values>
                    <values title="xray-reviewed">radiografia_revisada</values>
                </widget>
            </column>
            <column name="status" numcolumns="3" order="130">
                <widget type="select" fieldname="estado" translate="true">
                    <values title="active">activo</values>
                    <values title="inactive">inactivo</values>
                </widget>
            </column>
            <column name="reason" numcolumns="12" order="140">
                <widget type="textarea" fieldname="motivo_consulta" />
            </column>
            <column name="diagnosis" numcolumns="12" order="150">
                <widget type="textarea" fieldname="diagnostico" />
            </column>
            <column name="treatment" numcolumns="12" order="160">
                <widget type="textarea" fieldname="tratamiento_recomendado" />
            </column>
            <column name="done" numcolumns="12" order="170">
                <widget type="textarea" fieldname="tratamiento_realizado" />
            </column>
            <column name="medication" numcolumns="12" order="180">
                <widget type="textarea" fieldname="medicacion_prescrita" />
            </column>
            <column name="observations" numcolumns="12" order="190">
                <widget type="textarea" fieldname="observaciones_clinicas" />
            </column>
            <column name="next-review" numcolumns="3" order="200">
                <widget type="date" fieldname="proxima_revision" />
            </column>
        </group>
    </columns>
</view>
