{% extends "Master/PanelController.html.twig" %}

{% block body %}
<div class="container-fluid">
    <div id="odonto-toast" style="display:none;position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#27ae60;color:#fff;padding:8px 20px;border-radius:6px;font-size:14px;z-index:9999;box-shadow:0 2px 8px rgba(0,0,0,.25);">
    </div>
    <iframe
        id="odontograma-frame"
        src="/Plugins/Dental/Assets/odontograma/index.html{% if fsc.idpaciente %}?idpaciente={{ fsc.idpaciente }}&t={{ "now"|date("YmdHis") }}{% endif %}"
        style="width:100%; height:1200px; border:none;">
    </iframe>
</div>
<script>
window.addEventListener('message', function(e) {
    if (e.data && e.data.type === 'odonto-toast') {
        var toast = document.getElementById('odonto-toast');
        toast.textContent = e.data.message;
        toast.style.background = e.data.error ? '#c0392b' : '#27ae60';
        toast.style.display = 'block';
        setTimeout(function() {
            toast.style.display = 'none';
        }, 3000);
    }
});
</script>
{% endblock %}
