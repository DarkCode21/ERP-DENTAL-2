{% block javascripts %}
	{{ parent() }}
	<script>
		function cargarOdontogramaLimpio() {
			var iframe = document.getElementById('odontograma-frame');
			if (!iframe) return;
			iframe.src = 'about:blank';
			setTimeout(function () {
				iframe.src = iframe.dataset.baseSrc + '&force=' + Date.now() + '-' + Math.random();
			}, 100);
		}

		window.addEventListener('message', function (e) {
			if (e.data && e.data.type === 'odonto-toast') {
				var toast = document.getElementById('odonto-toast');
				toast.textContent = e.data.message;
				toast.style.background = e.data.error ? '#c0392b' : '#27ae60';
				toast.style.display = 'block';
				setTimeout(function () {
					toast.style.display = 'none';
				}, 3000);
			}
		});

		document.addEventListener('DOMContentLoaded', function () {
			cargarOdontogramaLimpio();
			document.querySelector('#odonto-tab')?.addEventListener('shown.bs.tab', cargarOdontogramaLimpio);

			$('#editCitaModal').on('show.bs.modal', function (e) {
				var btn = e.relatedTarget;
				if (!btn) return;
				$('#edit-cita-id').val(btn.dataset.id || '');
				$('#edit-cita-idespecialista').val(btn.dataset.idespecialista || '');
				$('#edit-cita-idgabinete').val(btn.dataset.idgabinete || '');
				$('#edit-cita-idtratamiento').val(btn.dataset.idtratamiento || '');
				$('#edit-cita-fecha').val(btn.dataset.fecha || '');
				$('#edit-cita-hora_inicio').val(btn.dataset.hora_inicio || '');
				$('#edit-cita-hora_fin').val(btn.dataset.hora_fin || '');
				$('#edit-cita-duracion').val(btn.dataset.duracion || '30');
				$('#edit-cita-motivo').val(btn.dataset.motivo || '');
				$('#edit-cita-estado').val(btn.dataset.estado || 'pendiente');
				$('#edit-cita-observaciones').val(btn.dataset.observaciones || '');
			});

			$('#editTratamientoModal').on('show.bs.modal', function (e) {
				var btn = e.relatedTarget;
				if (!btn) return;
				$('#edit-tratamiento-id').val(btn.dataset.id || '');
				$('#edit-tratamiento-referencia').val(btn.dataset.referencia_servicio || '');
				$('#edit-tratamiento-fecha_inicio').val(btn.dataset.fecha_inicio || '');
				$('#edit-tratamiento-fecha_fin').val(btn.dataset.fecha_fin || '');
				$('#edit-tratamiento-precio').val(btn.dataset.precio || '0');
				$('#edit-tratamiento-descuento').val(btn.dataset.descuento || '0');
				$('#edit-tratamiento-estado_clinico').val(btn.dataset.estado_clinico || 'propuesto');
				$('#edit-tratamiento-estado_economico').val(btn.dataset.estado_economico || 'pendiente');
				$('#edit-tratamiento-observaciones').val(btn.dataset.observaciones || '');
			});

			$('#editHistorialModal').on('show.bs.modal', function (e) {
				var btn = e.relatedTarget;
				if (!btn) return;
				$('#edit-historial-id').val(btn.dataset.id || '');
				$('#edit-historial-fecha').val(btn.dataset.fecha || '');
				$('#edit-historial-tipo').val(btn.dataset.tipo || 'nota');
				$('#edit-historial-motivo_consulta').val(btn.dataset.motivo_consulta || '');
				$('#edit-historial-diagnostico').val(btn.dataset.diagnostico || '');
				$('#edit-historial-tratamiento_recomendado').val(btn.dataset.tratamiento_recomendado || '');
				$('#edit-historial-tratamiento_realizado').val(btn.dataset.tratamiento_realizado || '');
				$('#edit-historial-medicacion_prescrita').val(btn.dataset.medicacion_prescrita || '');
				$('#edit-historial-observaciones_clinicas').val(btn.dataset.observaciones_clinicas || '');
				$('#edit-historial-proxima_revision').val(btn.dataset.proxima_revision || '');
			});
		});
	</script>
{% endblock %}
