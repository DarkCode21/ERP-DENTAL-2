{% extends "Master/PanelController.html.twig" %}

{% set version = "20260703-1" %}

{% block body %}
	<div class="container-fluid">
		<div id="odonto-toast" style="display:none;position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#27ae60;color:#fff;padding:8px 20px;border-radius:6px;font-size:14px;z-index:9999;box-shadow:0 2px 8px rgba(0,0,0,.25);"></div>

		{% set cliente = fsc.paciente.getCliente() %}
		<div class="patient-header d-flex justify-content-between align-items-center mb-3">
			<h4 class="patient-title mb-0">
				<i class="fas fa-user-injured mr-2"></i>
				{{ cliente ? cliente.razonsocial : 'Paciente' }}</h4>
			<a href="Paciente" class="btn btn-secondary btn-sm">
				<i class="fas fa-arrow-left mr-1"></i>Volver</a>
		</div>

		<ul class="nav nav-tabs patient-tabs mb-3" id="pacienteTab" role="tablist">
			<li class="nav-item">
				<a class="nav-link active" id="odonto-tab" data-toggle="tab" href="#odonto-panel" role="tab">
					<i class="fas fa-tooth mr-1"></i>Odontograma
				</a>
			</li>
			<li class="nav-item">
				<a class="nav-link" id="tratamiento-tab" data-toggle="tab" href="#tratamiento-panel" role="tab">
					<i class="fas fa-hand-holding-medical mr-1"></i>Tratamiento
				</a>
			</li>
			<li class="nav-item">
				<a class="nav-link" id="archivo-tab" data-toggle="tab" href="#archivo-panel" role="tab">
					<i class="fas fa-folder mr-1"></i>Archivo
				</a>
			</li>
			<li class="nav-item">
				<a class="nav-link" id="cita-tab" data-toggle="tab" href="#cita-panel" role="tab">
					<i class="fas fa-calendar-alt mr-1"></i>Cita
				</a>
			</li>
			<li class="nav-item">
				<a class="nav-link" id="historial-tab" data-toggle="tab" href="#historial-panel" role="tab">
					<i class="fas fa-history mr-1"></i>Historial
				</a>
			</li>
		</ul>

		<div class="tab-content" id="pacienteTabContent">
			<div class="tab-pane fade" id="archivo-panel" role="tabpanel">
				<div class="card patient-card">
					<div class="card-header">
						<div class="d-flex justify-content-between align-items-center">
							<h5 class="mb-0">
								<i class="fas fa-folder mr-2"></i>Archivos</h5>
							<a href="EditArchivoFromPaciente?cod={{ fsc.paciente.id }}" class="btn btn-primary btn-sm">
								<i class="fas fa-plus mr-1"></i>Nuevo Archivo
							</a>
						</div>
					</div>
					<div class="card-body">
						{% set archivos = fsc.paciente.getArchivos() %}
						{% if archivos|length > 0 %}
							<table class="table table-hover table-patient mb-0">
								<thead>
									<tr>
										<th>Nombre</th>
										<th>Fecha</th>
										<th></th>
									</tr>
								</thead>
								<tbody>
									{% for archivo in archivos %}
										<tr>
											<td>{{ archivo.nombre }}</td>
											<td>{{ archivo.created_at }}</td>
											<td class="text-right">
												<a href="EditArchivo?code={{ archivo.id }}" class="btn btn-outline-secondary btn-sm">
													<i class="fas fa-eye"></i>
												</a>
											</td>
										</tr>
									{% endfor %}
								</tbody>
							</table>
						{% else %}
							<p class="text-muted mb-0">No hay archivos registrados.</p>
						{% endif %}
					</div>
				</div>
			</div>

			<div class="tab-pane fade" id="cita-panel" role="tabpanel">
				<div class="card patient-card">
					<div class="card-header">
						<div class="d-flex justify-content-between align-items-center">
							<h5 class="mb-0">
								<i class="fas fa-calendar-alt mr-2"></i>Citas</h5>
							<button type="button" class="btn btn-primary btn-sm" data-toggle="modal" data-target="#newCitaModal">
								<i class="fas fa-plus mr-1"></i>Nueva Cita
							</button>
						</div>
					</div>
					<div class="card-body">
						{% set citas = fsc.paciente.getCitas() %}
						{% if citas|length > 0 %}
							<table class="table table-hover table-patient mb-0">
								<thead>
									<tr>
										<th>Especialista</th>
										<th>Gabinete</th>
										<th>Tratamiento</th>
										<th>Fecha</th>
										<th>Hora Inicio</th>
										<th></th>
									</tr>
								</thead>
								<tbody>
									{% for cita in citas %}
										{% set especialista = cita.getEspecialista() %}
										{% set gabinete = cita.getGabinete() %}
										{% set tratamiento = cita.idtratamiento ? fsc.tratamientos|filter(t => t.id == cita.idtratamiento)|first : null %}
										<tr>
											<td>{{ especialista ? especialista.nombre : '-' }}</td>
											<td>{{ gabinete ? gabinete.nombre : '-' }}</td>
											<td>{{ tratamiento ? tratamiento.referencia_servicio : '-' }}</td>
											<td>{{ cita.fecha }}</td>
											<td>{{ cita.hora_inicio }}</td>
											<td class="text-right">
												<button type="button" class="btn btn-outline-secondary btn-sm" data-toggle="modal" data-target="#editCitaModal" data-id="{{ cita.id }}" data-idespecialista="{{ cita.idespecialista }}" data-idgabinete="{{ cita.idgabinete }}" data-idtratamiento="{{ cita.idtratamiento ?: '' }}" data-fecha="{{ cita.fecha ? cita.fecha|date('Y-m-d') : '' }}" data-hora_inicio="{{ cita.hora_inicio }}" data-hora_fin="{{ cita.hora_fin }}" data-duracion="{{ cita.duracion }}" data-motivo="{{ cita.motivo|e }}" data-estado="{{ cita.estado }}" data-observaciones="{{ cita.observaciones|e }}">
													<i class="fas fa-eye"></i>
												</button>
											</td>
										</tr>
									{% endfor %}
								</tbody>
							</table>
						{% else %}
							<p class="text-muted mb-0">No hay citas registradas.</p>
						{% endif %}
					</div>
				</div>
			</div>

			<div class="tab-pane fade show active" id="odonto-panel" role="tabpanel">
				<iframe id="odontograma-frame" data-base-src="{{ asset('Plugins/Dental/Assets/odontograma/index.html') }}?idpaciente={{ fsc.paciente.id }}" src="{{ asset('Plugins/Dental/Assets/odontograma/index.html') }}?idpaciente={{ fsc.paciente.id }}&token=MhdRAHYoTDzZu4xXfPcQ" style="width:100%; height:1200px; border:1px solid #dee2e6; border-radius:8px; background:#fff;"></iframe>
			</div>

			<div class="tab-pane fade" id="historial-panel" role="tabpanel">
				<div class="card patient-card">
					<div class="card-header">
						<div class="d-flex justify-content-between align-items-center">
							<h5 class="mb-0">
								<i class="fas fa-history mr-2"></i>Historial</h5>
							<button type="button" class="btn btn-primary btn-sm" data-toggle="modal" data-target="#newHistorialModal">
								<i class="fas fa-plus mr-1"></i>Nueva Entrada
							</button>
						</div>
					</div>
					<div class="card-body">
						{% set historial = fsc.paciente.getHistorial() %}
						{% if historial|length > 0 %}
							<table class="table table-hover table-patient mb-0">
								<thead>
									<tr>
										<th>Fecha</th>
										<th>Tipo</th>
										<th>Descripción</th>
										<th></th>
									</tr>
								</thead>
								<tbody>
									{% for item in historial %}
										<tr>
											<td>{{ item.fecha }}</td>
											<td>{{ item.tipo|default('Nota') }}</td>
											<td>{{ (item.observaciones_clinicas ?: item.motivo_consulta ?: '')|slice(0, 100) }}
												{% if (item.observaciones_clinicas ?: item.motivo_consulta ?: '')|length > 100 %}...
												{% endif %}
											</td>
											<td class="text-right">
												<button type="button" class="btn btn-outline-secondary btn-sm" data-toggle="modal" data-target="#editHistorialModal" data-id="{{ item.id }}" data-fecha="{{ item.fecha ? item.fecha|date('Y-m-d') : '' }}" data-tipo="{{ item.tipo|default('nota') }}" data-motivo_consulta="{{ item.motivo_consulta|e }}" data-diagnostico="{{ item.diagnostico|e }}" data-tratamiento_recomendado="{{ item.tratamiento_recomendado|e }}" data-tratamiento_realizado="{{ item.tratamiento_realizado|e }}" data-medicacion_prescrita="{{ item.medicacion_prescrita|e }}" data-observaciones_clinicas="{{ item.observaciones_clinicas|e }}" data-proxima_revision="{{ item.proxima_revision ? item.proxima_revision|date('Y-m-d') : '' }}">
													<i class="fas fa-eye"></i>
												</button>
											</td>
										</tr>
									{% endfor %}
								</tbody>
							</table>
						{% else %}
							<div class="empty-state">
								<i class="fas fa-history d-block"></i>
								<div>No hay entradas de historial.</div>
							</div>
						{% endif %}
					</div>
				</div>
			</div>

			<div class="tab-pane fade" id="tratamiento-panel" role="tabpanel">
				<div class="card patient-card">
					<div class="card-header">
						<div class="d-flex justify-content-between align-items-center">
							<h5 class="mb-0">
								<i class="fas fa-hand-holding-medical mr-2"></i>Tratamientos</h5>
							<button type="button" class="btn btn-primary btn-sm" data-toggle="modal" data-target="#newTratamientoModal">
								<i class="fas fa-plus mr-1"></i>Nuevo Tratamiento
							</button>
						</div>
					</div>
					<div class="card-body">
						{% set tratamientos = fsc.paciente.getTratamientos() %}
						{% if tratamientos|length > 0 %}
							<table class="table table-hover table-patient mb-0">
								<thead>
									<tr>
										<th>Referencia</th>
										<th>Precio</th>
										<th>Fecha Inicio</th>
										<th>Fecha Fin</th>
										<th>Estado Clínico</th>
										<th>Estado Eco.</th>
										<th></th>
									</tr>
								</thead>
								<tbody>
									{% for item in tratamientos %}
										<tr>
											<td>{{ item.referencia_servicio }}</td>
											<td>{{ item.precio|number_format(2, '.', ',') }}
												€</td>
											<td>{{ item.fecha_inicio }}</td>
											<td>{{ item.fecha_fin ?: '-' }}</td>
											<td>
												<span class="badge badge-{{ item.estado_clinico == 'completado' ? 'success' : (item.estado_clinico == 'cancelado' ? 'danger' : 'warning') }}">
													{{ item.estado_clinico }}
												</span>
											</td>
											<td>
												<span class="badge badge-{{ item.estado_economico == 'pagado' ? 'success' : (item.estado_economico == 'parcial' ? 'info' : 'secondary') }}">
													{{ item.estado_economico }}
												</span>
											</td>
											<td class="text-right">
												{% if item.idfactura %}
													<a href="EditFacturaCliente?code={{ item.idfactura }}" class="btn btn-outline-secondary btn-sm" title="Ver Factura">
														<i class="fas fa-file-invoice mr-1"></i>Ver
													</a>
												{% else %}
													<form method="post" action="Paciente" style="display:inline;">
														<input type="hidden" name="action" value="generar-factura">
														<input type="hidden" name="id" value="{{ item.id }}">
														<button type="submit" class="btn btn-success btn-sm" title="Generar Factura">
															<i class="fas fa-file-invoice-dollar mr-1"></i>Factura
														</button>
													</form>
												{% endif %}
												<button type="button" class="btn btn-outline-secondary btn-sm" data-toggle="modal" data-target="#editTratamientoModal" data-id="{{ item.id }}" data-referencia_servicio="{{ item.referencia_servicio|e }}" data-fecha_inicio="{{ item.fecha_inicio ? item.fecha_inicio|date('Y-m-d') : '' }}" data-fecha_fin="{{ item.fecha_fin ? item.fecha_fin|date('Y-m-d') : '' }}" data-precio="{{ item.precio }}" data-descuento="{{ item.descuento }}" data-estado_clinico="{{ item.estado_clinico }}" data-estado_economico="{{ item.estado_economico }}" data-observaciones="{{ item.observaciones|e }}">
													<i class="fas fa-eye"></i>
												</button>
											</td>
										</tr>
									{% endfor %}
								</tbody>
							</table>
						{% else %}
							<div class="empty-state">
								<i class="fas fa-hand-holding-medical d-block"></i>
								<div>No hay tratamientos registrados.</div>
							</div>
						{% endif %}
					</div>
				</div>
			</div>
		</div>
	</div>

	<div class="modal fade" id="newTratamientoModal" tabindex="-1" role="dialog">
		<div class="modal-dialog modal-lg modal-dialog-centered" role="document">
			<form method="post" action="Paciente">
				<input type="hidden" name="action" value="save-tratamiento">
				<input type="hidden" name="idpaciente" value="{{ fsc.paciente.id }}">
				<div class="modal-content">
					<div class="modal-header">
						<h5 class="modal-title">Nuevo Tratamiento</h5>
						<button type="button" class="close" data-dismiss="modal">
							<span>&times;</span>
						</button>
					</div>
					<div class="modal-body">
						<div class="row">
							<div class="col-md-6">
								<div class="form-group">
									<label>Servicio/Tratamiento *</label>
									<input type="text" name="referencia_servicio" class="form-control" required>
								</div>
							</div>
							<div class="col-md-2">
								<div class="form-group">
									<label>Precio (€)</label>
									<input type="number" step="0.01" name="precio" class="form-control" value="0">
								</div>
							</div>
							<div class="col-md-2">
								<div class="form-group">
									<label>Descuento (%)</label>
									<input type="number" step="0.01" name="descuento" class="form-control" value="0">
								</div>
							</div>
							<div class="col-md-2">
								<div class="form-group">
									<label>Fecha Inicio</label>
									<input type="date" name="fecha_inicio" class="form-control" value="{{ "now"|date("Y-m-d") }}">
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-md-3">
								<div class="form-group">
									<label>Fecha Fin</label>
									<input type="date" name="fecha_fin" class="form-control">
								</div>
							</div>
							<div class="col-md-3">
								<div class="form-group">
									<label>Estado Clínico</label>
									<select name="estado_clinico" class="form-control">
										<option value="propuesto">Propuesto</option>
										<option value="en_progreso">En Progreso</option>
										<option value="completado">Completado</option>
										<option value="cancelado">Cancelado</option>
									</select>
								</div>
							</div>
							<div class="col-md-3">
								<div class="form-group">
									<label>Estado Económico</label>
									<select name="estado_economico" class="form-control">
										<option value="pendiente">Pendiente</option>
										<option value="parcial">Parcial</option>
										<option value="pagado">Pagado</option>
									</select>
								</div>
							</div>
						</div>
						<div class="form-group mb-0">
							<label>Observaciones</label>
							<textarea name="observaciones" class="form-control" rows="3"></textarea>
						</div>
					</div>
					<div class="modal-footer">
						<button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
						<button type="submit" class="btn btn-primary">Guardar</button>
					</div>
				</div>
			</form>
		</div>
	</div>

	<div class="modal fade" id="newCitaModal" tabindex="-1" role="dialog">
		<div class="modal-dialog modal-lg modal-dialog-centered" role="document">
			<form method="post" action="Paciente">
				<input type="hidden" name="action" value="save-cita">
				<input type="hidden" name="idpaciente" value="{{ fsc.paciente.id }}">
				<div class="modal-content">
					<div class="modal-header">
						<h5 class="modal-title">Nueva Cita</h5>
						<button type="button" class="close" data-dismiss="modal">
							<span>&times;</span>
						</button>
					</div>
					<div class="modal-body">
						<div class="row">
							<div class="col-md-4">
								<div class="form-group">
									<label>Especialista *</label>
									<select name="idespecialista" class="form-control" required>
										<option value="">Seleccionar...</option>
										{% for esp in fsc.especialistas %}
											<option value="{{ esp.id }}">{{ esp.nombre }}</option>
										{% endfor %}
									</select>
								</div>
							</div>
							<div class="col-md-4">
								<div class="form-group">
									<label>Gabinete *</label>
									<select name="idgabinete" class="form-control" required>
										<option value="">Seleccionar...</option>
										{% for gab in fsc.gabientes %}
											<option value="{{ gab.id }}">{{ gab.nombre }}</option>
										{% endfor %}
									</select>
								</div>
							</div>
							<div class="col-md-4">
								<div class="form-group">
									<label>Tratamiento</label>
									<select name="idtratamiento" class="form-control">
										<option value="">Ninguno</option>
										{% for trat in fsc.tratamientos %}
											<option value="{{ trat.id }}">{{ trat.referencia_servicio }}</option>
										{% endfor %}
									</select>
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-md-3">
								<div class="form-group">
									<label>Fecha *</label>
									<input type="date" name="fecha" class="form-control" value="{{ "now"|date("Y-m-d") }}" required>
								</div>
							</div>
							<div class="col-md-3">
								<div class="form-group">
									<label>Hora Inicio *</label>
									<input type="time" name="hora_inicio" class="form-control" value="09:00" required>
								</div>
							</div>
							<div class="col-md-3">
								<div class="form-group">
									<label>Hora Fin</label>
									<input type="time" name="hora_fin" class="form-control" value="09:30">
								</div>
							</div>
							<div class="col-md-3">
								<div class="form-group">
									<label>Duración (min)</label>
									<input type="number" name="duracion" class="form-control" value="30">
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-md-6">
								<div class="form-group">
									<label>Motivo</label>
									<input type="text" name="motivo" class="form-control">
								</div>
							</div>
							<div class="col-md-3">
								<div class="form-group">
									<label>Estado</label>
									<select name="estado" class="form-control">
										<option value="pendiente">Pendiente</option>
										<option value="confirmada">Confirmada</option>
										<option value="completada">Completada</option>
										<option value="cancelada">Cancelada</option>
									</select>
								</div>
							</div>
						</div>
						<div class="form-group mb-0">
							<label>Observaciones</label>
							<textarea name="observaciones" class="form-control" rows="2"></textarea>
						</div>
					</div>
					<div class="modal-footer">
						<button type="button" class="btn btn-secondary" data-dismiss="modal">Cancelar</button>
						<button type="submit" class="btn btn-primary">Guardar</button>
					</div>
				</div>
			</form>
		</div>
	</div>

	<div class="modal fade" id="editCitaModal" tabindex="-1" role="dialog">
		<div class="modal-dialog modal-lg modal-dialog-centered" role="document">
			<form method="post" action="Paciente">
				<input type="hidden" name="action" value="update-cita">
				<input type="hidden" name="id" id="edit-cita-id" value="">
				<input type="hidden" name="idpaciente" value="{{ fsc.paciente.id }}">
				<div class="modal-content">
					<div class="modal-header">
						<h5 class="modal-title">Editar Cita</h5>
						<button type="button" class="close" data-dismiss="modal">
							<span>&times;</span>
						</button>
					</div>
					<div class="modal-body">
						<div class="row">
							<div class="col-md-4">
								<div class="form-group">
									<label>Especialista *</label>
									<select name="idespecialista" id="edit-cita-idespecialista" class="form-control" required>
										<option value="">Seleccionar...</option>
										{% for esp in fsc.especialistas %}
											<option value="{{ esp.id }}">{{ esp.nombre }}</option>
										{% endfor %}
									</select>
								</div>
							</div>
							<div class="col-md-4">
								<div class="form-group">
									<label>Gabinete *</label>
									<select name="idgabinete" id="edit-cita-idgabinete" class="form-control" required>
										<option value="">Seleccionar...</option>
										{% for gab in fsc.gabientes %}
											<option value="{{ gab.id }}">{{ gab.nombre }}</option>
										{% endfor %}
									</select>
								</div>
							</div>
							<div class="col-md-4">
								<div class="form-group">
									<label>Tratamiento</label>
									<select name="idtratamiento" id="edit-cita-idtratamiento" class="form-control">
										<option value="">Ninguno</option>
										{% for trat in fsc.tratamientos %}
											<option value="{{ trat.id }}">{{ trat.referencia_servicio }}</option>
										{% endfor %}
									</select>
								</div>
							</div>
						</div>
						<div class="row">
							<div class="col-md-3">
								<div class="form-group">
									<label>Fecha *</label>
