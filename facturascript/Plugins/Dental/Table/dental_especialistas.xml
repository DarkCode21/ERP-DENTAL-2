<?xml version="1.0" encoding="UTF-8"?>
<table>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>codusuario</name>
        <type>character varying(50)</type>
    </column>
    <column>
        <name>nombre</name>
        <type>character varying(100)</type>
        <null>NO</null>
    </column>
    <column>
        <name>apellidos</name>
        <type>character varying(100)</type>
        <null>NO</null>
    </column>
    <column>
        <name>numero_colegiado</name>
        <type>character varying(50)</type>
    </column>
    <column>
        <name>telefono</name>
        <type>character varying(20)</type>
    </column>
    <column>
        <name>email</name>
        <type>character varying(100)</type>
    </column>
    <column>
        <name>color_agenda</name>
        <type>character varying(7)</type>
        <default>'#3b82f6'</default>
    </column>
    <column>
        <name>salon_assistant_id</name>
        <type>integer</type>
    </column>
    <column>
        <name>estado</name>
        <type>character varying(20)</type>
        <default>'activo'</default>
    </column>
    <column>
        <name>observaciones</name>
        <type>text</type>
    </column>
    <column>
        <name>created_at</name>
        <type>timestamp</type>
        <default>current_timestamp</default>
    </column>
    <column>
        <name>updated_at</name>
        <type>timestamp</type>
        <default>current_timestamp</default>
    </column>
    <constraint>
        <name>dental_especialistas_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>dental_especialistas_fk_codusuario</name>
        <type>FOREIGN KEY (codusuario) REFERENCES users(nick) ON DELETE SET NULL</type>
    </constraint>
</table>
