    <column>
        <name>idmultiple</name>
        <type>integer</type>
    </column>
    <constraint>
        <name>ca_recibospagoscli_multiple_payments</name>
        <type>FOREIGN KEY (idmultiple) REFERENCES ppmm_customer_receipts (id) ON DELETE SET NULL ON UPDATE CASCADE</type>
