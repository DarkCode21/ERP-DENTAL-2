<view>
    <columns>
        <group name="multiple" numcolumns="12">
            <column name="wallet"  titleurl="ListCuenta" description="amount-to-wallet" order="100">
                <widget type="autocomplete" fieldname="codsubaccount_wallet">
                    <values source="subcuentas" fieldcode="codsubcuenta" fieldtitle="descripcion" />
                </widget>
            </column>
            <column name="difference" titleurl="ListCuenta" description="amount-to-difference" order="110">
                <widget type="autocomplete" fieldname="codsubaccount_difference">
                    <values source="subcuentas" fieldcode="codsubcuenta" fieldtitle="descripcion" />
                </widget>
            </column>
            <column name="payment" title="difference-payment" titleurl="ListCuenta" description="payment-to-difference" order="110">
                <widget type="autocomplete" fieldname="codsubaccount_payment">
                    <values source="subcuentas" fieldcode="codsubcuenta" fieldtitle="descripcion" />
                </widget>
            </column>
        </group>
    </columns>
</view>
