<view>
    <columns>
        <column name="id" display="none" order="100">
            <widget type="text" fieldname="id" />
        </column>
        <column name="multiple-payment" display="none" order="100">
            <widget type="text" fieldname="idmultiple" />
        </column>
        <column name="description" order="110">
            <widget type="text" fieldname="name" />
        </column>
        <column name="delivered" order="120">
            <widget type="date" fieldname="delivered" />
        </column>
        <column name="expiration" order="130">
            <widget type="date" fieldname="expiration" />
        </column>
        <column name="charged" order="130">
            <widget type="date" fieldname="charged" />
        </column>
        <column name="customer" order="150">
            <widget type="autocomplete" fieldname="idcustomer">
                <values source="clientes" fieldcode="codcliente" fieldtitle="nombre" />
            </widget>
        </column>
        <column name="total" order="160">
            <widget type="money" fieldname="total" />
        </column>
        <column name="subaccount" order="170">
            <widget type="autocomplete" fieldname="codsubaccount">
                <values source="subcuentas" fieldcode="codsubcuenta" />
            </widget>
        </column>
        <column name="bank-account" order="180">
            <widget type="select" fieldname="idbank" required="true">
                <values source="cuentasbanco" fieldcode="codcuenta" fieldtitle="descripcion" />
            </widget>
        </column>
    </columns>

    <rows>
        <row type="status" fieldname="status">
            <option color="warning" title="pending">10</option>
            <option color="danger" title="expired">20</option>
            <option color="white" title="charged">90</option>
        </row>
    </rows>
</view>