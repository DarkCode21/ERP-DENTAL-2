<view>
    <columns>
        <column name="code" order="100">
            <widget type="text" fieldname="id" />
        </column>
        <column name="company" order="110">
            <widget type="select" fieldname="idcompany">
                <values source="empresas" fieldcode="idempresa" fieldtitle="nombrecorto"></values>
            </widget>
        </column>
        <column name="agent" order="120">
            <widget type="select" fieldname="idagent">
                <values source="agentes" fieldcode="codagente" fieldtitle="nombre"></values>
            </widget>
        </column>
        <column name="serie" order="125">
            <widget type="text" fieldname="idserie" />
        </column>
        <column name="date" order="130">
            <widget type="date" fieldname="groupdate" />
        </column>
        <column name="bank-account" order="140">
            <widget type="select" fieldname="idbank" required="true">
                <values source="cuentasbanco" fieldcode="codcuenta" fieldtitle="descripcion" />
            </widget>
        </column>
        <column name="receipts" order="150">
            <widget type="number" fieldname="receipts" decimal="0" />
        </column>
        <column name="total" order="160">
            <widget type="money" fieldname="total" />
        </column>
    </columns>

    <rows>
        <row type="status" fieldname="status">
            <option color="warning" title="pending">0</option>
            <option color="white" title="approved">1</option>
        </row>
    </rows>
</view>