<table>
    <column>
        <name>charged</name>
        <type>date</type>
    </column>

    <column>
        <name>codsubaccount</name>
        <type>character varying(15)</type>
    </column>

    <column>
        <name>delivered</name>
        <type>date</type>
    </column>

    <column>
        <name>expiration</name>
        <type>date</type>
    </column>

    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>

    <column>
        <name>idbank</name>
        <type>character varying(10)</type>
    </column>

    <column>
        <name>idcustomer</name>
        <type>character varying(10)</type>
    </column>

    <column>
        <name>identry</name>
        <type>integer</type>
    </column>

    <column>
        <name>idmultiple</name>
        <type>integer</type>
    </column>

    <column>
        <name>name</name>
        <type>character varying(30)</type>
        <null>NO</null>
    </column>

    <column>
        <name>total</name>
        <type>double precision</type>
        <default>0</default>
    </column>

    <constraint>
        <name>ppmm_customer_bankchecks_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>ca_ppmm_customer_bankchecks_cuentasbanco</name>
        <type>FOREIGN KEY (idbank) REFERENCES cuentasbanco (codcuenta) ON DELETE SET NULL ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_ppmm_customer_bankchecks_clientes</name>
        <type>FOREIGN KEY (idcustomer) REFERENCES clientes (codcliente) ON DELETE SET NULL ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_ppmm_customer_bankchecks_entry</name>
        <type>FOREIGN KEY (identry) REFERENCES asientos (idasiento) ON DELETE SET NULL ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_ppmm_customer_bankchecks_multiple</name>
        <type>FOREIGN KEY (idmultiple) REFERENCES ppmm_customer_receipts (id) ON DELETE RESTRICT ON UPDATE CASCADE</type>
    </constraint>
</table>
