<view>
    <columns>
        <column name="id" order="100">
            <widget type="text" fieldname="id"/>
        </column>
        <column name="codcuenta" title="account-code" order="110">
            <widget type="text" fieldname="codcuenta"/>
        </column>
        <column name="amount" display="right" order="120">
            <widget type="number" fieldname="amount"/>
        </column>
        <column name="date" order="130">
            <widget type="date" fieldname="date"/>
        </column>
        <column name="reconciled" display="center" order="140">
            <widget type="checkbox" fieldname="reconciled"/>
        </column>
        <column name="observations" display="left" order="150">
            <widget type="textarea" fieldname="observations"/>
        </column>
        <column name="creation-date" display="none" order="160">
            <widget type="datetime" fieldname="creationdate"/>
        </column>
        <column name="user" display="none" order="170">
            <widget type="text" fieldname="nick"/>
        </column>
        <column name="last-update" display="none" order="180">
            <widget type="datetime" fieldname="lastupdate"/>
        </column>
        <column name="last-user" display="none" order="190">
            <widget type="text" fieldname="lastnick"/>
        </column>
    </columns>
    <modals>
        <group name="upload-banking-movements" title="import-banking-movements" icon="fas fa-file-import">
            <column name="file" numcolumns="12" order="100">
                <widget type="file" fieldname="bankingmovementsfile" accept=".csv,.ods,.xls,.xlsx" required="true"/>
            </column>
            <column name="template" numcolumns="12" order="110">
                <widget type="select" fieldname="template" required="true">
                    <values/>
                </widget>
            </column>
            <column name="import-mode" numcolumns="12" order="120">
                <widget type="select" fieldname="mode" translate="true" required="true">
                    <values title="default">automatic</values>
                    <values title="only-insert">insert</values>
                    <values title="only-update">update</values>
                    <values title="insert-update">insert-update</values>
                </widget>
            </column>
        </group>
    </modals>
    <rows>
        <row type="status">
            <option color="success" fieldname="amount" title="sales">gt:0</option>
            <option color="danger" fieldname="amount" title="purchases">lt:0</option>
        </row>
    </rows>
</view>
