<table>
    <column>
        <name>amount</name>
        <type>double precision</type>
        <null>NO</null>
    </column>
    <column>
        <name>codcuenta</name>
        <type>character varying(10)</type>
        <null>NO</null>
    </column>
    <column>
        <name>creationdate</name>
        <type>timestamp</type>
        <null>NO</null>
    </column>
    <column>
        <name>date</name>
