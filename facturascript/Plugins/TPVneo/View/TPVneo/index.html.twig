        function saveAddCustomer() {
            let razonsocial = $('#modalAddCustomer input[name="razonsocial"]').val();
            let cifnif = $('#modalAddCustomer input[name="cifnif"]').val();
            let address = $('#modalAddCustomer input[name="address"]').val();
            let apartado = $('#modalAddCustomer input[name="apartado"]').val();
            let codpostal = $('#modalAddCustomer input[name="codpostal"]').val();
            let ciudad = $('#modalAddCustomer input[name="ciudad"]').val();
            let provincia = $('#modalAddCustomer input[name="provincia"]').val();
            let telefono1 = $('#modalAddCustomer input[name="telefono1"]').val();
            let email = $('#modalAddCustomer input[name="email"]').val();
            let personafisica = $('#modalAddCustomer select[name="personafisica"] option:selected').val();
            let tipoidfiscal = $('#modalAddCustomer select[name="tipoidfiscal"] option:selected').val();
            let codpais = $('#modalAddCustomer select[name="codpais"] option:selected').val();

            let formData = new FormData();
            formData.append('action', 'add-customer');
            formData.append('empresa', razonsocial);
            formData.append('cifnif', cifnif);
            formData.append('direccion', address);
            formData.append('apartado', apartado);
            formData.append('codpostal', codpostal);
            formData.append('ciudad', ciudad);
            formData.append('provincia', provincia);
            formData.append('telefono1', telefono1);
            formData.append('email', email);
            formData.append('personafisica', personafisica);
            formData.append('tipoidfiscal', tipoidfiscal);
            formData.append('codpais', codpais);
            return sendForm(formData);
        }

        function saveCart() {
            document.forms['saleForm']['action'].value = 'save-cart';
            document.forms['saleForm']['action-code'].value = '';

            let formData = new FormData(document.forms['saleForm']);
            formData.append('observations', $('#modalColletMoney #observations').val());
            let moneyReceived = 0;
            let formasPagos = 0;

            $("#modalColletMoney #paymentMethods input").each(function () {
                let money = parseFloat($(this).val());
                if (money > 0) {
                    formasPagos++;
                    moneyReceived += money;
                    formData.append($(this).attr('codpago'), money);
                }
            });

            let decimals = totalCart.split('.');
            if (moneyReceived.toFixed(decimals.length) >= parseFloat(totalCart)) {
                formData.append('formasPagos', formasPagos);
                if (codpark != '') {
                    document.forms['saleForm']['codpark'].value = codpark;
                    formData.append('codpark', codpark);
                }
                return sendForm(formData);
            }

            return false;
        }

        function savePark() {
            if (totalCart <= 0) {
                return false;
            }

            document.forms['saleForm']['action'].value = 'save-park';
            document.forms['saleForm']['action-code'].value = '';
            if (codpark !== '') {
                document.forms['saleForm']['codpark'].value = codpark;
            }
            let formData = new FormData(document.forms['saleForm']);
            formData.append('advance-payment-amount', $('#modalPark #amount').val());
            formData.append('advance-payment', $('#modalPark #payments option:selected').val());
            formData.append('observations', $('#modalPark #observations').val());
            return sendForm(formData);
        }

        function saveReturn() {
            let formData = new FormData();
            let cont = 0;
            $('#modalReturn #productsReturn tbody tr').each(function () {
                let val = parseFloat($(this).find('input').val());

                if (val > 0) {
                    formData.append('referencia_' + cont, $(this).attr('referencia'));
                    formData.append('idlinea_' + cont, $(this).attr('idlinea'));
                    formData.append('cantidad_' + cont, val);
                    cont++;
                }
            });
            formData.append('action', 'save-return');
            formData.append('lines', cont);
            formData.append('idDocReturn', idDocReturn);
            return sendForm(formData);
        }

        function searchProducts() {
            document.forms['productsForm']['productlimit'].value = 0;
            let formData = new FormData(document.forms['productsForm']);
            return sendForm(formData);
        }

        function searchTickets(codigo = '') {
            $('#listTickets tbody').html('<i class="fas fa-spinner fa-spin"></i>');
            let formData = new FormData();
            formData.append('action', 'modal-tickets');
            formData.append('codigo', codigo);
            return sendForm(formData);
        }

        function sendDoc(idDoc) {
            let formData = new FormData();
            formData.append('action', 'send-doc');
            formData.append('idDoc', idDoc);
            formData.append('email', $('#modalPrintTicket #emailInput').val());
            return sendForm(formData);
        }

        function sendForm(formData) {
            if (editLine > 1) {
                editLine--;
                return false;
            }

            editLine = 0;
            animateSpinner('add');

            formData.append('linesCart', $('#linesCart .line').length);
            formData.append('codcliente', codcliente);
            formData.append('idtpv', {{ fsc.tpv.idtpv }});
            formData.append('idcaja', {{ fsc.caja.idcaja }});
            formData.append('ajax', true);

            console.log(Object.fromEntries(formData));

            fetch('{{ fsc.url() }}', {
                method: 'POST',
                body: formData
            }).then(function (response) {
                if (response.ok) {
                    animateSpinner('remove', true);
                    return response.json();
                }

                animateSpinner('remove', false);
                return Promise.reject(response);
            }).then(function (data) {
                console.log(data);

                if (data.refresh) {
                    $('#btnChangeTerminal').click();
                }

                if (['add-product', 'new-line'].includes(formData.get('action'))) {
                    $('.modalProductInfo').modal('hide');
                    $("#saleDiv").animate({ scrollTop: $('#saleDiv').prop("scrollHeight")}, 1000);
                }

                if (formData.get('action') === 'delete-park') {
                    modalListPark();
                    $('#deletePark').modal('hide');
                    $('#btnPark span.badge').html(data.totalParks);

                    if (parseInt(formData.get('codpark')) === parseInt(codpark)) {
                        codpark = '';
                        document.forms['saleForm']['codpark'].value = codpark;
                    }
                }
				
				// INI MOD ERICK
				if (formData.get('action') === 'verify-barcode') {
					console.log('ref', data.referencia);
					if (data.referencia != null) {
						return addProduct(data.referencia);
					}
				}
				// FIN MOD ERICK
                if (formData.get('action') === 'load-park') {
                    $('#modalListPark').modal('hide');

                    // cargamos los pagos anticipados
                    collectMoneyClear();
                    $.each(data['advance-payments'], function (key, value) {
                        $('#modalColletMoney #paymentMethods input[codpago="' + value.codpago + '"]').val(value.amount);
                    });
                }

                if (formData.get('action') === 'modal-list-park') {
                    $('#modalListPark').modal('show');
                }

                if (formData.get('action') === 'save-park') {
                    $('#modalPark').modal('hide');
                }

                if (formData.get('action') === 'modal-tickets') {
                    $('#modalTickets').modal('show');
                    $('#modalTickets #boxEstimated').html(data.boxEstimated);
                    $('#modalTickets #boxIncomesManual').html(data.boxIncomesManual);
                    $('#modalTickets #boxOutcomesManual').html(data.boxOutcomesManual);
                    $('#modalTickets #boxTotal').html(data.boxTotal);
                }

                if (['open-drawer', 'print-ticket'].includes(formData.get('action'))) {
                    $('#modalPrintTicket #iframe').html('<iframe class="d-none" src="http://localhost:8089"></iframe>');
                }

                if (data.totalCart) {
                    totalCart = data.totalCart;

                    if (data.totalCart > 0) {
                        $('#saleAmount').popover('show');
						$('#btnSaleFooter').show(); //MOD ERICK
                        setInterval(function () {
                            $('#saleAmount').popover('hide');
                        }, 2000);
                    } else if (formData.get('action') !== 'recalculate' && formData.get('action') !== 'load-park') {
                        $('#btnSaleFooter').hide();
                        $('#products-tab').click();
                    }
                }

                if (data.amount && data.amount !== '' && data.amount !== document.getElementById("saleAmount").innerHTML) {
                    document.getElementById("saleAmount").innerHTML = data.amount;
                }

                if (data.cart && data.cart !== '') {
                    document.getElementById("saleDiv").innerHTML = data.cart;
                    if ($('#linesCart .line').length > 0) {
                        $('#btnSaleFooter').show();
                    }
                } else if (data.cartMap && !data.cartMap.length) {
                    $.each(data.cartMap, function (index, value) {
                        $('#saleDiv').find('#' + index).html(value);
                    });
                }

                if (formData.get('action') === 'new-line') {
                    $('#linesCart .line:last input.precio').val('').focus();
                }

                if (data.products && data.products !== '') {
                    document.getElementById("productList").innerHTML = data.products;
                    heightProductCard();
                }

                if (data.savecart) {
                    $('#modalColletMoney').modal('hide');
                    collectMoneyClear();
                    if (false === openInvoiceForGeneralSeries(data.document)) {
                        btnPrintAuto(data.document.code);
                    }
                    $('#btnPark span.badge').html(data.totalParks);
                }

                if (data.savereturn) {
                    $('#modalReturn').modal('hide');
                    btnPrintAuto(data.document.code);
                }

                if (data.savepark || data.savecart || data.clearcart) {
                    searchProducts();
                    $('#btnSaleFooter').hide();
                    $('#products-tab').click();
                }
				
                if (data.savecart && codpark !== '' || $('#linesCart .line').length === 0 && codpark !== '') {
                    codpark = '';
                }

                if (data.savepark) {
                    $('#btnPark button').popover('show');
                    setInterval(function () {
                        $('#btnPark button').popover('hide');
                    }, 2000);
                    $('#btnPark span.badge').html(data.totalParks);
                }

                if (data.codpark && data.codpark !== '') {
                    codpark = data.codpark;
                }

                if (data.presupuestos && data.presupuestos !== '') {
                    $('#listPark tbody').html(data.presupuestos);
                }

                if (data.tickets && data.tickets !== '') {
                    $('#listTickets tbody').html(data.tickets);
                }

                if (data.docprint && data.docprint !== '') {
                    $('#modalPrintTicket #optsPrint').html(data.docprint);
					addPeviewPrintAutomatic();					
                }

				// INI MOD ERICK
				if (data.docpreviewprint && data.docpreviewprint !== '') {
                    $('#modalPrintPreviewTicket #optsPrint').html(data.docpreviewprint);
				    $('#modalPrintPreviewTicket #previewPDF').html(data.docprintPDF);
					
					addPrintAutomatic();
		        }
				// FIN MOD ERICK

                if (formData.get('action') === 'preview-escpos-ticket') {
                    if (data.html) {
                        $('#escposPreviewContent').html(data.html);
                    } else {
                        $('#escposPreviewContent').html('<p class="text-danger">Error al generar la vista previa.</p>');
                    }
                }
				
                if (data.docreturn && data.docreturn !== '') {
                    $('#modalReturn #productsReturn').html(data.docreturn);
                    $('#modalReturn #methodReturn').html(data.methodreturn);

                    totalReturn = 0;
                    idDocReturn = data.idDoc;
                    $('#modalReturn #totalReturn .money').html(totalReturn.toFixed(2));
                    $('#modalReturn #optsReturn').show();
                }

                if (formData.get('action') === 'add-customer' && data.customer) {
                    codcliente = data.customer.codcliente;
                    $('#customertpv').val(data.customer.nombre);
                    $('#saleDiv input[name="codcliente"]').val(codcliente);
                    $('#iconCustomerSearch').removeClass('fa-search').addClass('cursor-pointer fa-times text-danger');
                    changeClient();
                    $('#modalAddCustomer').modal('hide');
                }

                document.forms['productsForm']['productlimit'].value = {{ fsc.tpv.productlimit }};

                // si no hay foco, establecemos el foco si tenemos el name del input donde se estaba escribiendo
                if (formData.get('action') === 'recalculate-line' && document.activeElement.name === undefined && keyupInputName !== null) {
                    let focusInput = $('input[name="' + keyupInputName + '"]');
                    let focusLength = focusInput.val().length;
                    let focusType = focusInput[0].type;
                    // para establecer el cursor al final de input el type debe ser text
                    if (focusType !== 'text') {
                        focusInput[0].type = 'text';
                    }
                    focusInput.focus();
                    focusInput[0].setSelectionRange(focusLength, focusLength);
                    focusInput[0].type = focusType;
                    keyupInputName = null;
                }

                if (Array.isArray(data.messages)) {
                    data.messages.forEach(item => alert(item.message));
                }
            }).catch(function (error) {
                alert('error');
                console.warn(error);
            });

            return false;
        }

        function showFamily(codfamilia) {
            document.forms['productsForm']['codfamilia'].value = codfamilia;
            document.forms['productsForm']['query'].value = '';
            let formData = new FormData(document.forms['productsForm']);
            return sendForm(formData);
        }

        $(document).on('keyup', '#linesCart .line input', async function () {
            let min = parseFloat($(this).attr('min'));
            let max = parseFloat($(this).attr('max'));
            let val = parseFloat($(this).val());
            console.log(min, max, val);
            if (val < min) {
                $(this).val(min);
            }

            if (val > max) {
                $(this).val(max);
            }

            // usamos un contador y un temporizador para solamente procesar la última llamada
            waitCounter++;
            let waitNum = waitCounter;
            await new Promise(r => setTimeout(r, 300));
            if (waitNum < waitCounter) {
                return;
            }

            // obtenemos el name del input si cumple la condición de pulsado
            keyupInputName = $(this).attr('name');

            editLine++;
            document.forms['saleForm']['action'].value = 'recalculate-line';
            let formData = new FormData(document.forms['saleForm']);
            sendForm(formData);
        });

        $(document).on('keyup', '#modalColletMoney #paymentMethods input', function () {
            checkTotalPayments($(this));
        });

        $(document).on('click', '#modalColletMoney #paymentMethods .setMaxPayment', function(){
            let input = $(this).parent().parent().find('input');
            let defaultPay = $('#paymentMethods input:first').val();

            if (defaultPay === '') {
                defaultPay = 0;
            }

            let diff = parseFloat($(input).attr('max')) - parseFloat(defaultPay);

            if (diff <= 0) {
                return;
            }

            $(input).val(diff.toFixed(2));
            checkTotalPayments(input);
        });

        $(document).on('keyup change', '#modalReturn #productsReturn tbody tr input', function () {
            let max = parseFloat($(this).attr('max'));
            let val = parseFloat($(this).val());

            if (val > max) {
                $(this).val(max);
            }

            totalReturn = 0;
            $('#modalReturn #productsReturn tbody tr').each(function () {
                let input = $(this).find('input');

                if (parseFloat($(input).val()) > 0) {
                    totalReturn += parseFloat($(input).val()) * parseFloat($(this).attr('pvpunitario'));
                }
            });

            $('#modalReturn #totalReturn .money').html(totalReturn.toFixed(2));
        });

        $(document).on('keyup change', '#searchTicket', function () {
            let val = $(this).val();
            if (val.length >= 3) {
                return searchTickets(val);
            } else if (val === '') {
                return searchTickets();
            }
        });

        $(document).ready(function () {
            $('#btnSaleFooter').hide();
            let changeAgentTime = parseInt({{ fsc.tpv.closeagent }});

            if (changeAgentTime > 0) {
                let intervalCloseAgent;

                function startCounter() {
                    intervalCloseAgent = setInterval(function () {
                        window.location.href = '{{ fsc.url() }}?action=agent-out';
                    }, changeAgentTime * 60000);
                }

                startCounter();

                function stopCounter() {
                    clearInterval(intervalCloseAgent);
                    startCounter();
                }

                $(document).mousemove(function (e) {
                    stopCounter();
                });

                $(document).click(function (e) {
                    stopCounter();
                });

                $(document).keypress(function (e) {
                    stopCounter();
                });
            }

            function widthCart() {
                let parentDiv = $('#cart').parent().width();
                $('#cart').css({'width': '100%', 'max-width': parentDiv + 'px'});
            }
            widthCart();

            let observerCart = new IntersectionObserver(function(entries) {
                if(entries[0]['isIntersecting'] === true) {
                    if (entries[0].intersectionRatio >= 0.5) {
                        $('#floatCart').hide('slow');
                    } else {
                        $('#floatCart').show('slow');
                    }
                } else {
                    $('#floatCart').show('slow');
                }
            }, { threshold: [0, 0.5, 1] });
            observerCart.observe(document.querySelector("#cart"));

            $('#floatCart').click(function () {
                $('html,body').animate({
                    scrollTop: $('#cart').offset().top
                }, 'slow');
            });

            $('#saleAmount').popover({
                placement: 'bottom',
                trigger: 'manual',
                content: '{{ i18n.trans('updated-cart') }}'
            });

            $('#btnPark button').popover({
                placement: 'bottom',
                trigger: 'hover manual',
                content: '{{ i18n.trans('cart-parking') }}'
            });

            $('#saleAmount').click(function () {
                $('#saleAmount').popover('hide');
            });

            $('#iconCustomerSearch').click(function () {
                if ($("#customertpv").val() != '') {
                    $('#iconCustomerSearch').removeClass('cursor-pointer fa-times text-danger').addClass('fa-search');
                    $("#customertpv").val('');
                    codcliente = '';
                    changeClient();
                }
            });

            $("#customertpv").autocomplete({
                source: function (request, response) {
                    let formData = {};
                    formData["action"] = "autocomplete-customer";
                    formData["query"] = $("#customertpv").val();
                    formData["idcaja"] = '{{ fsc.caja.idcaja }}';
                    formData["idtpv"] = '{{ fsc.tpv.idtpv }}';
                    formData["ajax"] = true;

                    $.ajax({
                        method: "POST",
                        url: "{{ fsc.url() }}",
                        data: formData,
                        dataType: "json",
                        success: function (results) {
                            if (results.refresh) {
                                $('#btnChangeTerminal').click();
                            }

                            let values = [];
                            results.forEach(function (element) {
                                if (element.key === null || element.key === element.value) {
                                    values.push(element);
                                } else {
                                    values.push({key: element.key, value: element.key + " | " + element.value});
                                }
                            });
                            response(values);
                        },
                        error: function (msg) {
                            alert(msg.status + " " + msg.responseText);
                        }
                    });
                },
                select: function (event, ui) {
                    if (ui.item.key !== null) {
                        codcliente = ui.item.key;
                        $('#iconCustomerSearch').removeClass('fa-search').addClass('cursor-pointer fa-times text-danger');
                        changeClient();
                        let value = ui.item.value.split(" | ");
                        if (value.length > 1) {
                            ui.item.value = value[1];
                        } else {
                            ui.item.value = value[0];
                        }
                    }
                }
            });

            heightProductCard();
            heightCart();
        });
    </script>
