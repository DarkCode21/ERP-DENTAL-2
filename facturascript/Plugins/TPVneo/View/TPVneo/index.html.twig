{% block body %}
    {{ parent() }}
    <style>
        /* Ocultar flechas en inputs number para Chrome, Safari, Edge */
        input[type="number"]::-webkit-outer-spin-button,
        input[type="number"]::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        /* Ocultar flechas en inputs number para Firefox */
        input[type="number"] {
            -moz-appearance: textfield;
            appearance: textfield;
        }

        /* Opcional: Estilos específicos para los inputs de precio y descuento */
        .precio::-webkit-outer-spin-button,
        .precio::-webkit-inner-spin-button,
        .descuento::-webkit-outer-spin-button,
        .descuento::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        .precio,
        .descuento {
            -moz-appearance: textfield;
            appearance: textfield;
        }

        /* CSS para productos responsive personalizado */
        .product-card {
            flex: 0 0 50%;
            max-width: 50%;
            padding: 0 7.5px;
            margin-bottom: 15px;
        }

        /* Hacer que todas las tarjetas tengan la misma altura */
        .product-card .card {
            height: 200px !important; /* Altura fija para todas las tarjetas */
            display: flex !important;
            flex-direction: column !important;
        }

        /* Móviles pequeños */
        @media (min-width: 576px) {
            .product-card {
                flex: 0 0 33.333333%;
                max-width: 33.333333%;
            }
        }

        /* Tablets */
        @media (min-width: 768px) {
            .product-card {
                flex: 0 0 25%;
                max-width: 25%;
            }
        }

        /* Laptops medianas (1024px-1399px) - 5 productos */
        @media (min-width: 1024px) and (max-width: 1399px) {
            .product-card {
                flex: 0 0 20%;
                max-width: 20%;
            }
        }

        /* Pantallas grandes (1400px+) - 5 productos */
        @media (min-width: 1400px) {
            .product-card {
                flex: 0 0 20%;
                max-width: 20%;
            }
        }

        #linesCart {
            max-height: calc(100vh - 400px); /* Ajusta según el espacio que necesites para los botones */
            overflow-y: auto;
            overflow-x: hidden;
        }
        
        /* Asegurar que el carrito no se expanda más allá del contenedor */
        .col-lg-5, .col-xl-5 {
            display: flex;
            flex-direction: column;
            max-height: 100vh;
        }
        
        /* Hacer que los botones del carrito siempre sean visibles - SOLO para el formulario saleForm */
        form[name="saleForm"] + .card-footer,
        #saleForm .card-footer,
        .carrito-container .card-footer {
            position: sticky;
            bottom: 0;
            background: white;
            z-index: 10;
            border-top: 1px solid #dee2e6;
            padding: 15px 0;
        }
        
        /* Mejorar el scroll en dispositivos móviles */
        #linesCart::-webkit-scrollbar {
            width: 6px;
        }
        
        #linesCart::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }
        
        #linesCart::-webkit-scrollbar-thumb {
            background: #888;
            border-radius: 10px;
        }
        
        #linesCart::-webkit-scrollbar-thumb:hover {
            background: #555;
        }

        @media (min-width: 1441px) {
            .col-xl-5 {
                flex: 0 0 33.333333% !important;
                max-width: 33.333333% !important;
            }
        }
        
        /* Ajustar también la columna de productos para compensar */
        @media (min-width: 1441px) {
            .col-xl-7 {
                flex: 0 0 66.666667% !important;
                max-width: 66.666667% !important;
            }
        }

        /* Columnas personalizadas: productos ~55%, carrito ~45% */
        @media (min-width: 992px) {
            .col-productos {
                flex: 0 0 55% !important;
                max-width: 55% !important;
            }
            .col-carrito {
                flex: 0 0 45% !important;
                max-width: 45% !important;
            }
        }
