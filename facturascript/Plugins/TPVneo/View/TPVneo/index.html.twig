            if ($('#linesCart .line').length > 0) {
                $('#modalColletMoney #moneyTotal').html($('#saleAmount').html());
                $('#modalColletMoney #moneyChange').html('');
                $('#modalColletMoney #symbolChange').html('');

                $("#modalColletMoney #paymentMethods input").each(function () {
                    if ($(this).attr('codpago') !== '{{ fsc.tpv.codpago }}') {
                        $(this).attr('max', totalCart);
                    }
                    checkTotalPayments($(this));
                });

                $('#modalColletMoney').modal('show');
                $('#modalColletMoney').on('shown.bs.modal', function () {
                    $('#modalColletMoney #paymentMethods input:first').focus();
                });
            }
        }

