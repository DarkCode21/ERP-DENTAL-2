            $('#modalEscposPreview').modal('hide');
            if (idDoc) {
                return btnPrintTicket(idDoc);
            }
        }

        function printEscposDirect(idDoc, relayUrl) {
            console.log('[ESC/POS] printEscposDirect idDoc=', idDoc, 'relayUrl=', relayUrl);
            let formData = new FormData();
            formData.append('action', 'print-escpos-direct');
            formData.append('idDoc', idDoc);
            formData.append('idtpv', {{ fsc.tpv.idtpv }});
            formData.append('idcaja', {{ fsc.caja.idcaja }});
            formData.append('ajax', true);
            fetch('{{ fsc.url() }}', {method: 'POST', body: formData})
                .then(function(r) { return r.json(); })
                .then(function(d) {
                    console.log('[ESC/POS] respuesta PHP:', d);
                    if (!d.ok || !d.buffer) {
                        console.warn('[ESC/POS] sin buffer, abortando');
                        var toast = document.createElement('div');
                        toast.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#c0392b;color:#fff;padding:8px 20px;border-radius:6px;font-size:14px;z-index:9999;box-shadow:0 2px 8px rgba(0,0,0,.25);';
                        toast.textContent = 'Error: No se pudo generar el ticket';
                        document.body.appendChild(toast);
                        setTimeout(function(){ toast.remove(); }, 6000);
                        return;
                    }
                    var payload = {buffer: d.buffer};
                    if (d.tipo === 'usb') { payload.usb = d.usb; }
                    else { payload.ip = d.ip; payload.port = d.port; }
                    console.log('[ESC/POS] enviando a relay:', relayUrl, 'payload keys:', Object.keys(payload));
                    return fetch(relayUrl, {
                        method: 'POST',
                        headers: {'Content-Type': 'application/json'},
                        body: JSON.stringify(payload)
                    }).then(function(r) { return r.json(); })
                      .then(function(rd) {
                          console.log('[ESC/POS] relay respuesta:', rd);
                          if (rd && rd.ok) {
                              var toast = document.createElement('div');
                              toast.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#27ae60;color:#fff;padding:8px 20px;border-radius:6px;font-size:14px;z-index:9999;box-shadow:0 2px 8px rgba(0,0,0,.25);';
                              toast.textContent = 'Enviado a impresora';
                              document.body.appendChild(toast);
                              setTimeout(function(){ toast.remove(); }, 3000);
                          } else {
                              var toast = document.createElement('div');
                              toast.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#c0392b;color:#fff;padding:8px 20px;border-radius:6px;font-size:14px;z-index:9999;box-shadow:0 2px 8px rgba(0,0,0,.25);';
                              toast.textContent = 'Relay error: ' + (rd.error || 'Verifique conexión');
                              document.body.appendChild(toast);
                              setTimeout(function(){ toast.remove(); }, 6000);
                          }
                      });
                })
                .catch(function(e) {
                    console.error('[ESC/POS] error:', e);
                    var toast = document.createElement('div');
                    toast.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#c0392b;color:#fff;padding:8px 20px;border-radius:6px;font-size:14px;z-index:9999;box-shadow:0 2px 8px rgba(0,0,0,.25);';
                    toast.textContent = 'No se pudo conectar con el relay: ' + e.message;
                    document.body.appendChild(toast);
                    setTimeout(function(){ toast.remove(); }, 6000);
                });
        }

        function btnPrintTicket(idDoc) {
            var btn = document.querySelector('.btnPrintTicket[onclick*="' + idDoc + '"]');
            var escposTipo = btn ? (btn.dataset.escposTipo || '') : '';
            var relayUrl   = btn ? (btn.dataset.escposRelay || '') : '';
            console.log('[ESC/POS] btnPrintTicket idDoc=', idDoc, 'escposTipo=', escposTipo, 'relayUrl=', relayUrl);
            if (escposTipo !== '') {
                return printEscposDirect(idDoc, relayUrl);
