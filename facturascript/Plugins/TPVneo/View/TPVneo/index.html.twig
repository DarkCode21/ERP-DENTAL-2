        function changeLineDescription(num) {
            let desc = prompt('{{ i18n.trans('description') }}');
            if (desc.trim() === '') {
                return false;
            }

            $('#linesCart .line' + num + ' .desc').html(desc);
            $('#linesCart .line' + num + ' input[name="descripcion_' + num + '"]').val(desc);
        }

        function checkTotalPayments(input) {
            let total = 0;
            let cont = 0;
            let totalDefault = 0;
            let totalLine = 0;

            if (input.attr('max') !== '' && parseFloat(input.val()) > parseFloat(input.attr('max'))) {
                input.val('');
            }

            $("#modalColletMoney #paymentMethods input").each(function () {
                if ($(this).val() !== '') {
                    let value = parseFloat($(this).val());

                    if ($(this).attr('max') === '') {
                        totalDefault = value;
                    } else {
                        totalLine += value;
                    }
                }
            });

            if (totalLine > 0 && parseFloat((totalDefault + totalLine).toFixed(2)) > parseFloat(totalCart)) {
                input.val('');
            }

            $("#modalColletMoney #paymentMethods input").each(function () {
                if ($(this).val() !== '') {
                    total += parseFloat($(this).val());
                    cont++;
                }
            });

            if (total === 0) {
                $('#modalColletMoney #moneyChange, #modalColletMoney #symbolChange').html('');
            } else {
                let amount = $('#saleAmount').html().split(' ');
                $('#modalColletMoney #moneyChange').html((total - totalCart).toFixed(2));
                $('#modalColletMoney #symbolChange').html(amount[1]);
            }
        }

        function clearCart() {
            codpark = '';
            document.forms['saleForm']['action'].value = 'clear-cart';
            document.forms['saleForm']['action-code'].value = '';
            let formData = new FormData(document.forms['saleForm']);
            return sendForm(formData);
