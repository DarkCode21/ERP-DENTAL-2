<view>
    <columns>
        <group name="coins" numcolumns="12">
            <column name="code" display="none" order="0">
                <widget type="text" fieldname="idcoin"/>
            </column>
            <column name="currency" display="none" order="0">
                <widget type="text" fieldname="coddivisa"/>
            </column>
            <column name="name" order="100">
                <widget type="number" min="0" decimal="2" fieldname="name" required="true"/>
            </column>
        </group>
    </columns>
</view>
