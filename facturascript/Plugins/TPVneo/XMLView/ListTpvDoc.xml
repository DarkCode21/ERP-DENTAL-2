<view>
    <columns>
        <column name="idalbaran" display="none" order="90">
            <widget type="text" fieldname="idalbaran"/>
        </column>
        <column name="idfactura" display="none" order="90">
            <widget type="text" fieldname="idfactura"/>
        </column>
        <column name="company" display="none" order="100">
            <widget type="select" fieldname="idempresa">
                <values source="empresas" fieldcode="idempresa" fieldtitle="nombrecorto"/>
            </widget>
        </column>
        <column name="code" order="110">
            <widget type="text" fieldname="codigo"/>
        </column>
        <column name="number2" order="120">
            <widget type="text" fieldname="numero2"/>
        </column>
        <column name="customer" order="130">
            <widget type="text" fieldname="nombrecliente"/>
        </column>
        <column name="agent" order="140">
            <widget type="autocomplete" fieldname="codagente" onclick="EditAgente">
                <values source="agentes" fieldcode="codagente" fieldtitle="nombre"/>
            </widget>
        </column>
        <column name="method-payment" order="150">
            <widget type="select" fieldname="codpago">
                <values source="formaspago" fieldcode="codpago" fieldtitle="descripcion"/>
            </widget>
        </column>
        <column name="total" display="right" order="160">
            <widget type="money" fieldname="total">
                <option color="danger">lt:0</option>
            </widget>
        </column>
        <column name="expiration" display="right" order="170">
            <widget type="date" fieldname="finoferta"/>
        </column>
        <column name="date" display="right" order="180">
            <widget type="date" fieldname="fecha"/>
        </column>
        <column name="observations" order="190">
            <widget type="text" fieldname="observaciones"/>
        </column>
    </columns>
</view>