{% for item in getIncludeViews('PortalAccount', 'passwordBefore') %}
    {% include item['path'] %}
{% endfor %}

<div class="card shadow-sm mb-3">
    <div class="card-header">
        <h2 class="h5 mb-0">
            <i class="fas fa-edit fa-fw"></i> {{ trans('edit-account') }}
        </h2>
    </div>
    <div class="card-body">
        <form method="post" onsubmit="animateSpinner('add')">
            {{ formToken() }}
            <input type="hidden" name="action" value="edit-account"/>
            <input type="hidden" name="idcontacto" value="{{ fsc.contact.idcontacto }}"/>
            <div class="form-row flex">
                <div class="col-sm-auto align-self-center">
                    <div class="form-group">
                        {{ trans('language') }}
                        <select class="form-control" name="langcode">
                            <option value="">------</option>
                            {% for item in fsc.languages() %}
                                <option value="{{ item.value }}" {{ item.value is same as(fsc.contact.langcode) ? 'selected' : '' }}>{{ item.title }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
                <div class="col-sm align-self-center">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="admitemarketing" value="1"
                               id="admitemarketing"
                                {{ fsc.contact.admitemarketing ? 'checked' : '' }}>
                        <label class="form-check-label" for="admitemarketing">
                            {{ trans('allow-marketing') }}
                        </label>
                    </div>
                </div>
                <div class="col-sm-auto align-self-center">
                    <button type="submit" class="btn btn-primary btn-spin-action">
                        {{ trans('save') }}
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card border-warning shadow-sm mb-3">
    <div class="card-header">
        <h2 class="h5 mb-0">
            <i class="fas fa-key fa-fw"></i> {{ trans('new-password') }}
        </h2>
    </div>
    <div class="card-body">
        <form method="post" onsubmit="animateSpinner('add')">
            {{ formToken() }}
            <input type="hidden" name="action" value="edit-password"/>
            <input type="hidden" name="idcontacto" value="{{ fsc.contact.idcontacto }}"/>
            <div class="form-row">
                <div class="col-sm">
                    <div class="form-group">
                        <input class="form-control" type="password" name="new_password"
                               placeholder="{{ trans('new-password') }}"/>
                    </div>
                </div>
                <div class="col-sm">
                    <div class="form-group">
                        <input class="form-control" type="password" name="repeat_password"
                               placeholder="{{ trans('repeat-password') }}"/>
                    </div>
                </div>
                <div class="col-sm-auto">
                    <button type="submit" class="btn btn-warning btn-spin-action">
                        {{ trans('save') }}
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

{% for item in getIncludeViews('PortalAccount', 'passwordAfter') %}
    {% include item['path'] %}
{% endfor %}