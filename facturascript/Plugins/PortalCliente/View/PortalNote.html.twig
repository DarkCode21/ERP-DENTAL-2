{% set note = fsc.getCurrentView().model %}

<div class="container pt-3 pb-3">
    <div class="form-row d-flex align-items-center">
        <div class="col-sm">
            <h1 class="h3 m-0 p-0">
                <i class="far fa-comment-dots"></i>
                {{ note.title }}
            </h1>
        </div>

        {% for item in getIncludeViews('PortalNote', 'buttonsBefore') %}
            {% include item['path'] %}
        {% endfor %}

        {% block buttons %}
            <div class="col-sm-auto text-right">
                <a href="{{ asset('PortalCliente') }}?activetab=ListPortalNote" class="btn btn-secondary">
                    <i class="fas fa-list fa-fw"></i>
                    {{ trans('back') }}
                </a>
            </div>
            <div class="col-sm-auto text-right">
                <form action="{{ asset('PortalCliente') }}" method="post">
                    <button type="submit" name="action" value="logout" class="btn btn-danger"
                            title="{{ trans('logout') }}">
                        <i class="fas fa-door-open"></i>
                        {{ trans('exit') }}
                    </button>
                </form>
            </div>
        {% endblock %}

        {% for item in getIncludeViews('PortalNote', 'buttonsAfter') %}
            {% include item['path'] %}
        {% endfor %}
    </div>
</div>