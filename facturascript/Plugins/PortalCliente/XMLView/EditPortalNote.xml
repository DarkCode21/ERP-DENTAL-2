<view>
    <columns>
        <group name="data" numcolumns="12">
            <column name="id" display="none" order="100">
                <widget type="text" fieldname="id" readonly="true"/>
            </column>
            <column name="customer" display="none" order="110">
                <widget type="text" fieldname="codcliente"/>
            </column>
            <column name="contact" display="none" order="120">
                <widget type="text" fieldname="idcontacto"/>
            </column>
            <column name="title" order="130">
                <widget type="text" fieldname="title" required="true" maxlength="100"/>
            </column>
            <column name="body" title="note" numcolumns="12" order="140">
                <widget type="markdown" fieldname="body"/>
            </column>
        </group>
        <group name="logs" numcolumns="12">
            <column name="creation-date" display="none" order="100">
                <widget type="datetime" fieldname="creation_date" required="true"/>
            </column>
            <column name="nick" display="none" order="110">
                <widget type="select" fieldname="nick">
                    <values source="users" fieldcode="nick" fieldtitle="nick"/>
                </widget>
            </column>
            <column name="last-update" display="none" order="120">
                <widget type="datetime" fieldname="last_update"/>
            </column>
            <column name="last-nick" display="none" order="130">
                <widget type="select" fieldname="last_nick">
                    <values source="users" fieldcode="nick" fieldtitle="nick"/>
                </widget>
            </column>
        </group>
    </columns>
</view>