<view>
    <columns>
        <column name="contact" order="100">
            <widget type="autocomplete" fieldname="idcontacto">
                <values source="contactos" fieldcode="idcontacto" fieldtitle="pc_nick"/>
            </widget>
        </column>
        <column name="products" display="center" order="110">
            <widget type="number" decimal="0" fieldname="products"/>
        </column>
        <column name="creation-date" display="right" order="120">
            <widget type="datetime" fieldname="creation_date"/>
        </column>
    </columns>
</view>