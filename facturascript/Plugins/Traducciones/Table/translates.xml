<table>
    <column>
        <name>creationdate</name>
        <type>timestamp</type>
        <null>NO</null>
    </column>
    <column>
        <name>id</name>
        <type>serial</type>
    </column>
    <column>
        <name>idlang</name>
        <type>int</type>
        <null>NO</null>
    </column>
    <column>
        <name>keytrans</name>
        <type>character varying(100)</type>
        <null>NO</null>
    </column>
    <column>
        <name>lastnick</name>
        <type>character varying(50)</type>
    </column>
    <column>
        <name>lastupdate</name>
        <type>timestamp</type>
    </column>
    <column>
        <name>nick</name>
        <type>character varying(50)</type>
    </column>
    <column>
        <name>valuetrans</name>
        <type>text</type>
        <null>NO</null>
    </column>
    <constraint>
        <name>translates_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>uniq_translates</name>
        <type>UNIQUE (idlang,keytrans)</type>
    </constraint>
    <constraint>
        <name>ca_translates_languages</name>
        <type>FOREIGN KEY (idlang) REFERENCES languages (id) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_translates_users_lastnick</name>
        <type>FOREIGN KEY (lastnick) REFERENCES users (nick) ON DELETE SET NULL ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_translates_users_nick</name>
        <type>FOREIGN KEY (nick) REFERENCES users (nick) ON DELETE SET NULL ON UPDATE CASCADE</type>
    </constraint>
</table>