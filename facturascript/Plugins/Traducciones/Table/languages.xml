<table>
    <column>
        <name>codicu</name>
        <type>character varying(10)</type>
        <null>NO</null>
    </column>
    <column>
        <name>codpais</name>
        <type>character varying(20)</type>
        <null>NO</null>
    </column>
    <column>
        <name>creationdate</name>
        <type>timestamp</type>
        <null>NO</null>
    </column>
    <column>
        <name>idflag</name>
        <type>int</type>
    </column>
    <column>
        <name>id</name>
        <type>serial</type>
    </column>
    <column>
        <name>lastnick</name>
        <type>character varying(50)</type>
    </column>
    <column>
        <name>lastupdate</name>
        <type>timestamp</type>
    </column>
    <column>
        <name>name</name>
        <type>character varying(100)</type>
        <null>NO</null>
    </column>
    <column>
        <name>nick</name>
        <type>character varying(50)</type>
    </column>
    <constraint>
        <name>languages_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>uniq_languages</name>
        <type>UNIQUE (codicu)</type>
    </constraint>
    <constraint>
        <name>ca_languages_paises</name>
        <type>FOREIGN KEY (codpais) REFERENCES paises (codpais) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_languages_users_lastnick</name>
        <type>FOREIGN KEY (lastnick) REFERENCES users (nick) ON DELETE SET NULL ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_languages_users_nick</name>
        <type>FOREIGN KEY (nick) REFERENCES users (nick) ON DELETE SET NULL ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_languages_attached_files</name>
        <type>FOREIGN KEY (idflag) REFERENCES attached_files (idfile) ON DELETE SET NULL ON UPDATE CASCADE</type>
    </constraint>
</table>