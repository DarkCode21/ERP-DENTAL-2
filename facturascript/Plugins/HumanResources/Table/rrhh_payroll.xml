<table>
    <column>
        <name>creationdate</name>
        <type>date</type>
        <null>NO</null>
    </column>
    <column>
        <name>enddate</name>
        <type>date</type>
        <null>NO</null>
    </column>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>idcompany</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>name</name>
        <type>character varying(100)</type>
        <null>NO</null>
    </column>
    <column>
        <name>note</name>
        <type>text</type>
    </column>
    <column>
        <name>startdate</name>
        <type>date</type>
        <null>NO</null>
    </column>

    <!-- Constraints -->
    <constraint>
        <name>rrhh_payroll_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>ca_rrhh_payroll_empresas</name>
        <type>FOREIGN KEY (idcompany) REFERENCES empresas (idempresa) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
</table>
