<table>
    <column>
        <name>creationdate</name>
        <type>date</type>
        <null>NO</null>
    </column>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>identry</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>idpayroll</name>
        <type>integer</type>
        <null>NO</null>
    </column>

    <!-- Constraints -->
    <constraint>
        <name>rrhh_payrollaccounting_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>ca_rrhh_payrollaccounting_asientos</name>
        <type>FOREIGN KEY (identry) REFERENCES asientos (idasiento) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
</table>
