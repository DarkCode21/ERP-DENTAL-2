<table>
    <column>
        <name>authorized</name>
        <type>boolean</type>
        <default>true</default>
    </column>
    <column>
        <name>automatic</name>
        <type>boolean</type>
        <default>true</default>
    </column>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>totaldays</name>
        <type>integer</type>
        <null>NO</null>
        <default>1</default>
    </column>
    <column>
        <name>idemployee</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>note</name>
        <type>text</type>
    </column>
    <column>
        <name>startdate</name>
        <type>date</type>
        <null>NO</null>
    </column>
    <column>
        <name>enddate</name>
        <type>date</type>
    </column>
    <constraint>
        <name>rrhh_employeesholidays_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>ca_rrhh_employeesholidays_employees</name>
        <type>FOREIGN KEY (idemployee) REFERENCES rrhh_employees (id) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
</table>

