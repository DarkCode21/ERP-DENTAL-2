<table>
    <column>
        <name>compensation</name>
        <type>integer</type>                    <!-- 0: No compensation, 1: monetary, 2: holidays -->
        <null>NO</null>
        <default>0</default>
    </column>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>idemployee</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>idclosing</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>overtime</name>
        <type>double precision</type>
        <null>NO</null>
        <default>0</default>
    </column>

    <!-- Constraints -->
    <constraint>
        <name>rrhh_employeesovertime_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>ca_rrhh_employeesovertime_employees</name>
        <type>FOREIGN KEY (idemployee) REFERENCES rrhh_employees (id) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_rrhh_employeesovertime_closing</name>
        <type>FOREIGN KEY (idclosing) REFERENCES rrhh_overtimeclosing (id) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
</table>