<table>
    <column>
        <name>idemployee</name>
        <type>integer</type>
    </column>
    <constraint>
        <name>ca_contactos_employees</name>
        <type>FOREIGN KEY (idemployee) REFERENCES rrhh_employees (id) ON DELETE SET NULL ON UPDATE CASCADE</type>
    </constraint>
</table>