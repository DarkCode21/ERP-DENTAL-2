<view>
    <columns>
        <column name="code" numcolumns="2" display="none" order="100">
            <widget type="text" fieldname="id" readonly="true" />
        </column>
        <column name="name" order="110">
            <widget type="text" fieldname="name" />
        </column>
        <column name="device" order="120">
            <widget type="text" fieldname="device" />
        </column>
        <column name="host" display="none" order="130">
            <widget type="text" fieldname="host" />
        </column>
        <column name="port" display="none" order="140">
            <widget type="text" fieldname="port" />
        </column>
        <column name="address" order="150">
            <widget type="text" fieldname="roadname" />
        </column>
        <column name="zip-code" display="none" order="160">
            <widget type="text" fieldname="zipcode" maxlength="10" />
        </column>
        <column name="city" order="170">
            <widget type="autocomplete" fieldname="idcity">
                <values source="ciudades" fieldcode="idciudad" fieldtitle="ciudad" />
            </widget>
        </column>
        <column name="province" order="180">
            <widget type="autocomplete" fieldname="idprovince">
                <values source="provincias" fieldcode="idprovincia" fieldtitle="provincia" />
            </widget>
        </column>
        <column name="type" order="190">
            <widget type="select" fieldname="type">
                <values title="Anviz">1</values>
            </widget>
        </column>
    </columns>

    <rows>
        <row type="status" fieldname="auto_import">
            <option title="manual" color="white">0</option>
            <option title="auto-import" color="info">1</option>
        </row>
    </rows>

    <modals>
        <group name="device" title="import" icon="fa-solid fa-fingerprint">
            <column name="device" numcolumns="12">
                <widget type="select" fieldname="device_id" required="true" icon="fa-solid fa-tablet-alt">
                    <values source="rrhh_devices" fieldcode="id" fieldtitle="name"></values>
                </widget>
            </column>
        </group>
    </modals>
</view>