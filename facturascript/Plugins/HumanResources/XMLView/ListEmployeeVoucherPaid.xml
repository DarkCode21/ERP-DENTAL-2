<view>
    <columns>
            <column name="code" order="100">
                <widget type="text" fieldname="id" />
            </column>
            <column name="voucher" display="none" order="100">
                <widget type="text" fieldname="idvoucher" />
            </column>
            <column name="date" order="110">
                <widget type="date" fieldname="startdate" />
            </column>
            <column name="hour" order="120">
                <widget type="text" fieldname="starttime" />
            </column>
            <column name="amount" display="right" order="130">
                <widget type="money" fieldname="amount" />
            </column>
            <column name="user" display="center" order="140">
                <widget type="select" fieldname="nick" >
                    <values source="users" fieldcode="nick" fieldtitle="nick"></values>
                </widget>
            </column>
            <column name="accounting-entry" display="none" order="200">
                <widget type="autocomplete" fieldname="idaccounting">
                    <values source="asientos" fieldcode="idasiento" fieldtitle="numero"></values>
                </widget>
            </column>
    </columns>

    <modals>
        <group name="insertpaid" title="add-payment" icon="fa-solid fa-coins">
            <column name="idvoucher" display="none" order="0">
                <widget type="text" fieldname="modalVoucher" readonly="true" />
            </column>
            <column name="amount" numcolumns="12" order="100">
                <widget type="money" fieldname="modalAmount" required="true" />
            </column>
            <column name="date" description="optional-current" order="110">
                <widget type="date" fieldname="modalDate" />
            </column>
        </group>
    </modals>
</view>
