<view>
    <columns>
        <column name="code" numcolumns="2" display="none" order="100">
            <widget type="text" fieldname="id" readonly="true" />
        </column>
        <column name="company" numcolumns="3" order="110">
            <widget type="select" fieldname="idcompany" required="true">
                <values source="empresas" fieldcode="idempresa" fieldtitle="nombrecorto"></values>
            </widget>
        </column>
        <column name="starting-date" numcolumns="3" order="210">
            <widget type="date" fieldname="startdate" required="true" icon="fa-solid fa-sign-in-alt" />
        </column>
        <column name="end-date" numcolumns="3" order="220">
            <widget type="date" fieldname="enddate" required="true" icon="fa-solid fa-sign-out-alt" />
        </column>
    </columns>
</view>