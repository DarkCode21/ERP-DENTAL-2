<view>
    <columns>
        <column name="code" order="100">
            <widget type="text" fieldname="id" />
        </column>
        <column name="origin" order="110">
            <widget type="select" fieldname="origin" translate="true">
                <values title="manual">1</values>
                <values title="justified">2</values>
                <values title="external">3</values>
            </widget>
        </column>
        <column name="date" display="center" order="120">
            <widget type="date" fieldname="checkdate" />
        </column>
        <column name="hour" display="center" order="130">
            <widget type="time" fieldname="checktime" />
        </column>
        <column name="delay" display="center" order="135">
            <widget type="number" fieldname="inputdelay" decimal="0" />
        </column>
        <column name="employee" order="140">
            <widget type="select" fieldname="idemployee">
                <values source="rrhh_employees" fieldcode="id" fieldtitle="nombre"></values>
            </widget>
        </column>
        <column name="type" display="center" order="150">
            <widget type="select" fieldname="kind" translate="true">
                <values title="input">1</values>
                <values title="output">2</values>
            </widget>
        </column>
        <column name="credential" order="160">
            <widget type="text" fieldname="credentialid" />
        </column>
        <column name="absence-concept" order="170" >
            <widget type="select" fieldname="idabsenceconcept" >
                <values source="rrhh_absencesconcepts" fieldcode="id" fieldtitle="name"></values>
            </widget>
        </column>
        <column name="description" display="none" order="180" >
            <widget type="text" fieldname="note" />
        </column>
    </columns>
    <rows>
        <row type="status">
            <option title="pending-authorization" fieldname="authorized" color="danger">0</option>
            <option title="manual" fieldname="origin" color="info">1</option>
            <option title="justified" fieldname="origin" color="warning">2</option>
        </row>

        <row type="actions">
            <button type="modal" label="justified" color="info" action="justified" icon="fa-solid fa-unlink" />
        </row>
    </rows>
    <modals>
        <group name="justified" title="absence-concept" icon="fa-solid fa-unlink" class="modal-lg">
            <column name="employee" numcolumns="12">
                <widget type="select" fieldname="employee_id" required="true">
                    <values source="rrhh_employees" fieldcode="id" fieldtitle="nombre"></values>
                </widget>
            </column>
            <column name="absence-concept" numcolumns="4">
                <widget type="select" fieldname="absenceconcept_id" required="true" >
                    <values source="rrhh_absencesconcepts" fieldcode="id" fieldtitle="name"></values>
                </widget>
            </column>
            <column name="description" numcolumns="8">
                <widget type="text" fieldname="justified_note" required="true" />
            </column>
            <column name="date">
                <widget type="date" fieldname="justified_date" required="true" />
            </column>
            <column name="starttime">
                <widget type="time" fieldname="justified_time1" required="true" />
            </column>
            <column name="endtime">
                <widget type="time" fieldname="justified_time2" required="true" />
            </column>
        </group>
        <group name="import" title="import" icon="fa-solid fa-file-import">
            <column name="full-path" order="110">
                <widget type="file" fieldname="filedata" accept=".csv" />
            </column>
        </group>
    </modals>
</view>
