<view>
    <columns>
        <column name="code" order="100">
            <widget type="text" fieldname="id" />
        </column>
        <column name="name" order="110">
            <widget type="text" fieldname="name" />
        </column>
        <column name="area" order="120">
            <widget type="autocomplete" fieldname="idarea">
                <values source="rrhh_coursesareas" fieldcode="id" fieldtitle="name" />
            </widget>
        </column>
        <column name="cost" order="130">
            <widget type="autocomplete" fieldname="idcost">
                <values source="rrhh_coursescosts" fieldcode="id" fieldtitle="name" />
            </widget>
        </column>
        <column name="method" order="140">
            <widget type="autocomplete" fieldname="idmethod">
                <values source="rrhh_coursesmethods" fieldcode="id" fieldtitle="name" />
            </widget>
        </column>
        <column name="objective" order="150">
            <widget type="autocomplete" fieldname="idobjective">
                <values source="rrhh_coursesobjectives" fieldcode="id" fieldtitle="name" />
            </widget>
        </column>
    </columns>
</view>
