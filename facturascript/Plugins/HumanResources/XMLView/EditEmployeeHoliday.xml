<view>
    <columns>
        <group name="employee" numcolumns="12" valign="bottom">
            <column name="code" display="none" numcolumns="2" order="100">
                <widget type="text" fieldname="id" />
            </column>
            <column name="employee" order="110">
                <widget type="autocomplete" fieldname="idemployee" required="true" readonly="dinamic">
                    <values source="rrhh_employees" fieldcode="id" fieldtitle="nombre"></values>
                </widget>
            </column>
            <column name="starting-date" numcolumns="2" order="120">
                <widget type="date" fieldname="startdate" icon="fa-solid fa-sign-in-alt" />
            </column>
            <column name="end-date" numcolumns="2" order="130">
                <widget type="date" fieldname="enddate" icon="fa-solid fa-sign-out-alt" />
            </column>
            <column name="totaldays" numcolumns="2" order="140">
                <widget type="number" fieldname="totaldays" icon="fa-solid fa-calculator" />
            </column>
        </group>

        <group name="others" numcolumns="12">
            <column name="calculate" numcolumns="1" order="100">
                <widget type="checkbox" fieldname="automatic" />
            </column>
            <column name="authorized" numcolumns="1" order="110">
                <widget type="checkbox" fieldname="authorized" />
            </column>
        </group>

        <group name="notes" numcolumns="12">
            <column name="notes" numcolumns="12" order="160">
                <widget type="textarea" fieldname="note" rows="3" />
            </column>
        </group>
    </columns>
</view>