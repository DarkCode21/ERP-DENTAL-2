<view>
    <columns>
        <column name="code" order="100">
            <widget type="text" fieldname="id" />
        </column>
        <column name="date" order="110">
            <widget type="datetime" fieldname="dateaction" />
        </column>
        <column name="action" order="120">
            <widget type="select" fieldname="action" translate="true">
                <values title="update">1</values>
                <values title="delete">2</values>
            </widget>
        </column>
        <column name="reason" order="130">
            <widget type="text" fieldname="reason" />
        </column>
        <column name="user" order="140">
            <widget type="text" fieldname="nick" />
        </column>
        <column name="attendance" order="150">
            <widget type="text" fieldname="idattendance" />
        </column>
    </columns>
</view>