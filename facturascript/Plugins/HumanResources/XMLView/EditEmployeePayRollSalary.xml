<view>
    <columns>
        <column name="code" numcolumns="2" display="none" order="100">
            <widget type="text" fieldname="id" readonly="true" required="true" />
        </column>
        <column name="employeepayroll" numcolumns="2" display="none" order="100">
            <widget type="text" fieldname="idemployeepayroll" readonly="true" required="true" />
        </column>
        <column name="employee" numcolumns="4" display="none" order="100">
            <widget type="text" fieldname="idemployee" readonly="true" required="true" />
        </column>
        <column name="channel" numcolumns="1" order="110">
            <widget type="number" decimal="0" fieldname="channel" />
        </column>
        <column name="concept" numcolumns="2" order="120">
            <widget type="select" fieldname="idsalaryconcept" required="true">
                <values source="rrhh_salaryconcepts" fieldcode="id" fieldtitle="name"></values>
            </widget>
        </column>
        <column name="calculation" numcolumns="1" order="130">
            <widget type="select" fieldname="calculation" required="true" translate="true">
                <values title="unitary">1</values>
                <values title="quantity">2</values>
                <values title="percentage">80</values>
                <values title="total">99</values>
            </widget>
        </column>
        <column name="quantity" numcolumns="1" order="140">
            <widget type="number" decimal="2" min="0" fieldname="quantity" required="true" />
        </column>
        <column name="amount" numcolumns="2" order="150">
            <widget type="money" min="0" fieldname="amount" required="true" />
        </column>
        <column name="total" numcolumns="2" order="150">
            <widget type="money" fieldname="total" readonly="true" />
        </column>
        <column name="position" numcolumns="1" order="150">
            <widget type="select" fieldname="position" translate="true">
                <values title="debit">1</values>
                <values title="credit">2</values>
            </widget>
        </column>
        <column name="subaccount" order="160">
            <widget type="autocomplete" fieldname="codsubaccount" required="true">
                <values source="subcuentas" fieldcode="codsubcuenta" fieldtitle="descripcion"></values>
            </widget>
        </column>
    </columns>
</view>
