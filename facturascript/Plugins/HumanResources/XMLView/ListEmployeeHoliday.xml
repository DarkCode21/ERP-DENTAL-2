<view>
    <columns>
        <column name="code" order="100">
            <widget type="text" fieldname="id" />
        </column>
        <column name="employee" order="110">
            <widget type="select" fieldname="idemployee">
                <values source="rrhh_employees" fieldcode="id" fieldtitle="nombre"></values>
            </widget>
        </column>
        <column name="starting-date" order="120">
            <widget type="date" fieldname="startdate" />
        </column>
        <column name="end-date" order="130">
            <widget type="date" fieldname="enddate" />
        </column>
        <column name="totaldays" display="center" order="140">
            <widget type="number" decimal="0" fieldname="totaldays" />
        </column>
        <column name="notes" order="150">
            <widget type="text" fieldname="note" />
        </column>
    </columns>
    <rows>
        <row type="status" fieldname="authorized">
            <option title="pending-authorization" color="danger">0</option>
        </row>
    </rows>
</view>