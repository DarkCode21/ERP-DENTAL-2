<view>
    <columns>
        <group name="data" numcolumns="12">
            <column name="code" display="none" numcolumns="2" order="100">
                <widget type="text" fieldname="id" />
            </column>
            <column name="employee" order="100">
                <widget type="autocomplete" fieldname="idemployee" required="true">
                    <values source="rrhh_employees" fieldcode="id" fieldtitle="nombre"></values>
                </widget>
            </column>
            <column name="course" order="130">
                <widget type="autocomplete" fieldname="idcourse" required="true">
                    <values source="rrhh_coursestrainings" fieldcode="id" fieldtitle="name"></values>
                </widget>
            </column>
            <column name="starting-date" numcolumns="3" order="130">
                <widget type="date" fieldname="startdate" icon="fa-solid fa-sign-in-alt" />
            </column>
            <column name="end-date" numcolumns="3" order="140">
                <widget type="date" fieldname="enddate" icon="fa-solid fa-sign-out-alt" />
            </column>
            <column name="amount" numcolumns="2" order="150">
                <widget type="money" fieldname="amount" />
            </column>
        </group>
    </columns>
</view>
