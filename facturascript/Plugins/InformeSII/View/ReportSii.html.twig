{% extends "Master/MenuBghTemplate.html.twig" %}

{% block bodyHeaderOptions %}
    <br/>
    <br/>
    <br/>
{% endblock %}

{% block body %}
    <form method="post">
        <div class="container" style="margin-top: -50px;">
            <div class="row">
                <div class="col-12">
                    <div class="card shadow mb-3">
                        <div class="card-body">
                            <h1 class="h3 mb-3">
                                <i class="{{ fsc.getPageData().icon }}"></i> {{ fsc.title }}
                            </h1>
                            <div class="form-row">
                                <div class="col-sm-3">
                                    <div class="form-group">
                                        {{ trans('company') }}
                                        <select name="idempresa" class="form-control" required>
                                            {% for empresa in fsc.empresa.all() %}
                                                {% if empresa.idempresa == fsc.idempresa %}
                                                    <option value="{{ empresa.idempresa }}" selected>
                                                        {{ empresa.nombrecorto | raw }}
                                                    </option>
                                                {% else %}
                                                    <option value="{{ empresa.idempresa }}">{{ empresa.nombrecorto | raw }}</option>
                                                {% endif %}
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                                <div class="col-sm-3">
                                    <div class="form-group">
                                        {{ trans('type') }}
                                        <select name="source" class="form-control">
                                            {% for key,value in fsc.getSources() %}
                                                {% if key is same as(fsc.source) %}
                                                    <option value="{{ key }}" selected>{{ value }}</option>
                                                {% else %}
                                                    <option value="{{ key }}">{{ value }}</option>
                                                {% endif %}
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                                <div class="col-sm-3">
                                    <div class="form-group">
                                        {{ trans('from-date') }}
                                        <input type="date" name="datefrom" value="{{ fsc.datefrom }}"
                                               class="form-control" required/>
                                    </div>
                                </div>
                                <div class="col-sm-3">
                                    <div class="form-group">
                                        {{ trans('until-date') }}
                                        <input type="date" name="dateto" value="{{ fsc.dateto }}" class="form-control"
                                               required/>
                                    </div>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="col-sm-3">
                                    <div class="form-group">
                                        {{ trans('serie') }}
                                        <select name="codserie" class="form-control">
                                            <option value="">{{ i18n.trans('all') }}</option>
                                            <option value="">------</option>
                                            {% for serie in fsc.getSeries() %}
                                                {% if serie.codserie == fsc.codserie %}
                                                    <option value="{{ serie.codserie }}"
                                                            selected="">{{ serie.descripcion | raw }}</option>
                                                {% else %}
                                                    <option value="{{ serie.codserie }}">{{ serie.descripcion | raw }}</option>
                                                {% endif %}
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                                <div class="col-sm-3">
                                    <div class="form-group">
                                        {{ trans('payment-method') }}
                                        <select name="codpago" class="form-control">
                                            <option value="">{{ i18n.trans('all') }}</option>
                                            <option value="">------</option>
                                            {% for pago in fsc.getFormasPagos() %}
                                                {% if pago.codpago == fsc.codpago %}
                                                    <option value="{{ pago.codpago }}"
                                                            selected="">{{ pago.descripcion | raw }}</option>
                                                {% else %}
                                                    <option value="{{ pago.codpago }}">{{ pago.descripcion | raw }}</option>
                                                {% endif %}
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                                <div class="col-sm-3">
                                    <div class="form-group">
                                        {{ trans('country') }}
                                        <select name="codpais" class="form-control">
                                            <option value="">{{ i18n.trans('all') }}</option>
                                            <option value="">------</option>
                                            {% for pais in fsc.getPaises() %}
                                                {% if pais.codpais == fsc.codpais %}
                                                    <option value="{{ pais.codpais }}"
                                                            selected="">{{ pais.nombre | raw }}</option>
                                                {% else %}
                                                    <option value="{{ pais.codpais }}">{{ pais.nombre | raw }}</option>
                                                {% endif %}
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                                <div class="col-sm-3">
                                    <div class="form-group">
                                        {{ trans('province') }}
                                        <select name="provincia" class="form-control">
                                            <option value="">{{ i18n.trans('all') }}</option>
                                            <option value="">------</option>
                                            {% for prov in fsc.getProvincias() %}
                                                {% if prov.provincia == fsc.provincia %}
                                                    <option value="{{ prov.provincia }}"
                                                            selected="">{{ prov.provincia | raw }}</option>
                                                {% else %}
                                                    <option value="{{ prov.provincia }}">{{ prov.provincia | raw }}</option>
                                                {% endif %}
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer">
                            <button type="submit" name="action" value="send" class="btn btn-warning btn-spin-action">
                                <i class="fas fa-upload fa-fw"></i>
                                {{ trans('send-to-aeat') }}
                            </button>
                            <button type="submit" name="action" value="download"
                                    class="btn btn-primary btn-spin-action">
                                <i class="fas fa-download fa-fw"></i>
                                {{ trans('download-xml') }}
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
    {% if fsc.sendXml is not empty %}
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>{{ trans('invoice') }}</th>
                        <th>{{ trans('status') }}</th>
                        <th>{{ trans('common-error') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {{ fsc.sendXml['trs'] ? fsc.sendXml['trs'] | raw :  '' }}
                </tbody>
            </table>
        </div>
    {% endif %}
{% endblock %}