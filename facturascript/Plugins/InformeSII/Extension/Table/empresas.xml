<table>
    <column>
        <name>sii_debugmode</name>
        <type>boolean</type>
    </column>
    <column>
        <name>sii_password</name>
        <type>character varying(200)</type>
    </column>
    <column>
        <name>sii_signature</name>
        <type>character varying(200)</type>
    </column>
    <column>
        <name>sii_idfile</name>
        <type>integer</type>
    </column>
    <constraint>
        <name>ca_empresas_attached_files</name>
        <type>FOREIGN KEY (sii_idfile) REFERENCES attached_files (idfile) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
</table>