<view>
    <columns>
        <group name="sii" title="report-sii" icon="fas fa-file-invoice" numcolumns="12" valign="bottom">
            <column name="signature" order="100">
                <widget type="file" fieldname="sii_signature" accept=".p12" readonly="dinamic"/>
            </column>
            <column name="password" order="110">
                <widget type="password" fieldname="sii_password"/>
            </column>
            <column name="debug-mode" order="120">
                <widget type="checkbox" fieldname="sii_debugmode"/>
            </column>
        </group>
    </columns>
    <modals>
        <group name="upload-new-file" title="signature" icon="fas fa-file-upload">
            <column name="file" order="100">
                <widget type="file" fieldname="newfile" accept=".p12" required="true"/>
            </column>
        </group>
    </modals>
</view>