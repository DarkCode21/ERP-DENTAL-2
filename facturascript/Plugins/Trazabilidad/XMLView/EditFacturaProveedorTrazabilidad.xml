<view>
    <columns>
        <column name="id" display="none" order="80">
            <widget type="text" fieldname="id" readonly="true"/>
        </column>
        <column name="docmodel" display="none" order="90">
            <widget type="text" fieldname="docmodel" readonly="true"/>
        </column>
        <column name="docid" display="none" order="100">
            <widget type="text" fieldname="docid" required="true" readonly="true"/>
        </column>
        <column name="product" description="trazability-leyend-product" order="110">
            <widget type="selectTraza" fieldname="idlinea" required="true" readonly="dinamic" onchange="getQtyNewLoteProv(this)">
                <values/>
            </widget>
        </column>
        <column name="batch-serial-number" order="120">
            <widget type="text" fieldname="numserie" required="true" readonly="dinamic"/>
        </column>
        <column name="date" display="right" order="130">
            <widget type="date" fieldname="fecha" required="true"/>
        </column>
        <column name="quantity" display="right" order="140">
            <widget type="number" fieldname="cantidad" required="true"/>
        </column>
    </columns>
</view>