<view>
    <columns>
        <group name="id" numcolumns="12">
            <column name="code" numcolumns="2" display="none" order="100">
                <widget type="text" fieldname="id" readonly="true"/>
            </column>
            <column name="name" numcolumns="3" order="110">
                <widget type="text" fieldname="name" required="true"/>
            </column>
        </group>
        <group name="other" numcolumns="12">
            <column name="description" numcolumns="12" order="100">
                <widget type="textarea" fieldname="note" rows="5" icon="fa-solid fa-sticky-note"/>
            </column>
        </group>
    </columns>
</view>
