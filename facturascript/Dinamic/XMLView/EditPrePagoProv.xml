<view>
    <columns>
        <group name="data" numcolumns="12">
            <column name="id" display="none" order="0">
                <widget type="text" fieldname="id" required="true"/>
            </column>
            <column name="modelname" display="none" order="0">
                <widget type="text" fieldname="modelname" required="true"/>
            </column>
            <column name="modelid" display="none" order="0">
                <widget type="text" fieldname="modelid" required="true"/>
            </column>
            <column name="supplier" order="0">
                <widget type="autocomplete" fieldname="codproveedor" onclick="EditProveedor" required="true">
                    <values source="proveedores" fieldcode="codproveedor" fieldtitle="nombre"/>
                </widget>
            </column>
            <column name="amount" display="right" order="100">
                <widget type="money" fieldname="amount" required="true"/>
            </column>
            <column name="method-payment" order="110">
                <widget type="select" fieldname="codpago" required="true">
                    <values source="formaspago" fieldcode="codpago" fieldtitle="descripcion"/>
                </widget>
            </column>
            <column name="payment-date" order="120">
                <widget type="date" fieldname="payment_date" required="true"/>
            </column>
            <column name="accounting-entry" order="130">
                <widget type="autocomplete" fieldname="idasiento" onclick="EditAsiento" readonly="true">
                    <values source="asientos" fieldcode="idasiento" fieldtitle="numero"/>
                </widget>
            </column>
            <column name="notes" numcolumns="12" order="140">
                <widget type="textarea" fieldname="notes"/>
            </column>
        </group>
        <group name="logs" numcolumns="12">
            <column name="creation-date" order="100">
                <widget type="datetime" fieldname="creationdate" readonly="true"/>
            </column>
            <column name="user" order="110">
                <widget type="select" fieldname="nick" readonly="true">
                    <values source="users" fieldcode="nick" fieldtitle="nick"/>
                </widget>
            </column>
            <column name="last-update" order="120">
                <widget type="datetime" fieldname="lastupdate" readonly="true"/>
            </column>
            <column name="last-user" order="130">
                <widget type="select" fieldname="lastnick" readonly="true">
                    <values source="users" fieldcode="nick" fieldtitle="nick"/>
                </widget>
            </column>
        </group>
    </columns>
    <modals>
        <group name="link-document" title="link-document" icon="fa-solid fa-link">
            <column name="estimation" numcolumns="12">
                <widget type="autocomplete" fieldname="estimation">
                    <values source="presupuestoscli" fieldcode="idpresupuesto" fieldtitle="codigo"/>
                </widget>
            </column>
            <column name="order" numcolumns="12">
                <widget type="autocomplete" fieldname="order">
                    <values source="pedidoscli" fieldcode="idpedido" fieldtitle="codigo"/>
                </widget>
            </column>
            <column name="delivery-note" numcolumns="12">
                <widget type="autocomplete" fieldname="delivery_note">
                    <values source="albaranescli" fieldcode="idalbaran" fieldtitle="codigo"/>
                </widget>
            </column>
        </group>
    </modals>
</view>
