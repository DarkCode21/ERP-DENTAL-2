<view>
    <columns>
        <column name="code" order="100">
            <widget type="text" fieldname="id"/>
        </column>
        <column name="template" order="110">
            <widget type="text" fieldname="name"/>
        </column>
        <column name="years" display="center" order="140">
            <widget type="text" fieldname="periods"/>
        </column>
        <column name="codsubcuentacierre" title="subaccount-closing" order="160">
            <widget type="text" fieldname="closing_subaccount"/>
        </column>
        <column name="codsubcuentadebe" title="subaccount-debit" order="170">
            <widget type="text" fieldname="debit_subaccount"/>
        </column>
        <column name="codsubcuentahaber" title="subaccount-credit" order="180">
            <widget type="text" fieldname="credit_subaccount"/>
        </column>
        <column name="codsubcuentabeneficios" title="subaccount-benefits" order="190">
            <widget type="text" fieldname="benefits_subaccount"/>
        </column>
        <column name="codsubcuentaperdidas" title="subaccount-lost" order="200">
            <widget type="text" fieldname="loss_subaccount"/>
        </column>
    </columns>
</view>
