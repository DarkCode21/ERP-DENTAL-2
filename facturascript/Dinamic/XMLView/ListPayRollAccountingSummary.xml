<view>
    <columns>
        <column name="id" display="none" order="0">
            <widget type="text" fieldname="id"/>
        </column>
        <column name="idpayroll" label="payroll" display="none" order="0">
            <widget type="text" fieldname="idpayroll"/>
        </column>
        <column name="identry" label="entry" display="none" order="0">
            <widget type="text" fieldname="identry"/>
        </column>
        <column name="channel" display="center" numcolumns="1" order="100">
            <widget type="number" decimal="0" fieldname="canal"/>
        </column>
        <column name="number" order="110">
            <widget type="text" fieldname="numero"/>
        </column>
        <column name="exercise" order="120">
            <widget type="text" fieldname="codejercicio"/>
        </column>
        <column name="journal" order="130">
            <widget type="text" fieldname="diario"/>
        </column>
        <column name="accounting-concept" order="140">
            <widget type="text" fieldname="concepto"/>
        </column>
        <column name="amount" display="right" order="150">
            <widget type="money" fieldname="importe">
                <option color="danger">&lt;0</option>
            </widget>
        </column>
        <column name="creation-date" display="center" order="160">
            <widget type="date" fieldname="creationdate"/>
        </column>
        <column name="accounting-date" display="center" order="170">
            <widget type="date" fieldname="fecha"/>
        </column>
    </columns>
</view>
