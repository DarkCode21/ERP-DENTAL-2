<view>
    <columns>
        <column name="code" display="none" order="100">
            <widget type="text" fieldname="id"/>
        </column>
        <column name="source" order="105">
            <widget type="text" fieldname="docmodel"/>
        </column>
        <column name="recipe" order="110">
            <widget type="autocomplete" fieldname="idreceta">
                <values source="produccion_recetas" fieldcode="idreceta" fieldtitle="descripcion"/>
            </widget>
        </column>
        <column name="quantity" order="120">
            <widget type="number" fieldname="cantidad"/>
        </column>
        <column name="date" order="130">
            <widget type="date" fieldname="fecha"/>
        </column>
        <column name="time" order="140">
            <widget type="time" fieldname="hora"/>
        </column>
        <column name="user" order="150">
            <widget type="text" fieldname="nick"/>
        </column>
    </columns>
</view>
