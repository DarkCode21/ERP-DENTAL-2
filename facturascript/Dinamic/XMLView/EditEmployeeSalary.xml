<view>
    <columns>
        <column name="code" display="none" numcolumns="2" order="100">
            <widget type="text" fieldname="id"/>
        </column>
        <column name="employee" display="none" numcolumns="4" order="110">
            <widget type="select" fieldname="idemployee" required="true">
                <values source="rrhh_employees" fieldcode="id" fieldtitle="nombre"/>
            </widget>
        </column>
        <column name="concept" numcolumns="2" order="120">
            <widget type="select" fieldname="idsalaryconcept" required="true">
                <values source="rrhh_salaryconcepts" fieldcode="id" fieldtitle="name"/>
            </widget>
        </column>
        <column name="calculation" numcolumns="2" order="130">
            <widget type="select" fieldname="calculation" required="true" translate="true">
                <values title="unitary">1</values>
                <values title="quantity">2</values>
                <values title="percentage">80</values>
                <values title="total">99</values>
            </widget>
        </column>
        <column name="amount" numcolumns="2" order="140">
            <widget type="number" decimal="2" min="0" fieldname="amount" required="true"/>
        </column>
        <column name="position" numcolumns="1" order="150">
            <widget type="select" fieldname="position" translate="true">
                <values title="debit">1</values>
                <values title="credit">2</values>
            </widget>
        </column>
        <column name="subaccount" order="160">
            <widget type="autocomplete" fieldname="codsubaccount" required="true">
                <values source="subcuentas" fieldcode="codsubcuenta" fieldtitle="descripcion"/>
            </widget>
        </column>
        <column name="channel" numcolumns="1" order="170">
            <widget type="number" decimal="0" fieldname="channel"/>
        </column>
    </columns>
    <rows>
        <row type="actions">
            <button type="js" label="" color="info" action="$('#help-card').toggle()" icon="fa-solid fa-question-circle"/>
        </row>
        <row type="header">
            <group name="help" id="help-card" class="collapse" html="Block/EmployeeSalaryInfo.html.twig"/>
        </row>
    </rows>
</view>
