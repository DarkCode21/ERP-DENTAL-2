<view>
    <columns>
        <group name="id" numcolumns="12">
            <column name="code" display="none" order="100">
                <widget type="text" fieldname="id"/>
            </column>
            <column name="name" numcolumns="12" order="110">
                <widget type="text" fieldname="name" required="true"/>
            </column>
            <column name="area" numcolumns="3" order="120">
                <widget type="select" fieldname="idarea" required="true">
                    <values source="rrhh_coursesareas" fieldcode="id" fieldtitle="name"/>
                </widget>
            </column>
            <column name="cost" numcolumns="3" order="130">
                <widget type="select" fieldname="idcost" required="true">
                    <values source="rrhh_coursescosts" fieldcode="id" fieldtitle="name"/>
                </widget>
            </column>
            <column name="method" numcolumns="3" order="140">
                <widget type="select" fieldname="idmethod" required="true">
                    <values source="rrhh_coursesmethods" fieldcode="id" fieldtitle="name"/>
                </widget>
            </column>
            <column name="objective" numcolumns="3" order="150">
                <widget type="select" fieldname="idobjective" required="true">
                    <values source="rrhh_coursesobjectives" fieldcode="id" fieldtitle="name"/>
                </widget>
            </column>
        </group>
    </columns>
</view>
