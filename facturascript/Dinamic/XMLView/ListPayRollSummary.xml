<view>
    <columns>
        <column name="id" display="none" order="0">
            <widget type="text" fieldname="id"/>
        </column>
        <column name="idpayroll" label="payroll" display="none" order="0">
            <widget type="text" fieldname="idpayroll"/>
        </column>
        <column name="employee" order="100">
            <widget type="text" fieldname="employee"/>
        </column>
        <column name="channel" display="center" numcolumns="1" order="110">
            <widget type="number" decimal="0" fieldname="channel"/>
        </column>
        <column name="holidays" display="right" order="120">
            <widget type="number" decimal="0" fieldname="holiday">
                <option color="danger">&gt;0</option>
                <option color="dark">0</option>
            </widget>
        </column>
        <column name="hours" display="right" order="130">
            <widget type="number" decimal="2" fieldname="hours"/>
        </column>
        <column name="worked" display="right" order="140">
            <widget type="number" decimal="2" fieldname="worked"/>
        </column>
        <column name="difference" display="right" order="150">
            <widget type="number" decimal="2" fieldname="difference">
                <option color="danger">&lt;0</option>
                <option color="success">&gt;0</option>
                <option color="dark">0</option>
            </widget>
        </column>
        <column name="extra-hours" display="right" numcolumns="2" order="160">
            <widget type="money" fieldname="overtime">
                <option color="danger">&lt;0</option>
                <option color="dark">0</option>
            </widget>
        </column>
        <column name="amount" display="right" numcolumns="2" order="170">
            <widget type="money" fieldname="amount">
                <option color="danger">&lt;0</option>
                <option color="dark">0</option>
            </widget>
        </column>
    </columns>

    <modals>
        <group name="insertemployees" title="add-employees" icon="fa-solid fa-id-card">
            <column name="option" numcolumns="12" order="100">
                <widget type="select" fieldname="option" required="true" translate="true">
                    <values title="employees-only-selected">SELECTED</values>
                    <values title="employees-all-active">ACTIVE</values>
                    <values title="employees-all">ALL</values>
                </widget>
            </column>
            <column name="employee" numcolumns="12" order="110">
                <widget type="autocomplete" fieldname="idemployee">
                    <values source="rrhh_employees" fieldcode="id" fieldtitle="nombre"/>
                </widget>
            </column>
        </group>
    </modals>
</view>
