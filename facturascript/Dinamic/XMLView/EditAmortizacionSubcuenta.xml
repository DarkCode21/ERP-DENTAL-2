<view>
    <columns>
        <column name="code" display="none" order="100">
            <widget type="text" fieldname="id"/>
        </column>
        <column name="type" order="110">
            <widget type="select" fieldname="grouptype" translate="true" required="true">
                <values title="intangible-assets">1</values>
                <values title="material-immobilizations">2</values>
                <values title="immobilization-real-estate">3</values>
                <values title="material-immobilizations-in-progress">4</values>
            </widget>
        </column>
        <column name="group" order="120">
            <widget type="select" fieldname="group" translate="true" required="true">
                <values title="subaccount-closing">1</values>
                <values title="subaccount-debit">2</values>
                <values title="subaccount-credit">3</values>
                <values title="subaccount-lost">4</values>
                <values title="subaccount-benefits">5</values>
            </widget>
        </column>
        <column name="account" order="140">
            <widget type="autocomplete" fieldname="code" required="true">
                <values source="cuentas" fieldcode="codcuenta" fieldtitle="descripcion"/>
            </widget>
        </column>
    </columns>
</view>
