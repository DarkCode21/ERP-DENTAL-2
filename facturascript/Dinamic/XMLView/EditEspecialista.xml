<?xml version="1.0" encoding="UTF-8"?>
<view>
    <columns>
        <group name="main" numcolumns="12">
            <column name="code" display="none" order="100">
                <widget type="text" fieldname="id"/>
            </column>
            <column name="name" numcolumns="6" order="110">
                <widget type="text" fieldname="nombre"/>
            </column>
            <column name="surname" numcolumns="6" order="120">
                <widget type="text" fieldname="apellidos"/>
            </column>
            <column name="main-specialty" numcolumns="4" order="125">
                <widget type="select" fieldname="idespecialidad" required="true">
                    <values source="dental_especialidades" fieldcode="id" fieldtitle="nombre"/>
                </widget>
            </column>
            <column name="license-number" numcolumns="4" order="130">
                <widget type="text" fieldname="numero_colegiado"/>
            </column>
            <column name="phone" numcolumns="4" order="140">
                <widget type="text" fieldname="telefono"/>
            </column>
            <column name="email" numcolumns="4" order="150">
                <widget type="text" fieldname="email"/>
            </column>
            <column name="salon-assistant-id" numcolumns="3" order="155">
                <widget type="number" decimal="0" fieldname="salon_assistant_id"/>
            </column>
            <column name="status" numcolumns="3" order="160">
                <widget type="select" fieldname="estado" translate="true">
                    <values title="active">activo</values>
                    <values title="inactive">inactivo</values>
                </widget>
            </column>
            <column name="observations" numcolumns="12" order="170">
                <widget type="textarea" fieldname="observaciones"/>
            </column>
        </group>
        <group name="user" title="erp-user" icon="fas fa-user-cog" numcolumns="12">
            <column name="linked-user" numcolumns="4" order="180">
                <widget type="select" fieldname="codusuario" readonly="true">
                    <values source="users" fieldcode="nick" fieldtitle="nick"/>
                </widget>
            </column>
            <column name="user-status" numcolumns="4" order="185">
                <widget type="text" fieldname="linked_user_status" readonly="true"/>
            </column>
        </group>
    </columns>
</view>
