<view>
    <columns>
        <column name="code" order="100">
            <widget type="text" fieldname="idremesa" onclick="EditRemesaSEPA"/>
        </column>
        <column name="date" display="right" order="110">
            <widget type="date" fieldname="fecha"/>
        </column>
        <column name="company" display="none" order="120">
            <widget type="select" fieldname="idempresa">
                <values source="empresas" fieldcode="idempresa" fieldtitle="nombre"/>
            </widget>
        </column>
        <column name="bank-account" order="130">
            <widget type="select" fieldname="codcuenta">
                <values source="cuentasbanco" fieldcode="codcuenta" fieldtitle="descripcion"/>
            </widget>
        </column>
        <column name="description" order="140">
            <widget type="textarea" fieldname="descripcion"/>
        </column>
        <column name="user" display="none" order="145">
            <widget type="select" fieldname="nick">
                <values source="users" fieldcode="nick" fieldtitle="nick"/>
            </widget>
        </column>
        <column name="amount" display="right" order="150">
            <widget type="money" fieldname="total"/>
        </column>
        <column name="status" order="160">
            <widget type="text" fieldname="estado"/>
        </column>
        <column name="charge-date" display="right" order="170">
            <widget type="date" fieldname="fechacargo"/>
        </column>
    </columns>
    <rows>
        <row type="status">
            <option color="success" fieldname="estado">Realizada</option>
            <option color="warning" fieldname="estado">Revisar</option>
            <option color="info" fieldname="estado">Preparada</option>
        </row>
    </rows>
</view>
