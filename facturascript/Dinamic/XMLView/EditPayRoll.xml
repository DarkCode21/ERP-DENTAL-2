<view>
    <columns>
        <group name="id" numcolumns="6">
            <column name="code" numcolumns="2" order="100">
                <widget type="text" fieldname="id" readonly="true"/>
            </column>
            <column name="company" numcolumns="4" order="110">
                <widget type="select" fieldname="idcompany">
                    <values source="empresas" fieldcode="idempresa" fieldtitle="nombrecorto"/>
                </widget>
            </column>
            <column name="description" numcolumns="6" order="120">
                <widget type="text" fieldname="name" required="true"/>
            </column>
            <column name="date" numcolumns="4" order="210">
                <widget type="date" fieldname="creationdate" icon="fa-solid fa-calendar"/>
            </column>
            <column name="starting-date" numcolumns="4" order="210">
                <widget type="date" fieldname="startdate" icon="fa-solid fa-sign-in-alt"/>
            </column>
            <column name="end-date" numcolumns="4" order="220">
                <widget type="date" fieldname="enddate" icon="fa-solid fa-sign-out-alt"/>
            </column>
        </group>
        <group name="other" numcolumns="6">
            <column name="notes" numcolumns="12" order="100">
                <widget type="textarea" rows="5" fieldname="note"/>
            </column>
        </group>
    </columns>
</view>
