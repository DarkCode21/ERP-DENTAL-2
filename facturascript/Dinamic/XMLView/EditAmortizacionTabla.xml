<view>
    <columns>
        <group name="general" numcolumns="12">
            <column name="code" display="none" order="100">
                <widget type="text" fieldname="id"/>
            </column>
            <column name="type" order="110">
                <widget type="select" fieldname="grouptype" translate="true" required="true">
                    <values title="simplified-direct-estimation">0</values>
                    <values title="normal-direct-estimate">1</values>
                </widget>
            </column>
            <column name="group" order="120">
                <widget type="select" fieldname="group" translate="true" required="true">
                    <values title="type-investments-assets">0</values>
                    <values title="civil-works">1</values>
                    <values title="centrals">2</values>
                    <values title="buildings">3</values>
                    <values title="facilities">4</values>
                    <values title="transport-elements">5</values>
                    <values title="furniture-fixtures">6</values>
                    <values title="electronic-computer">7</values>
                </widget>
            </column>
        </group>
        <group name="data" numcolumns="12">
            <column name="description" order="130">
                <widget type="text" fieldname="name" required="true"/>
            </column>
            <column name="coefficient" numcolumns="1" order="160">
                <widget type="number" decimal="2" fieldname="coefficient" required="true"/>
            </column>
            <column name="years" numcolumns="1" order="170">
                <widget type="number" fieldname="period" step="1" min="1" max="199" required="true"/>
            </column>
        </group>
    </columns>
</view>
