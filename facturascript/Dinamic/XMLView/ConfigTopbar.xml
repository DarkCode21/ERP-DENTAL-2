        </group>
        <group name="topbar-options" title="options" icon="fa-solid fa-cog" numcolumns="12">
            <column name="disable-cn-topbar" numcolumns="4" order="110">
                <widget type="checkbox" fieldname="tcndis"/>
            </column>
        </group>

    </columns>
</view>
