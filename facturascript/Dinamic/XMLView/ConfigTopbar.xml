                <widget type="color" fieldname="tbgcolor" required="true"/>
            </column>
            <column name="text-color" description="ttext-color-desc" numcolumns="3" order="110">
                <widget type="color" fieldname="ttxtcolor" required="true"/>
            </column>
            <column name="icons-color" description="icons-txtcolor-desc" numcolumns="3" order="110">
                <widget type="color" fieldname="itxtcolor" required="true"/>
