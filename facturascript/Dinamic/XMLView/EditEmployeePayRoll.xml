<view>
    <columns>
        <group name="payroll" numcolumns="8">
            <column name="code" display="none" order="100">
                <widget type="text" fieldname="id" readonly="true"/>
            </column>
            <column name="payroll" numcolumns="3" order="110">
                <widget type="autocomplete" fieldname="idpayroll" required="true" readonly="true">
                    <values source="rrhh_payroll" fieldcode="id" fieldtitle="name"/>
                </widget>
            </column>
            <column name="employee" numcolumns="6" order="120">
                <widget type="autocomplete" fieldname="idemployee" required="true" readonly="true">
                    <values source="rrhh_employees" fieldcode="id" fieldtitle="nombre"/>
                </widget>
            </column>
            <column name="amount" numcolumns="3" order="130">
                <widget type="money" min="1" fieldname="amount" readonly="true"/>
            </column>
        </group>
        <group name="data" numcolumns="4">
            <column name="holidays" numcolumns="3" order="100">
                <widget type="number" decimal="0" fieldname="holiday" readonly="true"/>
            </column>
            <column name="hours" numcolumns="3" order="110">
                <widget type="number" decimal="2" fieldname="hours" readonly="true"/>
            </column>
            <column name="worked" numcolumns="3" order="120">
                <widget type="number" decimal="2" fieldname="worked" readonly="true"/>
            </column>
            <column name="difference" numcolumns="3" order="130">
                <widget type="number" decimal="2" fieldname="difference" readonly="true"/>
            </column>
        </group>
    </columns>
</view>
