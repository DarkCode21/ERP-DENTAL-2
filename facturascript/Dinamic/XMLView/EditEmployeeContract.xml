<view>
    <columns>
        <group name="data" numcolumns="12">
            <column name="code" display="none" numcolumns="2" order="100">
                <widget type="text" fieldname="id"/>
            </column>
            <column name="employee" display="none" order="100">
                <widget type="select" fieldname="idemployee" required="true">
                    <values source="rrhh_employees" fieldcode="id" fieldtitle="nombre"/>
                </widget>
            </column>
            <column name="company" numcolumns="2" order="110">
                <widget type="select" fieldname="idcompany" required="true">
                    <values source="empresas" fieldcode="idempresa" fieldtitle="nombrecorto"/>
                </widget>
            </column>
            <column name="contract" order="130">
                <widget type="select" fieldname="idcontract" required="true">
                    <values source="rrhh_contracts" fieldcode="id" fieldtitle="name"/>
                </widget>
            </column>
            <column name="starting-date" numcolumns="3" order="130">
                <widget type="date" fieldname="startdate" icon="fa-solid fa-sign-in-alt"/>
            </column>
            <column name="end-date" numcolumns="3" order="140">
                <widget type="date" fieldname="enddate" icon="fa-solid fa-sign-out-alt"/>
            </column>
        </group>
        <group name="notes" numcolumns="12">
            <column name="notes" numcolumns="12" order="150">
                <widget type="textarea" fieldname="note" rows="2" icon="fa-solid fa-sticky-note"/>
            </column>
        </group>
    </columns>
</view>
