    Description:
        XML view for listing num serie counter records.
-->
<view>
    <columns>
        <column name="code" display="none" order="100">
            <widget type="text" fieldname="id"/>
        </column>
        <column name="family" order="110">
            <widget type="autocomplete" fieldname="idfamily">
                <values source="familias" fieldcode="codfamilia" fieldtitle="descripcion"/>
            </widget>
        </column>
        <column name="reference" order="120">
            <widget type="text" fieldname="reference" readonly="true"/>
        </column>
        <column name="product" order="120">
            <widget type="autocomplete" fieldname="idproduct">
                <values source="productos" fieldcode="idproducto" fieldtitle="descripcion"/>
            </widget>
        </column>
        <column name="last-counter" order="130">
            <widget type="number" fieldname="numserie" decimal="0" step="1" min="0"/>
        </column>
    </columns>
</view>
