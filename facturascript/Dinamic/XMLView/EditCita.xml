<?xml version="1.0" encoding="UTF-8"?>
<view>
    <columns>
        <group name="main" numcolumns="12">
            <column name="code" display="none" order="100">
                <widget type="text" fieldname="id"/>
            </column>
            <column name="patient" numcolumns="4" order="105">
                <widget type="select" fieldname="idpaciente"/>
            </column>
            <column name="specialist" numcolumns="4" order="106">
                <widget type="select" fieldname="idespecialista" required="true">
                    <values source="dental_especialistas" fieldcode="id" fieldtitle="nombre"/>
                </widget>
            </column>
            <column name="cabinet" numcolumns="4" order="107">
                <widget type="select" fieldname="idgabinete" required="true">
                    <values source="dental_gabinetes" fieldcode="id" fieldtitle="nombre"/>
                </widget>
            </column>
            <column name="treatment" numcolumns="4" order="108">
                <widget type="select" fieldname="idtratamiento">
                    <values source="dental_tratamientos_paciente" fieldcode="id" fieldtitle="referencia_servicio"/>
                </widget>
            </column>
            <column name="date" numcolumns="3" order="110">
                <widget type="date" fieldname="fecha"/>
            </column>
            <column name="start-time" numcolumns="2" order="120">
                <widget type="time" fieldname="hora_inicio"/>
            </column>
            <column name="end-time" numcolumns="2" order="130">
                <widget type="time" fieldname="hora_fin"/>
            </column>
            <column name="duration" numcolumns="2" order="140">
                <widget type="number" decimal="0" fieldname="duracion"/>
            </column>
            <column name="status" numcolumns="3" order="150">
                <widget type="select" fieldname="estado" translate="true">
                    <values title="pending">pendiente</values>
                    <values title="confirmed">confirmada</values>
                    <values title="waiting-room">en_sala</values>
                    <values title="in-progress">en_curso</values>
                    <values title="finished">finalizada</values>
                    <values title="cancelled-patient">cancelada_paciente</values>
                    <values title="cancelled-clinic">cancelada_clinica</values>
                    <values title="no-show">no_asistio</values>
                    <values title="rescheduled">reprogramada</values>
                </widget>
            </column>
            <column name="reason" numcolumns="12" order="160">
                <widget type="textarea" fieldname="motivo"/>
            </column>
            <column name="observations" numcolumns="12" order="170">
                <widget type="textarea" fieldname="observaciones"/>
            </column>
        </group>
        <group name="salon" title="Salon Booking" icon="fas fa-sync-alt" numcolumns="12">
            <column name="salon-service-id" numcolumns="3" order="210">
                <widget type="number" decimal="0" fieldname="salon_service_id"/>
            </column>
            <column name="salon-booking-id" numcolumns="3" order="220">
                <widget type="number" decimal="0" fieldname="salon_booking_id" readonly="true"/>
            </column>
            <column name="salon-customer-id" numcolumns="3" order="230">
                <widget type="number" decimal="0" fieldname="salon_customer_id" readonly="true"/>
            </column>
            <column name="salon-sync-status" numcolumns="3" order="240">
                <widget type="text" fieldname="salon_sync_status" readonly="true"/>
            </column>
            <column name="salon-synced-at" numcolumns="4" order="250">
                <widget type="text" fieldname="salon_synced_at" readonly="true"/>
            </column>
            <column name="salon-sync-error" numcolumns="8" order="260">
                <widget type="textarea" fieldname="salon_sync_error" readonly="true"/>
            </column>
        </group>
    </columns>
</view>
