<view>
    <columns>
        <group name="info" numcolumns="12" title="observations" icon="far fa-sticky-note">
            <column name="notes">
                <widget type="textarea" fieldname="observaciones" rows="6"/>
            </column>
        </group>
        <group name="hidden">
            <column name="id" numcolumns="2" display="none" order="0">
                <widget type="number" fieldname="idamortizacion" readonly="true"/>
            </column>
        </group>
    </columns>
</view>
