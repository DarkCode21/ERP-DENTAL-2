<view>
    <columns>
        <column name="code" order="100">
            <widget type="text" fieldname="id"/>
        </column>
        <column name="name" order="110">
            <widget type="text" fieldname="nombre"/>
        </column>
        <column name="credential" order="120">
            <widget type="text" fieldname="credentialid"/>
        </column>
        <column name="fiscal-number" display="none" order="130">
            <widget type="text" fieldname="cifnif"/>
        </column>
        <column name="company" order="140">
            <widget type="select" fieldname="idcompany">
                <values source="empresas" fieldcode="idempresa" fieldtitle="nombrecorto"/>
            </widget>
        </column>
        <column name="department" display="none" order="150">
            <widget type="select" fieldname="iddepartment">
                <values source="rrhh_departments" fieldcode="id" fieldtitle="name"/>
            </widget>
        </column>
        <column name="discharge-date" title="discharge-date-label" order="160">
            <widget type="date" fieldname="fechaalta"/>
        </column>
        <column name="gender" display="none" order="170">
            <widget type="select" fieldname="gender" translate="true">
                <values title="man">1</values>
                <values title="woman">2</values>
                <vales title="other">3</vales>
            </widget>
        </column>
        <column name="phone" order="180">
            <widget type="text" fieldname="telefono1"/>
        </column>
        <column name="phone2" display="none" order="190">
            <widget type="text" fieldname="telefono2"/>
        </column>
        <column name="email" order="200">
            <widget type="text" fieldname="email"/>
        </column>
    </columns>
    <rows>
        <row type="status" fieldname="dischargedate">
            <option title="suspended" color="danger">&gt;0</option>
        </row>
    </rows>
    <modals>
        <group name="discharge" title="discharge" icon="fas fa-file-import">
           <column name="date" numcolumns="12">
                <widget type="date" fieldname="discharge_date" required="true"/>
            </column>
            <column name="description" numcolumns="12">
                <widget type="textarea" fieldname="discharge_description" required="true" rows="5"/>
            </column>
        </group>
    </modals>
</view>
