<view>
    <columns>
        <column name="code" order="100">
            <widget type="text" fieldname="id"/>
        </column>
        <column name="company" order="110">
            <widget type="select" fieldname="idcompany">
                <values source="empresas" fieldcode="idempresa" fieldtitle="nombrecorto"/>
            </widget>
        </column>
        <column name="name" order="120">
            <widget type="text" fieldname="name"/>
        </column>
        <column name="date" order="130">
            <widget type="date" fieldname="creationdate"/>
        </column>
        <column name="starting-date" order="140">
            <widget type="date" fieldname="startdate"/>
        </column>
        <column name="end-date" order="150">
            <widget type="date" fieldname="enddate"/>
        </column>
        <column name="notes" display="none" order="160">
            <widget type="text" fieldname="note"/>
        </column>
    </columns>
</view>
