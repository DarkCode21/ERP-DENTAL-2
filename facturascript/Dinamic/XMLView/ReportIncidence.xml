<view>
    <columns>
        <column name="code" order="100">
            <widget type="text" fieldname="idemployee"/>
        </column>
        <column name="employee" order="110">
            <widget type="text" fieldname="name"/>
        </column>
        <column name="days" order="120">
            <widget type="number" decimal="0" fieldname="totaldays"/>
        </column>
        <column name="input" order="130">
            <widget type="number" decimal="0" fieldname="entries"/>
        </column>
        <column name="delays" order="135">
            <widget type="number" decimal="0" fieldname="delays"/>
        </column>
        <column name="withoutrest" order="140">
            <widget type="number" decimal="0" fieldname="withoutrest"/>
        </column>
        <column name="justified" order="150">
            <widget type="number" decimal="0" fieldname="justified"/>
        </column>
        <column name="leaves" title="sick-leave" order="160">
            <widget type="number" decimal="0" fieldname="leaves"/>
        </column>
        <column name="holidays" order="160">
            <widget type="number" decimal="0" fieldname="holidays"/>
        </column>
    </columns>
</view>
