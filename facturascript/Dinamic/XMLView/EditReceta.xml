<view>
    <columns>
        <group name="data" numcolumns="12">
            <column name="id" numcolumns="1" display="none" order="100">
                <widget type="text" fieldname="idreceta" readonly="true"/>
            </column>
            <column name="code" numcolumns="2" order="110">
                <widget type="text" fieldname="codreceta" readonly="dinamic" required="true"/>
            </column>
            <column name="description" order="120">
                <widget type="text" fieldname="descripcion"/>
            </column>
            <column name="last-production" numcolumns="2" order="170">
                <widget type="datetime" fieldname="ultimaproduccion" readonly="true"/>
            </column>
            <column name="total-cost" numcolumns="2" order="180">
                <widget type="money" fieldname="coste" readonly="true"/>
            </column>
        </group>
        <group name="others" numcolumns="6">
            <column name="warehouse-source" numcolumns="6" description="warehouse-source-desc" order="200">
                <widget type="select" fieldname="codalmacen" onclick="EditAlmacen" required="true">
                    <values source="almacenes" fieldcode="codalmacen" fieldtitle="nombre"/>
                </widget>
            </column>
            <column name="warehouse-target" numcolumns="6" description="warehouse-target-desc" order="210">
                <widget type="select" fieldname="codalmacen2" onclick="EditAlmacen" required="true">
                    <values source="almacenes" fieldcode="codalmacen" fieldtitle="nombre"/>
                </widget>
            </column>
        </group>
        <group name="notes" numcolumns="6">
            <column name="notes" order="100">
                <widget type="textarea" fieldname="observaciones"/>
            </column>
        </group>
    </columns>

    <rows>
        <row type="footer">
            <group name="productionProductCard" id="production-product-card" class="d-none" html="Block/ProductionProductModal.html.twig"/>
        </row>
    </rows>

    <modals>
        <group name="clone" title="clone-recipe" icon="fa-solid fa-clone">
            <column name="source_id" display="none" order="100">
                <widget type="text" fieldname="idreceta" readonly="true"/>
            </column>
            <column name="new-code" title="recipe" numcolumns="12" order="100">
                <widget type="text" fieldname="new_code" required="true"/>
            </column>
            <column name="new-name" title="description" numcolumns="12" order="100">
                <widget type="text" fieldname="new_name" required="true"/>
            </column>
            <column name="copy-ingredients" title="copy-ingredients" numcolumns="6" order="200">
                <widget type="checkbox" fieldname="copy_ingredients"/>
            </column>
            <column name="copy-production" title="copy-production" numcolumns="6" order="210">
                <widget type="checkbox" fieldname="copy_production"/>
            </column>
        </group>
        <group name="produce-product" title="produce-product" icon="fa-solid fa-cogs">
            <column name="code" display="none" order="0">
                <widget type="text" fieldname="idreceta" readonly="true"/>
            </column>
            <column name="recipe" display="none" order="0">
                <widget type="text" fieldname="codreceta" readonly="true"/>
            </column>
            <column name="quantity" numcolumns="6" order="100">
                <widget type="number" fieldname="quantity" min="1" required="true"/>
            </column>
            <column name="max-produce" numcolumns="6" order="100">
                <widget type="number" fieldname="maximum" readonly="true"/>
            </column>
            <column name="in-stock" numcolumns="4" order="500">
                <widget type="number" fieldname="stock" readonly="true"/>
            </column>
            <column name="reserved" numcolumns="4" order="500">
                <widget type="number" fieldname="reserved" readonly="true"/>
            </column>
            <column name="available" numcolumns="4" order="500">
                <widget type="number" fieldname="available" readonly="true"/>
            </column>
        </group>
    </modals>
</view>
