<view>
    <columns>
        <group name="data" numcolumns="12">
            <column name="code" display="none" numcolumns="2" order="100">
                <widget type="text" fieldname="id" readonly="true"/>
            </column>
            <column name="employee" display="none" order="110">
                <widget type="select" fieldname="idemployee" readonly="true" required="true">
                    <values source="rrhh_employees" fieldcode="id" fieldtitle="nombre"/>
                </widget>
            </column>
            <column name="cause" order="120">
                <widget type="select" fieldname="cause" required="true" translate="true">
                    <values title="accident">1</values>
                    <values title="disease">2</values>
                    <values title="others">99</values>
                </widget>
            </column>
            <column name="starting-date" order="210">
                <widget type="date" fieldname="startdate" icon="fa-solid fa-sign-in-alt"/>
            </column>
            <column name="end-date" order="220">
                <widget type="date" fieldname="enddate" icon="fa-solid fa-sign-out-alt"/>
            </column>
            <column name="totaldays" order="230">
                <widget type="number" fieldname="totaldays" readonly="true" icon="fa-solid fa-calculator"/>
            </column>
        </group>

        <group name="notes" numcolumns="12">
            <column name="notes" numcolumns="12" order="160">
                <widget type="textarea" fieldname="note" rows="2" icon="fa-solid fa-sticky-note"/>
            </column>
        </group>
    </columns>
</view>
