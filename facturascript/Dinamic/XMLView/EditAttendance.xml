<view>
    <columns>
        <group name="data" numcolumns="12" valign="bottom">
            <column name="code" numcolumns="2" order="100">
                <widget type="number" fieldname="id" icon="fa-solid fa-globe" readonly="true"/>
            </column>
            <column name="credential" numcolumns="2" order="120">
                <widget type="text" fieldname="credentialid" icon="fa-solid fa-fingerprint" hint="credential-hint" readonly="true"/>
            </column>
            <column name="origin" numcolumns="2" order="130">
                <widget type="select" fieldname="origin" translate="true">
                    <values title="manual">1</values>
                    <values title="justified">2</values>
                    <values title="external">3</values>
                </widget>
            </column>
            <column name="authorized" numcolumns="1" order="140">
                <widget type="checkbox" fieldname="authorized"/>
            </column>
        </group>
        <group name="data2" numcolumns="12">
            <column name="employee" numcolumns="4" order="100">
                <widget type="autocomplete" fieldname="idemployee" required="true">
                    <values source="rrhh_employees" fieldcode="id" fieldtitle="nombre"/>
                </widget>
            </column>
            <column name="date" numcolumns="3" order="110">
                <widget type="date" fieldname="checkdate"/>
            </column>
            <column name="hour" numcolumns="3" order="120">
                <widget type="time" fieldname="checktime"/>
            </column>
            <column name="type" numcolumns="2" order="130">
                <widget type="select" fieldname="kind" required="true" translate="true">
                    <values title="input">1</values>
                    <values title="output">2</values>
                </widget>
            </column>
        </group>
        <group name="absence" numcolumns="7" title="absence" icon="fa-solid fa-unlink">
            <column name="absence-concept" numcolumns="5" order="100">
                <widget type="select" fieldname="idabsenceconcept">
                    <values source="rrhh_absencesconcepts" fieldcode="id" fieldtitle="name"/>
                </widget>
            </column>
            <column name="description" numcolumns="7" order="110">
                <widget type="text" fieldname="note"/>
            </column>
        </group>

        <group name="audit" numcolumns="5" title="audit" icon="fa-solid fa-person-circle-question">
            <column name="reason" display="12" order="110">
                <widget type="text" fieldname="reason" required="true"/>
            </column>
        </group>
    </columns>
</view>
