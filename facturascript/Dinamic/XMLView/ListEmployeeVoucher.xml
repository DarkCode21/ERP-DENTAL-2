<view>
    <columns>
            <column name="code" order="100">
                <widget type="text" fieldname="id"/>
            </column>
            <column name="description" order="110">
                <widget type="text" fieldname="name"/>
            </column>
            <column name="employee" order="120">
                <widget type="autocomplete" fieldname="idemployee">
                    <values source="rrhh_employees" fieldcode="id" fieldtitle="nombre"/>
                </widget>
            </column>
            <column name="date" order="130">
                <widget type="date" fieldname="startdate"/>
            </column>
            <column name="amount" display="right" order="140">
                <widget type="money" fieldname="amount"/>
            </column>
            <column name="pending" display="right" order="150">
                <widget type="money" fieldname="pending"/>
            </column>
            <column name="liquidated" order="160">
                <widget type="date" fieldname="enddate"/>
            </column>
            <column name="accounting-entry" display="none" order="200">
                <widget type="autocomplete" fieldname="idaccounting">
                    <values source="asientos" fieldcode="idasiento" fieldtitle="numero"/>
                </widget>
            </column>
    </columns>
    <rows>
        <row type="status" fieldname="paid">
            <option title="pending" color="danger">0</option>
        </row>
    </rows>
</view>
