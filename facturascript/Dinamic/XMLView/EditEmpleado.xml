<?xml version="1.0" encoding="UTF-8"?>
<view>
    <columns>
        <group name="data" numcolumns="12">
            <column name="code" display="none" order="100">
                <widget type="text" fieldname="idempleado"/>
            </column>
            <column name="name" order="110" numcolumns="4">
                <widget type="text" fieldname="nombre" required="true"/>
            </column>
			<column name="fiscal-id" titleurl="EditSettings?activetab=EditIdentificadorFiscal" numcolumns="2" order="130">
                <widget type="select" fieldname="idfiscal" required="true">
                    <values source="idsfiscales" fieldcode="tipoidfiscal" fieldtitle="tipoidfiscal"/>
                </widget>
            </column>
 			<column name="fiscal-number" numcolumns="2" order="150">
                <widget type="text" fieldname="numfiscal" maxlength="30" icon="fas fa-id-card"/>
            </column>

			<column name="cccss" numcolumns="2" order="160">
                <widget type="text" fieldname="cccss" maxlength="30"/>
            </column>

			<column name="naf" numcolumns="2" order="170">
                <widget type="text" fieldname="naf" maxlength="30"/>
            </column>

			<column name="group-cotizacion" numcolumns="2" order="180">
                <widget type="text" fieldname="grupocotizacion" maxlength="30"/>
            </column>
			
			<column name="city" numcolumns="2" order="190">
                <widget type="text" fieldname="localidad" maxlength="30"/>
            </column>
			
			<column name="company" numcolumns="2" order="200">
				<widget type="select" fieldname="idempresa" onclick="EditEmpresa">
					<values source="empresas" fieldcode="idempresa" fieldtitle="nombrecorto"/>
				</widget>
        	</column>
			<column name="address" numcolumns="6" order="210">
                <widget type="text" fieldname="direccion"/>
            </column>	
		</group>	
	</columns>
</view>
