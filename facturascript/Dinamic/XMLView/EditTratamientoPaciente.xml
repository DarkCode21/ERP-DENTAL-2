<?xml version="1.0" encoding="UTF-8"?>
<view>
    <columns>
        <group name="main" numcolumns="12">
            <column name="code" display="none" order="100">
                <widget type="text" fieldname="id"/>
            </column>
            <column name="patient" numcolumns="4" order="105">
                <widget type="select" fieldname="idpaciente"/>
            </column>
            <column name="reference" numcolumns="4" order="107">
                <widget type="text" fieldname="referencia_servicio"/>
            </column>
            <column name="salon-service-id" numcolumns="3" order="108">
                <widget type="number" decimal="0" fieldname="salon_service_id"/>
            </column>
            <column name="start-date" numcolumns="3" order="110">
                <widget type="date" fieldname="fecha_inicio"/>
            </column>
            <column name="end-date" numcolumns="3" order="120">
                <widget type="date" fieldname="fecha_fin"/>
            </column>
            <column name="clinical-status" numcolumns="3" order="130">
                <widget type="text" fieldname="estado_clinico"/>
            </column>
            <column name="economic-status" numcolumns="3" order="140">
                <widget type="text" fieldname="estado_economico"/>
            </column>
            <column name="price" numcolumns="3" order="150">
                <widget type="money" fieldname="precio"/>
            </column>
            <column name="discount" numcolumns="2" order="160">
                <widget type="number" decimal="2" fieldname="descuento"/>
            </column>
            <column name="observations" numcolumns="12" order="170">
                <widget type="textarea" fieldname="observaciones"/>
            </column>
        </group>
    </columns>
</view>
