<?xml version="1.0" encoding="UTF-8"?>
<view>
    <columns>
        <column name="code" display="none" order="100">
            <widget type="text" fieldname="id"/>
        </column>
        <column name="patient" order="105">
            <widget type="text" fieldname="paciente_nombre"/>
        </column>
        <column name="date" order="110">
            <widget type="date" fieldname="fecha"/>
        </column>
        <column name="start-time" order="120">
            <widget type="text" fieldname="hora_inicio"/>
        </column>
        <column name="end-time" order="130">
            <widget type="text" fieldname="hora_fin"/>
        </column>
        <column name="status" display="center" order="150">
            <widget type="text" fieldname="estado" translate="true"/>
        </column>
        <column name="reason" order="160">
            <widget type="text" fieldname="motivo"/>
        </column>
    </columns>
</view>
