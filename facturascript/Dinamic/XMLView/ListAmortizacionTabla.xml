<view>
    <columns>
        <column name="code" display="none" order="100">
            <widget type="text" fieldname="id"/>
        </column>
        <column name="type" order="110">
            <widget type="text" fieldname="grouptypedesc"/>
        </column>
        <column name="group" order="120">
            <widget type="text" fieldname="groupdesc"/>
        </column>
        <column name="description" order="130">
            <widget type="text" fieldname="name"/>
        </column>
        <column name="coefficient" display="right" order="160">
            <widget type="number" decimal="2" fieldname="coefficient"/>
        </column>
        <column name="years" display="right" order="170">
            <widget type="text" fieldname="period"/>
        </column>
    </columns>
</view>
