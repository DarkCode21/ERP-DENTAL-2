<view>
    <columns>
        <column name="code" display="none" order="100">
            <widget type="text" fieldname="id"/>
        </column>
        <column name="type" order="110">
            <widget type="text" fieldname="grouptypedesc"/>
        </column>
        <column name="group" order="120">
            <widget type="text" fieldname="groupdesc"/>
        </column>
        <column name="account" order="130">
            <widget type="text" fieldname="code"/>
        </column>
        <column name="description" order="140">
            <widget type="autocomplete" fieldname="code">
                <values source="cuentas" fieldcode="codcuenta" fieldtitle="descripcion"/>
            </widget>
        </column>
    </columns>
</view>
