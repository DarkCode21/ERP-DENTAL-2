<view>
    <columns>
        <column name="code" display="none" order="90">
            <widget type="text" fieldname="idcaja"/>
        </column>
        <column name="start-money" display="right" order="100">
            <widget type="money" fieldname="dineroini"/>
        </column>
        <column name="end-money" order="110">
            <widget type="money" fieldname="dinerofin"/>
        </column>
        <column name="income" display="right" order="120">
            <widget type="money" fieldname="ingresos"/>
        </column>
        <column name="difference" order="130">
            <widget type="money" fieldname="diferencia"/>
        </column>
        <column name="start-date" display="right" order="140">
            <widget type="text" fieldname="fechaini"/>
        </column>
        <column name="end-date" order="150">
            <widget type="text" fieldname="fechafin"/>
        </column>
        <column name="user" order="160">
            <widget type="select" fieldname="nick">
                <values source="users" fieldcode="nick" fieldtitle="nick"/>
            </widget>
        </column>
        <column name="tickets" display="right" order="170">
            <widget type="text" fieldname="numtickets"/>
        </column>
        <column name="observations" order="180">
            <widget type="text" fieldname="observaciones"/>
        </column>
    </columns>
    <rows>
        <row type="status">
            <option color="success" fieldname="fechafin" title="open">null:</option>
            <option color="warning" fieldname="fechafin" title="closed">notnull:</option>
        </row>
    </rows>
</view>
