{% extends "Master/PanelController.html.twig" %}

{% block bodyHeaderOptions %}
	{{ parent() }}
{% endblock %}

{% block body %}
	<div
		class="container-fluid">

		{# ===================== KPIS ===================== #}
		<div class="row mt-3">

			<div class="col-xl-3 col-md-6 mb-3">
				<div class="card border-left-primary shadow h-100">
					<div class="card-body">
						<div class="row align-items-center">
							<div class="col">
								<div class="text-xs text-primary text-uppercase mb-1">
									Citas Hoy
								</div>
								<div class="h2 mb-0 font-weight-bold">
									{{ fsc.citasHoy|default(0) }}
								</div>
							</div>
							<div class="col-auto">
								<i class="fas fa-calendar-day fa-3x text-muted"></i>
							</div>
						</div>
					</div>
				</div>
			</div>

			<div class="col-xl-3 col-md-6 mb-3">
				<div class="card border-left-success shadow h-100">
					<div class="card-body">
						<div class="row align-items-center">
							<div class="col">
								<div class="text-xs text-success text-uppercase mb-1">
									Pacientes Totales
								</div>
								<div class="h2 mb-0 font-weight-bold">
									{{ fsc.totalPacientes|default(0) }}
								</div>
							</div>
							<div class="col-auto">
								<i class="fas fa-users fa-3x text-muted"></i>
							</div>
						</div>
					</div>
				</div>
			</div>

			<div class="col-xl-3 col-md-6 mb-3">
				<div class="card border-left-warning shadow h-100">
					<div class="card-body">
						<div class="row align-items-center">
							<div class="col">
								<div class="text-xs text-warning text-uppercase mb-1">
									Pendientes Confirmación
								</div>
								<div class="h2 mb-0 font-weight-bold">
									{{ fsc.citasPendientes|default(0) }}
								</div>
							</div>
							<div class="col-auto">
								<i class="fas fa-clock fa-3x text-muted"></i>
							</div>
						</div>
					</div>
				</div>
			</div>

			<div class="col-xl-3 col-md-6 mb-3">
				<div class="card border-left-danger shadow h-100">
					<div class="card-body">
						<div class="row align-items-center">
							<div class="col">
								<div class="text-xs text-danger text-uppercase mb-1">
									No Asistieron
								</div>
								<div class="h2 mb-0 font-weight-bold">
									{{ fsc.noAsistieron|default(0) }}
								</div>
							</div>
							<div class="col-auto">
								<i class="fas fa-user-times fa-3x text-muted"></i>
							</div>
						</div>
					</div>
				</div>
			</div>

		</div>


		{# ===================== ACCIONES RAPIDAS ===================== #}
		<div class="row">

			<div class="col-md-12 mb-4">
				<div class="card shadow">
					<div class="card-header">
						<h5 class="mb-0">
							<i class="fas fa-bolt"></i>
							Acciones rápidas
						</h5>
					</div>

					<div class="card-body">

						<div class="row">

							<div class="col-md-2 mb-2">
								<a href="EditPaciente?action=new" class="btn btn-primary btn-block p-3">
									<i class="fas fa-user-plus fa-2x d-block mb-2"></i>
									Nuevo paciente
								</a>
							</div>

							<div class="col-md-2 mb-2">
								<a href="EditCita?action=new" class="btn btn-success btn-block p-3">
									<i class="fas fa-calendar-plus fa-2x d-block mb-2"></i>
									Nueva cita
								</a>
							</div>

							<div class="col-md-2 mb-2">
								<a href="ListPaciente" class="btn btn-info btn-block p-3">
									<i class="fas fa-users fa-2x d-block mb-2"></i>
									Pacientes
								</a>
							</div>

							<div class="col-md-2 mb-2">
								<a href="ListGabinete" class="btn btn-warning btn-block p-3">
									<i class="fas fa-clinic-medical fa-2x d-block mb-2"></i>
									Gabinetes
								</a>
							</div>

							<div class="col-md-2 mb-2">
								<a href="ListCita" class="btn btn-secondary btn-block p-3">
									<i class="fas fa-calendar fa-2x d-block mb-2"></i>
									Agenda
								</a>
							</div>

							<div class="col-md-2 mb-2">
								<a href="ListHistorial" class="btn btn-light btn-block p-3">
									<i class="fas fa-notes-medical fa-2x d-block mb-2"></i>
									Historiales
								</a>
							</div>

							<div class="col-md-2 mb-2">
								<a href="ListTratamientoPaciente" class="btn btn-primary btn-block p-3">
									<i class="fas fa-teeth fa-2x d-block mb-2"></i>
									Tratamientos
								</a>
							</div>

							<div class="col-md-2 mb-2">
								<a href="ListArchivo" class="btn btn-dark btn-block p-3">
									<i class="fas fa-file-medical fa-2x d-block mb-2"></i>
									Archivos
								</a>
							</div>

						</div>

					</div>
				</div>
			</div>

		</div>


		{# ===================== DOS COLUMNAS ===================== #}

		<div
			class="row">

			{# Próximas citas #}
			<div class="col-lg-8 mb-4">

				<div class="card shadow">

					<div class="card-header">
						<h5 class="mb-0">
							<i class="fas fa-calendar-alt"></i>
							Próximas citas
						</h5>
					</div>

					<div class="card-body p-0">

						<table class="table table-hover mb-0">

							<thead class="thead-light">
								<tr>
									<th>Hora</th>
									<th>Paciente</th>
									<th>Especialista</th>
									<th>Gabinete</th>
									<th>Estado</th>
								</tr>
							</thead>

							<tbody>

								{% for cita in fsc.proximasCitas %}

									<tr>
										<td>{{ cita.hora_inicio }}</td>
										<td>{{ cita.pacienteNombre }}</td>
										<td>{{ cita.especialistaNombre }}</td>
										<td>{{ cita.gabineteNombre }}</td>

										<td>
											<span class="badge badge-primary">
												{{ cita.estado }}
											</span>
										</td>
									</tr>

								{% else %}

									<tr>
										<td colspan="5" class="text-center text-muted p-4">
											No hay citas programadas
										</td>
									</tr>

								{% endfor %}

							</tbody>

						</table>

					</div>

				</div>

			</div>


			{# Alertas #}
			<div class="col-lg-4 mb-4">

				<div class="card shadow">

					<div class="card-header bg-danger text-white">
						<h5 class="mb-0">
							<i class="fas fa-exclamation-triangle"></i>
							Alertas
						</h5>
					</div>

					<div class="card-body">

						<ul class="list-group">

							<li class="list-group-item d-flex justify-content-between">
								Citas sin confirmar
								<span class="badge badge-warning">
									{{ fsc.citasPendientes|default(0) }}
								</span>
							</li>

							<li class="list-group-item d-flex justify-content-between">
								Revisiones pendientes
								<span class="badge badge-danger">
									{{ fsc.revisionesPendientes|default(0) }}
								</span>
							</li>

							<li class="list-group-item d-flex justify-content-between">
								Tratamientos activos
								<span class="badge badge-info">
									{{ fsc.tratamientosActivos|default(0) }}
								</span>
							</li>

						</ul>

					</div>

				</div>

			</div>

		</div>

	</div>
{% endblock %}
