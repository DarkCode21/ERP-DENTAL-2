{#
 Plugin ReportTaxesPivot para FacturaScripts
 Informe de impuestos pivotado: una fila por factura con columnas dinámicas por tipo de IVA.
#}
{% extends "Master/MenuBghTemplate.html.twig" %}

{% block bodyHeaderOptions %}
    <br/><br/><br/><br/><br/>
{% endblock %}

{% block body %}
    <form id="fReportTaxesPivot" method="post">
        {{ formToken() }}
        <input type="hidden" name="action" value="export"/>
        <input type="hidden" name="source" value="sales"/>
        <div class="container" style="margin-top: -90px;">
            <div class="row">
                <div class="col-12">
                    <div class="card shadow mb-3">
                        <div class="card-body">
                            <h1 class="h3 mb-1">
                                <i class="{{ fsc.getPageData().icon }} mr-2"></i>
                                {{ trans('taxes-pivot') }}
                            </h1>
                            <p class="text-muted mb-4">
                                {{ trans('taxes-pivot-p') }}
                            </p>
                            <div class="form-row">
                                {% if fsc.empresa.count() > 1 %}
                                    <div class="col-sm mb-3">
                                        {{ trans('company') }}
                                        <select name="idempresa" class="form-control">
                                            {% for empresa in fsc.empresa.all() %}
                                                <option value="{{ empresa.idempresa }}"
                                                    {{ empresa.idempresa == fsc.idempresa ? 'selected' : '' }}>
                                                    {{ empresa.nombrecorto | raw }}
                                                </option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                {% else %}
                                    <input type="hidden" name="idempresa" value="{{ fsc.idempresa }}"/>
                                {% endif %}
                                <div class="col-sm mb-3">
                                    {{ trans('serie') }}
                                    <select name="codserie" class="form-control">
                                        <option value="">{{ trans('all') }}</option>
                                        <option value="">------</option>
                                        {% for serie in fsc.serie.all({}, {'descripcion': 'ASC'}, 0, 0) %}
                                            <option value="{{ serie.codserie }}"
                                                {{ serie.codserie == fsc.codserie ? 'selected' : '' }}>
                                                {{ serie.descripcion | raw }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="col-sm mb-3">
                                    {{ trans('currency') }}
                                    <select name="coddivisa" class="form-control">
                                        {% for divisa in fsc.divisa.all({}, {'descripcion': 'ASC'}, 0, 0) %}
                                            <option value="{{ divisa.coddivisa }}"
                                                {{ divisa.coddivisa == fsc.coddivisa ? 'selected' : '' }}>
                                                {{ divisa.descripcion | raw }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="col-sm mb-3">
                                    {{ trans('country') }}
                                    <select name="codpais" class="form-control">
                                        <option value="">{{ trans('all') }}</option>
                                        <option value="">------</option>
                                        {% for pais in fsc.pais.all({}, {'nombre': 'ASC'}, 0, 0) %}
                                            <option value="{{ pais.codpais }}"
                                                {{ pais.codpais == fsc.codpais ? 'selected' : '' }}>
                                                {{ pais.nombre | raw }}
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="col-sm-3 mb-3">
                                    {{ trans('date') }}
                                    <select name="type-date" class="form-control">
                                        <option value="create" {{ fsc.typeDate == 'create' ? 'selected' : '' }}>
                                            {{ trans('creation-date') }}
                                        </option>
                                        <option value="accrual" {{ fsc.typeDate == 'accrual' ? 'selected' : '' }}>
                                            {{ trans('accrual-date') }}
                                        </option>
                                    </select>
                                </div>
                                <div class="col-sm-3 mb-3">
                                    {{ trans('from-date') }}
                                    <input type="date" name="datefrom" value="{{ fsc.datefrom }}"
                                           class="form-control" required/>
                                </div>
                                <div class="col-sm-3 mb-3">
                                    {{ trans('until-date') }}
                                    <input type="date" name="dateto" value="{{ fsc.dateto }}"
                                           class="form-control" required/>
                                </div>
                                <div class="col-sm-3 mb-3">
                                    {{ trans('format') }}
                                    <select name="format" class="form-control">
                                        <option value="PDF">PDF</option>
                                        <option value="CSV">CSV</option>
                                        <option value="XLS">Excel</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-row mt-2">
                                <div class="col-12">
                                    <div class="alert alert-info mb-0">
                                        <i class="fa-solid fa-circle-info mr-1"></i>
                                        {{ trans('taxes-pivot-info') }}
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer">
                            <div class="form-row">
                                <div class="col-sm">
                                    <button type="button" onclick="sendReport('purchases')"
                                            class="btn btn-lg btn-block btn-secondary btn-spin-action">
                                        {{ trans('purchases') }}
                                    </button>
                                </div>
                                <div class="col-sm">
                                    <button type="button" onclick="sendReport('sales')"
                                            class="btn btn-lg btn-block btn-primary btn-spin-action">
                                        {{ trans('sales') }}
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        function sendReport(source) {
            animateSpinner('add');
            let form = document.getElementById('fReportTaxesPivot');
            form.source.value = source;
            form.submit();
            if (form.format.value === 'XLS' || form.format.value === 'CSV') {
                setTimeout(function () { animateSpinner('remove'); }, 3000);
            }
        }
    </script>
{% endblock %}
