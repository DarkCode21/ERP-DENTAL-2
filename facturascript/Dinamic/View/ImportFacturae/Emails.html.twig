{% extends "Master/MenuBghTemplate.html.twig" %}

{% block css %}
    {{ parent() }}
{% endblock %}

{% block bodyHeaderOptions %}
    <br/>
    <br/>
    <br/>
    <br/>
    <br/>
{% endblock %}

{% block body %}
    {{ parent() }}
    <div class="container" style="margin-top: -80px;">
        <div class="row">
            <div class="col-md-12">
                <form method="post">
                    {{ formToken() }}
                    <input type="hidden" name="action" value="email-file">
                    <div class="card shadow">
                        <div class="card-body">
                            <h1 class="card-title">
                                <i class="fa-solid fa-qrcode mr-2"></i> {{ trans('mails-factura-e') }}
                            </h1>
                            <p class="card-text">{{ trans('mails-factura-e-p') }}</p>
                            <div class="form-row">
                                <div class="col-sm-6">
                                    <div class="form-group">
                                        <label class="mb-1" for="file_warehouse">{{ trans('warehouse') }}</label>
                                        <select name="codalmacen" class="form-control" id="file_warehouse" required>
                                            {% for company in fsc.empresa.all() %}
                                                <optgroup label="{{ company.nombre }}">
                                                    {% for warehouse in company.getWarehouses() %}
                                                        {% if warehouse.isDefault() %}
                                                            <option value="{{ warehouse.codalmacen }}" selected>
                                                                {{ warehouse.nombre }}
                                                            </option>
                                                        {% else %}
                                                            <option value="{{ warehouse.codalmacen }}">
                                                                {{ warehouse.nombre }}
                                                            </option>
                                                        {% endif %}
                                                    {% endfor %}
                                                </optgroup>
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="form-group">
                                        <label class="mb-1" for="file_serie">{{ trans('serie') }}</label>
                                        <select name="codserie" class="form-control" id="file_serie" required>
                                            {% for serie in fsc.serie.all() %}
                                                {% if serie.isDefault() %}
                                                    <option value="{{ serie.codserie }}" selected>
                                                        {{ serie.descripcion }}
                                                    </option>
                                                {% else %}
                                                    <option value="{{ serie.codserie }}">
                                                        {{ serie.descripcion }}
                                                    </option>
                                                {% endif %}
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-striped table-hover mb-0">
                                <thead>
                                <tr>
                                    <th>{{ trans('date') }}</th>
                                    <th>{{ trans('form') }}</th>
                                    <th>{{ trans('subject') }}</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for item in fsc.mail_list %}
                                    <tr>
                                        <td>{{ item.date }}</td>
                                        <td>{{ item.from }}</td>
                                        <td>
                                            <p>{{ item.subject }}</p>
                                            {% for file in item.files %}
                                                <button type="submit" name="file_name" value="{{ file }}"
                                                        class="btn btn-primary btn-sm">
                                                    {{ file }}
                                                </button>
                                            {% endfor %}
                                        </td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
{% endblock %}