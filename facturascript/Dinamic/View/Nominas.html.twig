{% extends "Master/MenuBghTemplate.html.twig" %}

{% block body %}
    {{ parent() }}
    {% set divisa = fsc.getDivisa() %}
    <div class="bg-light pt-3 pb-5">
        <div class="container">
            <div class="row">
                <div class="col">
                    <h1 class="h2">
                        <i class="fas fa-users"></i> {{ i18n.trans('new-nomina') }}
                    </h1>
                    <small class="text-secondary">{{ i18n.trans('pos-nomina') }}</small>
                </div>
            </div>
        </div>
    </div>
    <div class="container" style="margin-top: -40px;">
        <div class="row">
            <div class="col-sm">
                <form action="{{ fsc.url() }}" method="post" onsubmit="return false;">
                    <input type="hidden" name="action" value="start-nomina"/>
                    <input type="hidden" name="idnomina" value="{{ fsc.tpv.idtpv }}"/>
                    <div class="card shadow mb-4">
                        <div class="card-body">
							<div class="form-row">
	                              <div class="col-sm-3 pb-3">
      							  	{{ i18n.trans('employee')  }}
									<input type="text" name="query" id="employeeNominas" class="form-control form-control-sm">
								  	<input type="hidden" name="codempleado" />
								  </div>
								  
								  <div class="col-sm-2 pb-3">
      							  	{{ i18n.trans('nif')  }}
									<input type="text" name="cifnif" id="cifnif" class="form-control form-control-sm">
								  </div>

								  <div class="col-sm-5 pb-3">
      							  	{{ i18n.trans('address')  }}
									<input type="text" name="direccion" class="form-control form-control-sm">
								  </div>

								  <div class="col-sm-2 pb-3">
      							  	{{ i18n.trans('home')  }}
									<input type="text" name="localidad" class="form-control form-control-sm">
								  </div>
							</div>
							
							<div class="form-row border-bottom">
	                              <div class="col-sm-2 pb-3">
      							  	{{ i18n.trans('cif')  }}
									<input type="text" name="cif" class="form-control form-control-sm">
								  </div>
								  
								  <div class="col-sm-3 pb-3">
      							  	{{ i18n.trans('group-professional')  }}
									<input type="text" name="grupoprofesional" class="form-control form-control-sm">
								  </div>

								  <div class="col-sm-2 pb-3">
      							  	{{ i18n.trans('ccss')  }}
									<input type="text" name="ccss" class="form-control form-control-sm">
								  </div>

								  <div class="col-sm-2 pb-3">
      							  	{{ i18n.trans('naf')  }}
									<input type="text" name="naf" class="form-control form-control-sm">
								  </div>

								  <div class="col-sm-3 pb-3">
      							  	{{ i18n.trans('group-cotizacion')  }}
									<input type="text" name="grupocotizacion" class="form-control form-control-sm">
								  </div>
							</div>

							<div class="form-row pt-2">
								<div class="col-sm-2 py-1">
									{{ i18n.trans('period-liquidacion')  }}
								</div>
								<div class="col-sm-2 pb-2">
									<input type="date" name="inicioliquidacion" id="inicioliquidacion" 
										class="form-control form-control-sm" 
										onchange="calcularPeriodo()">
								</div>
								<div class="col-sm-1 py-1 px-auto">
									{{ i18n.trans('to')  }}
								</div>
								<div class="col-sm-2 pb-2">
									<input type="date" name="finliquidacion" id="finliquidacion" class="form-control form-control-sm"
									onchange="calcularPeriodo()">
								</div>
								<div class="col-sm-1 py-1 px-auto">
									{{ i18n.trans('total-days')  }}
								</div>
								<div class="col-sm-1 pb-2">
									<input type="text" name="totaldias" id="totaldias" class="form-control form-control-sm text-center" readonly="">
								</div>
						    </div>
							
							<div class="form-row pt-2">
								<div class="col-sm-6"></div>
								<div class="col-sm-3 text-center"><strong>{{ i18n.trans('amount')  }}</strong></div>
								<div class="col-sm-3 text-center"><strong>{{ i18n.trans('totals')  }}</strong></div>
							</div>
							
							<div class="form-row">
								<div class="col-sm-6">
									<h4>I. DEVENGOS</h4>
									<h5>1. Percepciones Salariales <small>(Sujetas a cotización)</small></h5>
								</div>
							</div>
							
							<div class="form-row">
								<div class="col-sm-6">
									<p class="mb-0">Salario Base</p>
								</div>
								<div class="col-sm-3">
									<p class="col-sm-9 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right"
										 	id="salariobase"
											name="salariobase" onkeypress="return isNumberKey(event)" 
											onchange="calcularTotalDevengado()" />
									</p>
								</div>
							</div>
							
							<div class="form-row">
								<div class="col-sm-6">
									<p class="mb-0">Complementos Salariales</p>
								</div>

								<div class="col-sm-3">
									<p class="col-sm-9 mx-auto">
										<input type="text" step="0.01" min="0" 
										  class="form-control form-control-sm text-right" name="complementossalariales" 
										  id="complementossalariales" onchange="calcularTotalDevengado()"
										   onkeypress="return isNumberKey(event)" />
									</p>
								</div>
							</div>
							<div class="form-row">
								<div class="col-sm-6">
									<p class="mb-0">Horas Extras Fuerza Mayor</p>
								</div>

								<div class="col-sm-3">
									<p class="col-sm-9 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right" 
											name="extrasfuerzamayor" id="extrasfuerzamayor" onchange="calcularTotalDevengado()"
											onkeypress="return isNumberKey(event)" />
									</p>
								</div>	
							</div>

							<div class="form-row">
								<div class="col-sm-6">
									<p class="mb-0">Horas Extras Resto</p>
								</div>

								<div class="col-sm-3">
									<p class="col-sm-9 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right" 
										name="extrasresto" 
										id="extrasresto" onchange="calcularTotalDevengado()" onkeypress="return isNumberKey(event)"  />
									</p>
								</div>
							</div>

							<div class="form-row">
								<div class="col-sm-6">
									<p class="mb-0">Horas Complementarias (contratos a tiempo parcial)</p>
								</div>

								<div class="col-sm-3">
									<p class="col-sm-9 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right" 
											name="horascomplementarias" id="horascomplementarias" 
											onkeypress="return isNumberKey(event)" onchange="calcularTotalDevengado()" />
									</p>
								</div>
							</div>

							<div class="form-row">
								<div class="col-sm-6">
									<p class="mb-0">Gratificaciones extraordinarias</p>
								</div>

								<div class="col-sm-3">
									<p class="col-sm-9 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right"
										 name="gratificacionesextraordinarias" id="gratificacionesextraordinarias"
										 onchange="calcularTotalDevengado()"
										 onkeypress="return isNumberKey(event)" />
									</p>
								</div>
							</div>

							<div class="form-row">
								<div class="col-sm-6">
									<p class="mb-0">Salario en especie</p>
								</div>

								<div class="col-sm-3">
									<p class="col-sm-9 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right"
										name="salarioespecie" 
										id="salarioespecie" onchange="calcularTotalDevengado()"
										onkeypress="return isNumberKey(event)" />
									</p>
								</div>
							</div>

							<div class="form-row">
								<div class="col-sm-6">
									<h5>2. Percepciones no salariales <small>(Excluidas de cotización)</small></h5>
								</div>
							</div>

							<div class="form-row">
								<div class="col-sm-6">
									<p class="mb-0">Indemnizaciones o suplidos</p>
								</div>

								<div class="col-sm-3">
									<p class="col-sm-9 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right" 
										name="indemnizaciones" id="indemnizaciones" onchange="calcularTotalDevengado()" onkeypress="return isNumberKey(event)" />
									</p>
								</div>
							</div>

							<div class="form-row">
								<div class="col-sm-6">
									<p class="mb-0">Prestaciones e indemnizaciones de la Seguridad Social</p>
								</div>

								<div class="col-sm-3">
									<p class="col-sm-9 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right" 
										name="seguridadsocial" id="seguridadsocial" onchange="calcularTotalDevengado()" onkeypress="return isNumberKey(event)" />
									</p>
								</div>
							</div>

							<div class="form-row">
								<div class="col-sm-6">
									<p class="mb-0">Indemnizaciones por traslados, suspensiones o despidos</p>
								</div>

								<div class="col-sm-3">
									<p class="col-sm-9 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right" 
										name="despidos" id="despidos" onchange="calcularTotalDevengado()" onkeypress="return isNumberKey(event)"  />
									</p>
								</div>
							</div>

							<div class="form-row">
								<div class="col-sm-6">
									<p class="mb-0">Otras percepciones salariales</p>
								</div>

								<div class="col-sm-3">
									<p class="col-sm-9 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right" 
										name="otraspercepciones" id="otraspercepciones" onchange="calcularTotalDevengado()" onkeypress="return isNumberKey(event)" />
									</p>
								</div>
							</div>

							<div class="form-row">
								<div class="col-sm-9 text-center">
									<h4>A. TOTAL DEVENGADO</h4>
								</div>

								<div class="col-sm-3">
									<p class="col-sm-9 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right input-bold" 
										name="totaldevengado" id="totaldevengado" readonly="" />
									</p>
								</div>
							</div>

							<div class="form-row">
								<div class="col-sm-6">
									<h4>II. DEDUCCIONES</h4>
									<h5>1. Aportaciones del trabajador a las cotizaciones a la S.S. Y conceptos de recaudación conjunta:</small></h5>
								</div>
							</div>

							<div class="form-row">
								<div class="col-sm-3">
									<p class="mb-0">Contingencias Comunes</p>
								</div>

								<div class="col-sm-2">
									<p class="col-sm-12 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right" 
										name="porc_contingencias" id="porc_contingencias" onkeypress="return isNumberKey(event)"
										onchange="calcularTotalAportaciones()"/>
									</p>
								</div>

								<div class="col-sm-1 my-1">%</div>

								<div class="col-sm-3">
									<p class="col-sm-9 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right"
 										 name="monto_contingencias" id="monto_contingencias" onkeypress="return isNumberKey(event)"
										 onchange="calcularTotalAportaciones()"/>
									</p>
								</div>
							</div>

							<div class="form-row">
								<div class="col-sm-3">
									<p class="mb-0">Desempleo</p>
								</div>

								<div class="col-sm-2">
									<p class="col-sm-12 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right" 
										name="porc_desempleo" id="porc_desempleo" onkeypress="return isNumberKey(event)"
										onchange="calcularTotalAportaciones()"/>
									</p>
								</div>
								
								<div class="col-sm-1 my-1">%</div>
								
								<div class="col-sm-3">
									<p class="col-sm-9 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right"
 										 name="monto_desempleo" id="monto_desempleo" onkeypress="return isNumberKey(event)"
										 onchange="calcularTotalAportaciones()"/>
									</p>
								</div>
							</div>

							<div class="form-row">
								<div class="col-sm-3">
									<p class="mb-0">Formación Profesional</p>
								</div>

								<div class="col-sm-2">
									<p class="col-sm-12 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right" 
										name="porc_profesional" id="porc_profesional" onkeypress="return isNumberKey(event)" 
										onchange="calcularTotalAportaciones()"/>
									</p>
								</div>
								
								<div class="col-sm-1 my-1">%</div>
								
								<div class="col-sm-3">
									<p class="col-sm-9 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right"
 										 name="monto_profesional" id="monto_profesional" onkeypress="return isNumberKey(event)" 
										 onchange="calcularTotalAportaciones()"/>
									</p>
								</div>
							</div>

							<div class="form-row">
								<div class="col-sm-3">
									<p class="mb-0">Horas Extras Fuerza Mayor</p>
								</div>

								<div class="col-sm-2">
									<p class="col-sm-12 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right" 
										name="porc_extras_fuerza_mayor" id="porc_extras_fuerza_mayor" 
										onkeypress="return isNumberKey(event)" 
										onchange="calcularTotalAportaciones()"/>
									</p>
								</div>

								<div class="col-sm-1 my-1">%</div>
								
								<div class="col-sm-3">
									<p class="col-sm-9 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right"
 										 name="monto_extras_fuerza_mayor" 
										 id="monto_extras_fuerza_mayor" 
										 onkeypress="return isNumberKey(event)"
										 onchange="calcularTotalAportaciones()"/>
									</p>
								</div>
							</div>

							<div class="form-row">
								<div class="col-sm-3">
									<p class="mb-0">Horas Extras Resto</p>
								</div>

								<div class="col-sm-2">
									<p class="col-sm-12 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right" 
										name="porc_extras_resto" id="porc_extras_resto" onkeypress="return isNumberKey(event)" 
										onchange="calcularTotalAportaciones()"/>
									</p>
								</div>

								<div class="col-sm-1 my-1">%</div>
								
								<div class="col-sm-3">
									<p class="col-sm-9 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right"
 										 name="monto_extras_resto" id="monto_extras_resto" onkeypress="return isNumberKey(event)"
										 onchange="calcularTotalAportaciones()"/>
									</p>
								</div>
							</div>

							<div class="form-row">
								<div class="col-sm-6">
									<p class="mb-0 text-center"><strong>TOTAL APORTACIONES</strong></p>
								</div>
								
								<div class="col-sm-3">
									<p class="col-sm-9 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right input-bold"
 										 name="total_aportaciones" id="total_aportaciones" readonly="" />
									</p>
								</div>
							</div>

							<div class="form-row">
								<div class="col-sm-3">
									<p class="mb-0">2. Impuesto sobre la Renta de las Personas Físicas</p>
								</div>

								<div class="col-sm-2">
									<p class="col-sm-12 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right" 
										name="porc_impuesto_renta" id="porc_impuesto_renta" onkeypress="return isNumberKey(event)"
										onchange="calcularTotalAportaciones()"/>
									</p>
								</div>

								<div class="col-sm-1 my-1">%</div>
								
								<div class="col-sm-3">
									<p class="col-sm-9 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right"
 										 name="monto_impuesto_renta" id="monto_impuesto_renta" readonly="" />
									</p>
								</div>
							</div>

							<div class="form-row">
								<div class="col-sm-6">
									<p class="mb-0">3. Anticipos</p>
								</div>
								
								<div class="col-sm-3">
									<p class="col-sm-9 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right"
 										 name="monto_anticipos" id="monto_anticipos"
										 onkeypress="return isNumberKey(event)"
										 onchange="calcularTotalAportaciones()"/>
									</p>
								</div>
							</div>
							
							<div class="form-row">
								<div class="col-sm-6">
									<p class="mb-0">4. Valor de los productos recibidos en especie</p>
								</div>
								
								<div class="col-sm-3">
									<p class="col-sm-9 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right"
 										 name="monto_productos_especies" id="monto_productos_especies"
										 onkeypress="return isNumberKey(event)"
										 onchange="calcularTotalAportaciones()"/>
									</p>
								</div>
							</div>

							<div class="form-row">
								<div class="col-sm-6">
									<p class="mb-0">5. Otras deducciones</p>
								</div>
								
								<div class="col-sm-3">
									<p class="col-sm-9 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right"
 										 name="monto_deducciones" id="monto_deducciones"
										 onkeypress="return isNumberKey(event)"
										 onchange="calcularTotalAportaciones()"
										 />
									</p>
								</div>
							</div>

							<div class="form-row">
								<div class="col-sm-9 text-center">
									<h4>B. TOTAL A DEDUCIR</h4>
								</div>

								<div class="col-sm-3">
									<p class="col-sm-9 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right input-bold" 
										name="totaldeducir" id="totaldeducir" readonly="" />
									</p>
								</div>
							</div>

							<div class="form-row">
								<div class="col-sm-9 text-center">
									<h4>LIQUIDO TOTAL A PERCIBIR (A-B)</h4>
								</div>

								<div class="col-sm-3">
									<p class="col-sm-9 mx-auto">
										<input type="text" step="0.01" min="0" class="form-control form-control-sm text-right input-bold" 
										name="total_liquido_percibir" id="total_liquido_percibir" readonly="" />
									</p>
								</div>
							</div>

