                                    </div>
                                {% endfor %}
                            </div>
							-->
                        </div>
                        <div class="card-footer">
                            <div class="form-row">
                                <div class="col">
                                    <form action="{{ fsc.url() }}" method="post">
                                        <input type="hidden" name="idtpv" value="{{ fsc.tpv.idtpv }}">
                                        <button type="submit" name="action" value="agent-out" class="btn btn-danger">
                                            {{ i18n.trans('clean') }}
                                        </button>
                                    </form>
                                </div>
                                <div class="col text-right">
                                    <button type="submit" class="btn btn-success btn-spin-action">
                                        {{ i18n.trans('save') }}
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
                <!-- <div class="text-center">
                    <form action="{{ fsc.url() }}" method="post">
                        <a href="#" onclick="this.parentNode.submit();return false;"
                           class="btn btn-block btn-secondary">
                            <i class="fas fa-list mr-1"></i> {{ i18n.trans('pos-terminals') }}
                        </a>
                    </form>
                </div>
				
				-->
            </div>
        </div>
    </div>
{% endblock %}

{% block css %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('node_modules/jquery-ui-dist/jquery-ui.min.css') }}"/>
	<style>
		.input-bold {
			font-weight: bold;
			font-size: large;
		}
	</style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('node_modules/jquery-ui-dist/jquery-ui.min.js') }}"></script>
	<script>
		let cifnif = "";
		$(document).ready(function () {
			$("#employeeNominas").autocomplete({
                source: function (request, response) {
                    let formData = {};
                    formData["action"] = "autocomplete-employee";
                    formData["query"] = $("#employeeNominas").val();
                  
                    $.ajax({
                        method: "POST",
                        url: "{{ fsc.url() }}",
                        data: formData,
                        dataType: "json",
                        success: function (results) {
                            let values = [];
                            results.forEach(function (element) {
                                if (element.key === null || element.key === element.value) {
                                    values.push(element);
                                } else {
                                    values.push({key: element.key, value: element.key + " | " + element.value});
                                }
                            });
                            response(values);
                        },
                        error: function (msg) {
                            alert(msg.status + " " + msg.responseText);
                        }
                    });
                },
                select: function (event, ui) {
                    if (ui.item.key !== null) {
                        cifnif = ui.item.key;
						updateEmployee();
                        let value = ui.item.value.split(" | ");
                        if (value.length > 1) {
                            ui.item.value = value[1];
                        } else {
                            ui.item.value = value[0];
                        }
                    }
                }
            });
		});
		
		function getDataEmployee () {
			let formData = {};
			formData["action"] = "autocomplete-data-employee";
			formData["cifnif"] = $("#cifnif").val();
               
			$.ajax({
				method: "POST",
				url: "{{ fsc.url() }}",
				data: formData,
				dataType: "json",
				success: function (results) {
					let values = [];
					results.forEach(function (element) {
						if (element.key === null || element.key === element.value) {
							values.push(element);
						} else {
							values.push({key: element.key, value: element.key + " | " + element.value});
						}
					});
					response(values);
				},
				error: function (msg) {
					alert(msg.status + " " + msg.responseText);
				}
			});
		}
		
		function updateEmployee() {
			$('#cifnif').val(cifnif);
			getDataEmployee();
		}
		
		function calcularPeriodo() {
			let inicio = $('#inicioliquidacion').val();
			let fin = $('#finliquidacion').val();
			var dateInicio = new Date(inicio);
			var dateFin = new Date(fin);
			const diffInDays = Math.floor((dateFin - dateInicio)/ (1000 * 60 * 60 * 24) + 1);
			if (diffInDays > 0) {
				$('#totaldias').val(diffInDays);				
			} else {
				$('#totaldias').val("-1");
			}
		}
		
		function isBlank(str) {
 		   return (!str || /^\s*$/.test(str));
		}
		function calcularTotalAportaciones () {
			let totalDeducir = 0;
			let totalDeducirCompleto = 0;
			let porc_contingencias = $('#porc_contingencias').val();
			let monto_contingencias = $('#monto_contingencias').val();
			
			let porc_desempleo = $('#porc_desempleo').val();
			let monto_desempleo = $('#monto_desempleo').val();
			
			let porc_profesional = $('#porc_profesional').val();
			let monto_profesional = $('#monto_profesional').val();
			
			let porc_extras_fuerza_mayor = $('#porc_extras_fuerza_mayor').val();
			let monto_extras_fuerza_mayor = $('#monto_extras_fuerza_mayor').val();
			
			let porc_extras_resto = $('#porc_extras_resto').val();
			let monto_extras_resto = $('#monto_extras_resto').val();

			let porc_impuesto_renta = $('#porc_impuesto_renta').val();
			let monto_impuesto_renta = $('#monto_impuesto_renta').val();
			let total_devengado = $('#totaldevengado').val();
			
			let monto_anticipos = $('#monto_anticipos').val();
			let monto_productos_especies = $('#monto_productos_especies').val();
			let monto_deducciones = $('#monto_deducciones').val();
			
			if(!isBlank(porc_contingencias)) {
				$('#porc_contingencias').val(parseFloat(porc_contingencias).toFixed(2)); 
			}
			if(!isBlank(monto_contingencias)) { 
				totalDeducir += parseFloat(monto_contingencias); 
				$('#monto_contingencias').val(parseFloat(monto_contingencias).toFixed(2)); 
			}

			if(!isBlank(porc_desempleo)) {
				$('#porc_desempleo').val(parseFloat(porc_desempleo).toFixed(2)); 
			}
			if(!isBlank(monto_desempleo)) { 
				totalDeducir += parseFloat(monto_desempleo); 
				$('#monto_desempleo').val(parseFloat(monto_desempleo).toFixed(2)); 
			}

			if(!isBlank(porc_profesional)) {
				$('#porc_profesional').val(parseFloat(porc_profesional).toFixed(2)); 
			}
			if(!isBlank(monto_profesional)) { 
				totalDeducir += parseFloat(monto_profesional); 
				$('#monto_profesional').val(parseFloat(monto_profesional).toFixed(2)); 
			}

			if(!isBlank(porc_extras_fuerza_mayor)) {
				$('#porc_extras_fuerza_mayor').val(parseFloat(porc_extras_fuerza_mayor).toFixed(2)); 
			}
			if(!isBlank(monto_extras_fuerza_mayor)) { 
				totalDeducir += parseFloat(monto_extras_fuerza_mayor); 
				$('#monto_extras_fuerza_mayor').val(parseFloat(monto_extras_fuerza_mayor).toFixed(2)); 
			}

			if(!isBlank(porc_extras_resto)) {
				$('#porc_extras_resto').val(parseFloat(porc_extras_resto).toFixed(2)); 
			}
			if(!isBlank(monto_extras_resto)) { 
				totalDeducir += parseFloat(monto_extras_resto); 
				$('#monto_extras_resto').val(parseFloat(monto_extras_resto).toFixed(2)); 
			}

			if(!isBlank(porc_impuesto_renta)) {
				$('#porc_impuesto_renta').val(parseFloat(porc_impuesto_renta).toFixed(2)); 
				let monto_imp = parseFloat(porc_impuesto_renta)/100 * parseFloat(total_devengado);
				totalDeducirCompleto += parseFloat(monto_imp); 
				$('#monto_impuesto_renta').val(monto_imp.toFixed(2));
			}

			$('#total_aportaciones').val((Math.round(totalDeducir * 100) / 100).toFixed(2));
			totalDeducirCompleto += totalDeducir;

			if(!isBlank(monto_anticipos)) { 
				totalDeducirCompleto += parseFloat(monto_anticipos); 
				$('#monto_anticipos').val(parseFloat(monto_anticipos).toFixed(2)); 
			}

			if(!isBlank(monto_productos_especies)) { 
				totalDeducirCompleto += parseFloat(monto_productos_especies); 
				$('#monto_productos_especies').val(parseFloat(monto_productos_especies).toFixed(2)); 
			}

			if(!isBlank(monto_deducciones)) { 
				totalDeducirCompleto += parseFloat(monto_deducciones); 
				$('#monto_deducciones').val(parseFloat(monto_deducciones).toFixed(2)); 
			}

			$('#totaldeducir').val((Math.round(totalDeducirCompleto * 100) / 100).toFixed(2));
			calcularLiquidoPercibir();
		}
		
		function calcularLiquidoPercibir () {
			let totaldevengado = $('#totaldevengado').val();
			let totaldeducir = $('#totaldeducir').val();
			let liquido = 0;
			if(!isBlank(totaldevengado)) { 
				liquido = parseFloat(totaldevengado); 
			}

			if(!isBlank(totaldeducir)) { 
				liquido -= parseFloat(totaldeducir); 
			}

			$('#total_liquido_percibir').val((Math.round(liquido * 100) / 100).toFixed(2));
		}
		
		function calcularTotalDevengado() {
			let total = 0;
			let salario = $('#salariobase').val();
			let complementosalarial = $('#complementossalariales').val();
			let extrasfuerzamayor = $('#extrasfuerzamayor').val();
			let extrasresto = $('#extrasresto').val();
			let horascomplementarias = $('#horascomplementarias').val();
			let gratificacionesextraordinarias = $('#gratificacionesextraordinarias').val();
			let salarioespecie = $('#salarioespecie').val();
			
			let indemnizaciones = $('#indemnizaciones').val();
			let seguridadsocial = $('#seguridadsocial').val();
			let despidos = $('#despidos').val();	
			let otraspercepciones = $('#otraspercepciones').val();
			
			let porc_impuesto_renta = $('#porc_impuesto_renta').val();
			let monto_impuesto_renta = $('#monto_impuesto_renta').val();

			if(!isBlank(salario)) { 
				total += parseFloat(salario); 
				$('#salariobase').val(parseFloat(salario).toFixed(2)); 
			}
			if(!isBlank(complementosalarial)) { 
				total += parseFloat(complementosalarial); 
				$('#complementossalariales').val(parseFloat(complementosalarial).toFixed(2));
			}
			if(!isBlank(extrasfuerzamayor)) { 
				total += parseFloat(extrasfuerzamayor); 
				$('#extrasfuerzamayor').val(parseFloat(extrasfuerzamayor).toFixed(2));
			}
			if(!isBlank(extrasresto)) { 
				total += parseFloat(extrasresto); 
				$('#extrasresto').val(parseFloat(extrasresto).toFixed(2));
			}
			if(!isBlank(horascomplementarias)) { 
				total += parseFloat(horascomplementarias); 
				$('#horascomplementarias').val(parseFloat(horascomplementarias).toFixed(2));
			}
			if(!isBlank(gratificacionesextraordinarias)) { 
				total += parseFloat(gratificacionesextraordinarias); 
				$('#gratificacionesextraordinarias').val(parseFloat(gratificacionesextraordinarias).toFixed(2));
			}
			if(!isBlank(salarioespecie)) { 
				total += parseFloat(salarioespecie); 
				$('#salarioespecie').val(parseFloat(salarioespecie).toFixed(2));
			}
			if(!isBlank(indemnizaciones)) { 
				total += parseFloat(indemnizaciones); 
				$('#indemnizaciones').val(parseFloat(indemnizaciones).toFixed(2));
			}
			if(!isBlank(seguridadsocial)) { 
				total += parseFloat(seguridadsocial); 
				$('#seguridadsocial').val(parseFloat(seguridadsocial).toFixed(2));
			}
			if(!isBlank(despidos)) { 
				total += parseFloat(despidos); 
				$('#despidos').val(parseFloat(despidos).toFixed(2));
			}
			if(!isBlank(otraspercepciones)) { 
				total += parseFloat(otraspercepciones); 
				$('#otraspercepciones').val(parseFloat(otraspercepciones).toFixed(2));
			}
		
			$('#totaldevengado').val((Math.round(total * 100) / 100).toFixed(2));

			if(!isBlank(porc_impuesto_renta)) {
				let monto_imp = parseFloat(porc_impuesto_renta)/100 * parseFloat((Math.round(total * 100) / 100));
				$('#monto_impuesto_renta').val(monto_imp.toFixed(2));
				//totalDeducir += monto_imp.toFixed(2);
				calcularTotalAportaciones();
			}

			calcularLiquidoPercibir();
		}
		
		function isNumberKey(evt) {
 	   		const charCode = (evt.which) ? evt.which : event.keyCode;
    		// Permitir números y punto decimal
			if (charCode == 46 || (charCode >= 48 && charCode <= 57)) {
				if (charCode == 46) {
					return evt.target.value.includes('.')? false: true;
				}
				return true;
			} else {
				return false;
			}
		}
		
	</script>
{% endblock %}
