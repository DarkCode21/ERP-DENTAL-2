<div class="col-12 text-secondary" style="font-size: smaller">
    <div class="row text-info">
        <div class="col-12 mb-3">
            <h5>{{ i18n.trans('periods-help-title') }}</h5>
        </div>
    </div>
    <div class="row">
        <div class="col-12">
            <ul class="nav nav-tabs nav-fill" role="tablist">
                {% for grouptype, grouptypedesc in fsc.infoView.getTableGroupType() %}
                <li class="nav-item">
                  <a class="h6 nav-link {% if loop.first %}active{% endif %}" href="#{{ 'div_tabletype_' ~ grouptype }}" data-toggle="tab">
                      {{ grouptypedesc }}
                  </a>
                </li>
                {% endfor %}
            </ul>
            <div class="tab-content">
                {% for grouptype, grouptypedesc in fsc.infoView.getTableGroupType() %}
                    <div class="table-responsive tab-pane{% if loop.first %} active{% endif %}" id="{{ 'div_tabletype_' ~ grouptype }}" role="tabpanel">
                        <table class="table table-sm table-hover mt-3">
                            {% for group, groupdesc in fsc.infoView.getTableGroup(grouptype) %}
                            <thead>
                                <tr>
                                    <th>{{ groupdesc }}</th>
                                    <th class="text-right">coeficiente lineal máximo (%)</th>
                                    <th class="text-right">Periodo máximo (años)</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for data in fsc.infoView.getTableDescription(grouptype, group) %}
                                <tr>
                                    <td>{{ data.name }}</td>
                                    <td class="text-right">{{ data.coefficient }}</td>
                                    <td class="text-right">{{ data.period }}</td>
                                 </tr>
                                {% endfor %}
                                <tr><td colspan="3">&nbsp;</td></tr>
                            </tbody>
                            {% endfor %}
                        </table>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>
