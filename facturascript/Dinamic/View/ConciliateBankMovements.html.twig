                        </div>
                        <div class="col-12 col-sm">
                            {{ trans('amount') }}
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">&gt;=</span>
                                </div>
                                <input type="number" class="form-control amountGreaterOrEqual" value=""
                                       onkeyup="getReceiptsPurchases()"/>
                            </div>
                        </div>
