    <script>
        function autocompleteClient() {
            const val = $('#clientsModal input[name="codcliente"]').val();
            if (val !== '') {
                $('#clientsModal button#deleteClient').removeClass('d-none');
                $('#clientsModal span#searchClient').addClass('d-none');
            } else {
                $('#clientsModal button#deleteClient').addClass('d-none');
                $('#clientsModal span#searchClient').removeClass('d-none');
            }
            getReceiptsSales();
        }

        function autocompleteSupplier() {
            const val = $('#suppliersModal input[name="codproveedor"]').val();
            if (val !== '') {
                $('#suppliersModal button#deleteSupplier').removeClass('d-none');
                $('#suppliersModal span#searchSupplier').addClass('d-none');
            } else {
                $('#suppliersModal button#deleteSupplier').addClass('d-none');
                $('#suppliersModal span#searchSupplier').removeClass('d-none');
            }
            getReceiptsPurchases();
        }

        function getAsientos() {
            let formData = new FormData();
            formData.append('concepto', $('#asientosModal .concepto').val());
            formData.append('amountGreaterOrEqual', $('#asientosModal .amountGreaterOrEqual').val());
            formData.append('amountLessThanOrEqual', $('#asientosModal .amountLessThanOrEqual').val());
            sendForm(formData, 'getAsientos');
        }

        function getBankMovements() {
            let formData = new FormData();
            sendForm(formData, 'getBankMovements');
        }

        function getReceiptsPurchases() {
            let formData = new FormData();
            formData.append('codproveedor', $('#suppliersModal input[name="codproveedor"]').val());
            formData.append('codpago', $('#suppliersModal .methodPayment option:selected').val());
            formData.append('amountGreaterOrEqual', $('#suppliersModal .amountGreaterOrEqual').val());
            formData.append('amountLessThanOrEqual', $('#suppliersModal .amountLessThanOrEqual').val());
            sendForm(formData, 'getReceiptsPurchases');
        }

        function getReceiptsSales() {
            let formData = new FormData();
            formData.append('codcliente', $('#clientsModal input[name="codcliente"]').val());
            formData.append('codpago', $('#clientsModal .methodPayment option:selected').val());
            formData.append('amountGreaterOrEqual', $('#clientsModal .amountGreaterOrEqual').val());
            formData.append('amountLessThanOrEqual', $('#clientsModal .amountLessThanOrEqual').val());
            sendForm(formData, 'getReceiptsSales');
        }

        function getRemesas() {
            let formData = new FormData();
            sendForm(formData, 'getRemesas');
        }

        function reconciliate(type) {
            let formData = new FormData();
            formData.append('type', type);

            if (type === 'asientos') {
                let idAsientos = [];
                $('#asientosModal .asientos input[type="checkbox"]:checked').each(function () {
                    idAsientos.push($(this).val());
                });
                formData.append('idAsientos', idAsientos);
                formData.append('idMovement', $('#asientosModal .idmovement').html());
                sendForm(formData, 'reconciliate');
                return;
            }

            if (type === 'new-asiento') {
                let contra = $('#nuevoAsientoContra').val();
                if (contra === '') {
                    $('#nuevoAsientoContra').select();
                    return;
                }

                formData.append('contra', contra);
                formData.append('idMovement', $('#asientosModal .idmovement').html());
                sendForm(formData, 'reconciliate');
                return;
            }

            if (type === 'purchases') {
                let idReceipts = [];
                $('#suppliersModal .receipts input[type="checkbox"]:checked').each(function () {
                    idReceipts.push($(this).val());
                });
                formData.append('idReceipts', idReceipts);
                formData.append('idMovement', $('#suppliersModal .idmovement').html());
                sendForm(formData, 'reconciliate');
            }

            if (type === 'remesas') {
                let idRemesas = [];
                $('#remesasModal .remesas input[type="checkbox"]:checked').each(function () {
                    idRemesas.push($(this).val());
                });
                formData.append('idRemesas', idRemesas);
                formData.append('idMovement', $('#remesasModal .idmovement').html());
                sendForm(formData, 'reconciliate');
                return;
            }

            if (type === 'sales') {
                let idReceipts = [];
                $('#clientsModal .receipts input[type="checkbox"]:checked').each(function () {
                    idReceipts.push($(this).val());
                });
                formData.append('idReceipts', idReceipts);
                formData.append('idMovement', $('#clientsModal .idmovement').html());
                sendForm(formData, 'reconciliate');
                return;
            }
        }

        function sendForm(formData, action) {
            animateSpinner('add');

            formData.append('action', action);
            formData.append('ajax', true);
            formData.append('codcuenta', $('#codcuenta option:selected').val());

            fetch('{{ fsc.url() }}', {
                method: 'POST',
                body: formData
            }).then(function (response) {
                if (response.ok) {
                    return response.json();
                }

                return Promise.reject(response);
            }).then(function (data) {
                if (data.getAsientos) {
                    $('#asientosModal .asientos').html(data.html);
                }

                if (data.getBankMovements) {
                    $('#listBankMovements').html(data.html);
                }

                if (data.getReceiptsPurchases) {
                    $('#suppliersModal .receipts').html(data.html);
                }

                if (data.getReceiptsSales) {
                    $('#clientsModal .receipts').html(data.html);
                }

                if (data.getRemesas) {
                    $('#remesasModal .remesas').html(data.html);
                }

                if (data.reconciliate) {
                    $('#clientsModal').modal('hide');
                    $('#suppliersModal').modal('hide');
                    $('#remesasModal').modal('hide');
                    $('#asientosModal').modal('hide');
                    getBankMovements();
                }

                // si hay mensajes de error
                if (data.messages) {
                    data.messages.forEach(function (msg) {
                        alert(msg.message);
                    });
                }

                animateSpinner('remove');
            }).catch(function (error) {
                alert('error');
                console.warn(error);
                animateSpinner('remove');
            });

            return false;
        }

        function showModalAsientos(btn) {
            // limpiamos los campos
            $('#asientosModal .concepto').val('');
            $('#asientosModal .amountGreaterOrEqual').val('');
            $('#asientosModal .amountLessThanOrEqual').val('');
            getAsientos();

            // obtenemos el tr al que pertenece el btn
