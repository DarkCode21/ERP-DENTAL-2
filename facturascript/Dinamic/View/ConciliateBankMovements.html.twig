                                <th>{{ trans('receipt') }}</th>
                                <th class="text-right">{{ trans('amount') }}</th>
                                <th class="text-nowrap">{{ trans('method-payment') }}</th>
                                <th class="text-right">{{ trans('expiration') }}</th>
                            </tr>
