    <!-- Modal recibos proveedores -->
    <div class="modal fade" id="suppliersModal" tabindex="-1" aria-labelledby="suppliersModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="suppliersModalLabel">
                        <i class="fa-solid fa-link mr-1"></i> {{ trans('reconcile-purchases-movement') }}
                    </h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body p-0">
                    <div class="row p-3">
                        <div class="idmovement d-none"></div>
                        <div class="col-auto">
                            <div class="font-weight-bold">{{ trans('amount') }}</div>
                            <div class="amountData"></div>
                        </div>
                        <div class="col-auto">
                            <div class="font-weight-bold">{{ trans('date') }}</div>
                            <div class="dateData"></div>
                        </div>
                        <div class="col">
                            <div class="font-weight-bold">{{ trans('observations') }}</div>
                            <div class="observationsData"></div>
                        </div>
                    </div>
                    <div class="form-row p-3">
                        <div class="col-12 col-sm">
                            {{ trans('supplier') }}
                            <input type="hidden" name="codproveedor" value="">
                            <div class="input-group">
                                <input type="text" id="findSupplierInput" class="form-control" value=""/>
                                <div class="input-group-append">
                                    <button type="button" id="deleteSupplier" class="btn btn-warning d-none">
                                        <i class="fas fa-times" aria-hidden="true"></i>
                                    </button>
