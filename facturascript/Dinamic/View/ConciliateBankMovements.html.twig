                            {{ trans('amount') }}
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text">&lt;=</span>
                                </div>
                                <input type="number" class="form-control amountLessThanOrEqual" value=""
                                       onkeyup="getReceiptsPurchases()"/>
