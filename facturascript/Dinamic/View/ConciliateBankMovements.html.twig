        $(document).ready(function () {
            $('button#deleteClient').on('click', function () {
                $('input[name="codcliente"]').val('');
                $('input#findClientInput').val('');
                autocompleteClient();
            });

            $('button#deleteSupplier').on('click', function () {
                $('input[name="codproveedor"]').val('');
                $('input#findSupplierInput').val('');
                autocompleteSupplier();
            });

            $('#findClientInput').autocomplete({
                source: function (request, response) {
                    let formData = {};
                    formData["action"] = "autocomplete-client";
                    formData["query"] = request.term;
                    formData["ajax"] = true;

                    $.ajax({
                        method: "POST",
                        url: window.location.href,
                        data: formData,
                        dataType: "json",
                        success: function (results) {
                            let values = [];
                            results.clients.forEach(function (element) {
                                if (element.key === null || element.key === element.value) {
                                    values.push(element);
                                } else {
                                    values.push({key: element.key, value: element.key + " | " + element.value});
                                }
                            });
                            response(values);
                        },
                        error: function (msg) {
                            alert(msg.status + " " + msg.responseText);
                        }
                    });
                },
                select: function (event, ui) {
                    if (ui.item.key !== null) {
                        const value = ui.item.value.split(" | ");
                        $("#clientsModal input[name=\"codcliente\"]").val(value[0]);
                        autocompleteClient();
                    }
                },
                open: function (event, ui) {
                    $(this).autocomplete('widget').css('z-index', 1500);
                    return false;
                }
            });

            $('#findSupplierInput').autocomplete({
                source: function (request, response) {
                    let formData = {};
                    formData["action"] = "autocomplete-supplier";
                    formData["query"] = request.term;
                    formData["ajax"] = true;

                    $.ajax({
                        method: "POST",
                        url: window.location.href,
                        data: formData,
                        dataType: "json",
                        success: function (results) {
                            let values = [];
                            results.suppliers.forEach(function (element) {
                                if (element.key === null || element.key === element.value) {
                                    values.push(element);
                                } else {
                                    values.push({key: element.key, value: element.key + " | " + element.value});
                                }
                            });
                            response(values);
                        },
                        error: function (msg) {
                            alert(msg.status + " " + msg.responseText);
                        }
                    });
                },
                select: function (event, ui) {
                    if (ui.item.key !== null) {
                        const value = ui.item.value.split(" | ");
                        $("#suppliersModal input[name=\"codproveedor\"]").val(value[0]);
                        autocompleteSupplier();
                    }
                },
                open: function (event, ui) {
                    $(this).autocomplete('widget').css('z-index', 1500);
                    return false;
                }
            });

            // cada vez que cambie el select de cuentas bancarias
            // se recargan los movimientos
            $('#codcuenta').change(function () {
                getBankMovements();
            });

            getBankMovements();
        });
    </script>
{% endblock %}