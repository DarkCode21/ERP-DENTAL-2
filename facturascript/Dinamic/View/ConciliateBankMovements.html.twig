{% extends "Master/MenuBghTemplate.html.twig" %}

{% block bodyHeaderOptions %}
    {{ parent() }}
    <div class="container-fluid pb-3 mb-2">
        <div class="form-row align-items-end">
            <div class="col-auto">
                <a class="btn btn-secondary" href="{{ asset('EditCuentaBanco?code=' ~ fsc.codcuenta) }}">
                    <i class="fas fa-chevron-left mr-1" aria-hidden="true"></i>
                    {{ trans('bank-account') }}
                </a>
                <a class="btn btn-secondary" href="{{ fsc.url() }}?codcuenta={{ fsc.codcuenta }}"
                   title="{{ trans('refresh') }}">
                    <i class="fas fa-redo" aria-hidden="true"></i>
                </a>
            </div>
            <div class="col-3">
                {{ trans('bank-account') }}
                <select id="codcuenta" class="form-control">
                    {% for bank in fsc.getBankAccounts() %}
                        {% if bank.codcuenta == fsc.codcuenta %}
                            <option value="{{ bank.codcuenta }}" selected>{{ bank.descripcion }}</option>
                        {% else %}
                            <option value="{{ bank.codcuenta }}">{{ bank.descripcion }}</option>
                        {% endif %}
                    {% endfor %}
                </select>
            </div>
            <div class="col-sm text-right">
                <h1 class="h3">
                    {{ trans(fsc.getPageData()['title']) | capitalize }}
                    <i class="{{ fsc.getPageData()['icon'] }}" aria-hidden="true"></i>
                </h1>
            </div>
        </div>
    </div>
{% endblock %}

{% block css %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('/node_modules/jquery-ui-dist/jquery-ui.min.css') }}"/>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('/node_modules/jquery-ui-dist/jquery-ui.min.js') }}"></script>
{% endblock %}

