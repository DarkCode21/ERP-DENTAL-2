<div class="row">
	<div class="col-4">
		<div class="card">
			<form class="form" method="post" enctype="multipart/form-data">
				<div class="card-header bg-info text-white pb-1">
					<h5>Importar Factura de Factura-e</h5>
				</div>
		
				<div class="card-body">
					<div class="col-12 mb-3 px-0">
					    <input type="hidden" name="action" value="import" />
						<input type="file" class="form-control" accept="" required="" name="doc" />
					</div>
					<div class="buttons d-flex justify-content-end">
						<button type="submit" class="btn btn-sm btn-primary">
						 	<i class="fa fa-save" aria-hidden="true"></i>
							<span class="d-none d-xl-inline-block"> {{ i18n.trans('import') }}</span>
						</button>
					</div
				</div>
			</form>
		</div>
	</div>
</div>