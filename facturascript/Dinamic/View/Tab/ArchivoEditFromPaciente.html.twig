{% block body %}
<div class="container-fluid">
	<form id="formEditArchivoFromPacienteNew" method="post" enctype="multipart/form-data">
		{{ formToken() }}
		<input type="hidden" name="action" value="save"/>
		<input type="hidden" name="activetab" value="EditArchivoFromPaciente"/>
		<input type="hidden" name="code" value="{{ fsc.getViewModelValue('EditArchivoFromPaciente', 'id') }}"/>
		<input type="hidden" name="idpaciente" value="{{ fsc.idpaciente }}"/>

		<div class="card border-success shadow mb-2">
			<div class="card-body p-2">
				<button class="btn btn-sm btn-outline-success mr-1" type="button" data-toggle="collapse" data-target="#formEditArchivoFromPacienteNewCollapse" aria-expanded="false">
					<i class="fas fa-plus-square fa-fw"></i>
					Añadir
				</button>
				Archivos Clínicos
			</div>
			<div class="collapse" id="formEditArchivoFromPacienteNewCollapse">
				<div class="card-body border-top">
					<div class="form-row">
						<div class="col-md-4">
							<div class="form-group mb-2">
								<label class="mb-0">{{ trans('specialist') }}</label>
								<select name="idespecialista" id="idespecialista" class="form-control">
									<option value="">{{ trans('select-option') }}</option>
									{% for specialist in fsc.specialists %}
										<option value="{{ specialist.id }}">{{ specialist.nombre }}</option>
									{% endfor %}
								</select>
							</div>
						</div>
						<div class="col-md-4">
							<div class="form-group mb-2">
								<label class="mb-0">{{ trans('appointment') }}</label>
								<select name="idcita" id="idcita" class="form-control" disabled>
									<option value="">{{ trans('select-option') }}</option>
									{% for appt in fsc.appointments %}
										<option value="{{ appt.id }}" data-idpaciente="{{ appt.idpaciente }}" data-idespecialista="{{ appt.idespecialista }}">{{ appt.fecha }}</option>
									{% endfor %}
								</select>
							</div>
						</div>
						<div class="col-md-4">
							<div class="form-group mb-2">
								<label class="mb-0">{{ trans('treatment') }}</label>
								<select name="idtratamiento" id="idtratamiento" class="form-control" disabled>
									<option value="">{{ trans('select-option') }}</option>
									{% for treatment in fsc.treatments %}
										<option value="{{ treatment.id }}" data-idpaciente="{{ treatment.idpaciente }}">{{ treatment.referencia_servicio }}</option>
									{% endfor %}
								</select>
							</div>
						</div>
						<div class="col-md-4">
							<div class="form-group mb-2">
								<label class="mb-0">{{ trans('category') }} *</label>
								<input type="text" name="categoria" class="form-control" required>
							</div>
						</div>
						<div class="col-md-8">
							<div class="form-group mb-2">
								<label class="mb-0">{{ trans('observations') }}</label>
								<textarea name="descripcion" rows="2" class="form-control"></textarea>
							</div>
						</div>
						<div class="col-md-12">
							<div class="form-group mb-2">
								<label class="mb-0">{{ trans('file') }}</label>
								<input type="file" name="newfiles[]" class="form-control-file" multiple>
								<small class="text-muted">{{ trans('help-server-accepts-filesize', {'%size%': '100'}) }}</small>
							</div>
						</div>
					</div>
				</div>
				<div class="card-footer text-right p-2">
					<button class="btn btn-sm btn-success" type="submit">
						<i class="fas fa-save fa-fw"></i>
						<span class="d-none d-sm-inline-block">{{ trans('save') }}</span>
					</button>
				</div>
			</div>
		</div>
	</form>

	{% if fsc.archivosClinicos | length > 0 %}
		{% for archivo in fsc.archivosClinicos %}
			<form id="formEditArchivo-{{ archivo.id }}" method="post" enctype="multipart/form-data">
				{{ formToken() }}
				<input type="hidden" name="action" value="save"/>
				<input type="hidden" name="activetab" value="EditArchivoFromPaciente"/>
				<input type="hidden" name="code" value="{{ archivo.id }}"/>
				<input type="hidden" name="idpaciente" value="{{ fsc.idpaciente }}"/>

				<div class="card border-warning shadow mb-3">
					<div class="card-header">
						<h5 class="mb-0">
							<i class="fas fa-folder-open"></i>
							{% for appt in fsc.appointments %}
								{% if appt.id == archivo.idcita %}{{ appt.fecha }}{% endif %}
							{% endfor %}
							-
							{% for treatment in fsc.treatments %}
								{% if treatment.id == archivo.idtratamiento %}{{ treatment.referencia_servicio }}{% endif %}
							{% endfor %}
						</h5>
					</div>
					<div class="card-body p-2">
						<div class="form-row">
							<div class="col-md-4">
								<div class="form-group mb-2">
									<label class="mb-0">{{ trans('specialist') }}</label>
									<select name="idespecialista" class="form-control">
										<option value="">{{ trans('select-option') }}</option>
										{% for specialist in fsc.specialists %}
											<option value="{{ specialist.id }}" {% if archivo.idespecialista == specialist.id %}selected{% endif %}>{{ specialist.nombre }}</option>
										{% endfor %}
									</select>
								</div>
							</div>
							<div class="col-md-4">
								<div class="form-group mb-2">
									<label class="mb-0">{{ trans('appointment') }}</label>
									<select name="idcita" class="form-control">
										<option value="">{{ trans('select-option') }}</option>
										{% for appt in fsc.appointments %}
											<option value="{{ appt.id }}" data-idpaciente="{{ appt.idpaciente }}" data-idespecialista="{{ appt.idespecialista }}" {% if archivo.idcita == appt.id %}selected{% endif %}>{{ appt.fecha }}</option>
										{% endfor %}
									</select>
								</div>
							</div>
							<div class="col-md-4">
								<div class="form-group mb-2">
									<label class="mb-0">{{ trans('treatment') }}</label>
									<select name="idtratamiento" class="form-control">
										<option value="">{{ trans('select-option') }}</option>
										{% for treatment in fsc.treatments %}
											<option value="{{ treatment.id }}" data-idpaciente="{{ treatment.idpaciente }}" {% if archivo.idtratamiento == treatment.id %}selected{% endif %}>{{ treatment.referencia_servicio }}</option>
										{% endfor %}
									</select>
								</div>
							</div>
							<div class="col-md-4">
								<div class="form-group mb-2">
									<label class="mb-0">{{ trans('category') }} *</label>
									<input type="text" name="categoria" class="form-control" value="{{ archivo.categoria }}" required>
								</div>
							</div>
							<div class="col-md-8">
								<div class="form-group mb-2">
									<label class="mb-0">{{ trans('observations') }}</label>
									<textarea name="descripcion" rows="2" class="form-control">{{ archivo.descripcion }}</textarea>
								</div>
							</div>
							<div class="col-md-12">
								<div class="form-group mb-2">
									<label class="mb-0">{{ trans('file') }}</label>
									<input type="file" name="newfiles[]" class="form-control-file" multiple>
									<small class="text-muted">{{ trans('help-server-accepts-filesize', {'%size%': '100'}) }}</small>
								</div>
							</div>
						</div>

						<div class="row">
							{% if archivo.files | length > 0 %}
								{% for docfile in archivo.files %}
									<div class="col-md-4 mb-2">
										<div class="card">
											<div class="card-body p-2">
												{% set file = docfile.getFile() %}
												{% if file.mimetype starts with 'image/' %}
													<img src="{{ asset(file.url('download')) }}" class="img-fluid rounded w-100 mb-2">
												{% else %}
													<i class="fas fa-file fa-2x text-muted mr-3"></i>
												{% endif %}
												<div class="d-flex justify-content-between align-items-center">
													<div>
														<strong>{{ file.filename }}</strong>
														<br><small class="text-muted">{{ (file.size / 1024) | number_format(2) }} KB</small>
													</div>
											<div>
												<a href="{{ file.url('download-permanent') }}" target="_blank" class="btn btn-outline-primary btn-sm">
													<i class="fas fa-download"></i>
												</a>
												<button type="button" class="btn btn-outline-danger btn-sm btn-delete-file" data-id="{{ docfile.id }}">
													<i class="fas fa-trash"></i>
												</button>
											</div>
												</div>
											</div>
										</div>
									</div>
								{% endfor %}
							{% endif %}
						</div>
					</div>
					<div class="card-footer p-2">
					<div class="form-row">
						<div class="col-auto">
							<button type="button" class="btn btn-sm btn-danger btn-delete-archivo" data-id="{{ archivo.id }}">
								<i class="fas fa-trash-can fa-fw"></i>
								<span class="d-none d-sm-inline-block">Eliminar</span>
							</button>
						</div>
						<div class="col"></div>
						<div class="col-auto">
							<button class="btn btn-sm btn-secondary" type="reset">
								<i class="fas fa-undo fa-fw"></i>
								<span class="d-none d-sm-inline-block">Deshacer</span>
							</button>
							<button class="btn btn-sm btn-primary" type="submit">
								<i class="fas fa-save fa-fw"></i>
								<span class="d-none d-sm-inline-block">{{ trans('save') }}</span>
							</button>
						</div>
					</div>
				</div>
			</form>
		{% endfor %}
	{% endif %}
</div>

<script>
	document.addEventListener('DOMContentLoaded', function() {
		const idpaciente = String({{ fsc.idpaciente ?? 'null' }});
		const especialistaSelect = document.getElementById('idespecialista');
		const citaSelect = document.getElementById('idcita');
		const tratamientoSelect = document.getElementById('idtratamiento');

		function filterCitas() {
			const especialistaId = String(especialistaSelect.value);
			const options = citaSelect.querySelectorAll('option');

			options.forEach(function(option) {
				if (option.value === '') return;
				const matchPaciente = option.dataset.idpaciente === idpaciente;
				const matchEspecialista = !especialistaId || String(option.dataset.idespecialista) === especialistaId;
				option.style.display = (matchPaciente && matchEspecialista) ? '' : 'none';
			});
			citaSelect.disabled = options.length <= 1;
		}

		function filterTratamientos() {
			const options = tratamientoSelect.querySelectorAll('option');

			options.forEach(function(option) {
				if (option.value === '') return;
				const matchPaciente = option.dataset.idpaciente === idpaciente;
				option.style.display = matchPaciente ? '' : 'none';
			});
			tratamientoSelect.disabled = options.length <= 1;
		}

		especialistaSelect.addEventListener('change', filterCitas);

		filterCitas();
		filterTratamientos();

		document.querySelectorAll('.btn-delete-file').forEach(function(btn) {
			btn.addEventListener('click', function() {
				if (!confirm('{{ trans('are-you-sure') }}')) return;
				var id = this.getAttribute('data-id');
				var form = document.createElement('form');
				form.method = 'post';
				form.action = '{{ fsc.getViewModel('EditArchivoFromPaciente').url() }}';
				form.innerHTML = '<input type="hidden" name="action" value="delete-file"/><input type="hidden" name="id" value="' + id + '"/><input type="hidden" name="activetab" value="EditArchivoFromPaciente"/>';
				document.body.appendChild(form);
				form.submit();
			});
		});

		document.querySelectorAll('.btn-delete-archivo').forEach(function(btn) {
			btn.addEventListener('click', function() {
				if (!confirm('{{ trans('are-you-sure') }}')) return;
				var id = this.getAttribute('data-id');
				var form = document.createElement('form');
				form.method = 'post';
				form.action = '{{ fsc.getViewModel('EditArchivoFromPaciente').url() }}';
				form.innerHTML = '<input type="hidden" name="action" value="delete-archivo"/><input type="hidden" name="id" value="' + id + '"/><input type="hidden" name="activetab" value="EditArchivoFromPaciente"/>';
				document.body.appendChild(form);
				form.submit();
			});
		});
	});
</script>
{% endblock %}