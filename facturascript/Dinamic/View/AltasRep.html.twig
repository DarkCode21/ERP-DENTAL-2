{% extends "Master/MenuTemplate.html.twig" %}

{% block css %}
	{{ parent() }}
	<link rel="stylesheet" href="{{ asset('node_modules/jquery-ui-dist/jquery-ui.min.css') }}"/>
	<style>
		/* Solo estilos para el scanner */
		.spinner {
			display: inline-block;
			width: 20px;
			height: 20px;
			border: 3px solid rgba(255, 255, 255, 0.3);
			border-radius: 50%;
			border-top-color: #fff;
			animation: spin 1s ease-in-out infinite;
		}

		@keyframes spin {
			to {
				transform: rotate(360deg);
			}
		}

		.loading {
			opacity: 0.6;
			pointer-events: none;
		}

		#zxing-video {
			width: 100%;
			height: 100%;
			object-fit: cover;
		}
	</style>
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script src="{{ asset('node_modules/jquery-ui-dist/jquery-ui.min.js') }}"></script>
	<script src="https://unpkg.com/@zxing/library@latest"></script>
	<script>
		/**
		 * JavaScript para AltasRep - Funcionalidad de alta rápida de productos
		 * Incluye soporte para lector de código de barras usando QuaggaJS
		 */

// Evitar redeclaración usando IIFE
(function () {
'use strict';

// Si ya existe, no redeclarar
if (typeof window.AltasRepManager !== 'undefined') {
console.log('AltasRepManager ya existe, saltando redeclaración');
return;
}

class AltasRepManager {
constructor() {
this.form = document.getElementById('altasRepForm');
this.messageArea = document.getElementById('messageArea');
this.scanButton = document.getElementById('scanButton');
this.scanner = null;
this.isScanning = false;

this.init();
}

init() {
if (this.form) {
this.form.addEventListener('submit', (e) => this.handleSubmit(e));
}

if (this.scanButton) {
this.scanButton.addEventListener('click', (e) => {
e.preventDefault();
console.log('Botón de escaneo clickeado');

this.toggleScanner();
});
}

// Auto-focus en el primer campo
const firstInput = document.getElementById('descripcion');
if (firstInput) {
firstInput.focus();
}

// Validación en tiempo real del código de barras
const barcodeInput = document.getElementById('codbarras');
if (barcodeInput) {
barcodeInput.addEventListener('input', (e) => this.validateBarcode(e.target.value));
barcodeInput.addEventListener('keypress', (e) => {
if (e.key === 'Enter') {
e.preventDefault();
this.validateBarcode(e.target.value);
}
});
}

// Cálculo bidireccional de precio con/sin IVA
const precioInput = document.getElementById('precio');
const codimpuestoSelect = document.getElementById('codimpuesto');
const precioConIvaInput = document.getElementById('precio_con_iva');

// Evitar bucle de recálculo
let updatingPrice = false;

// precio s/IVA → calcula precio c/IVA
const calcPrecioConIva = () => {
if (updatingPrice) 
return;



updatingPrice = true;
const precio = parseFloat(precioInput.value) || 0;
const iva = parseFloat(codimpuestoSelect.value) || 0;
precioConIvaInput.value = precio > 0 ? (precio * (1 + iva / 100)).toFixed(2) : '';
setActivePriceMode('neto');
updatingPrice = false;
};

// precio c/IVA → calcula precio s/IVA
const calcPrecioSinIva = () => {
if (updatingPrice) 
return;



updatingPrice = true;
const precioConIva = parseFloat(precioConIvaInput.value) || 0;
const iva = parseFloat(codimpuestoSelect.value) || 0;
precioInput.value = precioConIva > 0 ? (precioConIva / (1 + iva / 100)).toFixed(4) : '';
setActivePriceMode('iva');
updatingPrice = false;
};

// al cambiar IVA, recalcular según el campo que tenga valor
const onIvaChange = () => {
const activeMode = document.getElementById('precio_active_mode').value;
if (activeMode === 'iva') {
calcPrecioSinIva();
} else {
calcPrecioConIva();
}
};

const setActivePriceMode = (mode) => {
const modeInput = document.getElementById('precio_active_mode');
if (modeInput) 
modeInput.value = mode;



const labelNeto = document.getElementById('label_precio_neto');
const labelIva = document.getElementById('label_precio_iva');
if (mode === 'iva') {
if (labelNeto) {
labelNeto.classList.remove('text-primary', 'font-weight-bold');
labelNeto.classList.add('text-muted');
}
if (labelIva) {
labelIva.classList.add('text-primary', 'font-weight-bold');
labelIva.classList.remove('text-muted');
}
} else {
if (labelIva) {
labelIva.classList.remove('text-primary', 'font-weight-bold');
labelIva.classList.add('text-muted');
}
if (labelNeto) {
labelNeto.classList.add('text-primary', 'font-weight-bold');
labelNeto.classList.remove('text-muted');
}
}
};

if (precioInput && codimpuestoSelect && precioConIvaInput) {
precioInput.addEventListener('input', calcPrecioConIva);
precioConIvaInput.addEventListener('input', calcPrecioSinIva);
codimpuestoSelect.addEventListener('change', onIvaChange);
}

// Autocomplete proveedor
const proveedorNombreInput = document.getElementById('proveedor_nombre');
const codproveedorInput = document.getElementById('codproveedor');
if (proveedorNombreInput && codproveedorInput) {
$(proveedorNombreInput).autocomplete({
minLength: 2,
source: function (request, response) {
$.ajax({
url: window.location.href,
method: 'POST',
data: {
action: 'search-proveedores',
term: request.term
},
success: function (data) {
response(data);
}
});
},
select: function (event, ui) {
codproveedorInput.value = ui.item.value;
proveedorNombreInput.value = ui.item.nombre;
return false;
}
});
proveedorNombreInput.addEventListener('input', function () {
if (this.value === '') 
codproveedorInput.value = '';



});
}

// Cargar librerías necesarias
this.loadExternalLibraries();
}

handleSubmit(event) {
const descripcion = document.getElementById('descripcion').value.trim();

if (! descripcion) {
event.preventDefault();
alert('El nombre del producto es obligatorio');
return;
}

// Dejar que el formulario se envíe normalmente con POST
}

async validateBarcode(barcode) {
if (!barcode || barcode.length < 3) 
return;



try {
const formData = new FormData();
formData.append('action', 'check-reference');
formData.append('referencia', barcode);

const response = await fetch(window.location.href, {
method: 'POST',
body: formData,
headers: {
'X-Requested-With': 'XMLHttpRequest'
}
});

const result = await response.json();

} catch (error) {
console.error('Error validating barcode:', error);
}
}

loadExternalLibraries() {
console.log('ZXing cargado para compatibilidad iOS');
}

toggleScanner() {
console.log('toggleScanner llamado, isScanning:', this.isScanning);
if (this.isScanning) {
console.log('Deteniendo scanner...');
this.stopScanner();
} else {
console.log('Iniciando scanner...');
this.startScanner();
}
}

async startScanner() {
console.log('Iniciando scanner...');

if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
console.error('Tu dispositivo no soporta cámara');
return;
}

try { // Intentar usar BarcodeDetector nativo primero (Android)
const usarNativo = 'BarcodeDetector' in window;
console.log('Usar detector nativo:', usarNativo);

if (usarNativo) { // ANDROID - Usar BarcodeDetector nativo (EL QUE FUNCIONABA)
this.createNativeScanner();
this.isScanning = true;
this.scanButton.innerHTML = '<i class="fas fa-times"></i> Cancelar';

const stream = await navigator.mediaDevices.getUserMedia({
video: {
facingMode: 'environment',
width: {
ideal: 1280
},
height: {
ideal: 720
}
}
});

const video = document.getElementById('native-scanner-video');
video.srcObject = stream;
await video.play();

this.startNativeBarcodeDetection(video);
} else { // iOS - Usar ZXing
this.createZXingScanner();
this.isScanning = true;
this.scanButton.innerHTML = '<i class="fas fa-times"></i> Cancelar';

const codeReader = new ZXing.BrowserMultiFormatReader();
const videoElement = document.getElementById('zxing-video');
const videoInputDevices = await codeReader.listVideoInputDevices();
const selectedDeviceId = videoInputDevices[videoInputDevices.length - 1] ?. deviceId;

codeReader.decodeFromVideoDevice(selectedDeviceId, videoElement, (result, err) => {
if (result) {
const code = result.getText();
console.log('Código ZXing:', code);
codeReader.reset();
this.stopScanner();
document.getElementById('codbarras').value = code;
this.validateBarcode(code);
}
});
this.currentCodeReader = codeReader;
}

} catch (error) {
console.error('Error:', error);
this.stopScanner();
}
}

stopScanner() {
if (this.isScanning) {
this.isScanning = false;
this.scanButton.innerHTML = '<i class="fas fa-barcode"></i> Escanear';
}
if (this.currentCodeReader) {
this.currentCodeReader.reset();
this.currentCodeReader = null;
}
this.closeNativeScanner();
this.closeZXingScanner();
}

createNativeScanner() {
const overlay = document.createElement('div');
overlay.id = 'native-scanner';
overlay.style.cssText = `position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: transparent; z-index: 9999;`;
overlay.innerHTML = `
	<video id="native-scanner-video" autoplay muted playsinline style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 1;"></video>
	<canvas id="native-scanner-canvas" style="display: none;"></canvas>
	<div style="position: absolute; top: 40%; left: 50%; transform: translate(-50%, -50%); width: 250px; height: 150px; border: 3px solid #00ff00; border-radius: 10px; z-index: 3; box-shadow: 0 0 0 9999px rgba(0, 0, 0, 0.6);">
		<div id="native-scanner-status" style="position: relative; top: 100%; color: white; font-size: 12px; text-align: center; margin-top: 10px;">Coloca el código dentro del cuadro verde</div>
	</div>
	<div style="position: absolute; top: 80vh; left: 50%; transform: translateX(-50%); z-index: 4;">
		<button onclick="altasRepManager.stopScanner()" class="btn btn-danger" style="padding: 10px 20px; font-size: 16px;">Cerrar</button>
	</div>
`;
document.body.appendChild(overlay);
}

createZXingScanner() {
const overlay = document.createElement('div');
overlay.id = 'zxing-scanner';
overlay.style.cssText = `position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: transparent; z-index: 9999;`;
overlay.innerHTML = `
	<video id="zxing-video" autoplay muted playsinline style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 1;"></video>
	<div style="position: absolute; top: 40%; left: 50%; transform: translate(-50%, -50%); width: 250px; height: 150px; border: 3px solid #00ff00; border-radius: 10px; z-index: 3; box-shadow: 0 0 0 9999px rgba(0, 0, 0, 0.6);">
		<div style="position: relative; top: 100%; color: white; font-size: 12px; text-align: center; margin-top: 10px;">Coloca el código dentro del cuadro verde</div>
	</div>
	<div style="position: absolute; top: 80vh; left: 50%; transform: translateX(-50%); z-index: 4;">
		<button onclick="altasRepManager.stopScanner()" class="btn btn-danger" style="padding: 10px 20px; font-size: 16px;">Cerrar</button>
	</div>
`;
document.body.appendChild(overlay);
}

closeNativeScanner() {
const overlay = document.getElementById('native-scanner');
const video = document.getElementById('native-scanner-video');
if (this.detectionInterval) 
clearInterval(this.detectionInterval);



if (video ?. srcObject) 
video.srcObject.getTracks().forEach(t => t.stop());



if (overlay) 
overlay.remove();



}

closeZXingScanner() {
const overlay = document.getElementById('zxing-scanner');
if (overlay) 
overlay.remove();



}

startNativeBarcodeDetection(video) {
const canvas = document.getElementById('native-scanner-canvas');
const context = canvas.getContext('2d');
const statusDiv = document.getElementById('native-scanner-status');
let lastCode = null,
count = 0;

this.detectionInterval = setInterval(async () => {
try {
const detector = new BarcodeDetector({
formats: [
'code_128',
'code_39',
'ean_13',
'ean_8',
'upc_a',
'upc_e'
]
});
canvas.width = video.videoWidth;
canvas.height = video.videoHeight;
context.drawImage(video, 0, 0);
const barcodes = await detector.detect(canvas);

if (barcodes.length > 0) {
const code = barcodes[0].rawValue;
if (code === lastCode) {
count++;
statusDiv.textContent = `Detectando... ${count}/5`;
if (count >= 5) {
statusDiv.textContent = '¡Confirmado!';
setTimeout(() => {
this.stopScanner();
document.getElementById('codbarras').value = code;
this.validateBarcode(code);
}, 500);
}
} else {
lastCode = code;
count = 1;
statusDiv.textContent = `Detectando... 1/5`;
}
} else if (lastCode) {
lastCode = null;
count = 0;
statusDiv.textContent = 'Coloca el código dentro del cuadro verde';
}
} catch (error) {
console.log('Buscando...');
}
}, 300);
}


setLoading(loading) {
const saveButton = document.getElementById('saveButton');
if (loading) {
saveButton.disabled = true;
saveButton.innerHTML = '<span class="spinner"></span> Guardando...';
this.form.classList.add('loading');
} else {
saveButton.disabled = false;
saveButton.innerHTML = '<i class="fas fa-save"></i> Guardar';
this.form.classList.remove('loading');
}
}

showMessage(message, type = 'info') {
const alertClass = type === 'error' ? 'alert-danger' : type === 'success' ? 'alert-success' : 'alert-info';

this.messageArea.innerHTML = `
					<div class="alert ${alertClass} alert-dismissible fade show" role="alert">
						${message}
						<button type="button" class="close" data-dismiss="alert" aria-label="Close">
							<span aria-hidden="true">&times;</span>
						</button>
					</div>
				`;

// Auto-hide después de 5 segundos para mensajes de éxito
if (type === 'success') {
setTimeout(() => {
const alert = this.messageArea.querySelector('.alert');
if (alert) {
alert.remove();
}
}, 5000);
}
}

resetForm() {
this.form.reset();
this.messageArea.innerHTML = '';
}
}

// Hacer la clase disponible globalmente
window.AltasRepManager = AltasRepManager;

// Inicializar cuando el DOM esté listo
document.addEventListener('DOMContentLoaded', () => {
if (typeof window.AltasRepManager !== 'undefined') {
window.altasRepManager = new AltasRepManager();
}
});

// Manejar teclas de acceso rápido
document.addEventListener('keydown', (e) => { // F2 para enfocar en descripción
if (e.key === 'F2') {
e.preventDefault();
document.getElementById('descripcion').focus();
}

// F3 para iniciar scanner
if (e.key === 'F3') {
e.preventDefault();
window.altasRepManager.toggleScanner();
}

// Enter en cualquier campo excepto textarea para guardar
if (e.key === 'Enter' && e.target.tagName !== 'TEXTAREA' && e.target.type !== 'submit') {
e.preventDefault();
const form = document.getElementById('altasRepForm');
if (form) {
form.dispatchEvent(new Event('submit'));
}
}
});

})(); // Cierre de la IIFE

	</script>
{% endblock %}

{% block body %}
	<div class="container">
		<div class="row justify-content-center">
			<div class="col-md-6 col-12">
				<div class="card shadow mb-4">
					<div class="card-header py-3">
						<h4 class="m-0 font-weight-bold text-primary">
							<i class="fas fa-plus-circle"></i>
							{{ i18n.trans('alta-rapida-productos') }}
						</h4>
					</div>
					<div class="card-body">
						{% if fsc.user.can('EditProducto') %}
							<form id="altasRepForm" class="mobile-form" action="{{ fsc.url() }}" method="post" enctype="multipart/form-data">
								{{ formToken() }}
								<input type="hidden" name="action" value="save-product"/>
								<div class="form-group">
									<label for="descripcion" class="required">{{ i18n.trans('product-name') }}:</label>
									<input type="text" id="descripcion" name="descripcion" class="form-control" maxlength="100" placeholder="{{ i18n.trans('product-name') }}" autocomplete="off">
								</div>

								<div class="row mb-2">
									<div class="col-md-6">
										<div class="form-group mb-0">
											<label for="proveedor_nombre">Proveedor:</label>
											<div class="input-group">
												<input type="text" id="proveedor_nombre" class="form-control" placeholder="Buscar proveedor..." autocomplete="off">
												<input type="hidden" id="codproveedor" name="codproveedor">
												<div class="input-group-append">
													<a href="EditProveedor" target="_blank" class="btn btn-outline-secondary" title="Nuevo proveedor">
														<i class="fas fa-plus"></i>
													</a>
												</div>
											</div>
										</div>
									</div>
									<div class="col-md-6">
										<div class="form-group mb-0">
											<label for="refproveedor">Ref. Proveedor:</label>
											<input type="text" id="refproveedor" name="refproveedor" class="form-control" maxlength="30" placeholder="Referencia del proveedor" autocomplete="off">
										</div>
									</div>
									<div class="col-md-12">
										<small class="text-muted">Escribe para buscar. Si no existe, usa
											<i class="fas fa-plus"></i>
											para dar de alta.</small>
									</div>
								</div>

								<div class="form-group">
									<label for="referencia">{{ i18n.trans('reference') }}:</label>
									<input type="text" id="referencia" name="referencia" class="form-control" maxlength="30" placeholder="{{ i18n.trans('automatic-reference') }}" autocomplete="off">
								</div>

								<input type="hidden" id="precio_active_mode" value="neto">
								<div class="form-group">
									<div class="row align-items-end">
										<div class="col-4">
											<label id="label_precio_neto" for="precio" class="font-weight-bold text-primary">{{ i18n.trans('price') }}
												s/IVA:</label>
											<input type="number" id="precio" name="precio" class="form-control" step="0.0001" min="0" placeholder="0.00" autocomplete="off">
										</div>
										<div class="col-4">
											<label for="codimpuesto">% IVA:</label>
											<select id="codimpuesto" name="codimpuesto" class="form-control">
												<option value="4">4%</option>
												<option value="10">10%</option>
												<option value="21" selected>21%</option>
											</select>
										</div>
										<div class="col-4">
											<label id="label_precio_iva" for="precio_con_iva" class="text-muted">Precio c/IVA:</label>
											<input type="number" id="precio_con_iva" name="precio_con_iva" class="form-control" step="0.01" min="0" placeholder="0.00" autocomplete="off">
										</div>
									</div>
									<small class="text-muted">
										<i class="fas fa-exchange-alt"></i>
										Introduce el precio con o sin IVA &mdash; el otro se calcula automáticamente.</small>
								</div>

								<div class="form-group">
									<label for="precio_compra">Precio compra s/IVA:</label>
									<input type="number" id="precio_compra" name="precio_compra" class="form-control" step="0.0001" min="0" placeholder="0.00" autocomplete="off">
								</div>

								<div class="form-group">
									<label for="ubicacion">{{ i18n.trans('location') }}:</label>
									<input type="text" id="ubicacion" name="ubicacion" class="form-control" maxlength="30" placeholder="{{ i18n.trans('location') }}" autocomplete="off">
								</div>

								<div class="form-group">
									<label for="codbarras">{{ i18n.trans('barcode') }}:</label>
									<div class="input-group">
										<input type="text" id="codbarras" name="codbarras" class="form-control" maxlength="20" placeholder="Escribe el código o escanea" autocomplete="off" style="height: fit-content;">
										<div class="input-group-append">
											<button type="button" id="scanButton" class="btn btn-primary">
												<i class="fas fa-barcode"></i>
												Escanear
											</button>
										</div>
									</div>
								</div>

								<div class="form-group">
									<label for="fotografia">{{ i18n.trans('image') }}:</label>
									<input type="file" id="fotografia" name="fotografia" class="form-control-file" accept="image/*" capture="environment">
									<small class="form-text text-muted">{{ i18n.trans('formats-accepted') }}: JPG, PNG, GIF, WEBP</small>
								</div>


								<div class="form-group text-center">
									<button type="submit" id="saveButton" class="btn btn-success btn-block">
										<i class="fas fa-save"></i>
										Guardar
									</button>
								</div>

								<div id="messageArea" class="mt-3"></div>
							</form>
						{% else %}
							<div class="alert alert-warning">
								<i class="fas fa-exclamation-triangle"></i>
								{{ i18n.trans('not-allowed-modify') }}
							</div>
						{% endif %}
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
