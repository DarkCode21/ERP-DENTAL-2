prod.descripcion descprod,
prod.referencia refprod,
sum(linalb.cantidad) cantlin,
sum(linalb.pvpsindto) impBrLinAlb,
sum(linalb.pvpsindto) impBr,
sum(linalb.pvptotal) impNetoLinAlb,
sum(linalb.pvptotal) impNeto,
CONCAT_WS("-",YEAR(alb.fecha),DATE_FORMAT(alb.fecha,'%m')) fecha,
alb.idempresa empid,
emp.nombre empnom

from productos prod, lineasalbaranescli linalb, albaranescli alb, empresas emp

where prod.referencia = linalb.referencia
