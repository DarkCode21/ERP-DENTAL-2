<table>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>name</name>
        <type>character varying(50)</type>
        <null>NO</null>
    </column>
    <column>
        <name>note</name>
        <type>text</type>
    </column>
    <constraint>
        <name>rrhh_coursesareas_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
</table>
