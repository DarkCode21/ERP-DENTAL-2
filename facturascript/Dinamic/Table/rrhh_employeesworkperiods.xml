<table>
    <column>
        <name>dayweek</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>endtime</name>
        <type>time without time zone</type>
        <null>NO</null>
    </column>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>idworkshift</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>starttime</name>
        <type>time without time zone</type>
        <null>NO</null>
    </column>
    <constraint>
        <name>rrhh_employeesworkperiods_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>ca_rrhh_employeesworkperiods_workshifts</name>
        <type>FOREIGN KEY (idworkshift) REFERENCES rrhh_employeesworkshifts (id) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>uniq_employeesworkperiods_period</name>
        <type>UNIQUE (idworkshift,dayweek,starttime)</type>
    </constraint>
</table>
