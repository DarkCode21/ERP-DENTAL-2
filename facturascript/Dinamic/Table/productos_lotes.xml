<table>
    <column>
        <name>cantidad</name>
        <type>double precision</type>
        <null>NO</null>
    </column>
    <column>
        <name>codalmacen</name>
        <type>character varying(4)</type>
    </column>
    <column>
        <name>fecha</name>
        <type>date</type>
    </column>
    <column>
        <name>fecha_caducidad</name>
        <type>date</type>
    </column>
    <column>
        <name>idlote</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>idproducto</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>numserie</name>
        <type>character varying(100)</type>
        <null>NO</null>
    </column>
    <column>
        <name>referencia</name>
        <type>character varying(30)</type>
    </column>
    <constraint>
        <name>productos_lotes_pkey</name>
        <type>PRIMARY KEY (idlote)</type>
    </constraint>
    <constraint>
        <name>uniq_productos_lotes_2</name>
        <type>UNIQUE (referencia,numserie,codalmacen)</type>
    </constraint>
    <constraint>
        <name>ca_lotes_productos</name>
        <type>FOREIGN KEY (idproducto) REFERENCES productos (idproducto) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_lotes_variantes</name>
        <type>FOREIGN KEY (referencia) REFERENCES variantes (referencia) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_lotes_almacenes</name>
        <type>FOREIGN KEY (codalmacen) REFERENCES almacenes (codalmacen) ON DELETE RESTRICT ON UPDATE CASCADE</type>
    </constraint>
</table>
