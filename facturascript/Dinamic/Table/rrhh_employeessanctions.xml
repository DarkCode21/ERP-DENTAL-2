<table>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>idemployee</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>idoffense</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>idsanction</name>
        <type>integer</type>
        <null>NO</null>
    </column>    
    <column>
        <name>level</name>
        <type>integer</type>
        <null>NO</null>
        <default>1</default>               <!-- 1: mild 2: medium, 3: severe, 4: very severe -->
    </column>    
    <column>
        <name>note</name>
        <type>text</type>
    </column>
    <column>
        <name>notice</name>
        <type>integer</type>
        <null>NO</null>
        <default>1</default>               <!-- 1: none, 2: written, 3: verbal -->
    </column>
    <column>
        <name>notification</name>
        <type>date</type>
    </column>
    <column>
        <name>startdate</name>
        <type>date</type>
    </column>
    
    <constraint>
        <name>rrhh_employeessanctions_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>        
    <constraint>
        <name>ca_rrhh_employeessanctions_employees</name>
        <type>FOREIGN KEY (idemployee) REFERENCES rrhh_employees (id) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_rrhh_employeessanctions_offenses</name>
        <type>FOREIGN KEY (idoffense) REFERENCES rrhh_disciplinaryoffenses (id) ON DELETE RESTRICT ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_rrhh_employeessanctions_sanctions</name>
        <type>FOREIGN KEY (idsanction) REFERENCES rrhh_sanctions (id) ON DELETE RESTRICT ON UPDATE CASCADE</type>
    </constraint>
</table>
