<table>
    <column>
        <name>canal</name>
        <type>integer</type>
    </column>
    <column>
        <name>coddivisa</name>
        <type>character varying(3)</type>
        <null>NO</null>
    </column>
    <column>
        <name>codsubcuentabeneficios</name>
        <type>character varying(15)</type>
    </column>
    <column>
        <name>codsubcuentacierre</name>
        <type>character varying(15)</type>
    </column>
    <column>
        <name>codsubcuentadebe</name>
        <type>character varying(15)</type>
    </column>
    <column>
        <name>codsubcuentahaber</name>
        <type>character varying(15)</type>
    </column>
    <column>
        <name>codsubcuentainteres</name>
        <type>character varying(15)</type>
    </column>
    <column>
        <name>codsubcuentaperdidas</name>
        <type>character varying(15)</type>
    </column>
    <column>
        <name>contabilizacion</name>
        <type>character varying(10)</type>
    </column>
    <column>
        <name>descripcion</name>
        <type>text</type>
    </column>
    <column>
        <name>fechafin</name>
        <type>date</type>
    </column>
    <column>
        <name>fechafinvidautil</name>
        <type>date</type>
    </column>
    <column>
        <name>fechainicio</name>
        <type>date</type>
    </column>
    <column>
        <name>idamortizacion</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>idasientofinvida</name>
        <type>integer</type>
    </column>
    <column>
        <name>idempresa</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>idfactura</name>
        <type>integer</type>
    </column>
    <column>
        <name>idfacturaventa</name>
        <type>integer</type>
    </column>
    <column>
        <name>observaciones</name>
        <type>text</type>
    </column>
    <column>
        <name>periodos</name>
        <type>integer</type>
    </column>
    <column>
        <name>residual</name>
        <type>double precision</type>
    </column>
    <column>
        <name>tasaanual</name>
        <type>double precision</type>
    </column>
    <column>
        <name>porcamort</name>
        <type>double precision</type>
    </column>
    <column>
        <name>tipo</name>
        <type>character varying(10)</type>
    </column>
    <column>
        <name>valor</name>
        <type>double precision</type>
    </column>
    <constraint>
        <name>amortizaciones_pkey</name>
        <type>PRIMARY KEY (idamortizacion)</type>
    </constraint>
    <constraint>
        <name>ca_amortizaciones_empresas</name>
        <type>FOREIGN KEY (idempresa) REFERENCES empresas (idempresa) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_amortizaciones_asientos</name>
        <type>FOREIGN KEY (idasientofinvida) REFERENCES asientos (idasiento) ON DELETE SET NULL ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_amortizaciones_facturasprov</name>
        <type>FOREIGN KEY (idfactura) REFERENCES facturasprov (idfactura) ON DELETE SET NULL ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_amortizaciones_facturascli</name>
        <type>FOREIGN KEY (idfacturaventa) REFERENCES facturascli (idfactura) ON DELETE SET NULL ON UPDATE CASCADE</type>
    </constraint>
</table>
