<table>
    <column>
        <name>amount</name>
        <type>double precision</type>
        <null>NO</null>
        <default>0</default>
    </column>
    <column>
        <name>calculation</name>
        <type>integer</type>
        <null>NO</null>
        <default>1</default>               <!-- 1: unitary, 2: by quantity, 80: by percentage, 99: Final balance -->
    </column>
    <column>
        <name>channel</name>
        <type>integer</type>
    </column>
    <column>
        <name>codsubaccount</name>
        <type>character varying(15)</type>
    </column>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>idemployee</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>idsalaryconcept</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>position</name>
        <type>integer</type>
        <null>NO</null>
        <default>1</default>               <!-- 1: debit, 2: credit -->
    </column>
    <constraint>
        <name>rrhh_employeessalary_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>ca_rrhh_employeessalary_employees</name>
        <type>FOREIGN KEY (idemployee) REFERENCES rrhh_employees (id) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_rrhh_employeessalary_salaryconcepts</name>
        <type>FOREIGN KEY (idsalaryconcept) REFERENCES rrhh_salaryconcepts (id) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
</table>
