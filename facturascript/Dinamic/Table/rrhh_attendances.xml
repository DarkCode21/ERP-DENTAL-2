<table>
    <column>
        <name>authorized</name>
        <type>boolean</type>
        <default>true</default>
    </column>
    <column>
        <name>credentialid</name>
        <type>character varying(13)</type>
    </column>
    <column>
        <name>checkdate</name>
        <type>date</type>
        <null>NO</null>
    </column>
    <column>
        <name>checktime</name>
        <type>time without time zone</type>
        <null>NO</null>
    </column>
    <column>
        <name>inputdelay</name>
        <type>integer</type>
        <default>0</default>
        <null>NO</null>
    </column>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>idabsenceconcept</name>
        <type>integer</type>
    </column>
    <column>
        <name>idclosing</name>
        <type>integer</type>
    </column>
    <column>
        <name>idemployee</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>kind</name>
        <type>integer</type>
        <null>NO</null>
        <default>1</default>                     <!-- 1: input, 2: output -->
    </column>
    <column>
        <name>note</name>
        <type>character varying(100)</type>
    </column>
    <column>
        <name>origin</name>
        <type>integer</type>
        <null>NO</null>
        <default>1</default>                   <!-- 1: manual, 2: automatic, 3: external -->
    </column>

    <!-- Audit fields -->
    <column>
        <name>creation_date</name>
        <type>timestamp</type>
    </column>
    <column>
        <name>last_update</name>
        <type>timestamp</type>
    </column>
    <column>
        <name>creation_ip</name>
        <type>character varying(40)</type>
    </column>
    <column>
        <name>last_nick</name>
        <type>varchar(30)</type>
    </column>
    <column>
        <name>location</name>
        <type>text</type>
    </column>

    <constraint>
        <name>rrhh_attendances_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>ca_rrhh_attendances_employees</name>
        <type>FOREIGN KEY (idemployee) REFERENCES rrhh_employees (id) ON DELETE RESTRICT ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_rrhh_attendances_absences</name>
        <type>FOREIGN KEY (idabsenceconcept) REFERENCES rrhh_absencesconcepts (id) ON DELETE SET NULL ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_rrhh_attendances_overtimeclosing</name>
        <type>FOREIGN KEY (idclosing) REFERENCES rrhh_overtimeclosing (id) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_rrhh_attendances_users</name>
        <type>FOREIGN KEY (last_nick) REFERENCES users (nick) ON DELETE SET NULL ON UPDATE CASCADE</type>
    </constraint>
</table>
