<table>
    <column>
        <name>amount</name>
        <type>double precision</type>
        <null>NO</null>
        <default>0</default>
    </column>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>identry</name>
        <type>integer</type>
    </column>
    <column>
        <name>idvoucher</name>
        <type>integer</type>
    </column>
    <column>
        <name>nick</name>
        <type>character varying(50)</type>
    </column>
    <column>
        <name>startdate</name>
        <type>date</type>
        <null>NO</null>
    </column>
    <column>
        <name>starttime</name>
        <type>time</type>
    </column>
    <constraint>
        <name>rrhh_employeesvoucherspaid_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>ca_rrhh_employeesvoucherspaid_asiento</name>
        <type>FOREIGN KEY (identry) REFERENCES asientos (idasiento) ON DELETE SET NULL ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_rrhh_employeesvoucherspaid_vouchers</name>
        <type>FOREIGN KEY (idvoucher) REFERENCES rrhh_employeesvouchers (id) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
</table>
