    Description:
        Estructura de la tabla de contadores para los números de serie de los productos fabricados.
-->
<table>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>idproduct</name>
        <type>integer</type>
    </column>
    <column>
        <name>idfamily</name>
        <type>character varying(8)</type>
    </column>
    <column>
        <name>numserie</name>
        <type>integer</type>
        <null>NO</null>
    </column>

    <constraint>
        <name>produccion_numseries_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>ca_produccion_numseries_productos</name>
        <type>FOREIGN KEY (idproduct) REFERENCES productos (idproducto) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_produccion_numseries_familias</name>
        <type>FOREIGN KEY (idfamily) REFERENCES familias (codfamilia) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>uniq_produccion_numseries</name>
        <type>UNIQUE (idproduct, idfamily)</type>
    </constraint>
</table>
