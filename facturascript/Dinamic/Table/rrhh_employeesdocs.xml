<table>
    <column>
        <name>downloadable</name>
        <type>boolean</type>
    </column>
    <column>
        <name>expires</name>
        <type>date</type>
    </column>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>idemployee</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>iddoctype</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>note</name>
        <type>text</type>
    </column>
    <column>
        <name>year_group</name>
        <type>integer</type>
        <null>NO</null>
    </column>

    <!-- Constraints -->
    <constraint>
        <name>rrhh_employeesdocs_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>

    <constraint>
        <name>ca_rrhh_employeesdocs_employees</name>
        <type>FOREIGN KEY (idemployee) REFERENCES rrhh_employees (id) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>

    <constraint>
        <name>ca_rrhh_employeesdocs_docstypes</name>
        <type>FOREIGN KEY (iddoctype) REFERENCES rrhh_documentstypes (id) ON DELETE RESTRICT ON UPDATE CASCADE</type>
    </constraint>
</table>
