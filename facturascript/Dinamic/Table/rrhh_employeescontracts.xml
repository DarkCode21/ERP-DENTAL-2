<table>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>idcompany</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>idemployee</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>idcontract</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>startdate</name>
        <type>date</type>
        <null>NO</null>
    </column>
    <column>
        <name>enddate</name>
        <type>date</type>
    </column>
    <column>
        <name>note</name>
        <type>text</type>
    </column>
    <constraint>
        <name>rrhh_employeescontracts_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>ca_rrhh_employeescontracts_empresas</name>
        <type>FOREIGN KEY (idcompany) REFERENCES empresas (idempresa) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_rrhh_employees_employees</name>
        <type>FOREIGN KEY (idemployee) REFERENCES rrhh_employees (id) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_rrhh_contracts_contracts</name>
        <type>FOREIGN KEY (idcontract) REFERENCES rrhh_contracts (id) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
</table>
