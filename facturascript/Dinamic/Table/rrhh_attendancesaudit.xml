<table>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>idattendance</name>
        <type>integer</type>
    </column>
    <column>
        <name>action</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>olddata</name>
        <type>text</type>
        <null>NO</null>
    </column>
    <column>
        <name>newdata</name>
        <type>text</type>
    </column>
    <column>
        <name>reason</name>
        <type>text</type>
        <null>NO</null>
    </column>
    <column>
        <name>dateaction</name>
        <type>timestamp</type>
        <null>NO</null>
    </column>
    <column>
        <name>nick</name>
        <type>varchar(30)</type>
        <null>NO</null>
    </column>
    <constraint>
        <name>pk_rrhh_attendancesaudit</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>ca_rrhh_attendancesaudit_users</name>
        <type>FOREIGN KEY (nick) REFERENCES users (nick) ON DELETE RESTRICT ON UPDATE CASCADE</type>
    </constraint>
</table>
