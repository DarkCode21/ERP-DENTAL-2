<table>
    <column>
        <name>amount</name>
        <type>double precision</type>
        <null>NO</null>
        <default>0</default>
    </column>
    <column>
        <name>difference</name>
        <type>double precision</type>
        <null>NO</null>
        <default>0</default>
    </column>
    <column>
        <name>holiday</name>
        <type>integer</type>
        <null>NO</null>
        <default>0</default>
    </column>
    <column>
        <name>hours</name>
        <type>double precision</type>
        <null>NO</null>
        <default>0</default>
    </column>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>idemployee</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>idpayroll</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>worked</name>
        <type>double precision</type>
        <null>NO</null>
        <default>0</default>
    </column>
    <constraint>
        <name>rrhh_employeespayroll_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>ca_rrhh_employeespayroll_employees</name>
        <type>FOREIGN KEY (idemployee) REFERENCES rrhh_employees (id) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_rrhh_employeespayroll_payroll</name>
        <type>FOREIGN KEY (idpayroll) REFERENCES rrhh_payroll (id) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
</table>
