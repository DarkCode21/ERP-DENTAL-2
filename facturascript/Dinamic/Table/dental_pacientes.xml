<?xml version="1.0" encoding="UTF-8"?>
<table>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>codcliente</name>
        <type>character varying(10)</type>
        <null>NO</null>
    </column>
    <column>
        <name>salon_customer_id</name>
        <type>integer</type>
    </column>
    <column>
        <name>aseguradora</name>
        <type>character varying(100)</type>
    </column>
    <column>
        <name>numero_poliza</name>
        <type>character varying(50)</type>
    </column>
    <column>
        <name>alergias</name>
        <type>text</type>
    </column>
    <column>
        <name>medicacion</name>
        <type>text</type>
    </column>
    <column>
        <name>antecedentes_medicos</name>
        <type>text</type>
    </column>
    <column>
        <name>antecedentes_odontologicos</name>
        <type>text</type>
    </column>
    <column>
        <name>observaciones</name>
        <type>text</type>
    </column>
    <column>
        <name>estado</name>
        <type>character varying(20)</type>
        <default>'activo'</default>
    </column>
    <column>
        <name>fecha_alta</name>
        <type>date</type>
    </column>
    <column>
        <name>created_by</name>
        <type>character varying(50)</type>
    </column>
    <column>
        <name>created_at</name>
        <type>timestamp</type>
        <default>current_timestamp</default>
    </column>
    <column>
        <name>updated_at</name>
        <type>timestamp</type>
        <default>current_timestamp</default>
    </column>
    <constraint>
        <name>dental_pacientes_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>dental_pacientes_codcliente_unique</name>
        <type>UNIQUE (codcliente)</type>
    </constraint>
    <constraint>
        <name>ca_dental_pacientes_clientes</name>
        <type>FOREIGN KEY (codcliente) REFERENCES clientes (codcliente) ON DELETE RESTRICT ON UPDATE CASCADE</type>
    </constraint>
</table>
