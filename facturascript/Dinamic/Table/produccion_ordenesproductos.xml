<table>
    <column>
        <name>cantidad</name>
        <type>double precision</type>
    </column>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>idorden</name>
        <type>integer</type>
        <null>NO</null>
    </column>
    <column>
        <name>numserietype</name>
        <type>integer</type>
    </column>
    <column>
        <name>referencia</name>
        <type>character varying(30)</type>
        <null>NO</null>
    </column>

    <constraint>
        <name>produccion_ordenesproductos_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>ca_produccion_ordenesproductos_ordenes</name>
        <type>FOREIGN KEY (idorden) REFERENCES produccion_ordenes (id) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
    <constraint>
        <name>ca_produccion_ordenesproductos_variantes</name>
        <type>FOREIGN KEY (referencia) REFERENCES variantes (referencia) ON DELETE RESTRICT ON UPDATE CASCADE</type>
    </constraint>
</table>
