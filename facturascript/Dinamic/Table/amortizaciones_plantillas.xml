<table>
    <column>
        <name>benefits_subaccount</name>
        <type>character varying(15)</type>
    </column>
    <column>
        <name>closing_subaccount</name>
        <type>character varying(15)</type>
    </column>
    <column>
        <name>credit_subaccount</name>
        <type>character varying(15)</type>
    </column>
    <column>
        <name>debit_subaccount</name>
        <type>character varying(15)</type>
    </column>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>loss_subaccount</name>
        <type>character varying(15)</type>
    </column>
    <column>
        <name>name</name>
        <type>text</type>
    </column>
    <column>
        <name>periods</name>
        <type>integer</type>
    </column>
    <constraint>
        <name>amortizaciones_plantillas_pkey</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
</table>
